<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Automation: generate a token when a partner tagged FANCY_FOOD_NY_2026 is
         created or (re)tagged. The tag filter lives in the server-action CODE
         (which has `env`/`records`), NOT in filter_domain: a stored filter_domain
         is safe_eval'd at RUNTIME where ref() is undefined (would break partner
         writes). Fires only on category_id change; code filters to tagged partners. -->
    <record id="automation_fancyfood_token" model="base.automation">
        <field name="name">Fancy Food NY — genera token su tag</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="active" eval="True"/>
        <field name="trigger">on_create_or_write</field>
        <field name="trigger_field_ids" eval="[(6, 0, [ref('base.field_res_partner__category_id')])]"/>
        <field name="filter_domain">[]</field>
    </record>

    <record id="server_fancyfood_ensure_token" model="ir.actions.server">
        <field name="name">Fancy Food NY — ensure token</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="base_automation_id" ref="automation_fancyfood_token"/>
        <field name="state">code</field>
        <field name="code">
tag = env.ref('casafolino_fancyfood.tag_partner_fancyfood', raise_if_not_found=False)
if tag:
    hit = records.filtered(lambda r: tag.id in r.category_id.ids)
    if hit:
        hit._ensure_fancyfood_token()
        </field>
    </record>
</odoo>
