<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fancyfood_event_list" model="ir.ui.view">
        <field name="name">casafolino.fancyfood.event.list</field>
        <field name="model">casafolino.fancyfood.event</field>
        <field name="arch" type="xml">
            <list string="Eventi Fancy Food" create="false">
                <field name="create_date" string="Quando"/>
                <field name="partner_id"/>
                <field name="event_type"/>
                <field name="meta" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_fancyfood_event_search" model="ir.ui.view">
        <field name="name">casafolino.fancyfood.event.search</field>
        <field name="model">casafolino.fancyfood.event</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <filter name="opens" string="Aperture" domain="[('event_type','=','open')]"/>
                <filter name="clicks" string="Click catalogo" domain="[('event_type','=','click')]"/>
                <filter name="logos" string="Load logo" domain="[('event_type','=','logo')]"/>
                <group expand="0" string="Raggruppa">
                    <filter name="g_partner" string="Contatto" context="{'group_by':'partner_id'}"/>
                    <filter name="g_type" string="Tipo" context="{'group_by':'event_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- partner-scoped action for the smart button -->
    <record id="action_fancyfood_events" model="ir.actions.act_window">
        <field name="name">Eventi Fancy Food</field>
        <field name="res_model">casafolino.fancyfood.event</field>
        <field name="view_mode">list</field>
        <field name="domain">[('partner_id', '=', active_id)]</field>
        <field name="context">{'search_default_partner_id': active_id}</field>
    </record>

    <!-- global engagement view -->
    <record id="action_fancyfood_events_all" model="ir.actions.act_window">
        <field name="name">Fancy Food NY — Engagement</field>
        <field name="res_model">casafolino.fancyfood.event</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_fancyfood_event_search"/>
    </record>

    <menuitem id="menu_fancyfood_root" name="Fancy Food NY" parent="contacts.menu_contacts"
              sequence="90"/>
    <menuitem id="menu_fancyfood_events" name="Engagement" parent="menu_fancyfood_root"
              action="action_fancyfood_events_all" sequence="10"/>
</odoo>
