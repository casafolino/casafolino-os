<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_project_list_crm360" model="ir.ui.view">
        <field name="name">project.project.list.crm360</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list string="Vista 360">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="cf_status_dossier" widget="badge"/>
                <field name="cf_project_type"/>
                <field name="user_id"/>
                <field name="cf_dossier_value_estimate"/>
            </list>
        </field>
    </record>

    <record id="view_project_project_form_crm360" model="ir.ui.view">
        <field name="name">project.project.form.crm360</field>
        <field name="model">project.project</field>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <form string="Vista 360">
                <header>
                    <button name="action_compose_email_f8"
                            type="object"
                            string="Scrivi mail"
                            icon="fa-envelope"
                            class="oe_highlight"
                            invisible="not partner_id"/>
                    <field name="cf_status_dossier"
                           widget="statusbar"
                           options="{'clickable': '1'}"
                           statusbar_visible="exploration,active,on_hold,closed"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="status">
                        <strong>VISTA 360</strong>
                        <span> - dossier commerciale operativo</span>
                    </div>
                    <div class="oe_title">
                        <span class="text-muted">Vista 360</span>
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nome dossier"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Cliente">
                            <field name="partner_id" string="Cliente"/>
                            <field name="cf_buyer_id" string="Buyer"/>
                            <field name="cf_partner_email" widget="email"/>
                            <field name="cf_partner_country_id"/>
                        </group>
                        <group string="Dossier">
                            <field name="user_id" string="Responsabile"/>
                            <field name="cf_project_type"/>
                            <field name="cf_dossier_value_estimate"/>
                            <field name="cf_next_action"/>
                            <field name="cf_next_action_date"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Sintesi" name="summary">
                            <group>
                                <group string="Stato cliente">
                                    <field name="cf_partner_orders_count" readonly="1"/>
                                    <field name="cf_partner_orders_amount" readonly="1"/>
                                    <field name="cf_partner_mails_count" readonly="1"/>
                                </group>
                                <group string="Pipeline">
                                    <field name="cf_lead_count" readonly="1"/>
                                    <field name="cf_last_activity_date" readonly="1"/>
                                    <field name="cf_open_issues_count" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Sottoprogetti" name="subprojects">
                            <field name="task_ids" mode="list">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="stage_id"/>
                                    <field name="user_ids" widget="many2many_tags"/>
                                    <field name="date_deadline"/>
                                </list>
                            </field>
                        </page>

                        <page string="Mail" name="mail">
                            <field name="cf_dossier_mail_ids" mode="list" readonly="1">
                                <list>
                                    <field name="email_date"/>
                                    <field name="subject"/>
                                    <field name="sender_email"/>
                                    <field name="partner_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Ordini" name="orders">
                            <field name="cf360_sale_order_ids" mode="list" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="date_order"/>
                                    <field name="partner_id"/>
                                    <field name="state"/>
                                    <field name="amount_total"/>
                                </list>
                            </field>
                        </page>

                        <page string="Opportunita" name="opportunities">
                            <field name="cf_lead_ids" mode="list" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="stage_id"/>
                                    <field name="expected_revenue"/>
                                    <field name="user_id"/>
                                </list>
                            </field>
                        </page>

                        <page string="Documenti" name="documents">
                            <field name="cf_dossier_attachment_ids" mode="list" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="mimetype"/>
                                    <field name="file_size"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>

                        <page string="Note" name="notes">
                            <field name="cf_internal_notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_crm360_dossiers" model="ir.actions.act_window">
        <field name="name">Vista 360</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cf_status_dossier', '!=', False), ('cf_parent_project_id', '=', False), ('active', '=', True)]</field>
        <field name="context">{'default_cf_status_dossier': 'exploration'}</field>
    </record>

    <record id="action_crm360_dossiers_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_project_project_list_crm360"/>
        <field name="act_window_id" ref="action_crm360_dossiers"/>
    </record>

    <record id="action_crm360_dossiers_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_project_project_form_crm360"/>
        <field name="act_window_id" ref="action_crm360_dossiers"/>
    </record>

</odoo>
