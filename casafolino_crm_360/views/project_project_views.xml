<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_project_project_list_crm360" model="ir.ui.view">
        <field name="name">project.project.list.crm360</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list string="Vista 360">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="cf_status_dossier" widget="badge"/>
                <field name="cf_project_type"/>
                <field name="user_id"/>
                <field name="cf_dossier_value_estimate"/>
            </list>
        </field>
    </record>

    <record id="view_project_project_form_crm360" model="ir.ui.view">
        <field name="name">project.project.form.crm360</field>
        <field name="model">project.project</field>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <form string="Vista 360">
                <header>
                    <button name="action_compose_email_f8"
                            type="object"
                            string="Scrivi mail"
                            icon="fa-envelope"
                            class="oe_highlight"
                            invisible="not partner_id"/>
                    <button name="action_open_lavagna_360"
                            type="object"
                            string="Apri Lavagna"
                            icon="fa-columns"
                            class="btn btn-primary"/>
                    <button name="action_sync_dossier_mail_history"
                            type="object"
                            string="Sync mail"
                            icon="fa-refresh"/>
                    <field name="cf_status_dossier"
                           widget="statusbar"
                           options="{'clickable': '1'}"
                           statusbar_visible="exploration,active,on_hold,closed"/>
                </header>
                <sheet class="o_cf360_sheet">
                    <div class="o_cf360_app">
                        <aside class="o_cf360_rail">
                            <div class="o_cf360_logo">CF</div>
                            <span class="o_cf360_rail_btn active" title="Dossier"><i class="fa fa-compass"/></span>
                            <span class="o_cf360_rail_btn" title="Mail"><i class="fa fa-envelope-o"/></span>
                            <span class="o_cf360_rail_btn" title="Task"><i class="fa fa-check"/></span>
                            <span class="o_cf360_rail_btn" title="Persone"><i class="fa fa-users"/></span>
                            <span class="o_cf360_rail_btn" title="Documenti"><i class="fa fa-th"/></span>
                        </aside>

                        <main class="o_cf360_main">
                            <div class="o_cf360_topbar">
                                <div class="o_cf360_crumb">
                                    <strong>CasaFolino CRM</strong>
                                    <span class="o_cf360_pill blue">Dossier 360</span>
                                    <span class="o_cf360_pill green"><field name="cf_status_dossier" readonly="1" nolabel="1"/></span>
                                </div>
                                <div class="o_cf360_command">
                                    <i class="fa fa-search" title="Cerca"/>
                                    <span>Cerca mail, contatto, campione, task...</span>
                                </div>
                                <div class="o_cf360_actions">
                                    <button name="action_sync_dossier_mail_history" type="object" string="Sync mail" icon="fa-refresh" class="btn btn-secondary"/>
                                    <button name="action_compose_email_f8" type="object" string="Scrivi" icon="fa-envelope" class="btn btn-primary" invisible="not partner_id"/>
                                </div>
                            </div>

                            <section class="o_cf360_hero">
                                <div class="o_cf360_title_stack">
                                    <div class="o_cf360_eyebrow">
                                        Dossier cliente attivo
                                        <span class="o_cf360_country"><field name="cf_partner_country_id" readonly="1" nolabel="1"/></span>
                                    </div>
                                    <h1><field name="name" placeholder="Nome dossier"/></h1>
                                    <div class="o_cf360_meta_row">
                                        <span class="o_cf360_pill violet">Broker: <field name="cf_buyer_id" readonly="1" nolabel="1"/></span>
                                        <span class="o_cf360_pill amber">Prossima azione: <field name="cf_next_action" nolabel="1" placeholder="da definire"/></span>
                                        <span>
                                            Owner <field name="user_id" readonly="1" nolabel="1"/> -
                                            <field name="cf360_mail_count" readonly="1" nolabel="1"/> mail collegate
                                        </span>
                                    </div>
                                </div>
                                <div class="o_cf360_stage">
                                    <div class="o_cf360_stage_labels">
                                        <span>Lead</span>
                                        <span>Campioni</span>
                                        <span>Offerta</span>
                                        <span>Negoziazione</span>
                                        <span>Ordine</span>
                                    </div>
                                    <div class="o_cf360_stage_track">
                                        <span class="done"/>
                                        <span class="done"/>
                                        <span class="now"/>
                                        <span/>
                                        <span/>
                                        <span/>
                                        <span/>
                                        <span/>
                                    </div>
                                </div>
                            </section>

                            <section class="o_cf360_workspace">
                                <div class="o_cf360_left_stack">
                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Dossier pulse</h2>
                                            <span class="o_cf360_pill green"><field name="cf_dossier_priority" readonly="1" nolabel="1"/></span>
                                        </div>
                                        <div class="o_cf360_panel_body o_cf360_score">
                                            <div class="o_cf360_ring"><field name="cf360_mail_count" readonly="1" nolabel="1"/></div>
                                            <div class="o_cf360_facts">
                                                <div class="o_cf360_fact"><span>Rischio</span><strong>medio basso</strong></div>
                                                <div class="o_cf360_fact"><span>Ultima attivita</span><strong><field name="cf_last_activity_date" readonly="1" nolabel="1"/></strong></div>
                                                <div class="o_cf360_fact"><span>Opportunita</span><strong><field name="cf_lead_count" readonly="1" nolabel="1"/></strong></div>
                                                <div class="o_cf360_fact"><span>Valore</span><strong><field name="cf_dossier_value_estimate" readonly="1" nolabel="1"/></strong></div>
                                            </div>
                                        </div>
                                    </article>

                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Persone</h2>
                                            <span class="o_cf360_pill blue">referenti</span>
                                        </div>
                                        <div class="o_cf360_panel_body o_cf360_people">
                                            <field name="cf_contact_ids" nolabel="1" mode="list">
                                                <list editable="bottom">
                                                    <field name="sequence" widget="handle"/>
                                                    <field name="name"/>
                                                    <field name="role"/>
                                                    <field name="email"/>
                                                    <field name="mail_sync_enabled"/>
                                                    <field name="mail_message_count"/>
                                                </list>
                                            </field>
                                        </div>
                                    </article>

                                    <article class="o_cf360_panel o_cf360_ai">
                                        <div class="o_cf360_panel_head">
                                            <h2>Sintesi AI dossier</h2>
                                            <span class="o_cf360_pill blue">live</span>
                                        </div>
                                        <div class="o_cf360_panel_body">
                                            <div class="o_cf360_ai_item">
                                                <strong>Contesto</strong>
                                                <p>Mail, referenti, sottoprogetti e documenti sono concentrati qui per decidere la prossima mossa senza cambiare modulo.</p>
                                            </div>
                                            <div class="o_cf360_ai_item">
                                                <strong>Da non perdere</strong>
                                                <p>Rispondi dal thread piu recente, mantieni broker e referente cliente allineati, collega ogni uscita al dossier.</p>
                                            </div>
                                        </div>
                                    </article>
                                </div>

                                <div class="o_cf360_center_stack">
                                    <div class="o_cf360_kpis">
                                        <button name="action_open_mails_360" type="object" class="o_cf360_kpi">
                                            <span>Mail dossier</span>
                                            <strong><field name="cf360_mail_count" readonly="1" nolabel="1"/></strong>
                                            <small>storico collegato</small>
                                        </button>
                                        <button name="action_open_tasks_360" type="object" class="o_cf360_kpi">
                                            <span>Sottoprogetti</span>
                                            <strong><field name="cf360_task_count" readonly="1" nolabel="1"/></strong>
                                            <small>in lavorazione</small>
                                        </button>
                                        <button name="action_open_dossier_leads" type="object" class="o_cf360_kpi">
                                            <span>Opportunita</span>
                                            <strong><field name="cf_lead_count" readonly="1" nolabel="1"/></strong>
                                            <small>pipeline</small>
                                        </button>
                                        <button name="action_open_dossier_orders" type="object" class="o_cf360_kpi">
                                            <span>Ordini</span>
                                            <strong><field name="cf_order_count" readonly="1" nolabel="1"/></strong>
                                            <small>collegati</small>
                                        </button>
                                    </div>

                                    <div class="o_cf360_next_move">
                                        <div>
                                            <h2><field name="cf_next_action" placeholder="Definire la prossima azione commerciale"/></h2>
                                            <p>Usa il thread piu recente, includi i referenti chiave e collega la risposta al dossier.</p>
                                        </div>
                                        <button name="action_compose_email_f8" type="object" string="Apri bozza" class="btn btn-primary" invisible="not partner_id"/>
                                    </div>

                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head o_cf360_mail_toolbar">
                                            <h2>Mail cockpit</h2>
                                            <div class="o_cf360_segmented">
                                                <span class="active">Tutte</span>
                                                <span>Da leggere</span>
                                                <span>Broker</span>
                                                <span>Cliente</span>
                                            </div>
                                            <button name="action_open_mails_360" type="object" string="Vista thread" class="btn btn-secondary"/>
                                        </div>
                                        <div class="o_cf360_panel_body o_cf360_mail_list">
                                            <field name="cf360_mail_ids" nolabel="1" mode="list" readonly="1">
                                                <list>
                                                    <field name="email_date"/>
                                                    <field name="subject"/>
                                                    <field name="sender_email"/>
                                                    <field name="partner_id"/>
                                                    <field name="state"/>
                                                </list>
                                            </field>
                                        </div>
                                    </article>

                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Execution board</h2>
                                            <span class="o_cf360_pill amber">azioni aperte</span>
                                        </div>
                                        <div class="o_cf360_panel_body o_cf360_board">
                                            <div class="o_cf360_lane">
                                                <h3>Oggi</h3>
                                                <div class="o_cf360_task"><strong><field name="cf_next_action" readonly="1" nolabel="1"/></strong><div><span><field name="user_id" readonly="1" nolabel="1"/></span><span><field name="cf_next_action_date" readonly="1" nolabel="1"/></span></div></div>
                                                <div class="o_cf360_task"><strong>Verifica materiali e listino</strong><div><span>Team</span><span>prima invio</span></div></div>
                                            </div>
                                            <div class="o_cf360_lane">
                                                <h3>In attesa</h3>
                                                <div class="o_cf360_task"><strong>Conferma prodotti target</strong><div><span>Cliente</span><span>esterno</span></div></div>
                                                <div class="o_cf360_task"><strong>Allineamento broker</strong><div><span>Broker</span><span>cc</span></div></div>
                                            </div>
                                            <div class="o_cf360_lane">
                                                <h3>Pronto</h3>
                                                <div class="o_cf360_task"><strong>Catalogo digitale export</strong><div><span>PDF</span><span>caricato</span></div></div>
                                                <div class="o_cf360_task"><strong>Schede prodotto</strong><div><span>QA</span><span>ok</span></div></div>
                                            </div>
                                        </div>
                                    </article>

                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Sottoprogetti e avanzamento</h2>
                                            <button name="action_open_tasks_360" type="object" string="Apri lista" class="btn btn-link"/>
                                        </div>
                                        <div class="o_cf360_panel_body">
                                            <field name="task_ids" nolabel="1" mode="list">
                                                <list editable="bottom">
                                                    <field name="sequence" widget="handle"/>
                                                    <field name="name"/>
                                                    <field name="stage_id"/>
                                                    <field name="date_deadline"/>
                                                    <field name="user_ids" widget="many2many_tags"/>
                                                </list>
                                            </field>
                                        </div>
                                    </article>
                                </div>

                                <aside class="o_cf360_right_stack">
                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Timeline</h2>
                                            <span class="o_cf360_pill blue">live</span>
                                        </div>
                                        <div class="o_cf360_panel_body o_cf360_facts">
                                            <div class="o_cf360_fact"><span>Ultima attivita</span><strong><field name="cf_last_activity_date" readonly="1" nolabel="1"/></strong></div>
                                            <div class="o_cf360_fact"><span>Mail nel dossier</span><strong><field name="cf360_mail_count" readonly="1" nolabel="1"/></strong></div>
                                            <div class="o_cf360_fact"><span>Lavagna</span><strong><field name="initiative_id" readonly="1" nolabel="1"/></strong></div>
                                            <div class="o_cf360_fact"><span>Responsabile</span><strong><field name="user_id" readonly="1" nolabel="1"/></strong></div>
                                        </div>
                                    </article>

                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Documenti e prove</h2>
                                            <span class="o_cf360_pill blue"><field name="cf360_document_count" readonly="1" nolabel="1"/> file</span>
                                        </div>
                                        <div class="o_cf360_panel_body">
                                            <field name="cf_dossier_attachment_ids" nolabel="1" mode="list" readonly="1">
                                                <list>
                                                    <field name="name"/>
                                                    <field name="mimetype"/>
                                                    <field name="create_date"/>
                                                </list>
                                            </field>
                                        </div>
                                    </article>

                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Lavagna operativa</h2>
                                            <button name="action_open_lavagna_360" type="object" string="Apri full screen" class="btn btn-link"/>
                                        </div>
                                        <div class="o_cf360_panel_body o_cf360_board compact">
                                            <div class="o_cf360_lane">
                                                <h3>Da fare</h3>
                                                <div class="o_cf360_task"><strong>Leggere mail ordine</strong></div>
                                                <div class="o_cf360_task"><strong>Controllare disponibilita</strong></div>
                                            </div>
                                            <div class="o_cf360_lane">
                                                <h3>In corso</h3>
                                                <div class="o_cf360_task"><strong>Preparare risposta</strong></div>
                                            </div>
                                            <div class="o_cf360_lane">
                                                <h3>Fatto</h3>
                                                <div class="o_cf360_task"><strong>Storico primo ordine</strong></div>
                                            </div>
                                        </div>
                                    </article>

                                    <article class="o_cf360_panel">
                                        <div class="o_cf360_panel_head">
                                            <h2>Guardrail</h2>
                                            <span class="o_cf360_pill red">attenzione</span>
                                        </div>
                                        <div class="o_cf360_panel_body o_cf360_facts">
                                            <div class="o_cf360_fact"><span>Broker in CC</span><strong>sempre</strong></div>
                                            <div class="o_cf360_fact"><span>Lingua</span><strong>ES / EN</strong></div>
                                            <div class="o_cf360_fact"><span>Risposta entro</span><strong>24h</strong></div>
                                            <div class="o_cf360_fact"><span>Owner backup</span><strong>Team</strong></div>
                                        </div>
                                    </article>
                                </aside>
                            </section>
                        </main>
                    </div>

                    <notebook>
                        <page string="Dettagli" name="details">
                            <group>
                                <group string="Cliente">
                                    <field name="partner_id" string="Cliente"/>
                                    <field name="cf_buyer_id" string="Buyer"/>
                                    <field name="cf_partner_email" widget="email"/>
                                    <field name="cf_partner_country_id"/>
                                </group>
                                <group string="Dossier">
                                    <field name="user_id" string="Responsabile"/>
                                    <field name="cf_project_type"/>
                                    <field name="cf_dossier_value_estimate"/>
                                    <field name="cf_dossier_priority"/>
                                    <field name="cf_next_action"/>
                                    <field name="cf_next_action_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Mail" name="mail">
                            <field name="cf360_mail_ids" mode="list" readonly="1">
                                <list>
                                    <field name="email_date"/>
                                    <field name="subject"/>
                                    <field name="sender_email"/>
                                    <field name="partner_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ordini" name="orders">
                            <field name="cf360_sale_order_ids" mode="list" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="date_order"/>
                                    <field name="partner_id"/>
                                    <field name="state"/>
                                    <field name="amount_total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Note" name="notes">
                            <field name="cf_internal_notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_crm360_dossiers" model="ir.actions.act_window">
        <field name="name">Vista 360</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cf_status_dossier', '!=', False), ('cf_parent_project_id', '=', False), ('active', '=', True)]</field>
        <field name="context">{'default_cf_status_dossier': 'exploration'}</field>
    </record>

    <record id="action_crm360_dossiers_view_list" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_project_project_list_crm360"/>
        <field name="act_window_id" ref="action_crm360_dossiers"/>
    </record>

    <record id="action_crm360_dossiers_view_form" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_project_project_form_crm360"/>
        <field name="act_window_id" ref="action_crm360_dossiers"/>
    </record>

</odoo>
