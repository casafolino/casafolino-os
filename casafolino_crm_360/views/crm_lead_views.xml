<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crm_lead_form_crm360_button" model="ir.ui.view">
        <field name="name">crm.lead.form.crm360.button</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">95</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_project_360"
                        type="object"
                        string="Vista 360"
                        icon="fa-compass"
                        class="oe_highlight"/>
            </xpath>
        </field>
    </record>

    <record id="crm_lead_form_premium_crm360_button" model="ir.ui.view">
        <field name="name">crm.lead.form.premium.crm360.button</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="casafolino_crm_export.cf_crm_lead_view_form_premium"/>
        <field name="priority">96</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_project_360"
                        type="object"
                        string="Vista 360"
                        icon="fa-compass"
                        class="oe_highlight"/>
            </xpath>
        </field>
    </record>

</odoo>
