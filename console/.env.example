# === Console CasaFolino — variabili d'ambiente (NESSUN valore reale qui) ===
# Copia in .env.local e riempi. .env.local è gitignorato.

# Mock mode: "1" = usa fixtures locali (nessun Odoo). "0" = collega Odoo reale.
# Default a 1 se mancano le credenziali sotto.
CONSOLE_USE_MOCK=1

# --- Odoo JSON-RPC (server-side only) ---
# STAGE per build/test; PROD solo in env Vercel separato.
ODOO_URL=https://erp.casafolino.com
ODOO_DB=folinofood_stage
ODOO_USERNAME=
ODOO_API_KEY=

# --- NextAuth / Auth.js (login per-umano S5) ---
# Segreto firma JWT sessione. Genera: `openssl rand -base64 32`. MAI in git → console.prod.env.
AUTH_SECRET=
# Opzionale dietro nginx/subpath: URL pubblico della console (es. https://erp.casafolino.com/console).
# AUTH_URL=

# --- Groq (bozza AI) ---
# Opzionale: se vuoto, la console legge casafolino.groq_api_key da Odoo (ir.config_parameter) via JSON-RPC.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
