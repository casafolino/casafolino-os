<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voice_agent_list" model="ir.ui.view">
        <field name="name">casafolino.voice.agent.list</field>
        <field name="model">casafolino.voice.agent</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="direction"/>
                <field name="model"/>
                <field name="voice"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_voice_agent_form" model="ir.ui.view">
        <field name="name">casafolino.voice.agent.form</field>
        <field name="model">casafolino.voice.agent</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="direction"/>
                            <field name="active"/>
                            <field name="language"/>
                            <field name="temperature"/>
                        </group>
                        <group>
                            <field name="model"/>
                            <field name="voice"/>
                            <field name="max_turns"/>
                            <field name="allow_tools"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Profilo" name="profile">
                            <field name="persona"/>
                            <field name="first_message"/>
                        </page>
                        <page string="Istruzioni" name="instructions">
                            <field name="instructions" nolabel="1"/>
                        </page>
                        <page string="Lingua" name="language_policy">
                            <field name="language_policy" nolabel="1"/>
                        </page>
                        <page string="Strumenti" name="tools">
                            <field name="tool_policy" nolabel="1"/>
                        </page>
                        <page string="Trasferimento" name="transfer">
                            <field name="transfer_policy" nolabel="1"/>
                        </page>
                        <page string="Qualita" name="quality">
                            <field name="success_criteria"/>
                            <field name="guardrails"/>
                            <field name="closing_policy"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_voice_agent" model="ir.actions.act_window">
        <field name="name">Agenti vocali</field>
        <field name="res_model">casafolino.voice.agent</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
