<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voice_number_list" model="ir.ui.view">
        <field name="name">casafolino.voice.number.list</field>
        <field name="model">casafolino.voice.number</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone_number"/>
                <field name="provider"/>
                <field name="default_agent_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_voice_number_form" model="ir.ui.view">
        <field name="name">casafolino.voice.number.form</field>
        <field name="model">casafolino.voice.number</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="phone_number"/>
                            <field name="provider"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="default_agent_id"/>
                            <field name="default_routing_rule_id"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_voice_number" model="ir.actions.act_window">
        <field name="name">Numeri</field>
        <field name="res_model">casafolino.voice.number</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_voice_schedule_form" model="ir.ui.view">
        <field name="name">casafolino.voice.schedule.form</field>
        <field name="model">casafolino.voice.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="timezone"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="active"/>
                            <field name="dayofweek"/>
                            <field name="hour_from"/>
                            <field name="hour_to"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_voice_schedule_list" model="ir.ui.view">
        <field name="name">casafolino.voice.schedule.list</field>
        <field name="model">casafolino.voice.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="timezone"/>
            </list>
        </field>
    </record>
    <record id="action_voice_schedule" model="ir.actions.act_window">
        <field name="name">Orari</field>
        <field name="res_model">casafolino.voice.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_voice_queue_list" model="ir.ui.view">
        <field name="name">casafolino.voice.queue.list</field>
        <field name="model">casafolino.voice.queue</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="strategy"/>
                <field name="timeout_seconds"/>
                <field name="max_wait_seconds"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_voice_queue_form" model="ir.ui.view">
        <field name="name">casafolino.voice.queue.form</field>
        <field name="model">casafolino.voice.queue</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="strategy"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="timeout_seconds"/>
                            <field name="max_wait_seconds"/>
                            <field name="overflow_action"/>
                            <field name="overflow_agent_id"/>
                            <field name="overflow_external_number"/>
                        </group>
                    </group>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="greeting"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_voice_queue" model="ir.actions.act_window">
        <field name="name">Code e reparti</field>
        <field name="res_model">casafolino.voice.queue</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_voice_ivr_menu_form" model="ir.ui.view">
        <field name="name">casafolino.voice.ivr.menu.form</field>
        <field name="model">casafolino.voice.ivr.menu</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="max_attempts"/>
                            <field name="timeout_seconds"/>
                        </group>
                        <group>
                            <field name="fallback_action"/>
                            <field name="fallback_agent_id"/>
                            <field name="fallback_queue_id"/>
                            <field name="fallback_external_number"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Prompt" name="prompt">
                            <field name="prompt"/>
                            <field name="repeat_prompt"/>
                        </page>
                        <page string="Tasti" name="options">
                            <field name="option_ids">
                                <list editable="bottom">
                                    <field name="digit"/>
                                    <field name="label"/>
                                    <field name="action"/>
                                    <field name="agent_id"/>
                                    <field name="queue_id"/>
                                    <field name="external_number"/>
                                    <field name="callback_reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_voice_ivr_menu_list" model="ir.ui.view">
        <field name="name">casafolino.voice.ivr.menu.list</field>
        <field name="model">casafolino.voice.ivr.menu</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="max_attempts"/>
                <field name="timeout_seconds"/>
                <field name="fallback_action"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="action_voice_ivr_menu" model="ir.actions.act_window">
        <field name="name">IVR</field>
        <field name="res_model">casafolino.voice.ivr.menu</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_voice_routing_rule_list" model="ir.ui.view">
        <field name="name">casafolino.voice.routing.rule.list</field>
        <field name="model">casafolino.voice.routing.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="number_id"/>
                <field name="schedule_id"/>
                <field name="when"/>
                <field name="action"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_voice_routing_rule_form" model="ir.ui.view">
        <field name="name">casafolino.voice.routing.rule.form</field>
        <field name="model">casafolino.voice.routing.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="number_id"/>
                            <field name="caller_contains"/>
                        </group>
                        <group>
                            <field name="schedule_id"/>
                            <field name="when"/>
                            <field name="action"/>
                        </group>
                    </group>
                    <group>
                        <field name="agent_id"/>
                        <field name="ivr_menu_id"/>
                        <field name="queue_id"/>
                        <field name="external_number"/>
                        <field name="voicemail_email"/>
                        <field name="callback_reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_voice_routing_rule" model="ir.actions.act_window">
        <field name="name">Regole routing</field>
        <field name="res_model">casafolino.voice.routing.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

