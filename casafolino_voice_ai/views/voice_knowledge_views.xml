<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voice_knowledge_list" model="ir.ui.view">
        <field name="name">casafolino.voice.knowledge.list</field>
        <field name="model">casafolino.voice.knowledge</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="category"/>
                <field name="title"/>
                <field name="source"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_voice_knowledge_form" model="ir.ui.view">
        <field name="name">casafolino.voice.knowledge.form</field>
        <field name="model">casafolino.voice.knowledge</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="title"/>
                            <field name="category"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="keywords"/>
                            <field name="source"/>
                        </group>
                    </group>
                    <group>
                        <field name="content" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_voice_knowledge" model="ir.actions.act_window">
        <field name="name">Knowledge agenti</field>
        <field name="res_model">casafolino.voice.knowledge</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
