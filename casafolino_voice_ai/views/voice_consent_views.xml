<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voice_consent_list" model="ir.ui.view">
        <field name="name">casafolino.voice.consent.list</field>
        <field name="model">casafolino.voice.consent</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="consent_outbound"/>
                <field name="consent_source"/>
                <field name="consent_date"/>
                <field name="opt_out_date"/>
            </list>
        </field>
    </record>

    <record id="view_voice_consent_form" model="ir.ui.view">
        <field name="name">casafolino.voice.consent.form</field>
        <field name="model">casafolino.voice.consent</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_opt_out" string="Opt-out" type="object" class="btn-secondary" invisible="not consent_outbound"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="consent_outbound"/>
                            <field name="consent_source"/>
                        </group>
                        <group>
                            <field name="consent_date"/>
                            <field name="opt_out_date"/>
                            <field name="opt_out_reason"/>
                        </group>
                    </group>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_voice_consent" model="ir.actions.act_window">
        <field name="name">Consensi voce AI</field>
        <field name="res_model">casafolino.voice.consent</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

