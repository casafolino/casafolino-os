<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_voice_ai" model="ir.ui.view">
        <field name="name">res.partner.form.voice.ai</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_voice_ai_enqueue_followup" type="object" class="oe_stat_button" icon="fa-phone">
                    <field name="voice_outbound_consent" widget="boolean_button" string="Voice AI"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Voice AI" name="voice_ai">
                    <div class="o_row mb-3">
                        <button name="action_voice_ai_enqueue_followup" string="Nuovo follow-up" type="object" class="btn btn-primary"/>
                    </div>
                    <group>
                        <field name="voice_outbound_consent"/>
                    </group>
                    <notebook>
                        <page string="Consensi" name="voice_consents">
                            <field name="voice_consent_ids">
                                <list editable="bottom">
                                    <field name="phone"/>
                                    <field name="consent_outbound"/>
                                    <field name="consent_source"/>
                                    <field name="consent_date"/>
                                    <field name="opt_out_date"/>
                                </list>
                            </field>
                        </page>
                        <page string="Chiamate" name="voice_calls">
                            <field name="voice_call_ids" readonly="1">
                                <list>
                                    <field name="started_at"/>
                                    <field name="direction"/>
                                    <field name="state"/>
                                    <field name="phone"/>
                                    <field name="outcome"/>
                                    <field name="summary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Follow-up" name="voice_followups">
                            <field name="voice_outbound_queue_ids" readonly="1">
                                <list>
                                    <field name="scheduled_at"/>
                                    <field name="state"/>
                                    <field name="phone"/>
                                    <field name="reason"/>
                                    <field name="attempt_count"/>
                                    <field name="blocked_reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

