<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voice_call_list" model="ir.ui.view">
        <field name="name">casafolino.voice.call.list</field>
        <field name="model">casafolino.voice.call</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="started_at"/>
                <field name="direction"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="outcome"/>
                <field name="agent_id"/>
            </list>
        </field>
    </record>

    <record id="view_voice_call_form" model="ir.ui.view">
        <field name="name">casafolino.voice.call.form</field>
        <field name="model">casafolino.voice.call</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_completed" string="Completa" type="object" class="btn-primary" invisible="state in ['completed', 'failed', 'transferred']"/>
                    <button name="action_transfer" string="Trasferita" type="object" invisible="state in ['completed', 'failed', 'transferred']"/>
                    <button name="action_create_callback_activity" string="Crea attivita" type="object" invisible="not partner_id"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,active,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="direction"/>
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="agent_id"/>
                        </group>
                        <group>
                            <field name="external_call_id"/>
                            <field name="started_at"/>
                            <field name="ended_at"/>
                            <field name="duration_seconds"/>
                            <field name="outcome"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Riepilogo" name="summary">
                            <field name="summary"/>
                            <field name="next_action"/>
                        </page>
                        <page string="Trascrizione" name="transcript">
                            <field name="transcript" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_voice_call" model="ir.actions.act_window">
        <field name="name">Chiamate AI</field>
        <field name="res_model">casafolino.voice.call</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

