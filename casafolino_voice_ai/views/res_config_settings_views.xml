<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_voice_ai" model="ir.ui.view">
        <field name="name">res.config.settings.voice.ai</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Voice AI" data-string="Voice AI" name="casafolino_voice_ai">
                    <block title="OpenAI Realtime" name="voice_ai_openai">
                        <setting string="OpenAI API Key" help="API key used by the bridge for Realtime voice calls">
                            <field name="voice_ai_openai_api_key" password="True"/>
                        </setting>
                        <setting string="Realtime Model" help="Default model for voice agents">
                            <field name="voice_ai_openai_realtime_model"/>
                        </setting>
                        <setting string="Realtime Voice" help="Default voice for voice agents">
                            <field name="voice_ai_openai_voice"/>
                        </setting>
                    </block>
                    <block title="Bridge and Security" name="voice_ai_bridge">
                        <setting string="Public Base URL" help="Public Odoo URL called by the telephony bridge">
                            <field name="voice_ai_public_base_url" placeholder="https://erp.casafolino.com"/>
                        </setting>
                        <setting string="Require Token" help="Protect operational endpoints with a bearer token">
                            <field name="voice_ai_require_token"/>
                        </setting>
                        <setting string="Webhook Token" help="Bearer token shared with the bridge and webhook clients">
                            <field name="voice_ai_webhook_token" password="True"/>
                        </setting>
                    </block>
                    <block title="Telephony" name="voice_ai_telephony">
                        <setting string="Human Transfer URI" help="Destination for human handoff">
                            <field name="voice_ai_human_transfer_uri" placeholder="tel:+390000000000"/>
                        </setting>
                        <setting string="Allow Outbound Calls" help="Enable only after consent and provider routing are ready">
                            <field name="voice_ai_allow_outbound"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_voice_ai_config" model="ir.actions.act_window">
        <field name="name">Voice AI Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'casafolino_voice_ai'}</field>
    </record>
</odoo>

