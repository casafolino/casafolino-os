<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_voice_outbound_queue_list" model="ir.ui.view">
        <field name="name">casafolino.voice.outbound.queue.list</field>
        <field name="model">casafolino.voice.outbound.queue</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="scheduled_at"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="language"/>
                <field name="reason"/>
                <field name="attempt_count"/>
                <field name="blocked_reason"/>
            </list>
        </field>
    </record>

    <record id="view_voice_outbound_queue_form" model="ir.ui.view">
        <field name="name">casafolino.voice.outbound.queue.form</field>
        <field name="model">casafolino.voice.outbound.queue</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_check_ready" string="Verifica consenso" type="object" class="btn-primary" invisible="state not in ['queued', 'blocked']"/>
                    <button name="action_mark_calling" string="Segna in chiamata" type="object" invisible="state != 'ready'"/>
                    <button name="action_cancel" string="Annulla" type="object" invisible="state in ['done', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="queued,ready,calling,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="language"/>
                            <field name="reason"/>
                            <field name="agent_id"/>
                        </group>
                        <group>
                            <field name="scheduled_at"/>
                            <field name="attempt_count"/>
                            <field name="max_attempts"/>
                            <field name="last_attempt_at"/>
                            <field name="consent_checked"/>
                            <field name="blocked_reason"/>
                        </group>
                    </group>
                    <group>
                        <field name="call_id"/>
                        <field name="external_job_id"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_voice_outbound_queue" model="ir.actions.act_window">
        <field name="name">Coda follow-up AI</field>
        <field name="res_model">casafolino.voice.outbound.queue</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
