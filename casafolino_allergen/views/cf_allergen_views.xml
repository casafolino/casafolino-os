<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ALLERGEN KANBAN -->
    <record id="view_cf_allergen_kanban" model="ir.ui.view">
        <field name="name">cf.allergen.kanban</field>
        <field name="model">cf.allergen</field>
        <field name="arch" type="xml">
            <kanban quick_create="false">
                <field name="name"/>
                <field name="code"/>
                <field name="products_count"/>
                <templates>
                    <t t-name="card">
                        <div class="cf-crm-card card-rotting-ok text-center" style="min-height:80px;">
                            <div style="font-size:28px; line-height:1;">
                                <field name="code"/>
                            </div>
                            <div class="fw-bold mt-1" style="font-size:13px;">
                                <field name="name"/>
                            </div>
                            <div class="mt-1">
                                <span class="badge bg-warning text-dark"
                                      style="font-size:10px;">
                                    <t t-esc="record.products_count.raw_value"/> prodotti
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_cf_allergen_list" model="ir.ui.view">
        <field name="name">cf.allergen.list</field>
        <field name="model">cf.allergen</field>
        <field name="arch" type="xml">
            <list string="14 Allergeni UE" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="products_count" string="Prodotti con allergene"/>
                <field name="regulation_ref"/>
            </list>
        </field>
    </record>
    <record id="view_cf_recipe_allergen_list" model="ir.ui.view">
        <field name="name">cf.recipe.allergen.list</field>
        <field name="model">cf.recipe.allergen</field>
        <field name="arch" type="xml">
            <list string="Allergeni Ricetta" editable="bottom"
                  decoration-danger="status=='present'"
                  decoration-warning="status=='traces'">
                <field name="allergen_id"/>
                <field name="status" widget="badge"
                       decoration-danger="status=='present'"
                       decoration-warning="status=='traces'"
                       decoration-success="status=='absent'"/>
                <field name="cross_contamination"/>
                <field name="validated_by" widget="many2one_avatar_user"/>
                <field name="validation_date"/>
                <field name="notes"/>
            </list>
        </field>
    </record>
</odoo>
