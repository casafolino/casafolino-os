<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions first -->
    <record id="action_cf_allergens" model="ir.actions.act_window">
        <field name="name">Dashboard Allergeni</field>
        <field name="res_model">cf.allergen</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_cf_allergen_products_alert" model="ir.actions.act_window">
        <field name="name">Prodotti con Alert Allergeni</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('allergen_check_state', '=', 'alert')]</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('product_allergen_alert_list')})]"/>
    </record>
    <record id="action_cf_allergen_products_all" model="ir.actions.act_window">
        <field name="name">Tutti i Prodotti</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'list', 'view_id': ref('product_allergen_alert_list')})]"/>
    </record>
    <record id="action_cf_allergen_categories" model="ir.actions.act_window">
        <field name="name">Categorie Allergeni</field>
        <field name="res_model">cf.allergen.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu structure -->
    <menuitem id="menu_cf_allergen_root" name="Allergeni" sequence="27"/>
    <menuitem id="menu_cf_allergens" name="Dashboard Allergeni"
              parent="menu_cf_allergen_root" action="action_cf_allergens" sequence="1"/>
    <menuitem id="menu_cf_allergen_alert" name="Prodotti con Alert"
              parent="menu_cf_allergen_root" action="action_cf_allergen_products_alert" sequence="2"/>
    <menuitem id="menu_cf_allergen_products" name="Tutti i Prodotti"
              parent="menu_cf_allergen_root" action="action_cf_allergen_products_all" sequence="3"/>
    <menuitem id="menu_cf_allergen_config" name="Configurazione"
              parent="menu_cf_allergen_root" sequence="99" groups="base.group_system"/>
    <menuitem id="menu_cf_allergen_categories" name="Categorie Allergeni"
              parent="menu_cf_allergen_config" action="action_cf_allergen_categories" sequence="1"/>
    <menuitem id="menu_cf_allergen_all" name="Tutti gli Allergeni"
              parent="menu_cf_allergen_config" action="action_cf_allergens" sequence="2"/>
</odoo>
