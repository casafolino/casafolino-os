<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Wizard form view -->
    <record id="view_fair_report_wizard_form" model="ir.ui.view">
        <field name="name">casafolino.fair.report.wizard.form</field>
        <field name="model">casafolino.fair.report.wizard</field>
        <field name="arch" type="xml">
            <form string="🏁 Genera Report Fiera">
                <group>
                    <field name="fiera_id"/>
                    <field name="close_fair"/>
                    <field name="include_contacts"/>
                </group>
                <footer>
                    <button name="action_generate_report"
                            string="📧 Genera e invia report"
                            type="object"
                            class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Server action: binding on crm.lead action menu -->
    <record id="action_fair_report_wizard" model="ir.actions.act_window">
        <field name="name">🏁 Genera Report Fiera</field>
        <field name="res_model">casafolino.fair.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="crm.model_crm_lead"/>
        <field name="binding_view_types">list,form</field>
    </record>

</odoo>
