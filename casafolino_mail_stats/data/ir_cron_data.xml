<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_rebuild_mail_engagement" model="ir.cron">
        <field name="name">Mail Stats: Rebuild Engagement Cache</field>
        <field name="model_id" ref="model_casafolino_mail_engagement"/>
        <field name="state">code</field>
        <field name="code">model._rebuild_cache_full()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_check_hot_leads" model="ir.cron">
        <field name="name">Mail Stats: Auto-Activity Hot Leads</field>
        <field name="model_id" ref="model_casafolino_mail_engagement"/>
        <field name="state">code</field>
        <field name="code">model._check_hot_leads_activity()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

</odoo>
