<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Email Performance action -->
    <record id="action_email_performance" model="ir.actions.act_window">
        <field name="name">Email Performance</field>
        <field name="res_model">mailing.trace</field>
        <field name="view_mode">pivot,list</field>
        <field name="search_view_id" ref="mailing_trace_view_search_enhanced"/>
        <field name="context">{'search_default_last_90_days': 1}</field>
    </record>

    <record id="action_email_performance_view_pivot" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="mailing_trace_view_pivot"/>
        <field name="act_window_id" ref="action_email_performance"/>
    </record>

    <record id="action_email_performance_view_list" model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="mailing_trace_view_list_enhanced"/>
        <field name="act_window_id" ref="action_email_performance"/>
    </record>

    <!-- Menu under CRM → Reporting -->
    <menuitem id="menu_email_performance"
              name="Email Performance"
              parent="crm.crm_menu_report"
              action="action_email_performance"
              sequence="99"/>

</odoo>
