<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Smart button on CRM lead form (standard) -->
    <record id="view_crm_lead_form_mail_stats" model="ir.ui.view">
        <field name="name">crm.lead.form.mail.stats</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_email_traces" type="object"
                        class="oe_stat_button" icon="fa-bar-chart"
                        invisible="mail_stats_total_sent == 0">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="mail_stats_opened_count"/>/<field name="mail_stats_total_sent"/>
                        </span>
                        <span class="o_stat_text">Email Aperte</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="mail_stats_engagement_status" widget="badge" readonly="1"
                       decoration-success="mail_stats_engagement_status == 'hot'"
                       decoration-warning="mail_stats_engagement_status == 'warm'"
                       decoration-danger="mail_stats_engagement_status == 'bounced'"
                       decoration-info="mail_stats_engagement_status == 'replied'"
                       invisible="not mail_stats_engagement_status or mail_stats_engagement_status == 'cold'"/>
            </xpath>
        </field>
    </record>

    <!-- Smart button on CRM lead premium form -->
    <record id="view_crm_lead_form_premium_mail_stats" model="ir.ui.view">
        <field name="name">crm.lead.form.premium.mail.stats</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="casafolino_crm_export.cf_crm_lead_view_form_premium"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_email_traces" type="object"
                        class="oe_stat_button" icon="fa-bar-chart"
                        invisible="mail_stats_total_sent == 0">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="mail_stats_opened_count"/>/<field name="mail_stats_total_sent"/>
                        </span>
                        <span class="o_stat_text">Email Aperte</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="mail_stats_engagement_status" widget="badge" readonly="1"
                       decoration-success="mail_stats_engagement_status == 'hot'"
                       decoration-warning="mail_stats_engagement_status == 'warm'"
                       decoration-danger="mail_stats_engagement_status == 'bounced'"
                       decoration-info="mail_stats_engagement_status == 'replied'"
                       invisible="not mail_stats_engagement_status or mail_stats_engagement_status == 'cold'"/>
            </xpath>
        </field>
    </record>

    <!-- Search view filters for CRM leads -->
    <record id="view_crm_lead_search_mail_stats" model="ir.ui.view">
        <field name="name">crm.lead.search.mail.stats</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="mail_hot" string="Hot Leads (Email)" domain="[('mail_stats_engagement_status', '=', 'hot')]"/>
                <filter name="mail_replied" string="Replied" domain="[('mail_stats_engagement_status', '=', 'replied')]"/>
                <filter name="mail_bounced" string="Bounced" domain="[('mail_stats_engagement_status', '=', 'bounced')]"/>
            </xpath>
        </field>
    </record>

</odoo>
