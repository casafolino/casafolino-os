<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_sync_nutrition_ingredients" model="ir.cron">
        <field name="name">Nutrition — Sincronizza ingredienti da fonti esterne</field>
        <field name="model_id" search="[('model','=','cf.nutrition.ingredient')]" model="ir.model"/>
        <field name="state">code</field>
        <field name="code">model._cron_sync_ingredients()</field>
        <field name="interval_number">1</field>
