<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
<t t-name="casafolino_haccp.CfHaccpDashboard">
    <div class="cf-haccp-control o_action">
        <div class="cf-haccp-topbar">
            <div class="cf-haccp-brand">
                <div class="cf-haccp-mark">CF</div>
                <div>
                    <div class="cf-haccp-title">HACCP Control Room</div>
                    <div class="cf-haccp-subtitle">Tracciabilita, gate operativi, evidenze audit</div>
                </div>
            </div>
            <div class="cf-haccp-top-actions">
                <span t-attf-class="cf-haccp-state-pill cf-state-#{state.data ? state.data.overall_state : 'gray'}">
                    <t t-if="state.data">
                        <t t-esc="state.data.overall_state == 'red' ? 'Critico' : state.data.overall_state == 'yellow' ? 'Attenzione' : 'Presidiato'"/>
                    </t>
                    <t t-else="">Caricamento</t>
                </span>
                <button class="cf-haccp-icon-btn" t-on-click="onRefresh" title="Aggiorna">↻</button>
            </div>
        </div>

        <t t-if="state.loading">
            <div class="cf-haccp-loading">
                <div class="cf-haccp-spinner"/>
                <span>Carico il quadro HACCP...</span>
            </div>
        </t>
        <t t-elif="state.error">
            <div class="cf-haccp-error"><t t-esc="state.error"/></div>
        </t>
        <t t-elif="state.data">
            <div class="cf-haccp-body">
                <section class="cf-haccp-hero">
                    <div class="cf-haccp-hero-main">
                        <div class="cf-haccp-hero-label">Stato audit</div>
                        <div class="cf-haccp-hero-value">
                            <t t-esc="state.data.audit_alerts"/>
                        </div>
                        <div class="cf-haccp-hero-copy">punti da presidiare ora</div>
                    </div>
                    <div class="cf-haccp-chain">
                        <button class="cf-chain-step" t-on-click="onOpenReceiptPending">
                            <span class="cf-chain-kicker">01</span>
                            <strong>Ricezione MP</strong>
                            <span><t t-esc="state.data.receipt_pending"/> da completare</span>
                        </button>
                        <div class="cf-chain-line"/>
                        <button class="cf-chain-step" t-on-click="onOpenProductionPending">
                            <span class="cf-chain-kicker">02</span>
                            <strong>Produzione</strong>
                            <span><t t-esc="state.data.production_pending"/> da completare</span>
                        </button>
                        <div class="cf-chain-line"/>
                        <button class="cf-chain-step" t-on-click="onOpenTraceability">
                            <span class="cf-chain-kicker">03</span>
                            <strong>Lotto → cliente</strong>
                            <span><t t-esc="state.data.trace_coverage"/>% copertura</span>
                        </button>
                    </div>
                </section>

                <section class="cf-haccp-search-panel">
                    <form class="cf-haccp-searchbar" t-on-submit="onLotSearch">
                        <input type="search"
                               placeholder="Cerca barcode, SKU prodotto o lotto..."
                               t-att-value="state.lotSearchQuery"
                               t-on-input="onLotSearchInput"/>
                        <button type="submit" t-att-disabled="state.lotSearchLoading">
                            <t t-esc="state.lotSearchLoading ? 'Cerco...' : 'Cerca'"/>
                        </button>
                    </form>
                    <t t-if="state.lotSearchError">
                        <div class="cf-haccp-search-error"><t t-esc="state.lotSearchError"/></div>
                    </t>
                    <t t-if="state.lotSearchResult">
                        <div class="cf-haccp-search-results">
                            <div class="cf-haccp-search-summary">
                                <span><t t-esc="state.lotSearchResult.summary.products"/> prodotti</span>
                                <span><t t-esc="state.lotSearchResult.summary.lots"/> lotti</span>
                                <span><t t-esc="state.lotSearchResult.summary.productions"/> produzioni</span>
                                <span><t t-esc="state.lotSearchResult.summary.deliveries"/> consegne</span>
                            </div>
                            <div class="cf-haccp-recall-chain cf-haccp-recall-chain-first">
                                <t t-if="state.lotSearchResult.chains.length">
                                    <t t-foreach="visibleSearchItems(state.lotSearchResult.chains)" t-as="chain" t-key="chain.id">
                                        <article class="cf-haccp-recall-card">
                                            <header class="cf-haccp-recall-head">
                                                <div>
                                                    <span><t t-esc="chain.role"/></span>
                                                    <h3><t t-esc="chain.lot"/></h3>
                                                    <small><t t-esc="chain.product"/> · SKU <t t-esc="chain.sku || '-'"/></small>
                                                </div>
                                                <button type="button" t-att-data-query="chain.lot" t-on-click="onLotDrill">Riapri questa pista</button>
                                            </header>
                                            <div class="cf-haccp-recall-strip">
                                                <div>
                                                    <span>Prodotto</span>
                                                    <strong><t t-esc="chain.product || '-'"/></strong>
                                                </div>
                                                <div>
                                                    <span>Lotto</span>
                                                    <strong><t t-esc="chain.lot || '-'"/></strong>
                                                </div>
                                                <div>
                                                    <span>Produzioni</span>
                                                    <strong><t t-esc="chain.productions.length + chain.impacted_productions.length"/></strong>
                                                </div>
                                                <div>
                                                    <span>Clienti</span>
                                                    <strong><t t-esc="chain.deliveries.length + chain.impacted_deliveries.length"/></strong>
                                                </div>
                                                <div>
                                                    <span>Materie prime</span>
                                                    <strong><t t-esc="chain.raw_lots.length"/></strong>
                                                </div>
                                            </div>
                                            <div class="cf-haccp-recall-flow">
                                                <section>
                                                    <h4>Ordini di produzione</h4>
                                                    <t t-if="chain.productions.length">
                                                        <t t-foreach="visibleSearchItems(chain.productions)" t-as="production" t-key="production.id">
                                                            <div class="cf-haccp-flow-row">
                                                                <strong><t t-esc="production.name"/></strong>
                                                                <small><t t-esc="production.product"/> · <t t-esc="production.date || '-'"/> · <t t-esc="production.state"/></small>
                                                            </div>
                                                        </t>
                                                    </t>
                                                    <t t-else=""><div class="cf-haccp-search-empty">Nessun ordine di produzione diretto</div></t>
                                                </section>
                                                <section>
                                                    <h4>Venduto a</h4>
                                                    <t t-if="chain.deliveries.length">
                                                        <t t-foreach="visibleSearchItems(chain.deliveries)" t-as="delivery" t-key="delivery.id">
                                                            <div class="cf-haccp-flow-row">
                                                                <strong><t t-esc="delivery.partner || 'Cliente non indicato'"/></strong>
                                                                <small><t t-esc="delivery.name"/> · <t t-esc="delivery.date || '-'"/></small>
                                                            </div>
                                                        </t>
                                                    </t>
                                                    <t t-else=""><div class="cf-haccp-search-empty">Nessuna vendita diretta trovata</div></t>
                                                </section>
                                                <section class="cf-haccp-flow-wide">
                                                    <h4>Materie prime usate, cliccabili</h4>
                                                    <t t-if="chain.raw_lots.length">
                                                        <div class="cf-haccp-chip-list cf-haccp-chip-list-compact">
                                                            <t t-foreach="visibleSearchItems(chain.raw_lots)" t-as="raw" t-key="raw.id">
                                                                <button type="button" class="cf-haccp-lot-chip cf-chip-warn" t-att-data-query="raw.name" t-on-click="onLotDrill">
                                                                    <strong><t t-esc="raw.name"/></strong>
                                                                    <small><t t-esc="raw.product"/></small>
                                                                </button>
                                                            </t>
                                                        </div>
                                                    </t>
                                                    <t t-else=""><div class="cf-haccp-search-empty">Nessuna materia prima letta dalla produzione</div></t>
                                                </section>
                                                <section>
                                                    <h4>Origine / ricezione</h4>
                                                    <t t-if="chain.suppliers.length">
                                                        <t t-foreach="visibleSearchItems(chain.suppliers)" t-as="supplier" t-key="supplier.id">
                                                            <div class="cf-haccp-flow-row">
                                                                <strong><t t-esc="supplier.name"/></strong>
                                                                <small><t t-esc="supplier.partner || 'Fornitore non indicato'"/> · <t t-esc="supplier.date || '-'"/></small>
                                                            </div>
                                                        </t>
                                                    </t>
                                                    <t t-else=""><div class="cf-haccp-search-empty">Nessuna ricezione collegata</div></t>
                                                </section>
                                                <section class="cf-haccp-flow-wide cf-haccp-impact-section">
                                                    <h4>Se questa e materia prima: prodotti finiti dove e andata</h4>
                                                    <t t-if="chain.impacted_lots.length">
                                                        <div class="cf-haccp-chip-list cf-haccp-chip-list-compact">
                                                            <t t-foreach="visibleSearchItems(chain.impacted_lots)" t-as="impactLot" t-key="impactLot.id">
                                                                <button type="button" class="cf-haccp-lot-chip cf-chip-impact" t-att-data-query="impactLot.name" t-on-click="onLotDrill">
                                                                    <strong><t t-esc="impactLot.name"/></strong>
                                                                    <small><t t-esc="impactLot.product"/></small>
                                                                </button>
                                                            </t>
                                                        </div>
                                                    </t>
                                                    <t t-else=""><div class="cf-haccp-search-empty">Nessun prodotto finito impattato</div></t>
                                                </section>
                                                <section>
                                                    <h4>Produzioni impattate</h4>
                                                    <t t-if="chain.impacted_productions.length">
                                                        <t t-foreach="visibleSearchItems(chain.impacted_productions)" t-as="production" t-key="production.id">
                                                            <div class="cf-haccp-flow-row">
                                                                <strong><t t-esc="production.name"/></strong>
                                                                <small><t t-esc="production.product"/> · lotto <t t-esc="production.lot || '-'"/></small>
                                                            </div>
                                                        </t>
                                                    </t>
                                                    <t t-else=""><div class="cf-haccp-search-empty">Nessuna produzione impattata</div></t>
                                                </section>
                                                <section>
                                                    <h4>Clienti coinvolti</h4>
                                                    <t t-if="chain.impacted_deliveries.length">
                                                        <t t-foreach="visibleSearchItems(chain.impacted_deliveries)" t-as="delivery" t-key="delivery.id">
                                                            <div class="cf-haccp-flow-row">
                                                                <strong><t t-esc="delivery.partner || 'Cliente non indicato'"/></strong>
                                                                <small><t t-esc="delivery.name"/> · <t t-esc="delivery.date || '-'"/></small>
                                                            </div>
                                                        </t>
                                                    </t>
                                                    <t t-else=""><div class="cf-haccp-search-empty">Nessuna consegna cliente collegata all'impatto</div></t>
                                                </section>
                                            </div>
                                        </article>
                                    </t>
                                    <t t-if="hiddenSearchCount(state.lotSearchResult.chains)">
                                        <button type="button" class="cf-haccp-more-btn cf-haccp-more-wide" t-on-click="onShowAllSearch">
                                            Mostra altre <t t-esc="hiddenSearchCount(state.lotSearchResult.chains)"/> catene di richiamo
                                        </button>
                                    </t>
                                </t>
                                <t t-else="">
                                    <div class="cf-haccp-search-empty">Nessuna catena di tracciabilita trovata.</div>
                                </t>
                            </div>
                            <div class="cf-haccp-recall-matches cf-haccp-recall-matches-secondary">
                                <div class="cf-haccp-recall-block">
                                    <h3>Altri prodotti trovati</h3>
                                    <t t-if="state.lotSearchResult.products.length">
                                        <t t-foreach="visibleSearchItems(state.lotSearchResult.products)" t-as="product" t-key="product.id">
                                            <div class="cf-haccp-search-row">
                                                <strong><t t-esc="product.name"/></strong>
                                                <small>SKU <t t-esc="product.sku || '-'"/> · Barcode <t t-esc="product.barcode || '-'"/></small>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-else=""><div class="cf-haccp-search-empty">Nessun prodotto</div></t>
                                </div>
                                <div class="cf-haccp-recall-block">
                                    <h3>Altri lotti cliccabili</h3>
                                    <t t-if="state.lotSearchResult.lots.length">
                                        <t t-foreach="visibleSearchItems(state.lotSearchResult.lots)" t-as="lot" t-key="lot.id">
                                            <button type="button" class="cf-haccp-lot-chip" t-att-data-query="lot.name" t-on-click="onLotDrill">
                                                <strong><t t-esc="lot.name"/></strong>
                                                <small><t t-esc="lot.product"/></small>
                                            </button>
                                        </t>
                                    </t>
                                    <t t-else=""><div class="cf-haccp-search-empty">Nessun lotto</div></t>
                                </div>
                            </div>                        </div>
                    </t>
                </section>

                <section class="cf-haccp-kpi-grid">
                    <button class="cf-haccp-kpi cf-kpi-warn" t-on-click="onOpenReceiptPending">
                        <span>Ricezioni aperte</span>
                        <strong><t t-esc="state.data.receipt_pending"/></strong>
                        <small><t t-esc="state.data.receipt_blocked"/> bloccate</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-info" t-on-click="onOpenProductionPending">
                        <span>Produzioni aperte</span>
                        <strong><t t-esc="state.data.production_pending"/></strong>
                        <small><t t-esc="state.data.production_blocked"/> in blocco/analisi</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-green" t-on-click="onOpenTraceability">
                        <span>Lotti tracciati</span>
                        <strong><t t-esc="state.data.traced_lots"/></strong>
                        <small><t t-esc="state.data.trace_with_customer"/> con destinatari</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-info" t-on-click="onOpenTraceability">
                        <span>Pronto IFS/BRCGS</span>
                        <strong><t t-esc="state.data.trace_ready_score"/>%</strong>
                        <small><t t-esc="state.data.trace_recall_tested"/> recall testati</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-red" t-on-click="onOpenQuarantine">
                        <span>Quarantene</span>
                        <strong><t t-esc="state.data.active_quarantines"/></strong>
                        <small>merce segregata</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-red" t-on-click="onOpenNcCritical">
                        <span>NC alte/critiche</span>
                        <strong><t t-esc="state.data.nc_critical_open"/></strong>
                        <small><t t-esc="state.data.nc_open"/> NC aperte</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-warn" t-on-click="onOpenTemperatureToday">
                        <span>Temperature</span>
                        <strong><t t-esc="state.data.temp_pending_today + state.data.temp_ko_today"/></strong>
                        <small>pending/KO oggi</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-info" t-on-click="onOpenSanificationToday">
                        <span>Sanificazioni</span>
                        <strong><t t-esc="state.data.san_missing_today"/></strong>
                        <small>da chiudere</small>
                    </button>
                    <button class="cf-haccp-kpi cf-kpi-warn" t-on-click="onOpenDocsExpiring">
                        <span>Doc. e strumenti</span>
                        <strong><t t-esc="state.data.docs_expired + state.data.instruments_expired"/></strong>
                        <small><t t-esc="state.data.docs_expiring + state.data.instruments_expiring"/> in scadenza</small>
                    </button>
                </section>

                <section class="cf-haccp-main-grid">
                    <div class="cf-haccp-panel cf-haccp-panel-wide">
                        <div class="cf-panel-head">
                            <div>
                                <h3>Tracciabilita recente</h3>
                                <span>lotto materia prima → produzione → cliente</span>
                            </div>
                            <button t-on-click="onOpenTraceability">Apri</button>
                        </div>
                        <div class="cf-trace-list">
                            <t t-if="state.data.recent_traces.length">
                                <t t-foreach="state.data.recent_traces" t-as="trace" t-key="trace.id">
                                    <div t-att-class="'cf-trace-row cf-trace-' + trace.status">
                                        <div class="cf-trace-lot">
                                            <strong><t t-esc="trace.lotto_pf"/></strong>
                                            <span>MP <t t-esc="trace.lotto_mp"/></span>
                                        </div>
                                        <div class="cf-trace-route">
                                            <span><t t-esc="trace.production"/></span>
                                            <div class="cf-trace-route-line"/>
                                            <span><t t-esc="trace.customers"/></span>
                                        </div>
                                        <div class="cf-trace-meta">
                                            <span><t t-esc="trace.status_label"/></span>
                                            <strong><t t-esc="trace.audit_ready_score"/>% audit</strong>
                                            <small><t t-esc="trace.risk_count"/> alert · <t t-esc="trace.mass_balance"/></small>
                                            <small><t t-esc="trace.date"/></small>
                                        </div>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="cf-empty">Nessuna scheda tracciabilita ancora presente.</div>
                            </t>
                        </div>
                    </div>

                    <div class="cf-haccp-panel">
                        <div class="cf-panel-head">
                            <div>
                                <h3>NC pipeline</h3>
                                <span>stati aperti e chiusure</span>
                            </div>
                            <button t-on-click="onOpenNcOpen">Apri</button>
                        </div>
                        <div class="cf-stage-flow">
                            <div><span>Aperte</span><strong><t t-esc="state.data.nc_open"/></strong></div>
                            <div><span>Analisi</span><strong><t t-esc="state.data.nc_analysis"/></strong></div>
                            <div><span>Azioni</span><strong><t t-esc="state.data.nc_action"/></strong></div>
                            <div><span>Chiuse</span><strong><t t-esc="state.data.nc_closed"/></strong></div>
                        </div>
                    </div>

                    <div class="cf-haccp-panel">
                        <div class="cf-panel-head">
                            <div>
                                <h3>Quarantene attive</h3>
                                <span>lotti segregati</span>
                            </div>
                            <button t-on-click="onOpenQuarantine">Apri</button>
                        </div>
                        <div class="cf-compact-list">
                            <t t-if="state.data.active_quarantine_rows.length">
                                <t t-foreach="state.data.active_quarantine_rows" t-as="q" t-key="q.id">
                                    <div class="cf-compact-row">
                                        <strong><t t-esc="q.reference"/></strong>
                                        <span><t t-esc="q.lot"/> · <t t-esc="q.product"/></span>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="cf-empty">Nessuna quarantena attiva.</div>
                            </t>
                        </div>
                    </div>

                    <div class="cf-haccp-panel">
                        <div class="cf-panel-head">
                            <div>
                                <h3>Azioni rapide</h3>
                                <span>percorsi facili per operatori</span>
                            </div>
                        </div>
                        <div class="cf-action-stack">
                            <button t-on-click="onOpenReceiptPending">Completa ricezioni</button>
                            <button t-on-click="onOpenProductionPending">Completa produzioni</button>
                            <button t-on-click="onOpenTemperatureToday">Registro temperature</button>
                            <button t-on-click="onOpenCcpKo">CCP fuori limite</button>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </div>
</t>
</templates>
