<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ cf.haccp.reception — Form ═══ -->
    <record id="view_cf_haccp_reception_form" model="ir.ui.view">
        <field name="name">cf.haccp.reception.form</field>
        <field name="model">cf.haccp.reception</field>
        <field name="arch" type="xml">
            <form string="Controllo HACCP Ricezione">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <field name="haccp_state" widget="badge"
                               decoration-danger="haccp_state == 'pending'"
                               decoration-success="haccp_state == 'done'"/>
                    </div>
                    <group>
                        <group string="Ricezione">
                            <field name="picking_id"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="date" readonly="1"/>
                            <field name="picking_origin" readonly="1"/>
                            <field name="product_names" readonly="1"/>
                        </group>
                        <group string="Controllo">
                            <field name="operator_id"/>
                            <field name="lot_number"/>
                            <field name="expiry_date"/>
                            <field name="temperature_value"/>
                        </group>
                    </group>
                    <group string="Checklist HACCP">
                        <group>
                            <field name="temperature_ok"/>
                            <field name="packaging_ok"/>
                        </group>
                        <group>
                            <field name="label_ok"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Note..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ cf.haccp.reception — List ═══ -->
    <record id="view_cf_haccp_reception_list" model="ir.ui.view">
        <field name="name">cf.haccp.reception.list</field>
        <field name="model">cf.haccp.reception</field>
        <field name="arch" type="xml">
            <list string="Controlli HACCP Ricezione"
                  decoration-success="haccp_state == 'done'"
                  decoration-danger="haccp_state == 'pending'">
                <field name="date"/>
                <field name="partner_id"/>
                <field name="picking_id"/>
                <field name="product_names"/>
                <field name="lot_number"/>
                <field name="expiry_date"/>
                <field name="operator_id" widget="many2one_avatar_user"/>
                <field name="haccp_state" widget="badge"
                       decoration-danger="haccp_state == 'pending'"
                       decoration-success="haccp_state == 'done'"/>
            </list>
        </field>
    </record>

    <!-- ═══ cf.haccp.reception — Search ═══ -->
    <record id="view_cf_haccp_reception_search" model="ir.ui.view">
        <field name="name">cf.haccp.reception.search</field>
        <field name="model">cf.haccp.reception</field>
        <field name="arch" type="xml">
            <search string="Cerca Ricezioni HACCP">
                <field name="partner_id"/>
                <field name="lot_number"/>
                <field name="picking_id"/>
                <filter name="filter_from_march" string="Da marzo 2026"
                        domain="[('date', '&gt;=', '2026-03-01')]"/>
                <separator/>
                <filter name="filter_pending" string="Da completare"
                        domain="[('haccp_state', '=', 'pending')]"/>
                <filter name="filter_done" string="Completati"
                        domain="[('haccp_state', '=', 'done')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_partner" string="Fornitore"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="group_state" string="Stato HACCP"
                            context="{'group_by': 'haccp_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ stock.picking — Tab HACCP Ricezione (solo incoming) ═══ -->
    <record id="view_picking_form_haccp_reception" model="ir.ui.view">
        <field name="name">stock.picking.haccp.reception.tab</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="priority">50</field>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Controllo HACCP" name="haccp_reception_tab"
                      invisible="picking_type_code != 'incoming'">
                    <field name="haccp_reception_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="operator_id"/>
                            <field name="lot_number"/>
                            <field name="expiry_date"/>
                            <field name="temperature_value"/>
                            <field name="temperature_ok"/>
                            <field name="packaging_ok"/>
                            <field name="label_ok"/>
                            <field name="notes"/>
                            <field name="haccp_state" widget="badge"
                                   decoration-danger="haccp_state == 'pending'"
                                   decoration-success="haccp_state == 'done'"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
