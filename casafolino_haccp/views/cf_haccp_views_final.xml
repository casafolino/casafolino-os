<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_cf_haccp_sp" model="ir.actions.act_window">
        <field name="name">Schede Produzione</field>
        <field name="res_model">cf.haccp.sp</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_cf_haccp_receipt" model="ir.actions.act_window">
        <field name="name">Controlli Ricezione</field>
        <field name="res_model">cf.haccp.receipt</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_cf_haccp_nc" model="ir.actions.act_window">
        <field name="name">Non Conformità</field>
        <field name="res_model">cf.haccp.nc</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
    <record id="action_cf_haccp_quarantine" model="ir.actions.act_window">
        <field name="name">Quarantena</field>
        <field name="res_model">cf.haccp.quarantine</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_cf_haccp_calibration" model="ir.actions.act_window">
        <field name="name">Calibrazioni</field>
        <field name="res_model">cf.haccp.calibration</field>
        <field name="view_mode">tree,form</field>
    </record>
    <record id="action_cf_haccp_document" model="ir.actions.act_window">
        <field name="name">Documenti HACCP</field>
        <field name="res_model">cf.haccp.document</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- SP FORM -->
    <record id="cf_haccp_sp_form" model="ir.ui.view">
        <field name="name">cf.haccp.sp.form</field>
        <field name="model">cf.haccp.sp</field>
        <field name="arch" type="xml">
            <form string="Scheda di Produzione">
                <header>
                    <button name="action_start" string="Avvia" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_complete" string="Completa" type="object" class="btn-success" invisible="state != 'in_progress'"/>
                    <button name="action_release" string="Rilascia" type="object" class="btn-info" invisible="state != 'completed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,completed,released"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="reference" readonly="1"/></h1></div>
                    <group>
                        <group string="Produzione">
                            <field name="production_id"/>
                            <field name="product_id" required="1"/>
                            <field name="lot_id"/>
                            <field name="quantity_produced"/>
                        </group>
                        <group string="Operatore">
                            <field name="operator_id"/>
                            <field name="date" required="1"/>
                            <field name="date_end"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="10 Step HACCP">
                            <group col="2">
                                <field name="step1_ok" string="1 - Verifica Materie Prime"/>
                                <field name="step2_ok" string="2 - Controllo Temperatura"/>
                                <field name="step3_ok" string="3 - Igiene Operatore"/>
                                <field name="step4_ok" string="4 - Pulizia Strumenti"/>
                                <field name="step5_ok" string="5 - Tracciabilità Inizio"/>
                                <field name="step6_ok" string="6 - Monitoraggio CCP"/>
                                <field name="step7_ok" string="7 - Controllo Intermedio"/>
                                <field name="step8_ok" string="8 - Analisi Finale"/>
                                <field name="step9_ok" string="9 - Tracciabilità Fine"/>
                                <field name="step10_ok" string="10 - Archiviazione"/>
                            </group>
                        </page>
                        <page string="CCP">
                            <field name="ccp_ids" nolabel="1">
                                <tree editable="bottom" decoration-success="state == 'ok'" decoration-danger="state == 'ko'" decoration-warning="state == 'pending'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="ccp_type"/>
                                    <field name="critical_limit_min"/>
                                    <field name="critical_limit_max"/>
                                    <field name="unit"/>
                                    <field name="measured_value"/>
                                    <field name="measurement_time"/>
                                    <field name="measured_by"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Non Conformità">
                            <field name="nc_ids" nolabel="1">
                                <tree decoration-danger="severity == 'critical'" decoration-warning="severity == 'high'">
                                    <field name="reference"/>
                                    <field name="severity" widget="badge"/>
                                    <field name="description"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Note">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- SP TREE -->
    <record id="cf_haccp_sp_tree" model="ir.ui.view">
        <field name="name">cf.haccp.sp.tree</field>
        <field name="model">cf.haccp.sp</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'released'" decoration-info="state == 'completed'" decoration-warning="state == 'in_progress'" decoration-danger="state == 'blocked'">
                <field name="reference"/>
                <field name="product_id"/>
                <field name="production_id"/>
                <field name="date"/>
                <field name="operator_id"/>
                <field name="quantity_produced"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- SP SEARCH -->
    <record id="cf_haccp_sp_search" model="ir.ui.view">
        <field name="name">cf.haccp.sp.search</field>
        <field name="model">cf.haccp.sp</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="product_id"/>
                <filter string="In Produzione" name="in_progress" domain="[('state','=','in_progress')]"/>
                <filter string="Bloccate" name="blocked" domain="[('state','=','blocked')]"/>
                <filter string="Rilasciate" name="released" domain="[('state','=','released')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Prodotto" name="grp_product" context="{'group_by':'product_id'}"/>
                    <filter string="Stato" name="grp_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- RECEIPT FORM -->
    <record id="cf_haccp_receipt_form" model="ir.ui.view">
        <field name="name">cf.haccp.receipt.form</field>
        <field name="model">cf.haccp.receipt</field>
        <field name="arch" type="xml">
            <form string="Controllo Ricezione">
                <header>
                    <button name="action_approve" string="Approva" type="object" class="btn-success" invisible="state != 'draft'"/>
                    <button name="action_reject" string="Rifiuta" type="object" class="btn-danger" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title"><h2><field name="name" readonly="1"/></h2></div>
                    <group>
                        <group string="Fornitore">
                            <field name="supplier_id" required="1"/>
                            <field name="purchase_order_id"/>
                            <field name="receipt_date" required="1"/>
                        </group>
                        <group string="Prodotto">
                            <field name="product_id" required="1"/>
                            <field name="quantity_received" required="1"/>
                            <field name="lot_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Controlli">
                            <group col="2">
                                <field name="check_appearance" string="Aspetto OK"/>
                                <field name="check_smell" string="Odore OK"/>
                                <field name="check_temperature" string="Temperatura OK"/>
                                <field name="check_packaging" string="Imballaggio OK"/>
                            </group>
                        </page>
                        <page string="Note"><field name="notes" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- RECEIPT TREE -->
    <record id="cf_haccp_receipt_tree" model="ir.ui.view">
        <field name="name">cf.haccp.receipt.tree</field>
        <field name="model">cf.haccp.receipt</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'approved'" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="supplier_id"/>
                <field name="product_id"/>
                <field name="receipt_date"/>
                <field name="quantity_received"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- NC FORM -->
    <record id="cf_haccp_nc_form" model="ir.ui.view">
        <field name="name">cf.haccp.nc.form</field>
        <field name="model">cf.haccp.nc</field>
        <field name="arch" type="xml">
            <form string="Non Conformità">
                <header>
                    <button name="action_close" string="Chiudi NC" type="object" class="btn-success" invisible="state in ('closed','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="open,analysis,action,verified,closed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="reference" readonly="1"/></h1></div>
                    <group>
                        <group string="Classificazione">
                            <field name="severity"/>
                            <field name="origin"/>
                            <field name="date"/>
                            <field name="reported_by"/>
                            <field name="assigned_to"/>
                        </group>
                        <group string="Collegamento">
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="sp_id"/>
                            <field name="receipt_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione"><field name="description" nolabel="1" required="1"/></page>
                        <page string="Azione Correttiva"><field name="corrective_action" nolabel="1"/></page>
                        <page string="Note"><field name="notes" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- NC TREE -->
    <record id="cf_haccp_nc_tree" model="ir.ui.view">
        <field name="name">cf.haccp.nc.tree</field>
        <field name="model">cf.haccp.nc</field>
        <field name="arch" type="xml">
            <tree decoration-danger="severity == 'critical'" decoration-warning="severity == 'high'" decoration-success="state == 'closed'">
                <field name="reference"/>
                <field name="date"/>
                <field name="origin"/>
                <field name="product_id"/>
                <field name="severity" widget="badge"/>
                <field name="assigned_to"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- NC KANBAN -->
    <record id="cf_haccp_nc_kanban" model="ir.ui.view">
        <field name="name">cf.haccp.nc.kanban</field>
        <field name="model">cf.haccp.nc</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false">
                <field name="reference"/>
                <field name="severity"/>
                <field name="state"/>
                <field name="product_id"/>
                <field name="assigned_to"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <strong><field name="reference"/></strong>
                                <field name="severity" widget="badge"/>
                            </div>
                            <div><field name="product_id"/></div>
                            <div class="o_kanban_record_bottom">
                                <field name="assigned_to" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- QUARANTINE FORM -->
    <record id="cf_haccp_quarantine_form" model="ir.ui.view">
        <field name="name">cf.haccp.quarantine.form</field>
        <field name="model">cf.haccp.quarantine</field>
        <field name="arch" type="xml">
            <form string="Quarantena">
                <header>
                    <button name="action_release" string="Rilascia" type="object" class="btn-success" invisible="state != 'active'"/>
                    <button name="action_destroy" string="Distruggi" type="object" class="btn-danger" invisible="state != 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,released,destroyed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="reference" readonly="1"/></h1></div>
                    <group>
                        <group string="Prodotto">
                            <field name="lot_id" required="1"/>
                            <field name="product_id"/>
                            <field name="receipt_id"/>
                        </group>
                        <group string="Logistica">
                            <field name="operator_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="location"/>
                        </group>
                    </group>
                    <group string="Motivo"><field name="reason" nolabel="1" required="1"/></group>
                    <group string="Risoluzione"><field name="resolution" nolabel="1"/></group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- QUARANTINE TREE -->
    <record id="cf_haccp_quarantine_tree" model="ir.ui.view">
        <field name="name">cf.haccp.quarantine.tree</field>
        <field name="model">cf.haccp.quarantine</field>
        <field name="arch" type="xml">
            <tree decoration-danger="state == 'active'" decoration-success="state == 'released'">
                <field name="reference"/>
                <field name="lot_id"/>
                <field name="product_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="location"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- CALIBRATION FORM -->
    <record id="cf_haccp_calibration_form" model="ir.ui.view">
        <field name="name">cf.haccp.calibration.form</field>
        <field name="model">cf.haccp.calibration</field>
        <field name="arch" type="xml">
            <form string="Calibrazione Strumento">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="valid,expiring,expired"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="instrument_name"/></h1>
                        <h2><field name="instrument_code"/></h2>
                    </div>
                    <group>
                        <group string="Strumento">
                            <field name="instrument_type"/>
                            <field name="location"/>
                            <field name="workcenter_id"/>
                        </group>
                        <group string="Calibrazione">
                            <field name="date_last_calibration"/>
                            <field name="date_next_calibration" required="1"/>
                            <field name="calibration_interval_months"/>
                            <field name="calibrated_by"/>
                            <field name="certificate_ref"/>
                            <field name="result_ok"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Storico">
                            <field name="calibration_history_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="calibrated_by"/>
                                    <field name="result_ok"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Note"><field name="notes" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- CALIBRATION TREE -->
    <record id="cf_haccp_calibration_tree" model="ir.ui.view">
        <field name="name">cf.haccp.calibration.tree</field>
        <field name="model">cf.haccp.calibration</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'valid'" decoration-warning="state == 'expiring'" decoration-danger="state == 'expired'">
                <field name="instrument_name"/>
                <field name="instrument_code"/>
                <field name="instrument_type"/>
                <field name="location"/>
                <field name="date_last_calibration"/>
                <field name="date_next_calibration"/>
                <field name="calibrated_by"/>
                <field name="result_ok"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- DOCUMENT FORM -->
    <record id="cf_haccp_document_form" model="ir.ui.view">
        <field name="name">cf.haccp.document.form</field>
        <field name="model">cf.haccp.document</field>
        <field name="arch" type="xml">
            <form string="Documento HACCP">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="valid,expiring,expired"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group string="Documento">
                            <field name="doc_type"/>
                            <field name="document_ref"/>
                            <field name="partner_id"/>
                            <field name="product_id"/>
                        </group>
                        <group string="Validità">
                            <field name="date_issue"/>
                            <field name="date_expiry"/>
                        </group>
                    </group>
                    <group string="Note"><field name="notes" nolabel="1"/></group>
                    <group string="Allegati">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- DOCUMENT TREE -->
    <record id="cf_haccp_document_tree" model="ir.ui.view">
        <field name="name">cf.haccp.document.tree</field>
        <field name="model">cf.haccp.document</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'valid'" decoration-warning="state == 'expiring'" decoration-danger="state == 'expired'">
                <field name="name"/>
                <field name="doc_type"/>
                <field name="partner_id"/>
                <field name="document_ref"/>
                <field name="date_issue"/>
                <field name="date_expiry"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- MENUS -->
    <menuitem id="menu_cf_haccp_root" name="HACCP" sequence="25"
              web_icon="casafolino_haccp,static/description/icon.png"/>
    <menuitem id="menu_cf_haccp_sp" name="Schede Produzione"
              parent="menu_cf_haccp_root" action="action_cf_haccp_sp" sequence="1"/>
    <menuitem id="menu_cf_haccp_receipt" name="Controlli Ricezione"
              parent="menu_cf_haccp_root" action="action_cf_haccp_receipt" sequence="2"/>
    <menuitem id="menu_cf_haccp_nc" name="Non Conformità"
              parent="menu_cf_haccp_root" action="action_cf_haccp_nc" sequence="3"/>
    <menuitem id="menu_cf_haccp_quarantine" name="Quarantena"
              parent="menu_cf_haccp_root" action="action_cf_haccp_quarantine" sequence="4"/>
    <menuitem id="menu_cf_haccp_calibration" name="Calibrazioni"
              parent="menu_cf_haccp_root" action="action_cf_haccp_calibration" sequence="5"/>
    <menuitem id="menu_cf_haccp_document" name="Documenti"
              parent="menu_cf_haccp_root" action="action_cf_haccp_document" sequence="6"/>

</odoo>
