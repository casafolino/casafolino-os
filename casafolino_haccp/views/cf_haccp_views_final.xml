<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cf_haccp_mrp_list" model="ir.ui.view">
        <field name="name">mrp.production.haccp.list</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_tree_view"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="haccp_state" widget="badge"
                       decoration-success="haccp_state == 'compliant'"
                       decoration-danger="haccp_state == 'nc'"
                       decoration-warning="haccp_state == 'partial'"
                       decoration-muted="haccp_state == 'na'"
                       optional="show"/>
            </field>
        </field>
    </record>

    <record id="cf_haccp_mrp_form" model="ir.ui.view">
        <field name="name">mrp.production.haccp.form</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="HACCP" name="haccp_tab">
                    <group string="Operatore e Date">
                        <group>
                            <field name="haccp_operator_id"/>
                            <field name="haccp_lot_id"/>
                        </group>
                        <group>
                            <field name="haccp_date_start"/>
                            <field name="haccp_date_end"/>
                        </group>
                    </group>
                    <group string="Temperature">
                        <group>
                            <field name="temp_ambiente"/>
                            <field name="temp_prodotto_inizio"/>
                        </group>
                        <group>
                            <field name="temp_prodotto_fine"/>
                            <field name="temp_stoccaggio"/>
                            <field name="temp_ok"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Igiene Personale">
                            <group col="4">
                                <field name="step_igiene_mani"/>
                                <field name="step_igiene_mani_note" placeholder="Note..."/>
                                <field name="step_abbigliamento"/>
                                <field name="step_abbigliamento_note" placeholder="Note..."/>
                                <field name="step_stato_salute"/>
                                <field name="step_stato_salute_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Pulizia e Sanificazione">
                            <group col="4">
                                <field name="step_pulizia_linea"/>
                                <field name="step_pulizia_linea_note" placeholder="Note..."/>
                                <field name="step_sanificazione"/>
                                <field name="step_sanificazione_note" placeholder="Note..."/>
                                <field name="step_pest_control"/>
                                <field name="step_pest_control_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Materie Prime">
                            <group col="4">
                                <field name="step_mp_conformi"/>
                                <field name="step_mp_conformi_note" placeholder="Note..."/>
                                <field name="step_mp_temp"/>
                                <field name="step_mp_temp_note" placeholder="Note..."/>
                                <field name="step_mp_scadenze"/>
                                <field name="step_mp_scadenze_note" placeholder="Note..."/>
                                <field name="step_allergeni"/>
                                <field name="step_allergeni_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Processo Produttivo">
                            <group col="4">
                                <field name="step_parametri_processo"/>
                                <field name="step_parametri_processo_note" placeholder="Note..."/>
                                <field name="step_tempi_cottura"/>
                                <field name="step_tempi_cottura_note" placeholder="Note..."/>
                                <field name="step_raffreddamento"/>
                                <field name="step_raffreddamento_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Confezionamento">
                            <group col="4">
                                <field name="step_imballaggio"/>
                                <field name="step_imballaggio_note" placeholder="Note..."/>
                                <field name="step_etichettatura"/>
                                <field name="step_etichettatura_note" placeholder="Note..."/>
                                <field name="step_peso_netto"/>
                                <field name="step_peso_netto_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Tracciabilita e Rilascio">
                            <group col="4">
                                <field name="step_lotto_assegnato"/>
                                <field name="step_lotto_assegnato_note" placeholder="Note..."/>
                                <field name="step_campione_conservato"/>
                                <field name="step_campione_conservato_note" placeholder="Note..."/>
                                <field name="step_doc_completa"/>
                                <field name="step_doc_completa_note" placeholder="Note..."/>
                                <field name="step_controllo_finale"/>
                                <field name="step_controllo_finale_note" placeholder="Note..."/>
                                <field name="step_rilascio"/>
                                <field name="step_rilascio_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="CCP">
                            <group string="CCP 1" col="6">
                                <field name="ccp1_name"/>
                                <field name="ccp1_limite_min"/>
                                <field name="ccp1_limite_max"/>
                                <field name="ccp1_valore"/>
                                <field name="ccp1_esito"/>
                                <field name="ccp1_note" placeholder="Note..."/>
                            </group>
                            <group string="CCP 2" col="6">
                                <field name="ccp2_name"/>
                                <field name="ccp2_limite_min"/>
                                <field name="ccp2_limite_max"/>
                                <field name="ccp2_valore"/>
                                <field name="ccp2_esito"/>
                                <field name="ccp2_note" placeholder="Note..."/>
                            </group>
                            <group string="CCP 3" col="6">
                                <field name="ccp3_name"/>
                                <field name="ccp3_limite_min"/>
                                <field name="ccp3_limite_max"/>
                                <field name="ccp3_valore"/>
                                <field name="ccp3_esito"/>
                                <field name="ccp3_note" placeholder="Note..."/>
                            </group>
                            <group string="CCP 4" col="6">
                                <field name="ccp4_name"/>
                                <field name="ccp4_limite_min"/>
                                <field name="ccp4_limite_max"/>
                                <field name="ccp4_valore"/>
                                <field name="ccp4_esito"/>
                                <field name="ccp4_note" placeholder="Note..."/>
                            </group>
                            <group string="CCP 5" col="6">
                                <field name="ccp5_name"/>
                                <field name="ccp5_limite_min"/>
                                <field name="ccp5_limite_max"/>
                                <field name="ccp5_valore"/>
                                <field name="ccp5_esito"/>
                                <field name="ccp5_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Note Generali">
                            <field name="haccp_notes" nolabel="1"/>
                        </page>
                    </notebook>
                    <group string="Stato HACCP">
                        <field name="haccp_state" widget="badge"/>
                        <button name="action_haccp_compliant" string="Rilascia HACCP"
                                type="object" class="btn-success"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
