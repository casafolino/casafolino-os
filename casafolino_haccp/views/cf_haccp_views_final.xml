    <record id="cf_haccp_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.haccp.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Controllo HACCP Ricezione" name="haccp_receipt_tab"
                      invisible="picking_type_code != 'incoming'">
                    <group string="Operatore e Data">
                        <group>
                            <field name="haccp_operator_id"/>
                            <field name="haccp_date"/>
                        </group>
                        <group>
                            <field name="check_lotto_fornitore"/>
                            <field name="haccp_decisione"/>
                        </group>
                    </group>
                    <group string="Temperature">
                        <group>
                            <field name="temp_prodotto"/>
                            <field name="temp_veicolo"/>
                        </group>
                        <group>
                            <field name="temp_ok"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Controlli Organolettici">
                            <group col="4">
                                <field name="check_aspetto"/>
                                <field name="check_aspetto_note" placeholder="Note..."/>
                                <field name="check_odore"/>
                                <field name="check_odore_note" placeholder="Note..."/>
                                <field name="check_colore"/>
                                <field name="check_colore_note" placeholder="Note..."/>
                                <field name="check_consistenza"/>
                                <field name="check_consistenza_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Documentazione">
                            <group col="4">
                                <field name="check_ddt"/>
                                <field name="check_ddt_note" placeholder="Note..."/>
                                <field name="check_coa"/>
                                <field name="check_coa_note" placeholder="Note..."/>
                                <field name="check_scadenza"/>
                                <field name="check_scadenza_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Imballaggio e Veicolo">
                            <group col="4">
                                <field name="check_packaging"/>
                                <field name="check_packaging_note" placeholder="Note..."/>
                                <field name="check_etichetta"/>
                                <field name="check_etichetta_note" placeholder="Note..."/>
                                <field name="check_veicolo_pulizia"/>
                                <field name="check_veicolo_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Allergeni">
                            <group col="4">
                                <field name="check_allergeni"/>
                                <field name="check_allergeni_note" placeholder="Note..."/>
                            </group>
                        </page>
                        <page string="Note"><field name="haccp_notes" nolabel="1"/></page>
                    </notebook>
                    <group string="Stato HACCP">
                        <field name="haccp_receipt_state" widget="badge"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <record id="cf_haccp_purchase_form" model="ir.ui.view">
        <field name="name">purchase.order.haccp.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="HACCP Fornitore" name="haccp_purchase_tab">
                    <group col="4">
                        <field name="haccp_fornitore_approvato"/>
                        <field name="haccp_fornitore_note" placeholder="Note..."/>
                        <field name="haccp_spec_tecniche"/>
                        <field name="haccp_spec_note" placeholder="Note..."/>
                        <field name="haccp_certificazioni"/>
                        <field name="haccp_cert_note" placeholder="Note..."/>
                        <field name="haccp_allergeni_dichiarati"/>
                        <field name="haccp_allergeni_note" placeholder="Note..."/>
                    </group>
                    <group string="Note HACCP">
                        <field name="haccp_notes" nolabel="1"/>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <record id="cf_haccp_picking_list" model="ir.ui.view">
        <field name="name">stock.picking.haccp.list</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="haccp_receipt_state" widget="badge" optional="show"/>
            </field>
        </field>
    </record>

    <record id="cf_haccp_nc_list" model="ir.ui.view">
        <field name="name">cf.haccp.nc.list</field>
        <field name="model">cf.haccp.nc</field>
        <field name="arch" type="xml">
            <list string="Non Conformita">
                <field name="reference"/>
                <field name="date"/>
                <field name="origin"/>
                <field name="product_id"/>
                <field name="severity" widget="badge"/>
                <field name="assigned_to"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="cf_haccp_nc_form" model="ir.ui.view">
        <field name="name">cf.haccp.nc.form</field>
        <field name="model">cf.haccp.nc</field>
        <field name="arch" type="xml">
            <form string="Non Conformita">
                <header>
                    <button name="action_close" string="Chiudi NC" type="object" class="btn-success"/>
                    <field name="state" widget="statusbar" statusbar_visible="open,analysis,action,verified,closed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="reference" readonly="1"/></h1></div>
                    <group>
                        <group string="Classificazione">
                            <field name="severity"/>
                            <field name="origin"/>
                            <field name="date"/>
                            <field name="reported_by"/>
                            <field name="assigned_to"/>
                        </group>
                        <group string="Collegamento">
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="sp_id"/>
                            <field name="receipt_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descrizione"><field name="description" nolabel="1"/></page>
                        <page string="Azione Correttiva"><field name="corrective_action" nolabel="1"/></page>
                        <page string="Note"><field name="notes" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="cf_haccp_quarantine_list" model="ir.ui.view">
        <field name="name">cf.haccp.quarantine.list</field>
        <field name="model">cf.haccp.quarantine</field>
        <field name="arch" type="xml">
            <list string="Quarantena">
                <field name="reference"/>
                <field name="lot_id"/>
                <field name="product_id"/>
                <field name="date_start"/>
                <field name="location"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="cf_haccp_quarantine_form" model="ir.ui.view">
        <field name="name">cf.haccp.quarantine.form</field>
        <field name="model">cf.haccp.quarantine</field>
        <field name="arch" type="xml">
            <form string="Quarantena">
                <header>
                    <button name="action_release" string="Rilascia" type="object" class="btn-success"/>
                    <button name="action_destroy" string="Distruggi" type="object" class="btn-danger"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,released,destroyed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="reference" readonly="1"/></h1></div>
                    <group>
                        <group string="Prodotto">
                            <field name="lot_id" required="1"/>
                            <field name="product_id"/>
                            <field name="receipt_id"/>
                        </group>
                        <group string="Logistica">
                            <field name="operator_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="location"/>
                        </group>
                    </group>
                    <group string="Motivo"><field name="reason" nolabel="1" required="1"/></group>
                    <group string="Risoluzione"><field name="resolution" nolabel="1"/></group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="cf_haccp_calibration_list" model="ir.ui.view">
        <field name="name">cf.haccp.calibration.list</field>
        <field name="model">cf.haccp.calibration</field>
        <field name="arch" type="xml">
            <list string="Calibrazioni">
                <field name="instrument_name"/>
                <field name="instrument_code"/>
                <field name="instrument_type"/>
                <field name="location"/>
                <field name="date_next_calibration"/>
                <field name="calibrated_by"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="cf_haccp_calibration_form" model="ir.ui.view">
        <field name="name">cf.haccp.calibration.form</field>
        <field name="model">cf.haccp.calibration</field>
        <field name="arch" type="xml">
            <form string="Calibrazione Strumento">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="valid,expiring,expired"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="instrument_name"/></h1></div>
                    <group>
                        <group string="Strumento">
                            <field name="instrument_code"/>
                            <field name="instrument_type"/>
                            <field name="location"/>
                            <field name="workcenter_id"/>
                        </group>
                        <group string="Calibrazione">
                            <field name="date_last_calibration"/>
                            <field name="date_next_calibration" required="1"/>
                            <field name="calibration_interval_months"/>
                            <field name="calibrated_by"/>
                            <field name="certificate_ref"/>
                            <field name="result_ok"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Note"><field name="notes" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="cf_haccp_document_list" model="ir.ui.view">
        <field name="name">cf.haccp.document.list</field>
        <field name="model">cf.haccp.document</field>
        <field name="arch" type="xml">
            <list string="Documenti HACCP">
                <field name="name"/>
                <field name="doc_type"/>
                <field name="partner_id"/>
                <field name="date_expiry"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>
    <record id="cf_haccp_document_form" model="ir.ui.view">
        <field name="name">cf.haccp.document.form</field>
        <field name="model">cf.haccp.document</field>
        <field name="arch" type="xml">
            <form string="Documento HACCP">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="valid,expiring,expired"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group string="Documento">
                            <field name="doc_type"/>
                            <field name="document_ref"/>
                            <field name="partner_id"/>
                            <field name="product_id"/>
                        </group>
                        <group string="Validita">
                            <field name="date_issue"/>
                            <field name="date_expiry"/>
                        </group>
                    </group>
                    <group string="Note"><field name="notes" nolabel="1"/></group>
                    <group string="Allegati">
                        <field name="attachment_ids" nolabel="1" widget="many2many_binary"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
</odoo>
