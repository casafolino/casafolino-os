    <!-- ═══════════════════════════════════════════════════════
         FORMAZIONE
    ═══════════════════════════════════════════════════════ -->
    <record id="action_report_formazione" model="ir.actions.report">
        <field name="name">Attestato Formazione HACCP</field>
        <field name="model">cf.haccp.formazione</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">casafolino_haccp.report_formazione</field>
        <field name="binding_model_id" ref="model_cf_haccp_formazione"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_formazione">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Registro Formazione HACCP</h2>
                        <table class="table table-bordered table-sm mt-3">
                            <tbody>
                                <tr>
                                    <th>Data</th>
                                    <td><span t-field="doc.date"/></td>
                                    <th>Durata</th>
                                    <td><span t-field="doc.durata_ore"/> ore</td>
                                </tr>
                                <tr>
                                    <th>Argomento</th>
                                    <td><span t-field="doc.argomento"/></td>
                                    <th>Docente</th>
                                    <td><span t-field="doc.docente"/></td>
                                </tr>
                                <tr>
                                    <th>Esito</th>
                                    <td colspan="3"><span t-field="doc.esito"/></td>
                                </tr>
                            </tbody>
                        </table>
                        <h5 class="mt-3">Elenco Partecipanti</h5>
                        <table class="table table-bordered table-sm">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Nome partecipante</th>
                                    <th>Firma</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="doc.partecipanti_ids" t-as="p">
                                    <tr>
                                        <td><t t-esc="p_index + 1"/></td>
                                        <td><t t-esc="p.name"/></td>
                                        <td style="min-width:120px;">_____________</td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                        <div class="mt-3" t-if="doc.note">
                            <strong>Note:</strong> <p t-field="doc.note"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

