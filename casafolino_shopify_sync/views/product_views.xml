<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_product_shopify_sync_form" model="ir.ui.view">
        <field name="name">product.product.shopify.sync.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Shopify" name="shopify_sync">
                    <div class="o_row mb-3">
                        <button name="action_shopify_sync_stock"
                                string="Sincronizza quantità"
                                type="object"
                                class="btn btn-primary"/>
                    </div>
                    <group>
                        <field name="shopify_inventory_item_gid"/>
                        <field name="shopify_last_stock_sync"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>

