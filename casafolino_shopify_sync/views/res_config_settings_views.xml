<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_shopify_sync" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.shopify.sync</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Shopify Sync" string="Shopify Sync" name="casafolino_shopify_sync">
                    <block title="Connessione">
                        <setting string="Shopify">
                            <field name="shopify_shop_domain"/>
                            <field name="shopify_access_token" password="True"/>
                            <field name="shopify_api_version"/>
                        </setting>
                        <setting string="Magazzino">
                            <field name="shopify_location_gid"/>
                            <field name="shopify_warehouse_id"/>
                        </setting>
                        <setting string="Webhook">
                            <field name="shopify_webhook_secret" password="True"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
