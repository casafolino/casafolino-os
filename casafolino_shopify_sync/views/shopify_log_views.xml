<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_casafolino_shopify_sync_log_list" model="ir.ui.view">
        <field name="name">casafolino.shopify.sync.log.list</field>
        <field name="model">casafolino.shopify.sync.log</field>
        <field name="arch" type="xml">
            <list create="false" edit="false">
                <field name="create_date"/>
                <field name="name"/>
                <field name="direction"/>
                <field name="status"/>
                <field name="sku"/>
                <field name="shopify_id"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="view_casafolino_shopify_sync_log_form" model="ir.ui.view">
        <field name="name">casafolino.shopify.sync.log.form</field>
        <field name="model">casafolino.shopify.sync.log</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="direction"/>
                        <field name="status"/>
                        <field name="sku"/>
                        <field name="shopify_id"/>
                        <field name="odoo_model"/>
                        <field name="odoo_res_id"/>
                    </group>
                    <notebook>
                        <page string="Messaggio" name="message">
                            <field name="message" nolabel="1"/>
                        </page>
                        <page string="Payload" name="payload">
                            <field name="payload" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_casafolino_shopify_sync_log" model="ir.actions.act_window">
        <field name="name">Log Shopify</field>
        <field name="res_model">casafolino.shopify.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_casafolino_shopify_sync_root"
              name="Shopify Sync"
              parent="sale.sale_menu_root"
              sequence="95"/>
    <menuitem id="menu_casafolino_shopify_sync_log"
              name="Log"
              parent="menu_casafolino_shopify_sync_root"
              action="action_casafolino_shopify_sync_log"
              sequence="10"/>
</odoo>

