<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cf_initiative_variant_form" model="ir.ui.view">
        <field name="name">cf.initiative.variant.form</field>
        <field name="model">cf.initiative.variant</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="family_id"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cf_initiative_variant_list" model="ir.ui.view">
        <field name="name">cf.initiative.variant.list</field>
        <field name="model">cf.initiative.variant</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="family_id"/>
            </list>
        </field>
    </record>

    <record id="action_cf_initiative_variant" model="ir.actions.act_window">
        <field name="name">Varianti</field>
        <field name="res_model">cf.initiative.variant</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
