<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cf_initiative_template_form" model="ir.ui.view">
        <field name="name">cf.initiative.template.form</field>
        <field name="model">cf.initiative.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="family_id"/>
                            <field name="variant_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                    <group string="Atomi">
                        <field name="atom_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cf_initiative_template_list" model="ir.ui.view">
        <field name="name">cf.initiative.template.list</field>
        <field name="model">cf.initiative.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="family_id"/>
                <field name="variant_id"/>
            </list>
        </field>
    </record>

    <record id="action_cf_initiative_template" model="ir.actions.act_window">
        <field name="name">Template</field>
        <field name="res_model">cf.initiative.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
