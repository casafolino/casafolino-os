<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- CRM Lead -->
    <record id="view_crm_lead_form_initiative" model="ir.ui.view">
        <field name="name">crm.lead.form.initiative</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(casafolino_initiative.action_cf_initiative_wizard)d" type="action" class="oe_stat_button" icon="fa-plus-square" context="{'default_partner_id': partner_id, 'default_name': name}">
                    <span class="o_stat_text">Crea Dossier</span>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Iniziativa" name="initiative">
                    <group>
                        <field name="initiative_id"/>
                        <field name="cf_tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Res Partner -->
    <record id="view_partner_form_initiative" model="ir.ui.view">
        <field name="name">res.partner.form.initiative</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_initiatives" type="object" class="oe_stat_button" icon="fa-folder-open" invisible="initiative_count == 0">
                    <field name="initiative_count" widget="statinfo" string="Dossier"/>
                </button>
                <button name="action_create_master_dossier" type="object" class="oe_stat_button" icon="fa-plus-square">
                    <span class="o_stat_text">Crea Dossier</span>
                </button>
            </xpath>
        </field>
    </record>

