<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- CRM Lead -->
    <record id="view_crm_lead_form_initiative" model="ir.ui.view">
        <field name="name">crm.lead.form.initiative</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Iniziativa" name="initiative">
                    <group>
                        <field name="initiative_id"/>
                        <field name="cf_tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"/>
                        <field name="source_atom_line_id" readonly="1"
                               invisible="not source_atom_line_id"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

