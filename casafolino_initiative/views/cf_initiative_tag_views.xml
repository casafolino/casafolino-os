<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cf_initiative_tag_form" model="ir.ui.view">
        <field name="name">cf.initiative.tag.form</field>
        <field name="model">cf.initiative.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cf_initiative_tag_list" model="ir.ui.view">
        <field name="name">cf.initiative.tag.list</field>
        <field name="model">cf.initiative.tag</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="category"/>
                <field name="color"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_cf_initiative_tag" model="ir.actions.act_window">
        <field name="name">Tag</field>
        <field name="res_model">cf.initiative.tag</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
