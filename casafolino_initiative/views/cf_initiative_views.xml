<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM -->
    <record id="view_cf_initiative_form" model="ir.ui.view">
        <field name="name">cf.initiative.form</field>
        <field name="model">cf.initiative</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" string="Avvia" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Completa" type="object"
                            class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Annulla" type="object"
                            invisible="state == 'draft' or state == 'cancelled'"/>
                    <button name="action_draft" string="Riporta a Bozza" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_atoms" type="object"
                                class="oe_stat_button" icon="fa-list-ol">
                            <field name="atom_count" widget="statinfo" string="Atomi"/>
                        </button>
                        <button name="action_generate_pending" type="object"
                                class="oe_stat_button" icon="fa-cogs"
                                invisible="pending_atom_count == 0">
                            <field name="pending_atom_count" widget="statinfo"
                                   string="Da Generare"/>
                        </button>
                        <button name="action_view_leads" type="object"
                                class="oe_stat_button" icon="fa-star"
                                invisible="lead_count == 0">
                            <field name="lead_count" widget="statinfo" string="Lead"/>
                        </button>
                        <button name="action_view_projects" type="object"
                                class="oe_stat_button" icon="fa-project-diagram"
                                invisible="project_count == 0">
                            <field name="project_count" widget="statinfo" string="Progetti"/>
                        </button>
                        <button name="action_view_sales" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="sale_count == 0">
                            <field name="sale_count" widget="statinfo" string="Ordini"/>
                        </button>
                        <button name="action_view_moves" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="move_count == 0">
                            <field name="move_count" widget="statinfo" string="Fatture"/>
                        </button>
                        <button name="action_view_pickings" type="object"
                                class="oe_stat_button" icon="fa-truck"
                                invisible="picking_count == 0">
                            <field name="picking_count" widget="statinfo" string="Picking"/>
                        </button>
                        <button name="action_view_productions" type="object"
                                class="oe_stat_button" icon="fa-industry"
                                invisible="production_count == 0">
                            <field name="production_count" widget="statinfo" string="Produzioni"/>
                        </button>
                        <button name="action_view_children" type="object"
                                class="oe_stat_button" icon="fa-sitemap"
                                invisible="child_count == 0">
                            <field name="child_count" widget="statinfo" string="Sotto-iniziative"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nome iniziativa..."/>
                        </h1>
                        <field name="code" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="family_id"/>
                            <field name="variant_id"/>
                            <field name="partner_id"/>
                            <field name="parent_id"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="budget"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="project_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="collaborator_ids" widget="many2many_tags"/>
                        <field name="tag_ids" widget="many2many_tags"
                               options="{'color_field': 'color'}"/>
                    </group>
                    <notebook>
                        <page string="Atomi" name="atoms">
                            <field name="atom_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="atom_id"/>
                                    <field name="user_id"/>
                                    <field name="date_deadline"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'todo'"
                                           decoration-warning="state == 'in_progress'"
                                           decoration-success="state == 'done'"
                                           decoration-muted="state == 'skipped'"/>
                                    <field name="generation_state" widget="badge"
                                           decoration-muted="generation_state == 'pending'"
                                           decoration-success="generation_state == 'generated'"
                                           decoration-danger="generation_state == 'error'"
                                           decoration-info="generation_state == 'manual'"/>
                                    <field name="generated_ref" widget="reference"/>
                                    <button name="action_generate" type="object"
                                            string="Genera" icon="fa-play"
                                            invisible="generation_state != 'manual'"/>
                                    <button name="action_regenerate" type="object"
                                            string="Rigenera" icon="fa-refresh"
                                            invisible="generation_state != 'error'"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Oggetti Collegati" name="linked_objects">
                            <group string="Lead CRM">
                                <field name="crm_lead_ids" nolabel="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="partner_id"/>
                                        <field name="stage_id"/>
                                        <field name="user_id"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Progetti">
                                <field name="project_ids" nolabel="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="user_id"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Ordini di Vendita">
                                <field name="sale_order_ids" nolabel="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="partner_id"/>
                                        <field name="state"/>
                                        <field name="amount_total"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Fatture">
                                <field name="account_move_ids" nolabel="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="partner_id"/>
                                        <field name="state"/>
                                        <field name="amount_total"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Picking">
                                <field name="stock_picking_ids" nolabel="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="partner_id"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </group>
                            <group string="Produzioni">
                                <field name="mrp_production_ids" nolabel="1">
                                    <list>
                                        <field name="name"/>
                                        <field name="product_id"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Gerarchia" name="hierarchy">
                            <group>
                                <field name="parent_id"/>
                            </group>
                            <group string="Sotto-iniziative">
                                <field name="child_ids" nolabel="1">
                                    <list>
                                        <field name="code"/>
                                        <field name="name"/>
                                        <field name="family_id"/>
                                        <field name="state" widget="badge"/>
                                        <field name="user_id"/>
                                    </list>
                                </field>
                            </group>
                        </page>
                        <page string="Descrizione" name="description">
                            <field name="description" placeholder="Descrizione iniziativa..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- LIST -->
    <record id="view_cf_initiative_list" model="ir.ui.view">
        <field name="name">cf.initiative.list</field>
        <field name="model">cf.initiative</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="family_id"/>
                <field name="variant_id"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="tag_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}"/>
                <field name="atom_count"/>
            </list>
        </field>
    </record>

    <!-- KANBAN -->
    <record id="view_cf_initiative_kanban" model="ir.ui.view">
        <field name="name">cf.initiative.kanban</field>
        <field name="model">cf.initiative</field>
        <field name="arch" type="xml">
            <kanban default_group_by="family_id">
                <field name="name"/>
                <field name="code"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="state"/>
                <field name="atom_count"/>
                <field name="child_count"/>
                <field name="tag_ids"/>
                <field name="family_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <small class="text-muted ms-1">
                                        <field name="code"/>
                                    </small>
                                </div>
                                <field name="state" widget="label_selection"
                                       options="{'classes': {'draft': 'info', 'in_progress': 'warning', 'done': 'success', 'cancelled': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="partner_id"/>
                                <div class="mt-1">
                                    <field name="tag_ids" widget="many2many_tags"
                                           options="{'color_field': 'color'}"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span title="Atomi">
                                        <i class="fa fa-list-ol"/> <field name="atom_count"/>
                                    </span>
                                    <span class="ms-2" title="Sotto-iniziative"
                                          t-if="record.child_count.raw_value > 0">
                                        <i class="fa fa-sitemap"/> <field name="child_count"/>
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_cf_initiative_search" model="ir.ui.view">
        <field name="name">cf.initiative.search</field>
        <field name="model">cf.initiative</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="tag_ids"/>
                <filter name="filter_draft" string="Bozza"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="filter_in_progress" string="In Corso"
                        domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_done" string="Completate"
                        domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="filter_my" string="Le Mie"
                        domain="[('user_id', '=', uid)]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter name="groupby_family" string="Famiglia"
                            context="{'group_by': 'family_id'}"/>
                    <filter name="groupby_state" string="Stato"
                            context="{'group_by': 'state'}"/>
                    <filter name="groupby_user" string="Owner"
                            context="{'group_by': 'user_id'}"/>
                    <filter name="groupby_partner" string="Cliente"
                            context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_cf_initiative" model="ir.actions.act_window">
        <field name="name">Iniziative</field>
        <field name="res_model">cf.initiative</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_cf_initiative_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea la tua prima iniziativa!
            </p>
        </field>
    </record>

</odoo>
