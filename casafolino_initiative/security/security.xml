<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_initiative" model="ir.module.category">
        <field name="name">Iniziative</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_initiative_user" model="res.groups">
        <field name="name">Utente Iniziative</field>
        <field name="category_id" ref="module_category_initiative"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_initiative_manager" model="res.groups">
        <field name="name">Manager Iniziative</field>
        <field name="category_id" ref="module_category_initiative"/>
        <field name="implied_ids" eval="[(4, ref('group_initiative_user'))]"/>
    </record>

    <record id="rule_initiative_user" model="ir.rule">
        <field name="name">Iniziative: utente vede proprie</field>
        <field name="model_id" ref="model_cf_initiative"/>
        <field name="domain_force">['|', '|',
            ('user_id', '=', user.id),
            ('collaborator_ids', 'in', [user.id]),
            ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_initiative_user'))]"/>
    </record>

    <record id="rule_initiative_manager" model="ir.rule">
        <field name="name">Iniziative: manager vede tutto</field>
        <field name="model_id" ref="model_cf_initiative"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_initiative_manager'))]"/>
    </record>

</odoo>
