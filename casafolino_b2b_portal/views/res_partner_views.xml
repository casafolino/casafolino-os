<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_b2b_portal" model="ir.ui.view">
        <field name="name">res.partner.form.casafolino.b2b.portal</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="CasaFolino B2B" name="casafolino_b2b">
                    <div class="o_row mb-3">
                        <button name="action_cf_b2b_approve" string="Approva B2B" type="object" class="btn btn-primary" invisible="cf_b2b_status == 'approved'"/>
                        <button name="action_cf_b2b_suspend" string="Sospendi B2B" type="object" class="btn btn-secondary" invisible="cf_b2b_status != 'approved'"/>
                    </div>
                    <group>
                        <group>
                            <field name="cf_b2b_status"/>
                            <field name="cf_b2b_category"/>
                            <field name="cf_b2b_vat_code"/>
                        </group>
                        <group>
                            <field name="cf_b2b_sdi_pec"/>
                            <field name="property_product_pricelist"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_cf_b2b_pending_partners" model="ir.actions.act_window">
        <field name="name">Clienti B2B da approvare</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cf_b2b_status','=','pending')]</field>
        <field name="context">{'search_default_customer': 1}</field>
    </record>

    <menuitem id="menu_cf_b2b_pending_partners"
        name="Clienti B2B"
        parent="contacts.menu_contacts"
        action="action_cf_b2b_pending_partners"
        sequence="35"/>
</odoo>
