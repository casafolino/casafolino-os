<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="b2b_header" name="CasaFolino B2B Header">
        <header class="cf-b2b-top">
            <a class="cf-b2b-brand" href="/b2b" aria-label="CasaFolino B2B">
                <img src="/casafolino_b2b_portal/static/src/img/brand/casafolino-logo.svg" alt="CasaFolino"/>
                <strong>B2B</strong>
            </a>
            <nav aria-label="Menu CasaFolino B2B">
                <a class="active" href="/b2b">Catalogo</a>
                <a href="/shop/cart">Carrello</a>
                <t t-if="request.env.user._is_public()">
                    <a href="/b2b/register">Registrazione</a>
                    <a href="/web/login">Accedi</a>
                </t>
                <t t-else="">
                    <a href="/my/orders">Ordini</a>
                    <a href="/my">
                        <t t-out="request.env.user.partner_id.commercial_partner_id.name or request.env.user.name"/>
                    </a>
                    <a href="/web/session/logout?redirect=/b2b">Esci</a>
                </t>
            </nav>
        </header>
    </template>

    <template id="catalog" name="CasaFolino B2B Catalog">
        <t t-call="website.layout">
            <t t-set="title">CasaFolino B2B</t>
            <div id="wrap" class="cf-b2b-page">
                <t t-call="casafolino_b2b_portal.b2b_header"/>
                <main class="cf-b2b-shell">
                    <section class="cf-b2b-catalog">
                        <section class="cf-buyer-strip">
                            <div>
                                <p class="cf-eyebrow">Per buyer professionali</p>
                                <h2>Assortimento pronto per grossisti, importatori e retail gourmet.</h2>
                            </div>
                            <ul>
                                <li>Distributori food service</li>
                                <li>Negozi gourmet e delicatessen</li>
                                <li>Hotel, ristoranti e catering</li>
                                <li>Importatori e private label</li>
                            </ul>
                        </section>

                        <div class="cf-category-rail" t-if="category_sections">
                            <a href="#cf-best-sellers" class="active">Best seller</a>
                            <a href="#cf-priority-lines">Linee focus</a>
                            <a t-foreach="category_sections" t-as="section" t-attf-href="#cf-cat-#{section_index}">
                                <span t-out="section['name']"/>
                                <strong t-out="len(section['products'])"/>
                            </a>
                        </div>

                        <div class="cf-shop-toolbar" t-if="products">
                            <div>
                                <strong><t t-out="len(products)"/> prodotti B2B</strong>
                                <span>ricerca, categorie e ordine a cartone</span>
                            </div>
                            <label class="cf-catalog-search">
                                <span>Cerca</span>
                                <input type="search" placeholder="SKU, prodotto, linea..." data-cf-product-search="1"/>
                            </label>
                            <a href="/b2b/register" t-if="account_state != 'approved'">Sblocca prezzi e ordini</a>
                            <a href="#carrello" t-else="">Vai al carrello</a>
                        </div>

                        <t t-if="products">
                            <section class="cf-category-section cf-best-sellers" id="cf-best-sellers">
                                <div class="cf-section-head">
                                    <p class="cf-eyebrow">Selezione CasaFolino</p>
                                    <h2>Best seller B2B</h2>
                                </div>
                                <div class="cf-b2b-grid cf-featured-grid">
                                    <t t-call="casafolino_b2b_portal.product_cards">
                                        <t t-set="items" t-value="best_sellers"/>
                                        <t t-set="account_state" t-value="account_state"/>
                                    </t>
                                </div>
                            </section>

                            <section class="cf-category-section cf-priority-lines" id="cf-priority-lines" t-if="priority_sections">
                                <div class="cf-section-head">
                                    <p class="cf-eyebrow">Priorita assortimento</p>
                                    <h2>Linee da spingere ora</h2>
                                    <span class="cf-section-count">focus wholesaler</span>
                                </div>
                                <div class="cf-line-grid">
                                    <article t-foreach="priority_sections" t-as="section" class="cf-line-card">
                                        <div>
                                            <span class="cf-line-number">0<t t-out="section_index + 1"/></span>
                                            <h3 t-out="section['name']"/>
                                            <p t-out="section['summary']"/>
                                        </div>
                                        <a t-attf-href="#cf-focus-#{section_index}"><t t-out="len(section['products'])"/> referenze</a>
                                    </article>
                                </div>
                            </section>

                            <section class="cf-category-section cf-focus-section" t-foreach="priority_sections" t-as="section" t-attf-id="cf-focus-#{section_index}">
                                <div class="cf-section-head">
                                    <p class="cf-eyebrow">Linea focus</p>
                                    <h2 t-out="section['name']"/>
                                    <span class="cf-section-count"><t t-out="len(section['products'])"/> referenze</span>
                                </div>
                                <div class="cf-b2b-grid">
                                    <t t-call="casafolino_b2b_portal.product_cards">
                                        <t t-set="items" t-value="section['products']"/>
                                        <t t-set="account_state" t-value="account_state"/>
                                    </t>
                                </div>
                            </section>

                            <section class="cf-category-section" t-foreach="category_sections" t-as="section" t-attf-id="cf-cat-#{section_index}">
                                <div class="cf-section-head">
                                    <p class="cf-eyebrow">Categoria</p>
                                    <h2 t-out="section['name']"/>
                                    <span class="cf-section-count"><t t-out="len(section['products'])"/> prodotti</span>
                                </div>
                                <div class="cf-b2b-grid">
                                    <t t-call="casafolino_b2b_portal.product_cards">
                                        <t t-set="items" t-value="section['products']"/>
                                        <t t-set="account_state" t-value="account_state"/>
                                    </t>
                                </div>
                            </section>
                        </t>
                        <div class="cf-empty" t-else="">
                            Nessun prodotto B2B pubblicato. Pubblica prodotti vendibili in Odoo per popolare il catalogo.
                        </div>
                    </section>

                    <details class="cf-floating-cart" id="carrello" t-if="account_state == 'approved'">
                        <summary>
                            <span>Carrello</span>
                            <strong><t t-out="cart['total_qty']"/></strong>
                        </summary>
                        <div class="cf-cart-title">
                            <strong>Ordine B2B</strong>
                            <form action="/b2b/cart/clear" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <button type="submit" aria-label="Svuota carrello">x</button>
                            </form>
                        </div>
                        <div class="cf-cart-lines">
                            <t t-if="cart['lines']">
                                <div class="cf-cart-line" t-foreach="cart['lines']" t-as="line">
                                    <div><strong t-out="line['product'].name"/><span><t t-out="'€ %.2f' % line['subtotal']"/></span></div>
                                    <small><t t-out="line['qty']"/> pezzi · collo da <t t-out="line['case_size']"/></small>
                                </div>
                            </t>
                            <p t-else="">Nessun prodotto selezionato.</p>
                        </div>
                        <div class="cf-cart-total"><span>Vasetti</span><strong t-out="cart['total_qty']"/></div>
                        <div class="cf-cart-total"><span>Totale</span><strong><t t-out="'€ %.2f' % cart['total_amount']"/></strong></div>
                        <t t-set="missing_amount" t-value="max(cart['min_amount'] - cart['total_amount'], 0)"/>
                        <t t-set="missing_jars" t-value="max(cart['min_jars'] - cart['total_qty'], 0)"/>
                        <div class="cf-minimum">
                            <span t-if="cart['can_checkout']">Minimi raggiunti</span>
                            <span t-else="">Mancano <t t-out="'€ %.2f' % missing_amount"/> e <t t-out="missing_jars"/> pezzi</span>
                            <i t-attf-style="width: #{min(cart['total_qty'] / cart['min_jars'], cart['total_amount'] / cart['min_amount'], 1) * 100}%"></i>
                        </div>
                        <form action="/b2b/order/submit" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button class="cf-submit" type="submit" t-att-disabled="not cart['can_checkout']">Invia ordine</button>
                        </form>
                    </details>
                </main>
            </div>
        </t>
    </template>

    <template id="product_cards" name="CasaFolino B2B Product Cards">
        <article class="cf-product" t-foreach="items" t-as="item" t-attf-data-cf-search="#{item['record'].name} #{item['category']} #{item['record'].default_code or ''} #{item['blurb']}">
            <a class="cf-product-img" t-att-href="item['detail_url']">
                <img t-att-src="item['image_url']" t-att-alt="item['record'].name" onerror="this.src='/casafolino_b2b_portal/static/src/img/products/crema-pistacchio.png'; this.onerror=null;"/>
                <span t-out="item['category']"/>
            </a>
            <div class="cf-product-body">
                <div class="cf-product-title">
                    <h3><a t-att-href="item['detail_url']" t-out="item['record'].name"/></h3>
                    <small t-if="item['record'].weight"><t t-out="item['record'].weight"/> kg</small>
                </div>
                <p class="cf-product-blurb" t-out="item['blurb']"/>
                <div class="cf-product-meta">
                    <span>SKU <t t-out="item['record'].default_code or '-'"/></span>
                    <span>Cartone <t t-out="item['case_size']"/> pz</span>
                </div>
                <div class="cf-price-row">
                    <span>Disponibile B2B</span>
                    <t t-if="account_state == 'approved'">
                        <strong><t t-out="'€ %.2f' % item['price']"/></strong>
                    </t>
                    <t t-else="">
                        <strong class="cf-locked-price">Prezzo riservato</strong>
                    </t>
                </div>
                <a class="cf-detail-link" t-att-href="item['detail_url']">Apri scheda prodotto</a>
                <form class="cf-add-row" action="/b2b/cart/add" method="post">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="hidden" name="product_id" t-att-value="item['record'].id"/>
                    <input class="cf-qty" type="number" name="quantity" t-att-value="item['case_size']" t-att-step="item['case_size']" t-att-min="item['case_size']"/>
                    <button type="submit" t-att-disabled="account_state != 'approved'">
                        <t t-if="account_state == 'approved'">Aggiungi cartone</t>
                        <t t-else="">Sblocca</t>
                    </button>
                </form>
            </div>
        </article>
    </template>

    <template id="product_detail" name="CasaFolino B2B Product Detail">
        <t t-call="website.layout">
            <t t-set="title"><t t-out="item['record'].name"/> | CasaFolino B2B</t>
            <div id="wrap" class="cf-b2b-page">
                <t t-call="casafolino_b2b_portal.b2b_header"/>
                <main class="cf-product-detail-shell">
                    <a class="cf-back-link" href="/b2b">Torna al catalogo</a>
                    <section class="cf-product-detail">
                        <div class="cf-detail-media">
                            <img t-att-src="item['image_url']" t-att-alt="item['record'].name" onerror="this.src='/casafolino_b2b_portal/static/src/img/products/crema-pistacchio.png'; this.onerror=null;"/>
                        </div>
                        <div class="cf-detail-info">
                            <p class="cf-eyebrow" t-out="item['priority_label']"/>
                            <h1 t-out="item['record'].name"/>
                            <p class="cf-detail-lead" t-out="description"/>
                            <dl class="cf-detail-specs">
                                <div><dt>Categoria</dt><dd t-out="item['category']"/></div>
                                <div><dt>SKU</dt><dd t-out="item['record'].default_code or '-'"/></div>
                                <div><dt>Cartone</dt><dd><t t-out="item['case_size']"/> pezzi</dd></div>
                                <div t-if="item['record'].weight"><dt>Peso</dt><dd><t t-out="item['record'].weight"/> kg</dd></div>
                            </dl>
                            <div class="cf-price-row cf-detail-price">
                                <span>Prezzo B2B per pezzo</span>
                                <t t-if="account_state == 'approved'">
                                    <strong><t t-out="'€ %.2f' % item['price']"/></strong>
                                </t>
                                <t t-else="">
                                    <strong class="cf-locked-price">Riservato</strong>
                                </t>
                            </div>
                            <form class="cf-detail-order" action="/b2b/cart/add" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <input type="hidden" name="product_id" t-att-value="item['record'].id"/>
                                <label>Quantita in pezzi
                                    <input class="cf-qty" type="number" name="quantity" t-att-value="item['case_size']" t-att-step="item['case_size']" t-att-min="item['case_size']"/>
                                </label>
                                <button class="cf-submit" type="submit" t-att-disabled="account_state != 'approved'">
                                    <t t-if="account_state == 'approved'">Aggiungi al carrello</t>
                                    <t t-else="">Accedi al listino</t>
                                </button>
                                <small>La quantita viene arrotondata automaticamente al multiplo del cartone.</small>
                            </form>
                        </div>
                    </section>
                    <section class="cf-category-section" t-if="related_products">
                        <div class="cf-section-head">
                            <p class="cf-eyebrow">Completa assortimento</p>
                            <h2>Altre referenze B2B</h2>
                        </div>
                        <div class="cf-b2b-grid">
                            <t t-call="casafolino_b2b_portal.product_cards">
                                <t t-set="items" t-value="related_products"/>
                                <t t-set="account_state" t-value="account_state"/>
                            </t>
                        </div>
                    </section>
                </main>
                <details class="cf-floating-cart" id="carrello" t-if="account_state == 'approved'">
                    <summary>
                        <span>Carrello</span>
                        <strong><t t-out="cart['total_qty']"/></strong>
                    </summary>
                    <div class="cf-cart-title">
                        <strong>Ordine B2B</strong>
                        <form action="/b2b/cart/clear" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <button type="submit" aria-label="Svuota carrello">x</button>
                        </form>
                    </div>
                    <div class="cf-cart-lines">
                        <t t-if="cart['lines']">
                            <div class="cf-cart-line" t-foreach="cart['lines']" t-as="line">
                                <div><strong t-out="line['product'].name"/><span><t t-out="'€ %.2f' % line['subtotal']"/></span></div>
                                <small><t t-out="line['qty']"/> pezzi · cartone da <t t-out="line['case_size']"/></small>
                            </div>
                        </t>
                        <p t-else="">Nessun prodotto selezionato.</p>
                    </div>
                    <div class="cf-cart-total"><span>Vasetti</span><strong t-out="cart['total_qty']"/></div>
                    <div class="cf-cart-total"><span>Totale</span><strong><t t-out="'€ %.2f' % cart['total_amount']"/></strong></div>
                </details>
            </div>
        </t>
    </template>

    <template id="register" name="CasaFolino B2B Registration">
        <t t-call="website.layout">
            <t t-set="title">Registrazione B2B CasaFolino</t>
            <div id="wrap" class="cf-b2b-page cf-register-page">
                <t t-call="casafolino_b2b_portal.b2b_header"/>
                <main class="cf-register-shell">
                    <form class="cf-register-form" action="/b2b/register" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="google_place_id" data-cf-google-place-id="1"/>
                        <input type="hidden" name="google_place_types" data-cf-google-place-types="1"/>
                        <input class="cf-hp" name="website_url" tabindex="-1" autocomplete="off"/>
                        <p class="cf-eyebrow">Richiesta accesso</p>
                        <h1>Registrazione cliente professionale</h1>
                        <div class="cf-message ok" t-if="sent">Richiesta ricevuta. Ti contatteremo dopo la verifica commerciale.</div>
                        <div class="cf-message locked" t-if="missing">Compila almeno ragione sociale, email e P.IVA.</div>
                        <div class="cf-form-grid">
                            <label>Ragione sociale
                                <input name="name" required="required" data-cf-company-name="1" autocomplete="organization"/>
                                <span class="cf-category-hint" data-cf-category-hint=""></span>
                            </label>
                            <label>P.IVA<input name="vat" required="required"/></label>
                            <label>Email ordini<input name="email" type="email" required="required"/></label>
                            <label>Telefono<input name="phone"/></label>
                            <label>SDI / PEC<input name="sdi_pec"/></label>
                            <label>Attivita
                                <select name="category" data-cf-category-select="1">
                                    <option value="restaurant">Ristorante</option>
                                    <option value="grocery">Gastronomia / Retail</option>
                                    <option value="hotel">Hotel</option>
                                    <option value="distributor">Distributore</option>
                                    <option value="other">Altro</option>
                                </select>
                            </label>
                            <label class="wide">Indirizzo fatturazione<input name="street"/></label>
                            <label class="wide">Note commerciali<textarea name="notes"></textarea></label>
                        </div>
                        <button class="cf-submit" type="submit">Invia richiesta</button>
                    </form>
                    <section class="cf-workflow">
                        <h2>Flusso approvazione</h2>
                        <ol>
                            <li><strong>Registrazione ricevuta</strong><span>Il catalogo resta visibile senza prezzi.</span></li>
                            <li><strong>Verifica CasaFolino</strong><span>Controllo canale, P.IVA e condizioni commerciali.</span></li>
                            <li><strong>Account approvato</strong><span>Attivazione listino e ordine B2B.</span></li>
                            <li><strong>Preventivo Odoo</strong><span>L'ordine entra nel flusso commerciale.</span></li>
                        </ol>
                    </section>
                </main>
                <t t-if="google_places_src">
                    <script>
                        window.cfB2BInitPlaces = window.cfB2BInitPlaces || function () {
                            window.cfB2BPlacesReady = true;
                            document.dispatchEvent(new Event("cf-b2b-places-ready"));
                        };
                    </script>
                    <script async="async" defer="defer" t-att-src="google_places_src"></script>
                </t>
            </div>
        </t>
    </template>

    <template id="thank_you" name="CasaFolino B2B Order Thank You">
        <t t-call="website.layout">
            <t t-set="title">Ordine B2B ricevuto</t>
            <div id="wrap" class="cf-b2b-page">
                <t t-call="casafolino_b2b_portal.b2b_header"/>
                <main class="cf-thanks">
                    <p class="cf-eyebrow">Ordine ricevuto</p>
                    <h1>Grazie, abbiamo ricevuto la tua richiesta.</h1>
                    <p>Il preventivo <strong t-out="order.name"/> e ora in gestione al team CasaFolino.</p>
                    <a class="cf-submit" href="/b2b">Torna al catalogo</a>
                </main>
            </div>
        </t>
    </template>
</odoo>
