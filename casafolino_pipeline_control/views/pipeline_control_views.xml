                            <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 0;border-bottom:1px solid #dfe5df;font-size:13px;font-weight:800;"><span>Scheda tecnica</span><span style="border-radius:999px;padding:6px 11px;background:#ffe8e5;color:#8f2e26;font-size:12px;font-weight:850;">Manca</span></div>
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 0;font-size:13px;font-weight:800;"><span>Condizioni trasporto</span><span style="border-radius:999px;padding:6px 11px;background:#fff0cf;color:#7c5312;font-size:12px;font-weight:850;">Bozza</span></div>
                        </section>

                        <section style="background:#ffffff;border:1px solid #dfe5df;border-radius:8px;padding:15px;">
                            <h2 style="margin:0 0 12px;font-size:17px;color:#1f2723;">Evoluzione</h2>
                            <div style="display:grid;gap:10px;">
                                <div style="display:grid;grid-template-columns:82px 1fr;gap:10px;font-size:12px;color:#6e786f;"><span>Oggi</span><div><strong style="color:#1f2723;display:block;font-size:13px;margin-bottom:2px;">Reparto sblocca</strong>Task chiave completata e allegata al dossier.</div></div>
                                <div style="display:grid;grid-template-columns:82px 1fr;gap:10px;font-size:12px;color:#6e786f;"><span>Domani</span><div><strong style="color:#1f2723;display:block;font-size:13px;margin-bottom:2px;">Commerciale invia</strong>Recap cliente dal composer collegato.</div></div>
                                <div style="display:grid;grid-template-columns:82px 1fr;gap:10px;font-size:12px;color:#6e786f;"><span>+3 giorni</span><div><strong style="color:#1f2723;display:block;font-size:13px;margin-bottom:2px;">Produzione pianifica</strong>Campioni o primo ordine in base alla risposta cliente.</div></div>
                            </div>
                        </section>
                    </aside>
                </div>
            </xpath>
        </field>
    </record>

