<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cf_pipeline_quick_task_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.quick.task.wizard.form</field>
        <field name="model">cf.pipeline.quick.task.wizard</field>
        <field name="arch" type="xml">
            <form string="Salva task veloce">
                <sheet>
                    <div style="display:grid;gap:12px;max-width:880px;">
                        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;border-bottom:1px solid #e2e8df;padding-bottom:10px;">
                            <div>
                                <h2 style="margin:0;font-size:22px;">Task salva-memoria</h2>
                                <p style="margin:4px 0 0;color:#667061;">Scrivi al volo, scegli preset, assegna reparto. Checklist, reminder e mini-progetto si generano sotto.</p>
                            </div>
                            <div style="min-width:290px;">
                                <field name="quick_kind" widget="radio" options="{'horizontal': true}"/>
                            </div>
                        </div>
                        <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;">
                            <div style="border:1px solid #dfe7dc;border-radius:8px;background:#fbfcfa;padding:10px;">
                                <strong style="display:block;color:#334033;">To-do</strong>
                                <span style="font-size:12px;color:#687266;">Promessa, memoria, azione interna.</span>
                            </div>
                            <div style="border:1px solid #dfe7dc;border-radius:8px;background:#fbfcfa;padding:10px;">
                                <strong style="display:block;color:#334033;">Chiamata</strong>
                                <span style="font-size:12px;color:#687266;">Da auto, telefono, Voice AI.</span>
                            </div>
                            <div style="border:1px solid #dfe7dc;border-radius:8px;background:#f7f1df;padding:10px;">
                                <strong style="display:block;color:#5f4a1d;">Catalogo</strong>
                                <span style="font-size:12px;color:#75653f;">Brief grafica e pagina cliente.</span>
                            </div>
                            <div style="border:1px solid #dfe7dc;border-radius:8px;background:#edf6f0;padding:10px;">
                                <strong style="display:block;color:#275c3d;">Campione</strong>
                                <span style="font-size:12px;color:#486a55;">Spedizione, tracking, feedback.</span>
                            </div>
                        </div>
                        <group>
                            <field name="name" placeholder="Es. Aggiungere pagina personalizzata al catalogo cliente"/>
                            <field name="note" placeholder="Scrivi come parli: chi ha chiamato, cosa vuole, promessa fatta, urgenza, reparti coinvolti..." nolabel="1"/>
                        </group>
                        <group>
                            <group string="Decisione rapida">
                                <field name="source_channel"/>
                                <field name="task_type"/>
                                <field name="department"/>
                                <field name="urgency"/>
                            </group>
                            <group string="Scadenza e owner">
                                <field name="due_preset" widget="radio"/>
                                <field name="user_ids" widget="many2many_tags_avatar"/>
                                <field name="deadline" invisible="due_preset != 'custom'"/>
                                <field name="is_mini_project"/>
                                <field name="checklist_required"/>
                            </group>
                        </group>
                        <group string="Memoria cliente">
                            <field name="customer_promise" placeholder="Es. Gli ho promesso risposta entro martedì"/>
                            <field name="next_checkpoint" placeholder="Es. Sentire grafica e confermare costo"/>
                        </group>
                        <group>
                            <group string="Collega">
                                <field name="partner_id" placeholder="Cliente / contatto"/>
                                <field name="project_id" placeholder="Dossier se esiste"/>
                                <field name="lead_id" placeholder="Lead pipeline se esiste"/>
                            </group>
                            <group string="Automazioni">
                                <field name="create_sample_shipment" invisible="task_type != 'sample_shipment'"/>
                                <field name="create_reminder"/>
                                <field name="ai_suggested_next_step" placeholder="Prossimo passo suggerito"/>
                            </group>
                        </group>
                        <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;">
                            <div style="border-left:4px solid #6f7f37;background:#f8faf6;border-radius:8px;padding:10px;">
                                <strong>1. Memoria</strong>
                                <p style="margin:3px 0 0;color:#667061;font-size:12px;">Descrivi la richiesta senza formalismi.</p>
                            </div>
                            <div style="border-left:4px solid #7b5570;background:#fbf8fb;border-radius:8px;padding:10px;">
                                <strong>2. Reparto</strong>
                                <p style="margin:3px 0 0;color:#667061;font-size:12px;">Owner, scadenza e priorità bastano.</p>
                            </div>
                            <div style="border-left:4px solid #4f8b67;background:#f6fbf8;border-radius:8px;padding:10px;">
                                <strong>3. Automazione</strong>
                                <p style="margin:3px 0 0;color:#667061;font-size:12px;">Checklist, reminder e TrackBot se campione.</p>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button name="action_create_task" string="Salva memoria" type="object" class="btn btn-primary"/>
                    <button name="action_create_and_open" string="Salva e apri task" type="object" class="btn btn-secondary"/>
                    <button string="Annulla" class="btn btn-light" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_promote_dossier_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.promote.dossier.wizard.form</field>
        <field name="model">cf.pipeline.promote.dossier.wizard</field>
        <field name="arch" type="xml">
            <form string="Promuovi a dossier">
                <sheet>
                    <group>
                        <field name="lead_id"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="project_name"/>
                        <field name="target_date"/>
                    </group>
                    <group string="Prossima azione">
                        <field name="next_action"/>
                        <field name="next_action_date"/>
                        <field name="create_next_task"/>
                        <field name="create_department_tasks"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_promote" string="Promuovi a dossier" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_create_dossier_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.create.dossier.wizard.form</field>
        <field name="model">cf.pipeline.create.dossier.wizard</field>
        <field name="arch" type="xml">
            <form string="Crea dossier da email">
                <sheet>
                    <group string="Origine ed Email">
                        <field name="message_id"/>
                        <field name="partner_id" placeholder="Seleziona un cliente se esistente"/>
                    </group>
                    <group string="Nuovo Cliente (se non esistente)" invisible="partner_id">
                        <field name="partner_name" required="not partner_id"/>
                        <field name="partner_email"/>
                    </group>
                    <group string="Dettagli Dossier">
                        <field name="project_name"/>
                        <field name="expected_revenue"/>
                        <field name="user_id"/>
                        <field name="target_date"/>
                    </group>
                    <group string="Prossima azione">
                        <field name="next_action"/>
                        <field name="next_action_date"/>
                        <field name="create_next_task"/>
                        <field name="create_department_tasks"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_dossier" string="Crea dossier" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_link_lead_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.link.lead.wizard.form</field>
        <field name="model">cf.pipeline.link.lead.wizard</field>
        <field name="arch" type="xml">
            <form string="Collega email a lead">
                <sheet>
                    <group>
                        <field name="message_id"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="lead_id" domain="[('type', '=', 'opportunity'), ('active', '=', True)]"/>
                        <field name="apply_to_thread"/>
                    </group>
                    <group string="Follow-up">
                        <field name="set_followup"/>
                        <field name="next_followup_date" invisible="not set_followup"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_link" string="Collega lead" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_snooze_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.snooze.wizard.form</field>
        <field name="model">cf.pipeline.snooze.wizard</field>
        <field name="arch" type="xml">
            <form string="Posticipa thread">
                <sheet>
                    <group>
                        <field name="message_id"/>
                        <field name="thread_id"/>
                    </group>
                    <group>
                        <field name="wake_at"/>
                        <field name="note"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_snooze" string="Posticipa" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_plan_fair_followup_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.plan.fair.followup.wizard.form</field>
        <field name="model">cf.pipeline.plan.fair.followup.wizard</field>
        <field name="arch" type="xml">
            <form string="Pianifica follow-up fiera">
                <sheet>
                    <group>
                        <field name="fair_id"/>
                        <field name="affected_count"/>
                    </group>
                    <group string="Pianificazione">
                        <field name="start_date"/>
                        <field name="batch_size"/>
                        <field name="batch_gap_days"/>
                        <field name="only_without_plan"/>
                    </group>
                    <group string="Task">
                        <field name="create_tasks"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_plan" string="Pianifica follow-up" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_crm_lead_form_pipeline_control" model="ir.ui.view">
        <field name="name">crm.lead.form.pipeline.control</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="casafolino_crm_export.cf_crm_lead_view_form_premium"/>
        <field name="priority">120</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Flusso operativo" name="cf_pipeline_control_flow">
                    <div class="o_row mb-3">
                        <button name="action_cf_pc_open_followup" type="object" string="Follow-up" class="btn btn-primary"/>
                        <button name="action_cf_pc_open_inbox" type="object" string="Inbox" class="btn btn-secondary"/>
                        <button name="action_cf_pc_open_quotes" type="object" string="Quotazioni" class="btn btn-secondary"/>
                        <button name="action_cf_pc_new_task" type="object" string="Nuova task" class="btn btn-secondary"/>
                        <button name="action_cf_pc_promote_dossier" type="object" string="Promuovi a dossier" class="btn btn-secondary"/>
                    </div>
                    <group>
                        <group string="Catena commerciale">
                            <field name="partner_id"/>
                            <field name="cf_fair_id"/>
                            <field name="cf_date_last_contact"/>
                            <field name="cf_date_next_followup"/>
                            <field name="cf_project_id"/>
                        </group>
                        <group string="Segnali collegati">
                            <field name="cf_pc_mail_count"/>
                            <field name="cf_pc_quote_count"/>
                            <field name="cf_sample_count"/>
                            <field name="cf_pc_task_count"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_project_project_form_pipeline_control_360" model="ir.ui.view">
        <field name="name">project.project.form.pipeline.control.360</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="casafolino_crm_export.project_project_form_casafolino"/>
        <field name="priority">130</field>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <field name="cf360_continent" invisible="1"/>
                <field name="cf360_mail_count" invisible="1"/>
                <field name="cf360_task_count" invisible="1"/>
                <field name="cf360_document_count" invisible="1"/>
                <field name="cf_lead_count" invisible="1"/>
                <div class="cf-dossier-workbench-360"
                     style="display:grid;grid-template-columns:260px minmax(0,1fr);gap:18px;margin:18px 0 24px;color:#1f2723;background:#f6f7f4;">
                    <aside style="background:#20342a;color:#f2f5ef;border-radius:8px;padding:22px 16px;min-height:720px;">
                        <div style="font-size:22px;font-weight:800;margin-bottom:4px;">Pipeline Export</div>
                        <div style="color:#c7d2c8;font-size:14px;margin-bottom:24px;">Sala controllo operativa</div>
                        <div style="height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;border-radius:7px;color:#dce4dc;font-weight:650;margin-bottom:8px;">
                            <span>Sala Controllo</span><span style="min-width:34px;height:26px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);font-size:13px;">260</span>
                        </div>
                        <div style="height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;border-radius:7px;color:#dce4dc;font-weight:650;margin-bottom:8px;">
                            <span>Follow-up</span><span style="min-width:34px;height:26px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);font-size:13px;">1</span>
                        </div>
                        <div style="height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;border-radius:7px;color:#dce4dc;font-weight:650;margin-bottom:8px;">
                            <span>Post-Fiera</span><span style="min-width:34px;height:26px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);font-size:13px;">54</span>
                        </div>
                        <div style="height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;border-radius:7px;color:#dce4dc;font-weight:650;margin-bottom:8px;">
                            <span>Inbox</span><span style="min-width:34px;height:26px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);font-size:13px;">129</span>
                        </div>
                        <div style="height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;border-radius:7px;color:#dce4dc;font-weight:650;margin-bottom:8px;">
                            <span>Pipeline</span><span style="min-width:34px;height:26px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);font-size:13px;">429</span>
                        </div>
                        <div style="height:48px;display:flex;align-items:center;justify-content:space-between;padding:0 12px;border-radius:7px;background:#41584a;outline:2px solid #75a7ff;color:#f2f5ef;font-weight:750;margin-bottom:8px;">
                            <span>Dossier</span><span style="min-width:34px;height:26px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.15);font-size:13px;">16</span>
                        </div>
                        <div style="margin-top:34px;border:1px solid rgba(255,255,255,.14);border-radius:8px;background:rgba(255,255,255,.08);padding:13px 14px;color:#dce4dc;font-size:13px;line-height:1.35;font-weight:650;">
                            Vista operativa per il lavoro commerciale di giornata.
                        </div>
                    </aside>
                    <div style="min-width:0;">
                        <section style="background:#ffffff;border:1px solid #dfe5df;border-radius:8px;padding:18px;margin-bottom:16px;">
                            <div style="display:grid;grid-template-columns:1fr auto;gap:18px;align-items:start;">
                                <div>
                                    <h1 style="margin:0 0 5px;font-size:28px;line-height:1.1;color:#1f2723;">
                                        <field name="name" readonly="1" nolabel="1"/>
                                    </h1>
                                    <div style="color:#6e786f;font-size:14px;font-weight:650;">
                                        Scrivania operativa dossier · cliente export · continente <field name="cf360_continent" readonly="1" nolabel="1"/>
                                    </div>
                                    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:14px;">
                                        <span style="min-height:30px;display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:6px 11px;font-size:12px;font-weight:850;background:#ffe8e5;color:#8f2e26;">Blocco da gestire</span>
                                        <span style="min-height:30px;display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:6px 11px;font-size:12px;font-weight:850;background:#fff0cf;color:#7c5312;">Avanzamento dossier</span>
                                        <span style="min-height:30px;display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:6px 11px;font-size:12px;font-weight:850;background:#e7f1fb;color:#244f7c;">Prossima azione: <field name="cf_next_action" readonly="1" nolabel="1"/></span>
                                        <span style="min-height:30px;display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:6px 11px;font-size:12px;font-weight:850;background:#f0f3ef;color:#435047;">Owner: <field name="user_id" readonly="1" nolabel="1"/></span>
                                    </div>
                                </div>
                                <button name="action_open_lavagna_360"
                                        type="object"
                                        string="Aggiorna avanzamento"
                                        style="height:40px;border:0;border-radius:8px;padding:0 14px;background:#694668;color:#ffffff;font-weight:850;font-size:14px;"/>
                            </div>
                            <div style="display:flex;gap:6px;margin-top:18px;border-bottom:1px solid #dfe5df;padding-bottom:0;">
                                <span style="height:38px;display:inline-flex;align-items:center;border:1px solid #20342a;border-bottom:0;border-radius:8px 8px 0 0;padding:0 13px;background:#20342a;color:#ffffff;font-weight:850;font-size:13px;">Vista 360</span>
                                <span style="height:38px;display:inline-flex;align-items:center;border:1px solid #dfe5df;border-bottom:0;border-radius:8px 8px 0 0;padding:0 13px;background:#fbfcfa;color:#536057;font-weight:850;font-size:13px;">Evoluzione</span>
                                <span style="height:38px;display:inline-flex;align-items:center;border:1px solid #dfe5df;border-bottom:0;border-radius:8px 8px 0 0;padding:0 13px;background:#fbfcfa;color:#536057;font-weight:850;font-size:13px;">Documenti</span>
                                <span style="height:38px;display:inline-flex;align-items:center;border:1px solid #dfe5df;border-bottom:0;border-radius:8px 8px 0 0;padding:0 13px;background:#fbfcfa;color:#536057;font-weight:850;font-size:13px;">Comunicazioni</span>
                                <span style="height:38px;display:inline-flex;align-items:center;border:1px solid #dfe5df;border-bottom:0;border-radius:8px 8px 0 0;padding:0 13px;background:#fbfcfa;color:#536057;font-weight:850;font-size:13px;">Storico</span>
                            </div>
                            <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:8px;margin-top:16px;">
                                <button name="action_quick_task_360" type="object" string="+  Task reparto" style="min-height:58px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;color:#3c473f;font-weight:850;font-size:12px;text-align:left;padding:9px 10px;"/>
                                <button name="action_compose_email_f8" type="object" string="✉  Scrivi email" invisible="not partner_id" style="min-height:58px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;color:#3c473f;font-weight:850;font-size:12px;text-align:left;padding:9px 10px;"/>
                                <button name="action_reply_last_email_f8" type="object" string="↩  Rispondi cliente" invisible="not partner_id" style="min-height:58px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;color:#3c473f;font-weight:850;font-size:12px;text-align:left;padding:9px 10px;"/>
                                <button name="action_upload_document_360" type="object" string="📎  Allega documento" style="min-height:58px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;color:#3c473f;font-weight:850;font-size:12px;text-align:left;padding:9px 10px;"/>
                                <button name="action_open_lavagna_360" type="object" string="✓  Chiudi blocco" style="min-height:58px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;color:#3c473f;font-weight:850;font-size:12px;text-align:left;padding:9px 10px;"/>
                                <button name="action_schedule_followup_360" type="object" string="⏱  Programma follow-up" style="min-height:58px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;color:#3c473f;font-weight:850;font-size:12px;text-align:left;padding:9px 10px;"/>
                            </div>
                        </section>

                        <section style="display:grid;grid-template-columns:1.1fr .9fr;gap:16px;">
                            <div style="background:#ffffff;border:1px solid #dfe5df;border-radius:8px;padding:15px;">
                                <h2 style="margin:0 0 12px;font-size:17px;color:#1f2723;">Cliente e opportunità</h2>
                                <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;">
                                    <div style="border:1px solid #dfe5df;border-radius:7px;padding:10px;background:#fbfcfa;min-height:70px;"><div style="color:#6e786f;text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:900;margin-bottom:5px;">Cliente</div><div style="font-size:13px;font-weight:800;line-height:1.25;"><field name="partner_id" readonly="1" nolabel="1"/></div></div>
                                    <div style="border:1px solid #dfe5df;border-radius:7px;padding:10px;background:#fbfcfa;min-height:70px;"><div style="color:#6e786f;text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:900;margin-bottom:5px;">Mercato</div><div style="font-size:13px;font-weight:800;line-height:1.25;"><field name="cf360_continent" readonly="1" nolabel="1"/> · Export</div></div>
                                    <div style="border:1px solid #dfe5df;border-radius:7px;padding:10px;background:#fbfcfa;min-height:70px;"><div style="color:#6e786f;text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:900;margin-bottom:5px;">Lead</div><div style="font-size:13px;font-weight:800;line-height:1.25;"><field name="cf_lead_count" readonly="1" nolabel="1"/> opportunità collegate</div></div>
                                    <div style="border:1px solid #dfe5df;border-radius:7px;padding:10px;background:#fbfcfa;min-height:70px;"><div style="color:#6e786f;text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:900;margin-bottom:5px;">Priorità</div><div style="font-size:13px;font-weight:800;line-height:1.25;">Dossier operativo</div></div>
                                    <div style="border:1px solid #dfe5df;border-radius:7px;padding:10px;background:#fbfcfa;min-height:70px;"><div style="color:#6e786f;text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:900;margin-bottom:5px;">Scadenza</div><div style="font-size:13px;font-weight:800;line-height:1.25;"><field name="cf_next_action_date" readonly="1" nolabel="1"/></div></div>
                                    <div style="border:1px solid #dfe5df;border-radius:7px;padding:10px;background:#fbfcfa;min-height:70px;"><div style="color:#6e786f;text-transform:uppercase;letter-spacing:.04em;font-size:10px;font-weight:900;margin-bottom:5px;">Rischio</div><div style="font-size:13px;font-weight:800;line-height:1.25;">Blocchi reparto da chiudere</div></div>
                                </div>
                            </div>
                            <div style="background:#ffffff;border:1px solid #dfe5df;border-radius:8px;padding:15px;">
                                <h2 style="margin:0 0 12px;font-size:17px;color:#1f2723;">Decisione da prendere</h2>
                                <div style="display:grid;grid-template-columns:10px 1fr auto;gap:10px;align-items:start;padding:11px 0;border-bottom:1px solid #dfe5df;">
                                    <span style="width:10px;height:10px;border-radius:999px;margin-top:5px;background:#bd4b42;"></span>
                                    <div><div style="font-size:13px;font-weight:850;margin-bottom:3px;">Cosa blocca il prossimo passo?</div><div style="color:#6e786f;font-size:12px;line-height:1.3;"><field name="cf_next_action" readonly="1" nolabel="1"/></div></div>
                                    <button name="action_open_tasks_360" type="object" string="Apri" style="height:30px;border:1px solid #dfe5df;border-radius:7px;background:#ffffff;font-weight:850;color:#4c564e;"/>
                                </div>
                                <div style="display:grid;grid-template-columns:10px 1fr auto;gap:10px;align-items:start;padding:11px 0;">
                                    <span style="width:10px;height:10px;border-radius:999px;margin-top:5px;background:#efb44f;"></span>
                                    <div><div style="font-size:13px;font-weight:850;margin-bottom:3px;">Trasporto o documenti da confermare</div><div style="color:#6e786f;font-size:12px;line-height:1.3;">Logistica e Back Office completano il dossier prima del recap cliente.</div></div>
                                    <button name="action_open_lavagna_360" type="object" string="Apri" style="height:30px;border:1px solid #dfe5df;border-radius:7px;background:#ffffff;font-weight:850;color:#4c564e;"/>
                                </div>
                            </div>
                        </section>

                        <section style="background:#ffffff;border:1px solid #dfe5df;border-radius:8px;padding:15px;margin-top:16px;">
                            <h2 style="margin:0 0 12px;font-size:17px;color:#1f2723;">Vista 360 per reparto</h2>
                            <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;">
                                <div style="border:1px solid #dfe5df;border-radius:8px;padding:11px;background:#fbfcfa;min-height:138px;"><h3 style="margin:0 0 9px;font-size:13px;">Commerciale</h3><div style="height:8px;border-radius:999px;background:#e6ebe6;overflow:hidden;margin-bottom:9px;"><span style="display:block;height:100%;width:72%;background:#694668;border-radius:inherit;"></span></div><div style="color:#6e786f;font-size:12px;line-height:1.3;">Listino, recap cliente e follow-up commerciale.</div></div>
                                <div style="border:1px solid #dfe5df;border-radius:8px;padding:11px;background:#fbfcfa;min-height:138px;"><h3 style="margin:0 0 9px;font-size:13px;">Back Office</h3><div style="height:8px;border-radius:999px;background:#e6ebe6;overflow:hidden;margin-bottom:9px;"><span style="display:block;height:100%;width:88%;background:#694668;border-radius:inherit;"></span></div><div style="color:#6e786f;font-size:12px;line-height:1.3;">Anagrafica, codici, allegati e dati cliente.</div></div>
                                <div style="border:1px solid #dfe5df;border-radius:8px;padding:11px;background:#fbfcfa;min-height:138px;"><h3 style="margin:0 0 9px;font-size:13px;">Produzione</h3><div style="height:8px;border-radius:999px;background:#e6ebe6;overflow:hidden;margin-bottom:9px;"><span style="display:block;height:100%;width:64%;background:#694668;border-radius:inherit;"></span></div><div style="color:#6e786f;font-size:12px;line-height:1.3;">Fattibilità, campioni e tempi del primo ordine.</div></div>
                                <div style="border:1px solid #dfe5df;border-radius:8px;padding:11px;background:#fbfcfa;min-height:138px;"><h3 style="margin:0 0 9px;font-size:13px;">Logistica</h3><div style="height:8px;border-radius:999px;background:#e6ebe6;overflow:hidden;margin-bottom:9px;"><span style="display:block;height:100%;width:46%;background:#694668;border-radius:inherit;"></span></div><div style="color:#6e786f;font-size:12px;line-height:1.3;">Indirizzo, resa, costo stimato e consegna.</div></div>
                                <div style="border:1px solid #edb2ad;border-radius:8px;padding:11px;background:#fff7f6;min-height:138px;"><h3 style="margin:0 0 9px;font-size:13px;">Qualità</h3><div style="height:8px;border-radius:999px;background:#e6ebe6;overflow:hidden;margin-bottom:9px;"><span style="display:block;height:100%;width:28%;background:#bd4b42;border-radius:inherit;"></span></div><div style="color:#6e786f;font-size:12px;line-height:1.3;">Schede, certificati, etichette e blocchi qualità.</div></div>
                            </div>
                        </section>
                    </div>

                    <aside style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px;align-content:start;grid-column:1 / -1;">
