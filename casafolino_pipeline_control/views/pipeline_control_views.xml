<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cf_pipeline_promote_dossier_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.promote.dossier.wizard.form</field>
        <field name="model">cf.pipeline.promote.dossier.wizard</field>
        <field name="arch" type="xml">
            <form string="Promuovi a dossier">
                <sheet>
                    <group>
                        <field name="lead_id"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="project_name"/>
                        <field name="target_date"/>
                    </group>
                    <group string="Prossima azione">
                        <field name="next_action"/>
                        <field name="next_action_date"/>
                        <field name="create_next_task"/>
                        <field name="create_department_tasks"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_promote" string="Promuovi a dossier" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_link_lead_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.link.lead.wizard.form</field>
        <field name="model">cf.pipeline.link.lead.wizard</field>
        <field name="arch" type="xml">
            <form string="Collega email a lead">
                <sheet>
                    <group>
                        <field name="message_id"/>
                        <field name="partner_id"/>
                    </group>
                    <group>
                        <field name="lead_id" domain="[('type', '=', 'opportunity'), ('active', '=', True)]"/>
                        <field name="apply_to_thread"/>
                    </group>
                    <group string="Follow-up">
                        <field name="set_followup"/>
                        <field name="next_followup_date" invisible="not set_followup"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_link" string="Collega lead" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_snooze_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.snooze.wizard.form</field>
        <field name="model">cf.pipeline.snooze.wizard</field>
        <field name="arch" type="xml">
            <form string="Posticipa thread">
                <sheet>
                    <group>
                        <field name="message_id"/>
                        <field name="thread_id"/>
                    </group>
                    <group>
                        <field name="wake_at"/>
                        <field name="note"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_snooze" string="Posticipa" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_cf_pipeline_plan_fair_followup_wizard" model="ir.ui.view">
        <field name="name">cf.pipeline.plan.fair.followup.wizard.form</field>
        <field name="model">cf.pipeline.plan.fair.followup.wizard</field>
        <field name="arch" type="xml">
            <form string="Pianifica follow-up fiera">
                <sheet>
                    <group>
                        <field name="fair_id"/>
                        <field name="affected_count"/>
                    </group>
                    <group string="Pianificazione">
                        <field name="start_date"/>
                        <field name="batch_size"/>
                        <field name="batch_gap_days"/>
                        <field name="only_without_plan"/>
                    </group>
                    <group string="Task">
                        <field name="create_tasks"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_plan" string="Pianifica follow-up" type="object" class="btn btn-primary"/>
                    <button string="Annulla" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="view_crm_lead_form_pipeline_control" model="ir.ui.view">
        <field name="name">crm.lead.form.pipeline.control</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="casafolino_crm_export.cf_crm_lead_view_form_premium"/>
        <field name="priority">120</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Flusso operativo" name="cf_pipeline_control_flow">
                    <div class="o_row mb-3">
                        <button name="action_cf_pc_open_followup" type="object" string="Follow-up" class="btn btn-primary"/>
                        <button name="action_cf_pc_open_inbox" type="object" string="Inbox" class="btn btn-secondary"/>
                        <button name="action_cf_pc_open_quotes" type="object" string="Quotazioni" class="btn btn-secondary"/>
                        <button name="action_cf_pc_new_task" type="object" string="Nuova task" class="btn btn-secondary"/>
                        <button name="action_cf_pc_promote_dossier" type="object" string="Promuovi a dossier" class="btn btn-secondary"/>
                    </div>
                    <group>
                        <group string="Catena commerciale">
                            <field name="partner_id"/>
                            <field name="cf_fair_id"/>
                            <field name="cf_date_last_contact"/>
                            <field name="cf_date_next_followup"/>
                            <field name="cf_project_id"/>
                        </group>
                        <group string="Segnali collegati">
                            <field name="cf_pc_mail_count"/>
                            <field name="cf_pc_quote_count"/>
                            <field name="cf_sample_count"/>
                            <field name="cf_pc_task_count"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_project_project_form_pipeline_control_360" model="ir.ui.view">
        <field name="name">project.project.form.pipeline.control.360</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="casafolino_crm_export.project_project_form_casafolino"/>
        <field name="priority">130</field>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('oe_title')]" position="after">
                <field name="cf360_continent" invisible="1"/>
                <field name="cf360_mail_count" invisible="1"/>
                <field name="cf360_task_count" invisible="1"/>
                <field name="cf360_document_count" invisible="1"/>
                <field name="cf_lead_count" invisible="1"/>
                <div class="cf-dossier-workbench-360"
                     style="display:grid;grid-template-columns:minmax(0,1fr) 360px;gap:16px;margin:16px 0 22px;padding:16px;border:1px solid #d8dee8;border-radius:8px;background:#eef2f7;">
                    <div class="cf-dossier-workbench-main"
                         style="min-width:0;border:1px solid #d8dee8;border-radius:8px;background:#ffffff;padding:16px;box-shadow:0 10px 25px rgba(15,23,42,.05);">
                        <div class="cf-dossier-workbench-head"
                             style="display:flex;justify-content:space-between;gap:12px;align-items:flex-start;margin-bottom:14px;">
                            <div>
                                <strong style="display:block;font-size:18px;color:#18212f;">Scrivania 360</strong>
                                <span style="display:block;margin-top:3px;color:#667085;font-size:13px;">Attività rapide, composer, blocchi e prossime decisioni del dossier.</span>
                            </div>
                            <span class="cf-dossier-continent"
                                  style="display:inline-flex;align-items:center;min-height:28px;padding:4px 10px;border-radius:999px;background:#eef6f4;color:#115e59;font-weight:750;white-space:nowrap;">
                                Continente: <field name="cf360_continent" readonly="1" nolabel="1"/>
                            </span>
                        </div>
                        <div class="cf-dossier-metrics"
                             style="display:grid;grid-template-columns:repeat(4,minmax(120px,1fr));gap:10px;margin-bottom:14px;">
                            <button name="action_open_mails_360" type="object"
                                    style="min-height:76px;text-align:left;padding:12px;border:1px solid #d8dee8;border-radius:8px;background:#fbfdff;">
                                <span style="display:block;color:#667085;font-size:12px;">Mail dossier</span>
                                <strong style="display:block;font-size:24px;color:#18212f;"><field name="cf360_mail_count" readonly="1" nolabel="1"/></strong>
                            </button>
                            <button name="action_open_tasks_360" type="object"
                                    style="min-height:76px;text-align:left;padding:12px;border:1px solid #d8dee8;border-radius:8px;background:#fbfdff;">
                                <span style="display:block;color:#667085;font-size:12px;">Task aperte</span>
                                <strong style="display:block;font-size:24px;color:#18212f;"><field name="cf360_task_count" readonly="1" nolabel="1"/></strong>
                            </button>
                            <button name="action_open_dossier_leads" type="object"
                                    style="min-height:76px;text-align:left;padding:12px;border:1px solid #d8dee8;border-radius:8px;background:#fbfdff;">
                                <span style="display:block;color:#667085;font-size:12px;">Opportunità</span>
                                <strong style="display:block;font-size:24px;color:#18212f;"><field name="cf_lead_count" readonly="1" nolabel="1"/></strong>
                            </button>
                            <button name="action_open_documents_360" type="object"
                                    style="min-height:76px;text-align:left;padding:12px;border:1px solid #d8dee8;border-radius:8px;background:#fbfdff;">
                                <span style="display:block;color:#667085;font-size:12px;">Documenti</span>
                                <strong style="display:block;font-size:24px;color:#18212f;"><field name="cf360_document_count" readonly="1" nolabel="1"/></strong>
                            </button>
                        </div>
                        <div class="cf-dossier-quick-actions"
                             style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:14px;">
                            <button name="action_quick_task_360"
                                    type="object"
                                    string="Task reparto"
                                    icon="fa-plus"
                                    class="btn btn-secondary"/>
                            <button name="action_compose_email_f8"
                                    type="object"
                                    string="Scrivi email"
                                    icon="fa-envelope"
                                    class="btn btn-primary"
                                    invisible="not partner_id"/>
                            <button name="action_reply_last_email_f8"
                                    type="object"
                                    string="Rispondi cliente"
                                    icon="fa-reply"
                                    class="btn btn-secondary"
                                    invisible="not partner_id"/>
                            <button name="action_upload_document_360"
                                    type="object"
                                    string="Allega documento"
                                    icon="fa-paperclip"
                                    class="btn btn-secondary"/>
                            <button name="action_schedule_followup_360"
                                    type="object"
                                    string="Programma follow-up"
                                    icon="fa-clock-o"
                                    class="btn btn-secondary"/>
                            <button name="action_open_lavagna_360"
                                    type="object"
                                    string="Apri Lavagna"
                                    icon="fa-columns"
                                    class="btn btn-secondary"/>
                        </div>
                        <div class="cf-dossier-lanes"
                             style="display:grid;grid-template-columns:repeat(5,minmax(120px,1fr));gap:8px;">
                            <div style="min-height:82px;padding:10px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;">
                                <strong style="display:block;margin-bottom:6px;">Commerciale</strong>
                                <span style="color:#667085;font-size:12px;">Cliente, listino, follow-up.</span>
                            </div>
                            <div style="min-height:82px;padding:10px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;">
                                <strong style="display:block;margin-bottom:6px;">Back Office</strong>
                                <span style="color:#667085;font-size:12px;">Anagrafica, codici, documenti.</span>
                            </div>
                            <div style="min-height:82px;padding:10px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;">
                                <strong style="display:block;margin-bottom:6px;">Produzione</strong>
                                <span style="color:#667085;font-size:12px;">Fattibilità, campioni, tempi.</span>
                            </div>
                            <div style="min-height:82px;padding:10px;border:1px solid #dfe5df;border-radius:8px;background:#fbfcfa;">
                                <strong style="display:block;margin-bottom:6px;">Logistica</strong>
                                <span style="color:#667085;font-size:12px;">Trasporto, resa, consegna.</span>
                            </div>
                            <div style="min-height:82px;padding:10px;border:1px solid #dfe5df;border-radius:8px;background:#fff7f6;">
                                <strong style="display:block;margin-bottom:6px;">Qualità</strong>
                                <span style="color:#667085;font-size:12px;">Certificati, schede, etichette.</span>
                            </div>
                        </div>
                    </div>
                    <div class="cf-dossier-composer-box"
                         style="display:flex;flex-direction:column;gap:12px;border:1px solid #d8c6df;border-radius:8px;background:#fdfaff;padding:16px;box-shadow:0 10px 25px rgba(15,23,42,.05);">
                        <div>
                            <strong style="display:block;font-size:17px;color:#18212f;">Composer email</strong>
                            <span style="display:block;margin-top:4px;color:#667085;font-size:13px;line-height:1.35;">Scrivi o rispondi dal composer F8, già collegato a cliente e dossier.</span>
                        </div>
                        <div class="cf-dossier-composer-actions"
                             style="display:grid;grid-template-columns:1fr;gap:8px;">
                            <button name="action_compose_email_f8"
                                    type="object"
                                    string="Nuova email"
                                    icon="fa-envelope"
                                    class="btn btn-primary"
                                    invisible="not partner_id"/>
                            <button name="action_reply_last_email_f8"
                                    type="object"
                                    string="Rispondi ultima mail"
                                    icon="fa-reply"
                                    class="btn btn-secondary"
                                    invisible="not partner_id"/>
                        </div>
                        <div style="margin-top:auto;padding:12px;border:1px solid #eadff0;border-radius:8px;background:#ffffff;">
                            <strong style="display:block;font-size:13px;">Prossima azione</strong>
                            <span style="display:block;margin-top:4px;color:#667085;font-size:13px;">
                                <field name="cf_next_action" readonly="1" nolabel="1"/>
                            </span>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_cf_pipeline_control" model="ir.actions.client">
        <field name="name">Sala Controllo</field>
        <field name="tag">casafolino_pipeline_control</field>
