                            <div style="display:grid;grid-template-columns:10px 1fr auto;gap:10px;align-items:start;padding:11px 0;"><span style="width:10px;height:10px;border-radius:999px;margin-top:5px;background:#efb44f;"></span><div><div style="font-size:13px;font-weight:850;margin-bottom:3px;">Confermare resa logistica</div><div style="color:#6e786f;font-size:12px;line-height:1.3;">Logistica · entro la prossima azione</div></div><button name="action_open_lavagna_360" type="object" string="Fai" style="height:30px;border:1px solid #dfe5df;border-radius:7px;background:#ffffff;font-weight:850;color:#4c564e;"/></div>
                        </section>

                        <section style="background:#ffffff;border:1px solid #dfe5df;border-radius:8px;padding:15px;">
                            <h2 style="margin:0 0 12px;font-size:17px;color:#1f2723;">Documenti dossier</h2>
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;padding:10px 0;border-bottom:1px solid #dfe5df;font-size:13px;font-weight:800;"><span>Anagrafica cliente</span><span style="border-radius:999px;padding:6px 11px;background:#f0f3ef;color:#435047;font-size:12px;font-weight:850;">OK</span></div>
