                                <div>
                                    <h2 style="margin:0 0 4px;font-size:17px;color:#1f2723;">Timeline mail dossier</h2>
                                    <div style="color:#6e786f;font-size:12px;font-weight:650;">
                                        <field name="cf360_mail_count" readonly="1" nolabel="1"/> comunicazioni collegate al cliente o al dossier.
                                    </div>
