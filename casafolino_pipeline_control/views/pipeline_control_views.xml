                                <div style="height:36px;display:flex;align-items:center;border:1px solid #dfe5df;border-radius:7px;background:#ffffff;color:#1f2723;font-size:13px;padding:0 10px;">Risposta cliente - recap dossier</div>
                                <div style="height:36px;display:flex;align-items:center;border:1px solid #dfe5df;border-radius:7px;background:#ffffff;color:#1f2723;font-size:13px;padding:0 10px;"><field name="partner_id" readonly="1" nolabel="1"/></div>
                                <div style="height:36px;display:flex;align-items:center;border:1px solid #dfe5df;border-radius:7px;background:#ffffff;color:#1f2723;font-size:13px;padding:0 10px;"><field name="name" readonly="1" nolabel="1"/> - documenti e prossimi passaggi</div>
                                <div style="min-height:112px;border:1px solid #dfe5df;border-radius:7px;background:#ffffff;color:#1f2723;font-size:13px;padding:10px;line-height:1.35;">
