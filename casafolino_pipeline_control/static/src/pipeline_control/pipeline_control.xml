<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="casafolino_pipeline_control.CFPipelineControl">
    <div class="cf-pipeline-control">
        <div t-if="state.loading" class="cf-pc-loading">
            <i class="fa fa-spinner fa-spin"/>
            <span>Caricamento sala controllo...</span>
        </div>

        <div t-elif="state.error" class="cf-pc-error">
            <i class="fa fa-exclamation-triangle"/>
            <div>
                <strong>Errore nel caricamento</strong>
                <p t-out="state.error"/>
                <button class="btn btn-primary btn-sm" t-on-click="loadData">Riprova</button>
            </div>
        </div>

        <div t-else="" class="cf-pc-shell">
            <aside class="cf-pc-sidebar">
                <div class="cf-pc-brand">
                    <strong>Pipeline Export</strong>
                    <span>Sala controllo operativa</span>
                </div>
                <div class="cf-pc-nav">
                    <t t-foreach="navItems" t-as="nav" t-key="nav.id">
                        <button t-attf-class="cf-pc-nav-btn #{state.activeView === nav.id ? 'active' : ''}"
                                t-on-click="() => this.setView(nav.id)">
                            <span t-out="nav.label"/>
                            <em t-out="nav.count"/>
                        </button>
                    </t>
                </div>
                <div class="cf-pc-note">
                    Dati letti da Odoo: CRM, mail, campionature, progetti e preventivi.
                </div>
            </aside>

            <main class="cf-pc-main">
                <div class="cf-pc-topbar">
                    <div>
                        <h1 t-if="state.activeView === 'control'">Sala Controllo</h1>
                        <h1 t-elif="state.activeView === 'followup'">Follow-up</h1>
                        <h1 t-elif="state.activeView === 'fair'">Post-Fiera</h1>
                        <h1 t-elif="state.activeView === 'inbox'">Inbox Commerciale</h1>
                        <h1 t-elif="state.activeView === 'pipeline'">Pipeline Export</h1>
                        <h1 t-elif="state.activeView === 'dossiers'">Dossier</h1>
                        <p>Priorita, prossime azioni e blocchi in un'unica postazione.</p>
                    </div>
                    <div class="cf-pc-actions">
                        <button class="btn btn-light" t-on-click="loadData" title="Aggiorna">
                            <i class="fa fa-refresh"/>
                        </button>
                        <button class="btn btn-light" t-on-click="newLead">
                            <i class="fa fa-plus"/>
                            Nuova richiesta
                        </button>
                        <button class="btn btn-primary" t-on-click="newDossier">
                            <i class="fa fa-folder-open"/>
                            Dossier
                        </button>
                    </div>
                </div>

                <t t-if="state.activeView === 'control'">
                    <div class="cf-pc-kpis">
                        <t t-foreach="state.data.kpis" t-as="kpi" t-key="kpi.key">
                            <div t-attf-class="cf-pc-kpi tone-#{kpi.tone}">
                                <div class="cf-pc-kpi-label">
                                    <span t-out="kpi.label"/>
                                </div>
                                <strong t-out="kpi.value"/>
                                <small t-out="kpi.hint"/>
                            </div>
                        </t>
                    </div>

                    <div class="cf-pc-board">
                        <t t-foreach="state.data.lanes" t-as="lane" t-key="lane.key">
                            <section class="cf-pc-lane">
                                <header>
                                    <h2 t-out="lane.title"/>
                                    <span t-attf-class="cf-pc-pill tone-#{lane.tone}" t-out="lane.count"/>
                                </header>
                                <div class="cf-pc-lane-body">
                                    <t t-if="lane.items.length">
                                        <t t-foreach="lane.items" t-as="item" t-key="item.model + '-' + item.id">
                                            <t t-call="casafolino_pipeline_control.ControlCard"/>
                                        </t>
                                    </t>
                                    <div t-else="" class="cf-pc-empty">Nessun elemento</div>
                                </div>
                            </section>
                        </t>
                    </div>
                </t>

                <t t-elif="state.activeView === 'followup'">
                    <div class="cf-pc-kpis cf-pc-kpis-4">
                        <t t-foreach="state.data.followup.kpis" t-as="kpi" t-key="kpi.label">
                            <div class="cf-pc-kpi">
                                <div class="cf-pc-kpi-label" t-out="kpi.label"/>
                                <strong t-out="kpi.value"/>
                                <small t-out="kpi.hint"/>
                            </div>
                        </t>
                    </div>

                    <div class="cf-pc-board">
                        <t t-foreach="state.data.followup.columns" t-as="column" t-key="column.title">
                            <section class="cf-pc-lane">
                                <header>
                                    <h2 t-out="column.title"/>
                                    <span t-attf-class="cf-pc-pill tone-#{column.tone}" t-out="column.count"/>
                                </header>
                                <div class="cf-pc-lane-body">
                                    <t t-if="column.items.length">
                                        <t t-foreach="column.items" t-as="item" t-key="item.model + '-' + item.id">
                                            <t t-call="casafolino_pipeline_control.ControlCard"/>
                                        </t>
                                    </t>
                                    <div t-else="" class="cf-pc-empty">Nessun elemento</div>
                                </div>
                            </section>
                        </t>
                    </div>

                    <section class="cf-pc-panel cf-pc-route-panel">
                        <header>
                            <h2>Strade operative</h2>
                            <span class="cf-pc-pill" t-out="state.data.followup.routes.length"/>
                        </header>
                        <div class="cf-pc-route-grid">
                            <t t-foreach="state.data.followup.routes" t-as="route" t-key="'route-' + route.title">
                                <section class="cf-pc-route">
                                    <header>
                                        <h3 t-out="route.title"/>
                                        <span t-attf-class="cf-pc-pill tone-#{route.tone}" t-out="route.count"/>
                                    </header>
                                    <div class="cf-pc-route-body">
                                        <t t-if="route.items.length">
                                            <t t-foreach="route.items" t-as="item" t-key="'route-item-' + item.model + '-' + item.id">
                                                <t t-call="casafolino_pipeline_control.CompactActionRow"/>
                                            </t>
                                        </t>
                                        <div t-else="" class="cf-pc-empty" t-out="route.empty"/>
                                    </div>
                                </section>
                            </t>
                        </div>
                    </section>

                    <section class="cf-pc-panel cf-pc-timeline-panel">
                        <header>
                            <h2>Agenda follow-up</h2>
                            <span class="cf-pc-pill" t-out="state.data.followup.timeline.length"/>
                        </header>
                        <table class="cf-pc-table">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Origine</th>
                                    <th>Stage</th>
                                    <th>Owner</th>
                                    <th>Prossima azione</th>
                                    <th>Valore</th>
                                    <th/>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.data.followup.timeline" t-as="row" t-key="'followup-line-' + row.id">
                                    <tr t-attf-class="#{row.is_overdue ? 'is-overdue' : ''}">
                                        <td>
                                            <strong t-out="row.title"/>
                                            <small t-out="row.subtitle"/>
                                        </td>
                                        <td t-out="row.origin"/>
                                        <td t-out="row.stage"/>
                                        <td t-out="row.owner"/>
                                        <td t-out="row.next_action || 'Da pianificare'"/>
                                        <td>
                                            <span t-if="row.value">€ <t t-out="Math.round(row.value).toLocaleString('it-IT')"/></span>
                                        </td>
                                        <td>
                                            <div class="cf-pc-row-actions">
                                                <button class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(row, 'open')" title="Apri lead">
                                                    <i class="fa fa-folder-open-o"/>
                                                </button>
                                                <button class="btn btn-sm btn-primary" t-on-click="() => this.leadQuickAction(row, 'email')" title="Scrivi email">
                                                    <i class="fa fa-envelope-o"/>
                                                </button>
                                                <button class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(row, 'followup7')" title="Follow-up tra 7 giorni">
                                                    <i class="fa fa-calendar-plus-o"/>
                                                </button>
                                                <button class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(row, 'dossier')" title="Promuovi a dossier">
                                                    <i class="fa fa-briefcase"/>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </section>
                </t>

                <t t-elif="state.activeView === 'fair'">
                    <div class="cf-pc-section-head">
                        <div>
                            <h2 t-out="state.data.post_fair.fair ? state.data.post_fair.fair.name : 'Nessuna fiera'"/>
                            <p t-if="state.data.post_fair.fair">
                                <span t-out="state.data.post_fair.fair.date"/>
                                <span t-if="state.data.post_fair.fair.location"> - <t t-out="state.data.post_fair.fair.location"/></span>
                                <span t-if="state.data.post_fair.fair.state"> - <t t-out="state.data.post_fair.fair.state"/></span>
                            </p>
                        </div>
                        <div class="cf-pc-section-tools">
                            <select class="form-select form-select-sm cf-pc-select"
                                    t-on-change="selectFair"
                                    t-att-value="state.selectedFairId || ''">
                                <t t-foreach="state.data.post_fair.fair_options" t-as="fairOption" t-key="fairOption.id">
                                    <option t-att-value="fairOption.id"
                                            t-att-selected="fairOption.id === state.selectedFairId">
                                        <t t-out="fairOption.name"/>
                                        <t t-if="fairOption.date"> - <t t-out="fairOption.date"/></t>
                                    </option>
                                </t>
                            </select>
                            <button class="btn btn-light" t-on-click="() => this.openModel('cf.export.fair', 'Fiere')">Apri fiere</button>
                        </div>
                    </div>
                    <div class="cf-pc-kpis">
                        <t t-foreach="state.data.post_fair.kpis" t-as="kpi" t-key="kpi.label">
                            <div class="cf-pc-kpi">
                                <div class="cf-pc-kpi-label" t-out="kpi.label"/>
                                <strong t-out="kpi.value"/>
                                <small t-out="kpi.hint"/>
                            </div>
                        </t>
                    </div>
                    <div class="cf-pc-board">
                        <t t-foreach="state.data.post_fair.columns" t-as="column" t-key="column.title">
                            <section class="cf-pc-lane">
                                <header>
                                    <h2 t-out="column.title"/>
                                    <span class="cf-pc-pill" t-out="column.count"/>
                                </header>
                                <div class="cf-pc-lane-body">
                                    <t t-foreach="column.items" t-as="item" t-key="item.model + '-' + item.id">
                                        <t t-call="casafolino_pipeline_control.ControlCard"/>
                                    </t>
                                </div>
                            </section>
                        </t>
                    </div>
                    <section class="cf-pc-panel cf-pc-timeline-panel">
                        <header>
                            <h2>Timeline lead fiera</h2>
                            <span class="cf-pc-pill" t-out="state.data.post_fair.timeline.length"/>
                        </header>
                        <table class="cf-pc-table">
                            <thead>
                                <tr>
                                    <th>Cliente</th>
                                    <th>Stage</th>
                                    <th>Ultimo contatto</th>
                                    <th>Prossima azione</th>
                                    <th>Email</th>
                                    <th>Valore</th>
                                    <th/>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.data.post_fair.timeline" t-as="row" t-key="'fair-line-' + row.id">
                                    <tr t-attf-class="#{row.is_overdue ? 'is-overdue' : ''}">
                                        <td>
                                            <strong t-out="row.title"/>
                                            <small t-out="row.subtitle"/>
                                        </td>
                                        <td t-out="row.stage"/>
                                        <td t-out="row.last_contact"/>
                                        <td>
                                            <span t-out="row.next_action || 'Da pianificare'"/>
                                            <small t-if="row.owner" t-out="row.owner"/>
                                        </td>
                                        <td>
                                            <span><t t-out="row.outbound"/> out</span>
                                            <small><t t-out="row.inbound"/> in</small>
                                        </td>
                                        <td>
                                            <span t-if="row.value">€ <t t-out="Math.round(row.value).toLocaleString('it-IT')"/></span>
                                        </td>
                                        <td>
                                            <button class="btn btn-sm btn-light" t-on-click="() => this.openRecord(row)">Apri</button>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </section>
                </t>

                <t t-elif="state.activeView === 'inbox'">
                    <div class="cf-pc-kpis">
                        <t t-foreach="state.data.inbox.kpis" t-as="kpi" t-key="'inbox-kpi-' + kpi.label">
                            <article class="cf-pc-kpi">
                                <span t-out="kpi.label"/>
                                <strong t-out="kpi.value"/>
                                <small t-out="kpi.hint"/>
                            </article>
                        </t>
                    </div>
                    <div class="cf-pc-segment-row">
                        <t t-foreach="inboxFilterOptions" t-as="filter" t-key="'inbox-filter-' + filter.id">
                            <button t-attf-class="btn btn-sm #{state.inboxFilter === filter.id ? 'btn-primary' : 'btn-light'}"
                                    t-on-click="() => this.setInboxFilter(filter.id)">
                                <t t-out="filter.label"/>
                                <span class="cf-pc-mini-count" t-out="filter.count"/>
                            </button>
                        </t>
                    </div>
                    <div class="cf-pc-grid-2">
                        <section class="cf-pc-panel">
                            <header>
                                <h2>Tocca a noi</h2>
                                <span class="cf-pc-pill tone-red" t-out="filteredToReplyRows.length"/>
                            </header>
                            <table class="cf-pc-table">
                                <thead>
                                    <tr>
                                        <th>Cliente</th>
                                        <th>Segnale</th>
                                        <th>Lead</th>
                                        <th>Stato</th>
                                        <th/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="filteredToReplyRows" t-as="row" t-key="'reply-' + row.id">
                                        <tr>
                                            <td>
                                                <strong t-out="row.title"/>
                                                <small t-out="row.meta"/>
                                            </td>
                                            <td>
                                                <span t-out="row.subtitle"/>
                                                <small t-out="row.snippet"/>
                                            </td>
                                            <td>
                                                <span t-if="row.lead" t-out="row.lead"/>
                                                <button t-else="" class="btn btn-sm btn-outline-primary" t-on-click="() => this.mailQuickAction(row, 'link_lead')">Collega</button>
                                            </td>
                                            <td>
                                                <span t-out="row.suggested_action"/>
                                                <small>
                                                    <t t-if="row.urgency">Urgenza <t t-out="row.urgency"/></t>
                                                    <t t-if="row.category"> · <t t-out="row.category"/></t>
                                                    <t t-if="row.thread_count"> · <t t-out="row.thread_count"/> msg</t>
                                                </small>
                                            </td>
                                            <td>
                                                <div class="cf-pc-row-actions">
                                                    <button class="btn btn-sm btn-primary" t-on-click="() => this.mailQuickAction(row, 'reply')" title="Rispondi">
                                                        <i class="fa fa-reply"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'open_thread')" title="Apri thread">
                                                        <i class="fa fa-envelope-open-o"/>
                                                    </button>
                                                    <button t-if="row.lead_id" class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'open_lead')" title="Apri lead">
                                                        <i class="fa fa-handshake-o"/>
                                                    </button>
                                                    <button t-else="" class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'create_lead')" title="Crea lead">
                                                        <i class="fa fa-plus"/>
                                                    </button>
                                                    <button t-if="row.lead_id" class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'link_lead')" title="Cambia lead">
                                                        <i class="fa fa-link"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'task')" title="Crea task">
                                                        <i class="fa fa-check-square-o"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'quote')" title="Crea quotazione">
                                                        <i class="fa fa-file-text-o"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'sample')" title="Crea campionatura">
                                                        <i class="fa fa-flask"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'snooze')" title="Posticipa">
                                                        <i class="fa fa-clock-o"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'archive')" title="Archivia">
                                                        <i class="fa fa-archive"/>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr t-if="!filteredToReplyRows.length">
                                        <td colspan="5" class="cf-pc-empty">Nessun thread per questo filtro</td>
                                    </tr>
                                </tbody>
                            </table>
                        </section>

                        <section class="cf-pc-panel">
                            <header>
                                <h2>Tocca al cliente</h2>
                                <span class="cf-pc-pill tone-amber" t-out="filteredWaitingRows.length"/>
                            </header>
                            <table class="cf-pc-table">
                                <tbody>
                                    <t t-foreach="filteredWaitingRows" t-as="row" t-key="'wait-' + row.id">
                                        <tr>
                                            <td>
                                                <strong t-out="row.title"/>
                                                <small>
                                                    <t t-out="row.subtitle"/>
                                                    <t t-if="row.thread_count"> · <t t-out="row.thread_count"/> msg</t>
                                                </small>
                                            </td>
                                            <td>
                                                <span t-out="row.meta"/>
                                                <small t-if="row.lead" t-out="row.lead"/>
                                                <button t-else="" class="btn btn-sm btn-outline-primary" t-on-click="() => this.mailQuickAction(row, 'link_lead')">Collega</button>
                                            </td>
                                            <td>
                                                <div class="cf-pc-row-actions">
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'open_thread')" title="Apri thread">
                                                        <i class="fa fa-envelope-open-o"/>
                                                    </button>
                                                    <button t-if="row.lead_id" class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'open_lead')" title="Apri lead">
                                                        <i class="fa fa-handshake-o"/>
                                                    </button>
                                                    <button t-if="row.lead_id" class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'link_lead')" title="Cambia lead">
                                                        <i class="fa fa-link"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'task')" title="Crea task">
                                                        <i class="fa fa-check-square-o"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'snooze')" title="Posticipa">
                                                        <i class="fa fa-clock-o"/>
                                                    </button>
                                                    <button class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(row, 'archive')" title="Archivia">
                                                        <i class="fa fa-archive"/>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr t-if="!filteredWaitingRows.length">
                                        <td colspan="3" class="cf-pc-empty">Nessun thread per questo filtro</td>
                                    </tr>
                                </tbody>
                            </table>
                        </section>
                    </div>
                </t>

                <t t-elif="state.activeView === 'pipeline'">
                    <div class="cf-pc-board cf-pc-board-wide">
                        <t t-foreach="state.data.pipeline" t-as="column" t-key="column.id">
                            <section class="cf-pc-lane">
                                <header>
                                    <h2 t-out="column.title"/>
                                    <span class="cf-pc-pill" t-out="column.count"/>
                                </header>
                                <div class="cf-pc-lane-body">
                                    <t t-foreach="column.items" t-as="item" t-key="item.model + '-' + item.id">
                                        <t t-call="casafolino_pipeline_control.ControlCard"/>
                                    </t>
                                </div>
                            </section>
                        </t>
                    </div>
                </t>

                <t t-elif="state.activeView === 'dossiers'">
                    <div class="cf-pc-dossiers">
                        <t t-foreach="state.data.dossiers" t-as="dossier" t-key="dossier.id">
                            <section class="cf-pc-panel">
                                <header>
                                    <div>
                                        <h2 t-out="dossier.name"/>
                                        <p>
                                            <span t-out="dossier.partner"/>
                                            <span t-if="dossier.target_date"> - <t t-out="dossier.target_date"/></span>
                                        </p>
                                    </div>
                                    <div class="cf-pc-row-actions">
                                        <span class="cf-pc-pill tone-amber" t-out="dossier.blocker"/>
                                        <button class="btn btn-sm btn-light" t-on-click="() => this.recordQuickAction(dossier, 'open')" title="Apri dossier">
                                            <i class="fa fa-folder-open-o"/>
                                        </button>
                                        <button class="btn btn-sm btn-primary" t-on-click="() => this.recordQuickAction(dossier, 'task')" title="Nuova task">
                                            <i class="fa fa-plus"/>
                                        </button>
                                    </div>
                                </header>
                                <div class="cf-pc-depts">
                                    <t t-foreach="dossier.departments" t-as="dept" t-key="dept.name">
                                        <div class="cf-pc-dept">
                                            <strong t-out="dept.name"/>
                                            <t t-if="dept.tasks.length">
                                                <t t-foreach="dept.tasks" t-as="task" t-key="task.id">
                                                    <div t-attf-class="cf-pc-task #{task.is_overdue ? 'overdue' : ''}">
                                                        <span t-out="task.name"/>
                                                        <small t-if="task.assignee" t-out="task.assignee"/>
                                                    </div>
                                                </t>
                                            </t>
                                            <small t-else="">Nessun task aperto</small>
                                        </div>
                                    </t>
                                </div>
                            </section>
                        </t>
                    </div>
                </t>
            </main>
        </div>
    </div>
</t>

<t t-name="casafolino_pipeline_control.ControlCard">
    <article class="cf-pc-card">
        <div class="cf-pc-card-title">
            <div>
                <strong t-out="item.title"/>
                <p t-out="item.subtitle"/>
            </div>
            <span t-if="item.value" class="cf-pc-value">
                € <t t-out="Math.round(item.value).toLocaleString('it-IT')"/>
            </span>
        </div>
        <div class="cf-pc-card-meta" t-out="item.meta"/>
        <div class="cf-pc-badges">
            <t t-foreach="item.badges" t-as="badge" t-key="badge_index">
                <span t-attf-class="cf-pc-badge tone-#{item.tone}" t-out="badge"/>
            </t>
        </div>
        <div class="cf-pc-card-actions">
            <button class="btn btn-sm btn-light" t-on-click="() => item.model === 'crm.lead' ? this.leadQuickAction(item, 'open') : this.openRecord(item)">
                Apri
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'email')">
                Email
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'followup7')">
                +7gg
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'today')">
                Oggi
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'sample')">
                Campione
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'dossier')">
                Dossier
            </button>
        </div>
    </article>
</t>

<t t-name="casafolino_pipeline_control.CompactActionRow">
    <article class="cf-pc-compact-row">
        <button class="cf-pc-compact-main" t-on-click="() => this.recordQuickAction(item, 'open')">
            <strong t-out="item.title"/>
            <small>
                <t t-out="item.subtitle"/>
                <t t-if="item.meta"> · <t t-out="item.meta"/></t>
            </small>
        </button>
        <span t-if="item.value" class="cf-pc-value">€ <t t-out="Math.round(item.value).toLocaleString('it-IT')"/></span>
        <div class="cf-pc-row-actions">
            <button class="btn btn-sm btn-light" t-on-click="() => this.recordQuickAction(item, 'open')" title="Apri">
                <i class="fa fa-folder-open-o"/>
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'email')" title="Email">
                <i class="fa fa-envelope-o"/>
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'today')" title="Metti a oggi">
                <i class="fa fa-calendar-check-o"/>
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'quote')" title="Quotazione">
                <i class="fa fa-file-text-o"/>
            </button>
            <button t-if="item.model === 'crm.lead'" class="btn btn-sm btn-light" t-on-click="() => this.leadQuickAction(item, 'sample')" title="Campione">
                <i class="fa fa-flask"/>
            </button>
            <button t-if="item.model === 'casafolino.mail.message'" class="btn btn-sm btn-primary" t-on-click="() => this.mailQuickAction(item, 'reply')" title="Rispondi">
                <i class="fa fa-reply"/>
            </button>
            <button t-if="item.model === 'casafolino.mail.message'" class="btn btn-sm btn-light" t-on-click="() => this.mailQuickAction(item, 'link_lead')" title="Collega lead">
                <i class="fa fa-link"/>
            </button>
            <button t-if="['sale.order', 'cf.export.sample', 'project.project'].includes(item.model)" class="btn btn-sm btn-light" t-on-click="() => this.recordQuickAction(item, 'today')" title="Follow-up oggi">
                <i class="fa fa-calendar-check-o"/>
            </button>
            <button t-if="['sale.order', 'cf.export.sample', 'project.project'].includes(item.model)" class="btn btn-sm btn-light" t-on-click="() => this.recordQuickAction(item, 'followup7')" title="Follow-up tra 7 giorni">
                <i class="fa fa-calendar-plus-o"/>
            </button>
            <button t-if="['sale.order', 'cf.export.sample', 'project.project'].includes(item.model)" class="btn btn-sm btn-primary" t-on-click="() => this.recordQuickAction(item, 'task')" title="Nuova task operativa">
                <i class="fa fa-plus"/>
            </button>
        </div>
    </article>
</t>

</templates>
