<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                USDA Search Wizard Form                       -->
    <!-- ============================================================ -->
    <record id="view_cf_nutrition_usda_wizard_form" model="ir.ui.view">
        <field name="name">cf.nutrition.usda.wizard.form</field>
        <field name="model">cf.nutrition.usda.wizard</field>
        <field name="arch" type="xml">
            <form string="Ricerca USDA FoodData Central">
                <group>
                    <group>
                        <field name="search_query"
                            placeholder="Es: white rice, whole milk, butter unsalted..."/>
                        <field name="data_type_filter"/>
                    </group>
                </group>
                <footer invisible="result_ids">
                    <button name="action_search" type="object"
                            string="Cerca" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
                <group invisible="not result_ids">
                    <field name="result_ids" nolabel="1">
                        <list editable="bottom"
                              decoration-success="energy_kcal > 0">
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="name" readonly="1"/>
                            <field name="brand" readonly="1" optional="show"/>
                            <field name="usda_category" readonly="1" optional="show"/>
                            <field name="usda_data_type" readonly="1" optional="show"/>
                            <field name="energy_kcal" readonly="1"/>
                            <field name="protein" readonly="1"/>
                            <field name="fat" readonly="1"/>
                            <field name="carbs" readonly="1"/>
                            <field name="salt" readonly="1" optional="show"/>
                            <field name="fdc_id" readonly="1" optional="hide"/>
                        </list>
                    </field>
                </group>
                <footer invisible="not result_ids">
                    <button name="action_confirm" type="object"
                            string="Conferma Selezione" class="btn-primary"/>
                    <button name="action_search" type="object"
                            string="Cerca di nuovo" class="btn-secondary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--               CIQUAL Search Wizard Form                      -->
    <!-- ============================================================ -->
    <record id="view_cf_nutrition_ciqual_wizard_form" model="ir.ui.view">
        <field name="name">cf.nutrition.ciqual.wizard.form</field>
        <field name="model">cf.nutrition.ciqual.wizard</field>
        <field name="arch" type="xml">
            <form string="Ricerca CIQUAL (ANSES)">
                <group>
                    <group>
                        <field name="search_query"
                            placeholder="Es: lait, beurre, farine..."/>
                    </group>
                </group>
                <footer invisible="result_ids">
                    <button name="action_search" type="object"
                            string="Cerca" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
                <group invisible="not result_ids">
                    <field name="result_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="ciqual_code" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="energy_kcal" readonly="1"/>
                            <field name="fat" readonly="1"/>
                            <field name="carbs" readonly="1"/>
                            <field name="protein" readonly="1"/>
                            <field name="salt" readonly="1"/>
                        </list>
                    </field>
                </group>
                <footer invisible="not result_ids">
                    <button name="action_confirm" type="object"
                            string="Conferma Selezione" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                 CREA Search Wizard Form                      -->
    <!-- ============================================================ -->
    <record id="view_cf_nutrition_crea_wizard_form" model="ir.ui.view">
        <field name="name">cf.nutrition.crea.wizard.form</field>
        <field name="model">cf.nutrition.crea.wizard</field>
        <field name="arch" type="xml">
            <form string="Ricerca CREA (ISS Italia)">
                <group>
                    <group>
                        <field name="search_query"
                            placeholder="Es: riso carnaroli, nocciole, latte intero..."/>
                    </group>
                </group>
                <footer invisible="result_ids">
                    <button name="action_search" type="object"
                            string="Cerca" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
                <group invisible="not result_ids">
                    <field name="result_ids" nolabel="1">
                        <list editable="bottom"
                              decoration-success="energy_kcal > 0">
                            <field name="selected" widget="boolean_toggle"/>
                            <field name="crea_code" readonly="1"/>
                            <field name="name" readonly="1"/>
                            <field name="categoria" readonly="1"/>
                            <field name="energy_kcal" readonly="1"/>
                            <field name="protein" readonly="1"/>
                            <field name="fat" readonly="1"/>
                            <field name="carbs" readonly="1"/>
                            <field name="sugars" readonly="1" optional="show"/>
                            <field name="fiber" readonly="1" optional="show"/>
                            <field name="salt" readonly="1" optional="show"/>
                        </list>
                    </field>
                </group>
                <footer invisible="not result_ids">
                    <button name="action_confirm" type="object"
                            string="Conferma Selezione" class="btn-primary"/>
                    <button name="action_search" type="object"
                            string="Cerca di nuovo" class="btn-secondary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ============================================================ -->
    <!--                    Wizard Actions                            -->
    <!-- ============================================================ -->
    <record id="action_cf_nutrition_crea_wizard" model="ir.actions.act_window">
        <field name="name">Ricerca CREA</field>
        <field name="res_model">cf.nutrition.crea.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_cf_nutrition_usda_wizard" model="ir.actions.act_window">
        <field name="name">Ricerca USDA</field>
        <field name="res_model">cf.nutrition.usda.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <record id="action_cf_nutrition_ciqual_wizard" model="ir.actions.act_window">
        <field name="name">Ricerca CIQUAL</field>
        <field name="res_model">cf.nutrition.ciqual.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- ============================================================ -->
    <!--            Bulk Import Wizard Form + Action                  -->
    <!-- ============================================================ -->
    <record id="view_cf_nutrition_bulk_import_wizard_form" model="ir.ui.view">
        <field name="name">cf.nutrition.bulk.import.wizard.form</field>
        <field name="model">cf.nutrition.bulk.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importazione massiva dati nutrizionali USDA">
                <group>
                    <field name="filter_mode"/>
                    <field name="source"/>
                    <field name="skip_existing"/>
                </group>
                <group invisible="not result_message">
                    <field name="result_message" nolabel="1" readonly="1"
                           widget="text"/>
                </group>
                <footer invisible="result_message">
                    <button name="action_run" type="object"
                            string="Avvia Importazione" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
                <footer invisible="not result_message">
                    <button string="Chiudi" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cf_nutrition_bulk_import" model="ir.actions.act_window">
        <field name="name">Importa dati nutrizionali</field>
        <field name="res_model">cf.nutrition.bulk.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Server action binding on product.template list -->
    <record id="action_bulk_import_usda_from_products" model="ir.actions.server">
        <field name="name">Importa dati nutrizionali</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Importa dati nutrizionali',
    'res_model': 'cf.nutrition.bulk.import.wizard',
    'view_mode': 'form',
    'target': 'new',
}
        </field>
    </record>

</odoo>
