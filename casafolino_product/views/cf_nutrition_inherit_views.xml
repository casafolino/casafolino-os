<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_bom_nutrition_tab" model="ir.ui.view">
        <field name="name">mrp.bom.form.nutrition</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="priority">15</field>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Nutrizione" name="cf_nutrition">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <button name="action_compute_from_bom" type="object"
                                string="Calcola da Componenti"
                                class="btn-primary"/>
                        <field name="nutrition_status_html" widget="html"
                               nolabel="1" readonly="1"/>
                    </div>
                    <field name="nutrition_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="regulation_id"/>
                            <field name="serving_size_g"/>
                            <field name="energy_kcal"/>
                            <field name="fat"/>
                            <field name="carbs"/>
                            <field name="protein"/>
                            <field name="salt"/>
                            <field name="nutri_score" widget="badge"
                                decoration-success="nutri_score == 'A'"
                                decoration-info="nutri_score == 'B'"
                                decoration-warning="nutri_score in ('C','D')"
                                decoration-danger="nutri_score == 'E'"/>
                            <field name="last_computed" readonly="1"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Colonna "Escludi nutrizionale" nella lista componenti BOM -->
    <record id="view_mrp_bom_line_exclude_nutrition" model="ir.ui.view">
        <field name="name">mrp.bom.line.exclude.nutrition</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="priority">18</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bom_line_ids']//field[@name='product_qty']"
                   position="after">
                <field name="exclude_from_nutrition" string="No Nutriz."
                       widget="boolean_toggle" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Nutri-Score nella list view BOM -->
    <record id="view_mrp_bom_list_nutriscore" model="ir.ui.view">
        <field name="name">mrp.bom.list.nutriscore</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_tree_view"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_tmpl_id']" position="after">
                <field name="nutrition_status_html" widget="html"
                       string="Nutrizione" optional="show" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_template_nutrition_tab" model="ir.ui.view">
        <field name="name">product.template.form.nutrition</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Nutrizione" name="cf_nutrition_product">

                    <!-- Stato: nessun dato configurato -->
                    <div class="alert alert-info mb-3"
                         invisible="nutrition_ingredient_id">
                        <div class="d-flex align-items-center gap-3">
                            <span class="flex-grow-1">
                                <strong>Nessun dato nutrizionale configurato.</strong>
                                Clicca per creare il record nutrizionale e abilitare la sincronizzazione.
                            </span>
                            <button name="action_setup_food_ingredient" type="object"
                                    string="Configura come ingrediente alimentare"
                                    class="btn btn-sm btn-info"/>
                        </div>
                    </div>

                    <!-- Configurazione (visibile quando ingrediente esiste) -->
                    <group invisible="not nutrition_ingredient_id">
                        <group string="Ingrediente Alimentare">
                            <field name="is_food_ingredient" widget="boolean_toggle"/>
                            <field name="nutrition_ingredient_id"
                                   options="{'no_create': False}"/>
                            <field name="nutri_score_final" widget="badge"
                                decoration-success="nutri_score_final == 'A'"
                                decoration-info="nutri_score_final == 'B'"
                                decoration-warning="nutri_score_final == 'C' or nutri_score_final == 'D'"
                                decoration-danger="nutri_score_final == 'E'"
                                readonly="1"/>
                        </group>
                        <group string="Azioni">
                            <button name="action_sync_ingredient_usda" type="object"
                                    string="Sync USDA" class="btn-secondary"/>
                            <button name="action_sync_ingredient_off" type="object"
                                    string="Sync Open Food Facts" class="btn-secondary"/>
                            <button name="action_create_nutrition" type="object"
                                    string="Calcola da BoM" class="btn-primary"/>
                        </group>
                    </group>

                    <!-- Etichette nutrizionali da BOM -->
                    <field name="nutrition_bom_ids" nolabel="1"
                           invisible="not nutrition_ingredient_id">
                        <list>
                            <field name="bom_id"/>
                            <field name="serving_size_g"/>
                            <field name="energy_kcal"/>
                            <field name="fat"/>
                            <field name="carbs"/>
                            <field name="protein"/>
                            <field name="salt"/>
                            <field name="nutri_score" widget="badge"
                                decoration-success="nutri_score == 'A'"
                                decoration-info="nutri_score == 'B'"
                                decoration-warning="nutri_score in ('C','D')"
                                decoration-danger="nutri_score == 'E'"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
