<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="casafolino_initiative_dashboard.LavagnaKanban">
        <div class="o_lavagna_kanban">
            <t t-if="!props.data || !props.data.stages || !props.data.stages.length">
                <div class="o_lavagna_kanban_empty">
                    <i class="fa fa-columns fa-3x"/>
                    <p>Nessuno stage configurato. Crea task per iniziare.</p>
                </div>
            </t>
            <t t-else="">
                <div class="o_lavagna_kanban_scroll">
                    <!-- Column headers -->
                    <div class="o_lavagna_kanban_columns">
                        <div t-foreach="props.data.stages" t-as="stage" t-key="stage.id"
                             class="o_lavagna_kanban_col"
                             t-att-class="{ 'o_folded': stage.fold }">
                            <div class="o_lavagna_col_header">
                                <span class="o_col_name" t-esc="stage.name"/>
                                <span class="o_col_count"
                                      t-esc="getTasksForCell(stage.id, null).length"/>
                                <button class="o_col_add_btn"
                                        t-on-click="() => this.startQuickAdd(stage.id, null)"
                                        title="Aggiungi task">
                                    <i class="fa fa-plus"/>
                                </button>
                            </div>

                            <!-- Quick add input -->
                            <div t-if="localState.quickAddStageId === stage.id and !localState.quickAddTagId"
                                 class="o_lavagna_quick_add">
                                <input type="text"
                                       class="o_quick_add_input"
                                       placeholder="Nome task..."
                                       t-att-value="localState.quickAddName"
                                       t-on-input="onQuickAddInput"
                                       t-on-keydown="onQuickAddKeydown"
                                       t-ref="quickAddInput"/>
                                <button class="o_quick_add_cancel"
                                        t-on-click="() => this.cancelQuickAdd()">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>

                            <!-- Drop zone (no swimlanes or swimlanes with unsorted) -->
                            <div class="o_lavagna_col_body"
                                 t-on-dragover="onDragOver"
                                 t-on-dragenter="onDragEnter"
                                 t-on-dragleave="onDragLeave"
                                 t-on-drop="(ev) => this.onDrop(ev, stage.id)">

                                <!-- If swimlanes active: show swimlane rows -->
                                <t t-if="hasSwimlines()">
                                    <div t-foreach="props.data.swimlanes" t-as="swim" t-key="swim.id"
                                         class="o_lavagna_swimlane_section">
                                        <div class="o_swimlane_label" t-if="stage_first"
                                             t-esc="swim.name"/>
                                        <t t-foreach="getTasksForCell(stage.id, swim.id)" t-as="task" t-key="task.id">
                                            <LavagnaTaskCard task="task"
                                                             draggable="'true'"
                                                             t-on-dragstart="(ev) => this.onDragStart(ev, task.id)"
                                                             t-on-dragend="onDragEnd"/>
                                        </t>
                                    </div>
                                    <!-- Unsorted tasks -->
                                    <t t-foreach="getUnsortedTasks(stage.id)" t-as="task" t-key="task.id">
                                        <LavagnaTaskCard task="task"
                                                         draggable="'true'"
                                                         t-on-dragstart="(ev) => this.onDragStart(ev, task.id)"
                                                         t-on-dragend="onDragEnd"/>
                                    </t>
                                </t>

                                <!-- No swimlanes: flat list -->
                                <t t-else="">
                                    <t t-foreach="getTasksForCell(stage.id, null)" t-as="task" t-key="task.id">
                                        <LavagnaTaskCard task="task"
                                                         draggable="'true'"
                                                         t-on-dragstart="(ev) => this.onDragStart(ev, task.id)"
                                                         t-on-dragend="onDragEnd"/>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
