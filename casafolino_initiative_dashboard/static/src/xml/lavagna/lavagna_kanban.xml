<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="casafolino_initiative_dashboard.LavagnaKanban">
        <div class="o_lavagna_kanban" t-att-class="hasSwimlanes ? 'o_kanban_2d' : 'o_kanban_linear'">

            <!-- RECOVERY STATE -->
            <t t-if="props.data and props.data.recovery_state">
                <div class="o_lavagna_recovery">
                    <div class="o_recovery_icon">
                        <i class="fa fa-exclamation-circle"/>
                    </div>
                    <h2 class="o_recovery_title">Lavagna non configurata</h2>
                    <p class="o_recovery_message" t-esc="props.data.recovery_message"/>
                    <div class="o_recovery_actions">
                        <button class="btn btn-primary o_lavagna_btn_primary"
                                t-on-click="() => this.recoverWithTemplate()">
                            <i class="fa fa-magic"/> Configura con template
                        </button>
                        <button class="btn btn-secondary"
                                t-on-click="() => this.recoverManually()">
                            <i class="fa fa-pencil"/> Configura manualmente
                        </button>
                    </div>
                    <p class="o_recovery_hint">
                        <small>Il template applica scenario, stage, swimlane e KPI in un click.</small>
                    </p>
                </div>
            </t>

            <t t-elif="!props.data || !visibleStages.length">
                <div class="o_lavagna_kanban_empty">
                    <i class="fa fa-columns fa-3x"/>
                    <p>Nessuno stage configurato.</p>
                </div>
            </t>
            <t t-else="">
                <div class="o_kanban_scroll">

                    <!-- ===== HEADER ROW: stage names ===== -->
                    <div class="o_kanban_header_row">
                        <div t-if="hasSwimlanes" class="o_kanban_corner"/>
                        <div t-foreach="allDisplayStages" t-as="stage" t-key="stage.id"
                             class="o_kanban_stage_header"
                             t-att-class="{ 'o_stage_folded': stage.fold }">
                            <span class="o_stage_name" t-esc="stage.name"/>
                            <span class="o_stage_count" t-esc="getTaskCountForStage(stage.id)"/>
                            <button class="o_stage_add_btn"
                                    t-on-click="(ev) => this.openQuickAdd(ev, stage.id, null)">
                                <i class="fa fa-plus"/>
                            </button>
                        </div>
                    </div>

                    <!-- ===== 2D SWIMLANE BODY ===== -->
                    <t t-if="hasSwimlanes">
                        <div t-foreach="props.data.swimlanes" t-as="swim" t-key="swim.id"
                             class="o_kanban_swim_row">
                            <!-- Swimlane label (first col) -->
                            <div class="o_kanban_swim_label"
                                 t-att-style="'border-left-color:' + getSwimlaneColor(swim.color)">
                                <span class="o_swim_name" t-esc="swim.name"/>
                                <span class="o_swim_count" t-esc="getTaskCountForSwimlane(swim.id)"/>
                            </div>

                            <!-- Cells: one per stage -->
                            <div t-foreach="allDisplayStages" t-as="stage" t-key="stage.id"
                                 class="o_kanban_cell"
                                 t-att-class="{ 'o_stage_folded': stage.fold }"
                                 t-on-dragover="onDragOver"
                                 t-on-dragenter="onDragEnter"
                                 t-on-dragleave="onDragLeave"
                                 t-on-drop="(ev) => this.onDrop(ev, stage.id)">

                                <!-- Quick add in this cell -->
                                <div t-if="state.quickAddStageId === stage.id and state.quickAddTagId === swim.id"
                                     class="o_kanban_quick_add">
                                    <input type="text" class="o_quick_input"
                                           placeholder="Nome task..."
                                           t-att-value="state.quickAddName"
                                           t-on-input="onQuickAddInput"
                                           t-on-keydown="onQuickAddKeydown"/>
                                    <button class="o_quick_cancel" t-on-click="() => this.cancelQuickAdd()">
                                        <i class="fa fa-times"/>
                                    </button>
                                </div>

                                <t t-set="cellTasks" t-value="getTasksForCell(swim.id, stage.id)"/>
                                <LavagnaTaskCard t-foreach="cellTasks" t-as="task" t-key="task.id"
                                                 task="task"/>

                                <div t-if="!cellTasks.length and state.quickAddStageId !== stage.id"
                                     class="o_kanban_cell_empty">
                                    <span class="o_empty_hint">Trascina qui o crea</span>
                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- ===== LINEAR BODY (no swimlanes) ===== -->
                    <t t-else="">
                        <div class="o_kanban_linear_row">
                            <div t-foreach="allDisplayStages" t-as="stage" t-key="stage.id"
                                 class="o_kanban_cell o_kanban_linear_cell"
                                 t-att-class="{ 'o_stage_folded': stage.fold }"
                                 t-on-dragover="onDragOver"
                                 t-on-dragenter="onDragEnter"
                                 t-on-dragleave="onDragLeave"
                                 t-on-drop="(ev) => this.onDrop(ev, stage.id)">

                                <!-- Quick add -->
                                <div t-if="state.quickAddStageId === stage.id and !state.quickAddTagId"
                                     class="o_kanban_quick_add">
                                    <input type="text" class="o_quick_input"
                                           placeholder="Nome task..."
                                           t-att-value="state.quickAddName"
                                           t-on-input="onQuickAddInput"
                                           t-on-keydown="onQuickAddKeydown"/>
                                    <button class="o_quick_cancel" t-on-click="() => this.cancelQuickAdd()">
                                        <i class="fa fa-times"/>
                                    </button>
                                </div>

                                <t t-set="cellTasks" t-value="getTasksForCell(null, stage.id)"/>
                                <LavagnaTaskCard t-foreach="cellTasks" t-as="task" t-key="task.id"
                                                 task="task"/>

                                <div t-if="!cellTasks.length and state.quickAddStageId !== stage.id"
                                     class="o_kanban_cell_empty">
                                    <span class="o_empty_hint">Nessun task</span>
                                </div>
                            </div>
                        </div>
                    </t>

                    <!-- ===== FOLDED STAGES TOGGLE ===== -->
                    <div t-if="foldedStages.length and !state.showFolded" class="o_kanban_folded_toggle"
                         t-on-click="() => this.toggleShowFolded()">
                        <i class="fa fa-caret-right"/>
                        <t t-esc="foldedStages.length"/> stage archiviati
                    </div>
                    <div t-if="foldedStages.length and state.showFolded" class="o_kanban_folded_toggle"
                         t-on-click="() => this.toggleShowFolded()">
                        <i class="fa fa-caret-down"/>
                        Nascondi archiviati
                    </div>

                </div>
            </t>
        </div>
    </t>
</templates>
