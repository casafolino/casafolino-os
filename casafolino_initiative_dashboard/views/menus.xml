<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action: Lavagne Attive (lista filtrata, apre Lavagna al click) -->
    <record id="action_cf_initiative_lavagne_attive" model="ir.actions.act_window">
        <field name="name">Lavagne Attive</field>
        <field name="res_model">cf.initiative</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('lavagna_enabled', '=', True)]</field>
        <field name="context">{'open_lavagna_on_click': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Nessuna Lavagna attiva</p>
            <p>Crea una nuova iniziativa con Lavagna dal menu "Apri Nuova Iniziativa".</p>
        </field>
    </record>

    <!-- Menu: Lavagne Attive (sequence 15, after core "Iniziative" at 10) -->
    <menuitem id="menu_cf_lavagne_attive"
              name="Lavagne Attive"
              parent="casafolino_initiative.menu_initiative_root"
              action="action_cf_initiative_lavagne_attive"
              sequence="15"/>

    <!-- Menu: Apri Nuova Iniziativa (sequence 20) -->
    <menuitem id="menu_cf_initiative_dashboard_wizard"
              name="Apri Nuova Iniziativa (Lavagna)"
              parent="casafolino_initiative.menu_initiative_root"
              action="action_cf_initiative_dashboard_wizard"
              sequence="20"/>

    <!-- Config sub-menus -->
    <menuitem id="menu_dashboard_kpi"
              name="KPI Lavagna"
              parent="casafolino_initiative.menu_initiative_config"
              action="action_dashboard_kpi"
              sequence="60"/>

    <menuitem id="menu_lavagna_template"
              name="Template Lavagna"
              parent="casafolino_initiative.menu_initiative_config"
              action="action_lavagna_template"
              sequence="70"/>

</odoo>
