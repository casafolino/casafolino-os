<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        F2.4: Initiative = Lavagna (always).
        Single user menu: core "Iniziative" (menu_initiative_list, seq=10).
        All other user-facing menus hidden.
        JS patches handle: click record → Lavagna OWL, "Nuova" → wizard premium.
    -->

    <!-- Hide dashboard-owned menus (no longer needed as separate entries) -->
    <record id="menu_cf_lavagne_attive" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
    <record id="menu_cf_initiative_dashboard_wizard" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Hide core "Nuova Iniziativa" (degraded wizard) -->
    <record id="casafolino_initiative.menu_initiative_wizard" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <!-- Config sub-menus (keep visible under Configurazione) -->
    <menuitem id="menu_dashboard_kpi"
              name="KPI Lavagna"
              parent="casafolino_initiative.menu_initiative_config"
              action="action_dashboard_kpi"
              sequence="60"/>

    <menuitem id="menu_lavagna_template"
              name="Template Lavagna"
              parent="casafolino_initiative.menu_initiative_config"
              action="action_lavagna_template"
              sequence="70"/>

</odoo>
