<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit form view di cf.initiative per aggiungere bottone "Apri Lavagna" -->
    <record id="cf_initiative_form_inherit_dashboard" model="ir.ui.view">
        <field name="name">cf.initiative.form.inherit.dashboard</field>
        <field name="model">cf.initiative</field>
        <field name="inherit_id" ref="casafolino_initiative.view_cf_initiative_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_lavagna"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-th-large"
                        invisible="not lavagna_enabled">
                    <span class="o_stat_text">Apri Lavagna</span>
                </button>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Lavagna" name="lavagna_config">
                    <group>
                        <group>
                            <field name="lavagna_enabled"/>
                            <field name="lavagna_swimlane_category"
                                   invisible="not lavagna_enabled"/>
                            <field name="lavagna_swimlane_tag_ids"
                                   widget="many2many_tags"
                                   options="{'color_field': 'color'}"
                                   invisible="not lavagna_enabled"/>
                        </group>
                        <group>
                            <field name="lavagna_kpi_ids"
                                   widget="many2many_tags"
                                   invisible="not lavagna_enabled"/>
                            <field name="lavagna_panels"
                                   invisible="not lavagna_enabled"/>
                            <field name="lavagna_task_count"
                                   invisible="not lavagna_enabled"/>
                            <field name="lavagna_lead_count"
                                   invisible="not lavagna_enabled"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
