<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_lavagna_template_list" model="ir.ui.view">
        <field name="name">casafolino.lavagna.template.list</field>
        <field name="model">casafolino.lavagna.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="family_id"/>
                <field name="swimlane_category"/>
                <field name="suggested_stage_names"/>
                <field name="default_panels"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_lavagna_template_form" model="ir.ui.view">
        <field name="name">casafolino.lavagna.template.form</field>
        <field name="model">casafolino.lavagna.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="family_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="swimlane_category"/>
                            <field name="suggested_swimlane_tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                            <field name="suggested_stage_names"/>
                            <field name="default_kpi_ids" widget="many2many_tags"/>
                            <field name="default_panels"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_lavagna_template" model="ir.actions.act_window">
        <field name="name">Template Lavagna</field>
        <field name="res_model">casafolino.lavagna.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
