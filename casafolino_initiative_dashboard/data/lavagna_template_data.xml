    <!-- ========== FAMIGLIA CE (Campionatura/Etichetta) ========== -->

    <record id="scenario_ce_sample_kit" model="casafolino.lavagna.template">
        <field name="name">Sample Kit B2B Generico</field>
        <field name="sequence">10</field>
        <field name="family_id" ref="casafolino_initiative.family_ce"/>
