<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<!-- ═══════════════════════════════════════════════════════ -->
<!-- ROOT COMPONENT                                          -->
<!-- ═══════════════════════════════════════════════════════ -->
<t t-name="casafolino_workspace.CfWorkspaceMain">
    <div class="cf-ws o_action">

        <!-- HEADER -->
        <div class="cf-ws-header">
            <div class="cf-ws-header-left">
                <div class="cf-ws-logo" t-on-click="onGoHome" style="cursor:pointer"><span class="cf-ws-logo-text">CF</span></div>
                <h4 class="cf-ws-title" t-on-click="onGoHome" style="cursor:pointer">Scrivania</h4>
                <div class="cf-ws-nav">
                    <span t-attf-class="cf-ws-nav-item #{state.page === 'lead' ? 'active' : ''}"
                          t-on-click="() => this.onNavigate('lead')">Lead</span>
                </div>
            </div>
            <div class="cf-ws-header-center">
                <div class="cf-ws-search">
                    <span class="cf-ws-search-icon"><i class="fa fa-search"/></span>
                    <input type="text" class="cf-ws-search-input"
                           placeholder="Cerca in Scrivania..."
                           t-att-value="state.searchQuery"
                           t-on-input="onSearchInput"
                           t-on-keydown="onSearchKeydown"/>
                </div>
            </div>
            <div class="cf-ws-header-right">
                <button class="cf-ws-header-btn" title="Aggiorna" t-on-click="onRefresh">
                    <i class="fa fa-refresh"/>
                </button>
                <button class="cf-ws-header-btn" title="Notifiche">
                    <i class="fa fa-bell-o"/>
                </button>
                <t t-if="state.data and state.data.user">
                    <div class="cf-ws-user-pill" t-att-title="state.data.user.full_name">
                        <span class="cf-ws-user-initials" t-esc="state.data.user.initials"/>
                    </div>
                </t>
                <t t-else="">
                    <div class="cf-ws-user-pill"><i class="fa fa-user-circle-o"/></div>
                </t>
            </div>
        </div>

        <!-- LOADING -->
        <t t-if="state.loading">
            <div class="cf-ws-loading">
                <div class="spinner-border text-secondary"/>
                <span>Caricamento scrivania...</span>
            </div>
        </t>

        <!-- ERROR -->
        <t t-elif="state.error">
            <div class="cf-ws-error">
                <i class="fa fa-exclamation-triangle"/>
                <span t-esc="state.error"/>
                <button class="btn btn-sm btn-outline-secondary ms-3" t-on-click="onRefresh">Riprova</button>
            </div>
        </t>

        <!-- LEAD SECTION -->
        <t t-elif="state.page === 'lead'">
            <div class="cf-ws-body">
                <WorkspaceLead onGoHome.bind="onGoHome"/>
            </div>
        </t>

        <!-- HOME DASHBOARD -->
        <t t-elif="state.data">
            <div class="cf-ws-body">
                <WorkspaceHero data="state.data"/>
                <WorkspaceKpis kpis="state.data.kpis"/>
                <WorkspaceMacro macro="state.data.macro" onSelect.bind="onSelectItem"/>
                <div class="cf-ws-two-col">
                    <div class="cf-ws-two-col-main">
                        <WorkspaceWork today="state.data.today"
                                       view="state.workView"
                                       onViewChange.bind="onWorkViewChange"
                                       onSelect.bind="onSelectItem"/>
                    </div>
                    <div class="cf-ws-two-col-side">
                        <WorkspaceFeed feed="state.data.feed"/>
                    </div>
                </div>
                <t t-if="state.selectedItem">
                    <WorkspaceDetail item="state.selectedItem" onClose.bind="onCloseDetail"/>
                </t>
            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- HERO                                                     -->
<!-- ═══════════════════════════════════════════════════════ -->
<t t-name="casafolino_workspace.WorkspaceHero">
    <div class="cf-hero">
        <div class="cf-hero-left">
            <div class="cf-hero-avatar" t-att-style="'border-color:' + (props.data.user.color || '#C8A43A')">
                <span class="cf-hero-avatar-text" t-esc="props.data.user.initials"/>
            </div>
            <div class="cf-hero-text">
                <h2 class="cf-hero-greet" t-esc="props.data.greet"/>
                <p class="cf-hero-sub" t-esc="props.data.sub"/>
            </div>
        </div>
        <div class="cf-hero-right">
            <div class="cf-hero-progress">
                <div class="cf-hero-progress-bar">
                    <div class="cf-hero-progress-fill" t-att-style="'width:' + (props.data.progress.pct || 0) + '%'"/>
                </div>
                <span class="cf-hero-progress-label">
                    <t t-esc="props.data.progress.done"/>/<t t-esc="props.data.progress.total"/> completati
                </span>
            </div>
            <div class="cf-hero-tip">
                <i class="fa fa-lightbulb-o cf-hero-tip-icon"/>
                <span class="cf-hero-tip-text" t-esc="props.data.tip.text"/>
            </div>
        </div>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- KPIs                                                     -->
<!-- ═══════════════════════════════════════════════════════ -->
<t t-name="casafolino_workspace.WorkspaceKpis">
    <div class="cf-kpis">
        <t t-foreach="props.kpis" t-as="kpi" t-key="kpi.id">
            <div class="cf-kpi-card">
                <div class="cf-kpi-icon-wrap">
                    <i t-attf-class="fa #{kpi.icon}"/>
                </div>
                <div class="cf-kpi-info">
                    <span class="cf-kpi-value" t-esc="kpi.value"/>
                    <span class="cf-kpi-label" t-esc="kpi.label"/>
                </div>
            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- MACRO AREAS                                              -->
<!-- ═══════════════════════════════════════════════════════ -->
<t t-name="casafolino_workspace.WorkspaceMacro">
    <div class="cf-macro-grid">
        <t t-foreach="props.macro" t-as="m" t-key="m.id">
            <t t-if="m.visible">
                <div class="cf-macro-tile" t-att-style="'background:' + m.color"
                     t-on-click="() => this.props.onSelect(m)">
                    <div class="cf-macro-tile-top">
                        <i t-attf-class="fa #{m.icon} cf-macro-tile-icon"/>
                        <span class="cf-macro-tile-count" t-esc="m.count"/>
                    </div>
                    <span class="cf-macro-tile-label" t-esc="m.label"/>
                </div>
            </t>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- WORK (La tua giornata)                                   -->
<!-- ═══════════════════════════════════════════════════════ -->
<t t-name="casafolino_workspace.WorkspaceWork">
    <div class="cf-work">
        <div class="cf-work-header">
            <h3 class="cf-work-title">La tua giornata</h3>
            <div class="cf-work-tabs">
                <button t-attf-class="cf-work-tab #{props.view === 'oggi' ? 'active' : ''}"
                        t-on-click="() => this.props.onViewChange('oggi')">Oggi</button>
                <button t-attf-class="cf-work-tab #{props.view === 'settimana' ? 'active' : ''}"
                        t-on-click="() => this.props.onViewChange('settimana')">Settimana</button>
                <button t-attf-class="cf-work-tab #{props.view === 'lavagna' ? 'active' : ''}"
                        t-on-click="() => this.props.onViewChange('lavagna')">Lavagna</button>
            </div>
        </div>

        <!-- OGGI VIEW -->
        <t t-if="props.view === 'oggi'">
            <t t-if="props.today.critical.length > 0">
                <div class="cf-work-section">
                    <h4 class="cf-work-section-title cf-work-critical">
                        <i class="fa fa-exclamation-circle"/> Critici (<t t-esc="props.today.critical.length"/>)
                    </h4>
                    <t t-foreach="props.today.critical" t-as="item" t-key="item.id">
                        <div class="cf-work-item cf-work-item-critical" t-on-click="() => this.props.onSelect(item)">
                            <i t-attf-class="fa #{item.icon}" t-att-style="'color:' + item.color"/>
                            <span class="cf-work-item-title" t-esc="item.title"/>
                            <span class="cf-work-item-date" t-esc="item.deadline"/>
                        </div>
                    </t>
                </div>
            </t>
            <div class="cf-work-section">
                <h4 class="cf-work-section-title">
                    <i class="fa fa-clock-o"/> Oggi (<t t-esc="props.today.oggi.length"/>)
                </h4>
                <t t-if="props.today.oggi.length === 0">
                    <p class="cf-work-empty">Nessuna attività per oggi.</p>
                </t>
                <t t-foreach="props.today.oggi" t-as="item" t-key="item.id">
                    <div class="cf-work-item" t-on-click="() => this.props.onSelect(item)">
                        <i t-attf-class="fa #{item.icon}" t-att-style="'color:' + item.color"/>
                        <span class="cf-work-item-title" t-esc="item.title"/>
                    </div>
                </t>
            </div>
            <t t-if="props.today.prossimi.length > 0">
                <div class="cf-work-section">
                    <h4 class="cf-work-section-title">
                        <i class="fa fa-arrow-right"/> Prossimi (<t t-esc="props.today.prossimi.length"/>)
                    </h4>
                    <t t-foreach="props.today.prossimi" t-as="item" t-key="item.id">
                        <div class="cf-work-item" t-on-click="() => this.props.onSelect(item)">
                            <i t-attf-class="fa #{item.icon}" t-att-style="'color:' + item.color"/>
                            <span class="cf-work-item-title" t-esc="item.title"/>
                            <span class="cf-work-item-date" t-esc="item.deadline"/>
                        </div>
                    </t>
                </div>
            </t>
        </t>

        <!-- SETTIMANA VIEW -->
        <t t-if="props.view === 'settimana'">
            <div class="cf-work-section">
                <h4 class="cf-work-section-title">
                    <i class="fa fa-calendar"/> Questa settimana (<t t-esc="props.today.week.length"/>)
                </h4>
                <t t-if="props.today.week.length === 0">
                    <p class="cf-work-empty">Nessuna attività questa settimana.</p>
                </t>
                <t t-foreach="props.today.week" t-as="item" t-key="item.id">
                    <div class="cf-work-item" t-on-click="() => this.props.onSelect(item)">
                        <i t-attf-class="fa #{item.icon}" t-att-style="'color:' + item.color"/>
                        <span class="cf-work-item-title" t-esc="item.title"/>
                        <span class="cf-work-item-date" t-esc="item.deadline"/>
                    </div>
                </t>
            </div>
        </t>

        <!-- LAVAGNA VIEW -->
        <t t-if="props.view === 'lavagna'">
            <div class="cf-work-lavagna">
                <div class="cf-work-lavagna-placeholder">
                    <i class="fa fa-sticky-note-o"/>
                    <p>La lavagna arriverà nelle prossime fasi.</p>
                    <span>Qui potrai aggiungere note rapide e promemoria.</span>
                </div>
            </div>
        </t>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- DETAIL PANEL                                             -->
<!-- ═══════════════════════════════════════════════════════ -->
<t t-name="casafolino_workspace.WorkspaceDetail">
    <div class="cf-detail">
        <div class="cf-detail-header">
            <h4 class="cf-detail-title" t-esc="props.item.title or props.item.label or 'Dettaglio'"/>
            <button class="cf-detail-close" t-on-click="props.onClose">
                <i class="fa fa-times"/>
            </button>
        </div>
        <div class="cf-detail-body">
            <t t-if="props.item.model">
                <div class="cf-detail-meta">
                    <span class="cf-detail-meta-label">Modello:</span>
                    <span t-esc="props.item.model"/>
                </div>
            </t>
            <t t-if="props.item.deadline">
                <div class="cf-detail-meta">
                    <span class="cf-detail-meta-label">Scadenza:</span>
                    <span t-esc="props.item.deadline"/>
                </div>
            </t>
            <t t-if="props.item.count !== undefined">
                <div class="cf-detail-meta">
                    <span class="cf-detail-meta-label">Elementi:</span>
                    <span t-esc="props.item.count"/>
                </div>
            </t>
            <div class="cf-detail-placeholder">
                <i class="fa fa-puzzle-piece"/>
                <p>Dettaglio completo nelle prossime fasi.</p>
            </div>
        </div>
    </div>
</t>

<!-- ═══════════════════════════════════════════════════════ -->
<!-- FEED                                                     -->
<!-- ═══════════════════════════════════════════════════════ -->
<t t-name="casafolino_workspace.WorkspaceFeed">
    <div class="cf-feed">
        <h3 class="cf-feed-title">Attività recenti</h3>
        <t t-if="!props.feed or props.feed.length === 0">
            <p class="cf-feed-empty">Nessuna attività recente.</p>
        </t>
        <t t-foreach="props.feed" t-as="f" t-key="f.id">
            <div class="cf-feed-item">
                <div class="cf-feed-avatar">
                    <span t-esc="f.initials"/>
                </div>
                <div class="cf-feed-content">
                    <div class="cf-feed-author">
                        <strong t-esc="f.author"/>
                        <span class="cf-feed-time" t-esc="this.getRelativeTime(f.date)"/>
                    </div>
                    <p class="cf-feed-body" t-esc="f.body"/>
                </div>
            </div>
        </t>
    </div>
</t>

</templates>
