<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cf_shipment_list" model="ir.ui.view">
        <field name="name">cf.shipment.list</field>
        <field name="model">cf.shipment</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'consegnato'" decoration-info="state == 'spedito'" decoration-muted="state == 'creato'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="sale_order_id" optional="show"/>
                <field name="carrier" optional="show"/>
                <field name="tracking_code" optional="show"/>
                <field name="state" widget="badge"/>
                <field name="date_spedito" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_cf_shipment_form" model="ir.ui.view">
        <field name="name">cf.shipment.form</field>
        <field name="model">cf.shipment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_preparazione" string="In preparazione" type="object" class="btn-primary" invisible="state != 'creato'"/>
                    <button name="action_set_spedito" string="Segna spedito" type="object" class="btn-primary" invisible="state not in ['preparazione','etichetta']"/>
                    <button name="action_set_consegnato" string="Segna consegnato" type="object" class="btn-primary" invisible="state != 'spedito'"/>
                    <field name="state" widget="statusbar" statusbar_visible="creato,preparazione,spedito,consegnato"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="lead_id"/>
                            <field name="sale_order_id"/>
                            <field name="task_id"/>
                        </group>
                        <group>
                            <field name="carrier"/>
                            <field name="tracking_code"/>
                            <field name="date_spedito" readonly="1"/>
                            <field name="date_consegnato" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_cf_shipment_search" model="ir.ui.view">
        <field name="name">cf.shipment.search</field>
        <field name="model">cf.shipment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="tracking_code"/>
                <filter name="f_spedito" string="Spediti" domain="[('state','=','spedito')]"/>
                <filter name="f_consegnato" string="Consegnati" domain="[('state','=','consegnato')]"/>
                <filter name="f_aperti" string="Aperti" domain="[('state','not in',['consegnato'])]"/>
                <group expand="0" string="Raggruppa per">
                    <filter name="g_state" string="Stato" context="{'group_by':'state'}"/>
                    <filter name="g_carrier" string="Corriere" context="{'group_by':'carrier'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_cf_shipment" model="ir.actions.act_window">
        <field name="name">Spedizioni campione</field>
        <field name="res_model">cf.shipment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cf_shipment_search"/>
    </record>

</odoo>
