<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="casafolino_crm_export.CFProjectDashboard">
    <!-- Loading state -->
    <div t-if="state.isLoading" class="cf-dash-loading">
        <div class="cf-dash-spinner"/>
        <span>Caricamento dashboard...</span>
    </div>

    <!-- Error state -->
    <div t-elif="state.error" class="cf-dash-error">
        <div class="cf-dash-error-icon">
            <i class="fa fa-exclamation-triangle"/>
        </div>
        <div class="cf-dash-error-msg">
            <strong>Errore nel caricamento</strong>
            <p t-out="state.error"/>
        </div>
        <button class="btn btn-primary btn-sm" t-on-click="onRefresh">Riprova</button>
    </div>

    <!-- Main dashboard -->
    <div t-else="" class="cf-dash">
        <!-- Top bar -->
        <div class="cf-dash-topbar">
            <button class="cf-dash-back" t-on-click="onGoBack" title="Torna alla pipeline">
                <i class="fa fa-arrow-left"/>
            </button>
            <div class="cf-dash-topbar-title">
                <span class="cf-dash-project-name" t-out="state.data.project.name"/>
                <span t-attf-class="cf-dash-status-pill cf-status-#{statusColor}"
                      t-out="statusLabel"/>
            </div>
            <div class="cf-dash-topbar-actions">
                <button class="btn btn-sm btn-outline-secondary" t-on-click="onRefresh" title="Aggiorna">
                    <i class="fa fa-refresh"/>
                </button>
            </div>
        </div>

        <!-- Header -->
        <div class="cf-dash-header">
            <!-- Owner avatar -->
            <div t-if="state.data.owner"
                 t-attf-class="cf-dash-owner-avatar cf-owner-#{state.data.owner.color_class}">
                <t t-out="state.data.owner.initials"/>
            </div>

            <!-- Project info -->
            <div class="cf-dash-header-info">
                <div class="cf-dash-header-top">
                    <span class="cf-dash-partner-name" t-if="state.data.partner">
                        <span t-out="partnerFlag"/>
                        <span t-out="state.data.partner.name" t-on-click="onOpenPartner"
                              class="cf-dash-link"/>
                    </span>
                    <span class="cf-dash-location" t-if="partnerLocation"
                          t-out="partnerLocation"/>
                </div>
                <div class="cf-dash-header-lead" t-if="state.data.lead">
                    <span class="cf-dash-lead-name cf-dash-link" t-on-click="onOpenLead">
                        <t t-out="state.data.lead.name"/>
                    </span>
                    <span class="cf-dash-stage-name" t-out="state.data.lead.stage_name"/>
                </div>
            </div>

            <!-- Stage progress 9-segment -->
            <div class="cf-dash-stage-progress" t-if="state.data.lead">
                <t t-foreach="stageSegments" t-as="seg" t-key="seg.index">
                    <div t-attf-class="cf-dash-seg #{seg.active ? 'cf-dash-seg-active' : ''} #{seg.current ? 'cf-dash-seg-current' : ''}"/>
                </t>
            </div>
        </div>

        <!-- KPI Rail -->
        <div class="cf-dash-kpi-rail">
            <div class="cf-dash-kpi-card">
                <div class="cf-dash-kpi-value" t-out="kpiRevenue"/>
                <div class="cf-dash-kpi-label">Ricavi</div>
            </div>
            <div class="cf-dash-kpi-card">
                <div class="cf-dash-kpi-value" t-out="state.data.kpi.sample_count"/>
                <div class="cf-dash-kpi-label">Campioni</div>
            </div>
            <div class="cf-dash-kpi-card">
                <div class="cf-dash-kpi-value" t-out="state.data.kpi.email_count"/>
                <div class="cf-dash-kpi-label">Email</div>
            </div>
            <div class="cf-dash-kpi-card">
                <div class="cf-dash-kpi-value"
                     t-out="state.data.kpi.next_activity ? state.data.kpi.next_activity.date : '—'"/>
                <div class="cf-dash-kpi-label">Prossima</div>
            </div>
        </div>

        <!-- Tab nav -->
        <div class="cf-dash-tabs">
            <t t-foreach="tabs" t-as="tab" t-key="tab.id">
                <button t-attf-class="cf-dash-tab #{state.activeTab === tab.id ? 'active' : ''}"
                        t-on-click="() => this.onTabChange(tab.id)">
                    <t t-out="tab.label"/>
                    <span t-if="tab.id === 'mail' and state.data and state.data.mail_count"
                          class="cf-dash-tab-counter"
                          t-out="'(' + state.data.mail_count + ')'"/>
                    <span t-if="tab.id === 'commerciale' and state.data and state.data.commerciale and state.data.commerciale.orders_count"
                          class="cf-dash-tab-counter"
                          t-out="'(' + state.data.commerciale.orders_count + ')'"/>
                    <span t-if="tab.id === 'campionature' and state.data and state.data.campionature and state.data.campionature.samples_count"
                          class="cf-dash-tab-counter"
                          t-out="'(' + state.data.campionature.samples_count + ')'"/>
                    <span t-if="tab.id === 'documenti' and state.data and state.data.documenti and state.data.documenti.attachments_count"
                          class="cf-dash-tab-counter"
                          t-out="'(' + state.data.documenti.attachments_count + ')'"/>
                </button>
            </t>
        </div>

        <!-- Content area -->
        <div class="cf-dash-content">
            <!-- Cockpit tab -->
            <div t-if="state.activeTab === 'cockpit'" class="cf-cockpit-grid">
                <section class="cf-cockpit-main">
                    <div class="cf-cockpit-strip">
                        <div class="cf-cockpit-metric">
                            <span class="cf-cockpit-label">Prossima azione</span>
                            <strong t-out="state.data.project.next_action || 'Da definire'"/>
                            <small t-if="state.data.project.next_action_date"
                                   t-out="state.data.project.next_action_date"/>
                        </div>
                        <div class="cf-cockpit-metric">
                            <span class="cf-cockpit-label">Mail dossier</span>
                            <strong t-out="state.data.mail_count || 0"/>
                            <button class="cf-cockpit-link" t-on-click="onSyncDossierMail">
                                <i class="fa fa-refresh"/> aggiorna storico
                            </button>
                        </div>
                        <div class="cf-cockpit-metric">
                            <span class="cf-cockpit-label">Referenti</span>
                            <strong t-out="state.data.contacts.length || 0"/>
                            <small>cliente, team, broker</small>
                        </div>
                        <div class="cf-cockpit-metric">
                            <span class="cf-cockpit-label">Responsabile</span>
                            <strong t-out="state.data.project.owner_name || '—'"/>
                            <small t-out="statusLabel"/>
                        </div>
                    </div>

                    <div class="cf-cockpit-section">
                        <div class="cf-cockpit-section-head">
                            <h3>Mail recenti</h3>
                            <button class="btn btn-sm btn-outline-secondary" t-on-click="() => this.onTabChange('mail')">
                                <i class="fa fa-envelope-o"/> Tutte
                            </button>
                        </div>
                        <div t-if="!state.data.mail || !state.data.mail.length" class="cf-dash-empty cf-cockpit-empty">
                            <i class="fa fa-envelope-o"/>
                            <span>Nessuna mail ancora posizionata</span>
                            <button class="btn btn-sm btn-secondary" t-on-click="onSyncDossierMail">Scarica storico referenti</button>
                        </div>
                        <div t-else="" class="cf-cockpit-mail-list">
                            <t t-foreach="state.data.mail.slice(0, 6)" t-as="m" t-key="m.casafolino_id">
                                <button t-attf-class="cf-cockpit-mail-row #{m.is_outbound ? 'outbound' : 'inbound'}"
                                        t-on-click="() => this.onOpenMailThread(m)">
                                    <span class="cf-cockpit-mail-dir">
                                        <i t-attf-class="fa #{m.is_outbound ? 'fa-paper-plane' : 'fa-inbox'}"/>
                                    </span>
                                    <span class="cf-cockpit-mail-copy">
                                        <strong t-out="m.subject"/>
                                        <small>
                                            <t t-out="m.sender_name"/> · <t t-out="m.date_label"/>
                                        </small>
                                    </span>
                                </button>
                            </t>
                        </div>
                    </div>
                </section>

                <aside class="cf-cockpit-side">
                    <t t-call="casafolino_crm_export.CFProjectDashboard.CustomerPanel"/>
                </aside>
            </div>

            <!-- Timeline tab -->
            <div t-if="state.activeTab === 'timeline'" class="cf-dash-content-row">
                <div class="cf-dash-timeline-col">
                    <!-- Timeline filters -->
                    <div class="cf-dash-timeline-filters">
                        <t t-foreach="timelineFilters" t-as="f" t-key="f.id">
                            <button t-attf-class="cf-dash-filter-pill #{state.timelineFilter === f.id ? 'active' : ''}"
                                    t-on-click="() => this.onTimelineFilter(f.id)">
                                <t t-out="f.label"/>
                            </button>
                        </t>
                    </div>

                    <!-- Timeline list -->
                    <div class="cf-dash-timeline" t-if="filteredTimeline.length">
                        <t t-foreach="filteredTimeline" t-as="ev" t-key="ev_index">
                            <div class="cf-dash-tl-item">
                                <div t-attf-class="cf-dash-tl-icon cf-tl-#{ev.color}">
                                    <i t-attf-class="fa #{ev.type === 'mail' ? 'fa-envelope' : ev.type === 'activity' ? 'fa-calendar' : ev.type === 'message' ? 'fa-comment' : ev.type === 'note' ? 'fa-sticky-note' : 'fa-bell'}"/>
                                </div>
                                <div class="cf-dash-tl-body">
                                    <div class="cf-dash-tl-header">
                                        <span class="cf-dash-tl-title" t-out="ev.title"/>
                                        <span class="cf-dash-tl-date" t-out="ev.date_label"/>
                                    </div>
                                    <div class="cf-dash-tl-meta" t-if="ev.author">
                                        <span t-out="ev.author"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                    <div t-else="" class="cf-dash-empty">
                        <i class="fa fa-inbox"/>
                        <span>Nessun evento in timeline</span>
                    </div>
                </div>

                <!-- Customer panel (sidebar) -->
                <div class="cf-dash-customer-col">
                    <t t-call="casafolino_crm_export.CFProjectDashboard.CustomerPanel"/>
                </div>
            </div>

            <!-- Cliente tab -->
            <div t-if="state.activeTab === 'cliente'" class="cf-dash-cliente-tab">
                <t t-call="casafolino_crm_export.CFProjectDashboard.CustomerPanel"/>
            </div>

            <!-- Commerciale tab (Brief #FINAL) -->
            <div t-if="state.activeTab === 'commerciale'" class="cf-tab-commerciale-content">
                <div class="cf-comm-summary">
                    <div class="cf-comm-summary-card">
                        <span class="cf-comm-label">Ordini totali</span>
                        <span class="cf-comm-value" t-out="state.data.commerciale.orders_count"/>
                    </div>
                    <div class="cf-comm-summary-card">
                        <span class="cf-comm-label">Valore aggregato</span>
                        <span class="cf-comm-value">
                            &#8364; <t t-out="(state.data.commerciale.orders_total_amount || 0).toLocaleString('it-IT', {maximumFractionDigits: 0})"/>
                        </span>
                    </div>
                    <div class="cf-comm-summary-card" t-if="state.data.commerciale.pricelist_id">
                        <span class="cf-comm-label">Listino</span>
                        <span class="cf-comm-value" t-out="state.data.commerciale.pricelist_id[1]"/>
                    </div>
                </div>
                <h5 class="cf-section-title">Ordini recenti</h5>
                <div t-if="!state.data.commerciale.orders.length" class="cf-dash-empty">
                    <i class="fa fa-shopping-cart"/>
                    <span>Nessun ordine registrato per questo cliente</span>
                </div>
                <div t-else="" class="cf-orders-list">
                    <t t-foreach="state.data.commerciale.orders" t-as="order" t-key="order.id">
                        <div t-on-click="() => this.onOpenSaleOrder(order.id)" class="cf-order-card">
                            <div class="cf-order-name">
                                <strong t-out="order.name"/>
                                <span t-attf-class="cf-order-state-badge cf-state-#{order.state}">
                                    <t t-out="order.state_label"/>
                                </span>
                            </div>
                            <div class="cf-order-meta">
                                <span class="cf-order-date" t-out="order.date_label"/>
                                <span class="cf-order-amount">
                                    <t t-out="order.currency"/> <t t-out="order.amount_total.toLocaleString('it-IT', {maximumFractionDigits: 2})"/>
                                </span>
                            </div>
                        </div>
                    </t>
                </div>
                <div t-if="state.data.commerciale.moq_notes" class="cf-moq-notes">
                    <h5 class="cf-section-title">Note commerciali</h5>
                    <p class="text-muted" t-out="state.data.commerciale.moq_notes"/>
                </div>
            </div>

            <!-- Campionature tab (Brief #FINAL) -->
            <div t-if="state.activeTab === 'campionature'" class="cf-tab-campionature-content">
                <div class="cf-samples-toolbar">
                    <button t-on-click="onCreateNewSample" class="btn btn-sm btn-primary">
                        <i class="fa fa-plus"/> Nuova campionatura
                    </button>
                </div>
                <div t-if="Object.keys(state.data.campionature.samples_by_state).length" class="cf-samples-summary">
                    <t t-foreach="Object.entries(state.data.campionature.samples_by_state)" t-as="entry" t-key="entry[0]">
                        <div class="cf-sample-stat">
                            <span class="cf-sample-state-label" t-out="entry[0]"/>
                            <span class="cf-sample-state-count" t-out="entry[1]"/>
                        </div>
                    </t>
                </div>
                <h5 class="cf-section-title">Storico campionature</h5>
                <div t-if="!state.data.campionature.samples.length" class="cf-dash-empty">
                    <i class="fa fa-flask"/>
                    <span>Nessuna campionatura registrata</span>
                    <button t-on-click="onCreateNewSample" class="btn btn-sm btn-secondary">Crea la prima</button>
                </div>
                <div t-else="" class="cf-samples-list">
                    <t t-foreach="state.data.campionature.samples" t-as="sample" t-key="sample.id">
                        <div t-on-click="() => this.onOpenSample(sample.id)" class="cf-sample-card">
                            <div class="cf-sample-name">
                                <strong t-out="sample.name"/>
                                <span t-attf-class="cf-sample-state-badge cf-sample-state-#{sample.state}">
                                    <t t-out="sample.state_label"/>
                                </span>
                            </div>
                            <div class="cf-sample-meta">
                                <span t-out="sample.date_label"/>
                                <span t-if="sample.product_count" class="text-muted">
                                    <t t-out="sample.product_count"/> prodotti
                                </span>
                                <span t-if="sample.feedback_score" t-out="sample.feedback_score"/>
                            </div>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Documenti tab (Brief #FINAL) -->
            <div t-if="state.activeTab === 'documenti'" class="cf-tab-documenti-content">
                <div t-if="!state.data.documenti.attachments.length" class="cf-dash-empty">
                    <i class="fa fa-folder-open-o"/>
                    <span>Nessun documento allegato a questo progetto o cliente</span>
                </div>
                <div t-else="" class="cf-attachments-grid">
                    <t t-foreach="state.data.documenti.attachments" t-as="att" t-key="att.id">
                        <a t-att-href="att.url" target="_blank" class="cf-attachment-card">
                            <i t-attf-class="fa #{att.icon_class} cf-attachment-icon"/>
                            <div class="cf-attachment-info">
                                <strong t-out="att.name"/>
                                <div class="cf-attachment-meta">
                                    <span t-out="att.size_label"/>
                                    <span> · </span>
                                    <span t-out="att.date_label"/>
                                    <span> · </span>
                                    <span t-attf-class="cf-attachment-source cf-source-#{att.source}">
                                        <t t-if="att.source === 'project'">progetto</t>
                                        <t t-else="">cliente</t>
                                    </span>
                                </div>
                            </div>
                        </a>
                    </t>
                </div>
            </div>

            <!-- Note tab (Brief #FINAL) -->
            <div t-if="state.activeTab === 'note'" class="cf-tab-note-content">
                <div t-if="state.data.note.description" class="cf-project-description">
                    <h5 class="cf-section-title">Descrizione progetto</h5>
                    <div class="cf-description-box" t-out="state.data.note.description"/>
                </div>
                <h5 class="cf-section-title">Note interne (chatter)</h5>
                <div t-if="!state.data.note.notes.length" class="cf-dash-empty">
                    <i class="fa fa-sticky-note-o"/>
                    <span>Nessuna nota interna registrata</span>
                </div>
                <div t-else="" class="cf-notes-timeline">
                    <t t-foreach="state.data.note.notes" t-as="note" t-key="note.id">
                        <div class="cf-note-card">
                            <div class="cf-note-header">
                                <strong t-out="note.author_name"/>
                                <span class="cf-note-date" t-out="note.date_label"/>
                            </div>
                            <div class="cf-note-body" t-out="note.body"/>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Mail tab (Brief #B6) -->
            <div t-if="state.activeTab === 'mail'" class="cf-dash-mail-tab">
                <div t-if="!state.data.mail or !state.data.mail.length" class="cf-dash-empty">
                    <i class="fa fa-envelope-o"/>
                    <span>Nessuna mail su questo dossier</span>
                    <p class="text-muted" style="font-size:12px;">
                        Le mail posizionate dal Posizionatore compariranno qui.
                    </p>
                </div>
                <div t-else="" class="cf-mail-timeline">
                    <t t-foreach="state.data.mail" t-as="m" t-key="m.casafolino_id">
                        <div t-attf-class="cf-mail-card #{m.is_outbound ? 'cf-mail-outbound' : 'cf-mail-inbound'}">
                            <div class="cf-mail-card-header">
                                <div class="cf-mail-icon">
                                    <i t-attf-class="fa #{m.is_outbound ? 'fa-paper-plane' : 'fa-envelope'}"/>
                                </div>
                                <div class="cf-mail-card-title">
                                    <strong t-out="m.subject"/>
                                    <div class="cf-mail-meta">
                                        <span class="cf-mail-sender">
                                            <t t-if="m.is_outbound">a </t>
                                            <t t-out="m.sender_name"/>
                                        </span>
                                        <span class="cf-mail-date" t-out="m.date_label"/>
                                    </div>
                                </div>
                            </div>
                            <div class="cf-mail-card-body">
                                <p class="cf-mail-preview" t-out="m.preview_text"/>
                            </div>
                            <div class="cf-mail-card-actions">
                                <button t-on-click="() => this.onOpenMailThread(m)"
                                        class="btn btn-sm btn-link">
                                    <i class="fa fa-external-link"/> Apri thread
                                </button>
                                <button t-on-click="() => this.onQuickReply(m)"
                                        class="btn btn-sm btn-link"
                                        t-att-disabled="!m.partner_id">
                                    <i class="fa fa-reply"/> Risposta veloce
                                </button>
                            </div>
                        </div>
                    </t>
                    <div t-if="state.data.mail.length >= 20" class="cf-mail-load-more">
                        <p class="text-muted">Le 20 piu recenti. Apri il chatter del partner per la cronologia completa.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick actions bar -->
        <div class="cf-dash-quick-actions">
            <button class="cf-dash-qa-btn" t-on-click="onQuickActionMail" title="Invia email">
                <i class="fa fa-envelope"/> Email
            </button>
            <button class="cf-dash-qa-btn" t-on-click="onQuickActionSample" title="Nuova campionatura">
                <i class="fa fa-flask"/> Campione
            </button>
            <button class="cf-dash-qa-btn" t-on-click="onQuickActionOffer" title="Nuova offerta">
                <i class="fa fa-file-text-o"/> Offerta
            </button>
            <button class="cf-dash-qa-btn" t-on-click="onQuickActionActivity" title="Pianifica attività">
                <i class="fa fa-calendar-plus-o"/> Attività
            </button>
        </div>
    </div>
</t>

<!-- Sub-template: Customer Panel -->
<t t-name="casafolino_crm_export.CFProjectDashboard.CustomerPanel">
    <div class="cf-dash-customer-panel">
        <!-- Partner card -->
        <div class="cf-dash-card" t-if="state.data.partner">
            <div class="cf-dash-card-title">Cliente</div>
            <div class="cf-dash-partner-info">
                <div class="cf-dash-partner-main">
                    <strong t-out="state.data.partner.name"/>
                </div>
                <div class="cf-dash-partner-detail" t-if="state.data.partner.email">
                    <i class="fa fa-envelope-o"/>
                    <span t-out="state.data.partner.email"/>
                </div>
                <div class="cf-dash-partner-detail" t-if="state.data.partner.phone">
                    <i class="fa fa-phone"/>
                    <span t-out="state.data.partner.phone"/>
                </div>
                <div class="cf-dash-partner-detail" t-if="state.data.partner.website">
                    <i class="fa fa-globe"/>
                    <span t-out="state.data.partner.website"/>
                </div>
                <div class="cf-dash-partner-detail" t-if="partnerLocation">
                    <i class="fa fa-map-marker"/>
                    <span><t t-out="partnerFlag"/> <t t-out="partnerLocation"/></span>
                </div>
            </div>
        </div>

        <!-- Contacts card -->
        <div class="cf-dash-card" t-if="state.data.contacts.length">
            <div class="cf-dash-card-title">
                Contatti
                <span class="cf-dash-card-count" t-out="state.data.contacts.length"/>
            </div>
            <div class="cf-dash-contacts-list">
                <t t-foreach="state.data.contacts" t-as="contact" t-key="contact.id">
                    <div class="cf-dash-contact-row" t-on-click="() => this.onContactClick(contact.id)">
                        <div class="cf-dash-contact-avatar">
                            <t t-set="cInitial" t-value="(contact.name || '?')[0].toUpperCase()"/>
                            <t t-out="cInitial"/>
                        </div>
                            <div class="cf-dash-contact-info">
                                <div class="cf-dash-contact-name">
                                    <t t-out="contact.name"/>
                                    <span t-if="contact.is_primary" class="cf-dash-primary-badge">P</span>
                                    <span t-if="contact.is_external" class="cf-dash-external-badge">EXT</span>
                                </div>
                                <div class="cf-dash-contact-meta" t-if="contact.function"
                                     t-out="contact.function"/>
                                <div class="cf-dash-contact-meta" t-if="contact.email">
                                    <i class="fa fa-envelope-o"/>
                                    <t t-out="contact.email"/>
                                    <span t-if="contact.mail_count"> · <t t-out="contact.mail_count"/> mail</span>
                                </div>
                            </div>
                        </div>
                </t>
            </div>
        </div>

        <!-- Lead summary card -->
        <div class="cf-dash-card" t-if="state.data.lead">
            <div class="cf-dash-card-title">Lead principale</div>
            <div class="cf-dash-lead-summary">
                <div class="cf-dash-lead-row">
                    <span class="cf-dash-lead-label">Stage</span>
                    <span t-out="state.data.lead.stage_name"/>
                </div>
                <div class="cf-dash-lead-row">
                    <span class="cf-dash-lead-label">Revenue</span>
                    <span><t t-out="kpiRevenue"/>&#8364;</span>
                </div>
                <div class="cf-dash-lead-row">
                    <span class="cf-dash-lead-label">Probabilità</span>
                    <span><t t-out="state.data.lead.probability"/>%</span>
                </div>
                <div class="cf-dash-lead-row">
                    <span class="cf-dash-lead-label">Score</span>
                    <span t-out="state.data.lead.score"/>
                </div>
                <div class="cf-dash-lead-row">
                    <span class="cf-dash-lead-label">Giorni in fase</span>
                    <span t-out="state.data.lead.days_in_stage"/>
                </div>
            </div>
        </div>
    </div>
</t>

</templates>
