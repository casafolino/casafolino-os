<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="casafolino_crm_export.CFProjectDashboard">
        <div t-if="state.isLoading" class="cf360-loading">
            <div class="cf360-spinner"/>
            <span>Caricamento dossier...</span>
        </div>

        <div t-elif="state.error" class="cf360-error">
            <i class="fa fa-exclamation-triangle" title="Errore"/>
            <strong>Errore nel caricamento</strong>
            <p t-out="state.error"/>
            <button class="btn primary" t-on-click="onRefresh">Riprova</button>
        </div>

        <div t-else="" class="deep-dossier">
            <div class="dossier-top">
                <div class="dossier-title">
                    <h2 t-out="state.data.project.name"/>
                    <div class="meta-row">
                        <span t-attf-class="pill #{statusColor === 'green' ? 'green' : statusColor === 'orange' ? 'amber' : statusColor === 'emerald' ? 'green' : ''}"
                              t-out="statusLabel || 'Dossier attivo'"/>
                        <span class="pill amber">
                            Fase:
                            <t t-if="state.data.lead" t-out="state.data.lead.stage_name || 'offerta'"/>
                            <t t-else="">dossier</t>
                        </span>
                        <span t-if="brokerContact" class="pill violet">
                            Broker: <t t-out="brokerContact.name"/>
                        </span>
                        <span class="pill">Owner: <t t-out="state.data.project.owner_name || 'Team'"/></span>
                        <span t-if="state.data.partner &amp;&amp; state.data.partner.country_name" class="pill teal" t-out="state.data.partner.country_name"/>
                    </div>
                </div>
                <div class="dossier-buttons">
                    <button class="btn primary" t-on-click="onUpdateDossier">Aggiorna dossier</button>
                    <button class="btn primary" t-on-click="onQuickActionMail">Scrivi mail</button>
                    <button class="btn" t-on-click="onSyncDossierMail">Sync mail</button>
                    <button class="btn" t-on-click="onQuickActionActivity">Nuovo task</button>
                    <button class="btn" t-on-click="onUploadDocument">Carica documento</button>
                    <button class="btn amber" t-on-click="onOpenLavagna">Apri lavagna</button>
                </div>
            </div>

            <div class="dossier-command">
                <form class="dossier-search" t-on-submit="onDossierSearchSubmit">
                    <b><i class="fa fa-search" title="Cerca"/></b>
                    <input type="search"
                           t-att-value="state.searchQuery"
                           t-on-input="onDossierSearchInput"
                           placeholder="Cerca dentro il dossier: mail, telefono, referente, documento, campione, quotazione o nota"/>
                    <button t-if="state.searchQuery"
                            type="button"
                            class="btn"
                            t-on-click="() => this.state.searchQuery = ''">Pulisci</button>
                </form>
                <div class="dossier-command-actions">
                    <button class="btn primary" t-on-click="onQuickActionMail">Componi mail</button>
                    <button class="btn" t-on-click="onQuickActionActivity">Aggiungi nota</button>
                    <button class="btn" t-on-click="onQuickActionActivity">Crea task</button>
                    <button class="btn" t-on-click="onOpenLead">Apri CRM</button>
                </div>
            </div>

            <div class="stage-line">
                <t t-foreach="dossierStageCards" t-as="step" t-key="step.id">
                    <div t-attf-class="d-step #{step.done ? 'done' : step.current ? 'now' : ''}">
                        <span t-out="step.id"/>
                        <strong t-out="step.label"/>
                    </div>
                </t>
            </div>

            <div class="decision-strip">
                <div class="next-action-card">
                    <div class="row-top">
                        <h3>
                            Prossima azione:
                            <t t-out="state.data.project.next_action || 'definire e inviare il prossimo follow-up commerciale'"/>
                        </h3>
                        <span class="pill red">bloccante</span>
                    </div>
                    <p>Il dossier deve dire subito cosa fare: thread corretto, referenti chiave, documenti, condizioni e prossima uscita collegata alla storia commerciale.</p>
                    <div class="next-action-foot">
                        <span class="mini">
                            Owner: <t t-out="state.data.project.owner_name || 'Team'"/>
                            <t t-if="brokerContact"> - referente: <t t-out="brokerContact.name"/></t>
                            - template: offerta export
                        </span>
                        <div class="actions">
                            <button class="btn primary" t-on-click="onQuickActionMail">Apri bozza</button>
                            <button class="btn" t-on-click="onQuickActionActivity">Segna fatto</button>
                        </div>
                    </div>
                </div>
                <div class="dossier-kpi-strip">
                    <div class="dossier-kpi">
                        <span>Ultima mail</span>
                        <strong t-out="state.data.mail &amp;&amp; state.data.mail.length ? state.data.mail[0].date_label : '-'"/>
                    </div>
                    <div class="dossier-kpi">
                        <span>Task aperti</span>
                        <strong t-out="state.data.kpi.next_activity ? 1 : 0"/>
                    </div>
                    <div class="dossier-kpi">
                        <span>Documenti mancanti</span>
                        <strong t-out="Math.max(0, 4 - displayedDocuments.length)"/>
                    </div>
                    <div class="dossier-kpi">
                        <span>Valore stimato</span>
                        <strong>€<t t-out="kpiRevenue"/></strong>
                    </div>
                </div>
            </div>

            <div class="dossier-grid">
                <aside class="stack">
                    <section class="panel">
                        <div class="panel-head">
                            <h3>Dossier pulse</h3>
                            <span class="pill green" t-out="dossierScore"/>
                        </div>
                        <div class="panel-body">
                            <div class="score-ring"><strong t-out="dossierScore"/></div>
                            <div class="fact-list">
                                <div class="fact"><span>Rischio</span><strong t-out="dossierScore &gt;= 70 ? 'medio' : 'da presidiare'"/></div>
                                <div class="fact"><span>Ultimo contatto</span><strong t-out="state.data.mail &amp;&amp; state.data.mail.length ? state.data.mail[0].date_label : '-'"/></div>
                                <div class="fact"><span>Mail collegate</span><strong t-out="state.data.mail_count || 0"/></div>
                                <div class="fact"><span>Task aperti</span><strong t-out="state.data.kpi.next_activity ? 1 : 0"/></div>
                                <div class="fact"><span>Valore stimato</span><strong>€<t t-out="kpiRevenue"/></strong></div>
                            </div>
                        </div>
                    </section>

                    <section class="panel">
                        <div class="panel-head">
                            <h3>Alert e dati mancanti</h3>
                            <span class="pill red">controllo</span>
                        </div>
                        <div class="panel-body">
                            <div class="checklist">
                                <div class="check"><span class="box ok"></span><span>Broker o referente collegato</span><span class="pill green">ok</span></div>
                                <div class="check"><span t-attf-class="box #{state.data.project.payment_term ? 'ok' : 'warn'}"></span><span>Condizioni pagamento</span><span t-attf-class="pill #{state.data.project.payment_term ? 'green' : 'amber'}"><t t-out="state.data.project.payment_term ? 'ok' : 'serve'"/></span></div>
                                <div class="check"><span t-attf-class="box #{state.data.project.moq ? 'ok' : 'warn'}"></span><span>MOQ e resa commerciale</span><span t-attf-class="pill #{state.data.project.moq ? 'green' : 'amber'}"><t t-out="state.data.project.moq ? 'ok' : 'serve'"/></span></div>
                                <div class="check"><span t-attf-class="box #{displayedDocuments.length ? 'ok' : 'warn'}"></span><span>Documenti commerciali pronti</span><span t-attf-class="pill #{displayedDocuments.length ? 'green' : 'amber'}"><t t-out="displayedDocuments.length ? 'ok' : 'serve'"/></span></div>
                            </div>
                        </div>
                    </section>

                    <section class="panel">
                        <div class="panel-head">
                            <h3>Brief commerciale</h3>
                        </div>
                        <div class="panel-body">
                            <div class="field-grid">
                                <div class="field"><span>Tipo</span><strong t-out="state.data.project.project_type || 'Dossier'"/></div>
                                <div class="field"><span>Prodotti</span><strong t-out="state.data.lead ? state.data.lead.name : state.data.project.name"/></div>
                                <div class="field"><span>Volume target</span><strong><t t-out="state.data.project.volume_target || '-'"/> <t t-out="state.data.project.volume_unit || ''"/></strong></div>
                                <div class="field"><span>Incoterm</span><strong t-out="state.data.project.incoterms || 'da definire'"/></div>
                                <div class="field"><span>Pagamento</span><strong t-out="state.data.project.payment_term || 'da definire'"/></div>
                                <div class="field"><span>Priorita</span><strong t-out="state.data.project.dossier_priority || 'media'"/></div>
                            </div>
                        </div>
                    </section>
                </aside>

                <main class="stack">
                    <section class="panel">
                        <div class="panel-head">
                            <h3>Centro operativo dossier</h3>
                            <div class="tabs">
                                <span class="tab active">Cockpit</span>
                                <span class="tab">Mail</span>
                                <span class="tab">Task</span>
                                <span class="tab">Documenti</span>
                                <span class="tab">Campioni</span>
                                <span class="tab">Offerte</span>
                                <span class="tab">Storico</span>
                            </div>
                        </div>
                        <div class="panel-body">
                            <div class="signal-grid">
                                <div class="signal"><span>Obiettivo</span><strong t-out="state.data.project.next_action || 'Far avanzare il dossier alla prossima decisione commerciale'"/></div>
                                <div class="signal"><span>Perche ora</span><strong>Mail e materiali sono nello stesso cockpit operativo</strong></div>
                                <div class="signal"><span>Rischio</span><strong t-out="dossierScore &gt;= 70 ? 'Presidiare tempi e risposta' : 'Dati mancanti da chiudere'"/></div>
                                <div class="signal"><span>Decisione richiesta</span><strong>Prossima uscita commerciale chiara e tracciata</strong></div>
                            </div>
                            <div class="board3">
                                <div class="lane">
                                    <h4>Oggi</h4>
                                    <div class="task-row">
                                        <div class="row-top"><strong t-out="state.data.project.next_action || 'Preparare follow-up'"/><span class="pill red">oggi</span></div>
                                        <p class="mini" t-out="state.data.project.owner_name || 'Owner'"/>
                                    </div>
                                    <div class="task-row">
                                        <div class="row-top"><strong>Verifica materiali e listino</strong><span class="pill">oggi</span></div>
                                        <p class="mini">Commerciale</p>
                                    </div>
                                </div>
                                <div class="lane">
                                    <h4>In attesa</h4>
                                    <div class="task-row">
                                        <div class="row-top"><strong>Conferma prodotti target</strong><span class="pill amber">cliente</span></div>
                                        <p class="mini">Referente esterno</p>
                                    </div>
                                    <div class="task-row">
                                        <div class="row-top"><strong>Allineamento broker</strong><span class="pill">broker</span></div>
                                        <p class="mini" t-out="brokerContact ? brokerContact.name : 'Broker'"/>
                                    </div>
                                </div>
                                <div class="lane">
                                    <h4>Pronto</h4>
                                    <div class="task-row">
                                        <div class="row-top"><strong>Catalogo digitale export</strong><span class="pill green">pdf</span></div>
                                        <p class="mini">Caricato nei documenti</p>
                                    </div>
                                    <div class="task-row">
                                        <div class="row-top"><strong>Schede prodotto</strong><span class="pill green">ok</span></div>
                                        <p class="mini">Disponibili se collegate</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="panel">
                        <div class="panel-head">
                            <h3>Mail recenti</h3>
                            <button class="btn" t-on-click="() => this.onTabChange('mail')">Vista thread completa</button>
                        </div>
                        <div class="panel-body">
                            <t t-if="!displayedMail.length">
                                <div class="empty">Nessuna mail su questo dossier</div>
                            </t>
                            <t t-foreach="displayedMail" t-as="m" t-key="m.casafolino_id">
                                <button class="mail-row" t-on-click="() => this.onOpenMailThread(m)">
                                    <div t-attf-class="icon #{m.is_outbound ? 'out' : ''}">
                                        <t t-if="m.is_outbound">OUT</t>
                                        <t t-else="">IN</t>
                                    </div>
                                    <div>
                                        <strong t-out="m.subject"/>
                                        <p class="mini">
                                            <t t-out="m.sender_name || m.partner_name || 'Mail'"/>
                                            <t t-if="m.preview_text"> - <t t-out="m.preview_text"/></t>
                                        </p>
                                    </div>
                                    <span t-attf-class="pill #{m.is_outbound ? 'green' : 'amber'}" t-out="m.date_label || 'mail'"/>
                                </button>
                            </t>
                        </div>
                    </section>

                    <section class="panel">
                        <div class="panel-head">
                            <h3>Timeline decisionale</h3>
                            <span class="pill">ultimi passaggi</span>
                        </div>
                        <div class="panel-body timeline-list">
                            <t t-if="!displayedTimeline.length">
                                <div class="empty">Nessuna attivita' recente</div>
                            </t>
                            <t t-foreach="displayedTimeline" t-as="ev" t-key="ev_index">
                                <div class="timeline-item">
                                    <span class="timeline-dot"></span>
                                    <div>
                                        <strong t-out="ev.title"/>
                                        <p class="mini"><t t-if="ev.author" t-out="ev.author + ' - '"/><t t-out="ev.date_label"/></p>
                                    </div>
                                    <span class="pill" t-out="ev.type || 'storia'"/>
                                </div>
                            </t>
                        </div>
                    </section>
                </main>

                <aside class="stack">
                    <section class="panel">
                        <div class="panel-head">
                            <h3>Persone</h3>
                            <button class="btn" t-on-click="onAddContact">+ Referente</button>
                        </div>
                        <div class="panel-body">
                            <t t-if="!displayedContacts.length">
                                <div class="empty">Nessun referente ancora collegato</div>
                            </t>
                            <t t-foreach="displayedContacts" t-as="contact" t-key="contact.project_contact_id || contact.id || contact_index">
                                <button class="person-row" t-on-click="() => this.onContactClick(contact.id)">
                                    <div class="row-top">
                                        <strong t-out="contact.name"/>
                                        <span t-attf-class="pill #{contact.role === 'broker' ? 'violet' : contact.is_primary ? 'green' : ''}">
                                            <t t-out="contact.role_label || contact.function || 'referente'"/>
                                        </span>
                                    </div>
                                    <p class="mini">
                                        <t t-out="contact.email || 'email non presente'"/>
                                        <t t-if="contact.mail_count"> - <t t-out="contact.mail_count"/> mail</t>
                                    </p>
                                </button>
                            </t>
                        </div>
                    </section>

                    <section class="panel">
                        <div class="panel-head">
                            <h3>Documenti</h3>
                            <span class="pill green"><t t-out="displayedDocuments.length"/> pronti</span>
                        </div>
                        <div class="panel-body">
                            <t t-if="!displayedDocuments.length">
                                <div class="empty">Nessun documento collegato</div>
                            </t>
                            <t t-foreach="displayedDocuments" t-as="doc" t-key="doc.id">
                                <a class="doc-row" t-att-href="doc.url" target="_blank">
                                    <div class="row-top">
                                        <strong t-out="doc.name"/>
                                        <span class="pill green">ok</span>
                                    </div>
                                    <p class="mini" t-out="doc.date_label || doc.size_label || 'Documento dossier'"/>
                                </a>
                            </t>
                        </div>
                    </section>

                    <section class="panel">
                        <div class="panel-head">
                            <h3>Campioni</h3>
                            <span class="pill amber"><t t-out="displayedSamples.length"/> collegati</span>
                        </div>
                        <div class="panel-body">
                            <t t-if="!displayedSamples.length">
                                <div class="empty">Nessuna campionatura collegata</div>
                            </t>
                            <t t-foreach="displayedSamples" t-as="sample" t-key="sample.id">
                                <button class="doc-row" t-on-click="() => this.onOpenSample(sample.id)">
                                    <div class="row-top">
                                        <strong t-out="sample.name"/>
                                        <span class="pill" t-out="sample.state_label || sample.state || 'campione'"/>
                                    </div>
                                    <p class="mini" t-out="sample.date_label || 'Campione dossier'"/>
                                </button>
                            </t>
                        </div>
                    </section>
                </aside>
            </div>
        </div>
    </t>
</templates>
