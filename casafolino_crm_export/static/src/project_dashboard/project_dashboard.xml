<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="casafolino_crm_export.CFProjectDashboard">
    <div t-if="state.isLoading" class="cf360-loading">
        <div class="cf360-spinner"/>
        <span>Caricamento dossier...</span>
    </div>

    <div t-elif="state.error" class="cf360-error">
        <i class="fa fa-exclamation-triangle" title="Errore"/>
        <strong>Errore nel caricamento</strong>
        <p t-out="state.error"/>
        <button class="cf360-btn cf360-btn-primary" t-on-click="onRefresh">Riprova</button>
    </div>

    <div t-else="" class="cf360-app">
        <aside class="cf360-rail">
            <div class="cf360-logo">CF</div>
            <button class="cf360-rail-btn active" title="Dossier">
                <i class="fa fa-compass"/>
            </button>
            <button class="cf360-rail-btn" title="Mail" t-on-click="() => this.onTabChange('mail')">
                <i class="fa fa-envelope-o"/>
            </button>
            <button class="cf360-rail-btn" title="Task">
                <i class="fa fa-check"/>
            </button>
            <button class="cf360-rail-btn" title="Persone" t-on-click="() => this.onTabChange('people')">
                <i class="fa fa-users"/>
            </button>
            <button class="cf360-rail-btn" title="Documenti">
                <i class="fa fa-th"/>
            </button>
        </aside>

        <main class="cf360-main">
            <header class="cf360-topbar">
                <div class="cf360-crumb">
                    <strong>CasaFolino CRM</strong>
                    <span class="cf360-pill blue">Dossier 360</span>
                    <span t-attf-class="cf360-pill #{statusColor === 'green' ? 'green' : statusColor === 'orange' ? 'amber' : statusColor === 'emerald' ? 'green' : 'blue'}"
                          t-out="statusLabel"/>
                </div>
                <label class="cf360-command">
                    <i class="fa fa-search" title="Cerca"/>
                    <input placeholder="Cerca mail, contatto, campione, task..."/>
                </label>
                <div class="cf360-actions">
                    <button class="cf360-btn" t-on-click="onOpenProjectForm">
                        <i class="fa fa-pencil"/> Modifica dossier
                    </button>
                    <button class="cf360-btn" t-on-click="onOpenPartner">
                        <i class="fa fa-address-card-o"/> Modifica cliente
                    </button>
                    <button class="cf360-btn" t-on-click="onSyncDossierMail">
                        <i class="fa fa-refresh"/> Sync mail
                    </button>
                    <button class="cf360-btn cf360-btn-primary" t-on-click="onQuickActionMail">
                        <i class="fa fa-envelope"/> Scrivi
                    </button>
                </div>
            </header>

            <section class="cf360-hero">
                <div class="cf360-title-stack">
                    <span class="cf360-eyebrow">
                        <t t-if="state.data.lead" t-out="state.data.lead.stage_name || 'Lead'"/>
                        <t t-else="">Dossier commerciale</t>
                        <t t-if="state.data.partner &amp;&amp; state.data.partner.country_name"> · <t t-out="state.data.partner.country_name"/></t>
                    </span>
                    <h1 t-out="state.data.project.name"/>
                    <div class="cf360-meta-row">
                        <button class="cf360-link-btn" t-on-click="onOpenProjectForm">
                            <i class="fa fa-pencil"/> Dossier
                        </button>
                        <button class="cf360-link-btn" t-if="state.data.partner" t-on-click="onOpenPartner">
                            <i class="fa fa-user"/> Cliente
                        </button>
                        <span t-if="brokerContact" class="cf360-pill violet">
                            Broker:
                            <t t-out="brokerContact.name"/>
                        </span>
                        <span class="cf360-pill amber">
                            Prossima azione:
                            <t t-out="state.data.project.next_action || 'da definire'"/>
                        </span>
                        <span>
                            Owner <t t-out="state.data.project.owner_name || '—'"/> ·
                            <t t-out="state.data.mail_count || 0"/> mail collegate ·
                            <t t-out="state.data.contacts.length || 0"/> referenti
                        </span>
                    </div>
                </div>
                <div class="cf360-stage">
                    <div class="cf360-stage-labels">
                        <span>Lead</span>
                        <span>Campioni</span>
                        <span>Offerta</span>
                        <span>Negoziazione</span>
                        <span>Ordine</span>
                    </div>
                    <div class="cf360-stage-track">
                        <t t-foreach="stageSegments.slice(0, 8)" t-as="seg" t-key="seg.index">
                            <span t-attf-class="cf360-stage-seg #{seg.current ? 'now' : seg.active ? 'done' : ''}"/>
                        </t>
                    </div>
                </div>
            </section>

            <nav class="cf360-tabs" aria-label="Sezioni dossier">
                <t t-foreach="tabs" t-as="tab" t-key="tab.id">
                    <button t-attf-class="cf360-tab #{state.activeTab === tab.id ? 'active' : ''}"
                            t-on-click="() => this.onTabChange(tab.id)"
                            t-out="tab.label"/>
                </t>
            </nav>

            <section class="cf360-workspace" t-if="state.activeTab === 'cockpit'">
                <div class="cf360-left-stack">
                    <article class="cf360-panel">
                        <div class="cf360-panel-head">
                            <h2>Dossier pulse</h2>
                            <span class="cf360-pill green">
                                <t t-out="state.data.project.dossier_priority || 'medio'"/>
                            </span>
                        </div>
                        <div class="cf360-panel-body cf360-score">
                            <div class="cf360-ring">
                                <strong t-out="Math.min(99, Math.max(35, (state.data.mail_count || 0) + 35))"/>
                            </div>
                            <div class="cf360-facts">
                                <div class="cf360-fact"><span>Rischio</span><strong>medio basso</strong></div>
                                <div class="cf360-fact"><span>Ultimo contatto</span><strong t-out="state.data.mail &amp;&amp; state.data.mail.length ? state.data.mail[0].date_label : '—'"/></div>
                                <div class="cf360-fact"><span>Lead collegati</span><strong t-out="state.data.project.lead_count || 0"/></div>
                                <div class="cf360-fact"><span>Priorità</span><strong t-out="state.data.project.dossier_priority || 'medium'"/></div>
                            </div>
                        </div>
                    </article>

                    <article class="cf360-panel">
                        <div class="cf360-panel-head">
                            <h2>Persone</h2>
                            <button class="cf360-btn" t-on-click="onAddContact">+ Contatto</button>
                        </div>
                        <div class="cf360-panel-body cf360-people">
                            <t t-if="!state.data.contacts.length">
                                <div class="cf360-empty">Nessun referente ancora collegato</div>
                            </t>
                            <t t-foreach="state.data.contacts" t-as="contact" t-key="contact.project_contact_id || contact.id || contact_index">
                                <button class="cf360-person" t-on-click="() => this.onContactClick(contact.id)">
                                    <span t-attf-class="cf360-avatar #{contact.role === 'broker' ? 'violet' : contact.is_external ? 'violet' : contact.is_primary ? 'blue' : 'green'}">
                                        <t t-out="contactInitials(contact)"/>
                                    </span>
                                    <span class="cf360-person-copy">
                                        <strong t-out="contact.name"/>
                                        <small>
                                            <t t-out="contact.role_label || contact.function || 'Referente'"/>
                                            <t t-if="contact.email"> · <t t-out="contact.email"/></t>
                                        </small>
                                    </span>
                                    <span t-attf-class="cf360-pill #{contact.role === 'broker' ? 'violet' : contact.is_primary ? 'blue' : 'green'}">
                                        <t t-if="contact.mail_count" t-out="contact.mail_count + ' mail'"/>
                                        <t t-else="">team</t>
                                    </span>
                                </button>
                            </t>
                        </div>
                    </article>

                    <article class="cf360-panel cf360-ai">
                        <div class="cf360-panel-head">
                            <h2>Sintesi AI dossier</h2>
                            <span class="cf360-pill blue">live</span>
                        </div>
                        <div class="cf360-panel-body">
                            <div class="cf360-ai-item">
                                <strong>Contesto</strong>
                                <p>Mail, referenti e attività sono concentrati qui per decidere la prossima mossa senza saltare tra moduli.</p>
                            </div>
                            <div class="cf360-ai-item">
                                <strong>Da non perdere</strong>
                                <p>Rispondi dal thread più recente, mantieni broker e referente cliente allineati, collega ogni uscita al dossier.</p>
                            </div>
                        </div>
                    </article>
                </div>

                <div class="cf360-center-stack">
                    <div class="cf360-kpis">
                        <div class="cf360-kpi">
                            <span>Mail dossier</span>
                            <strong t-out="state.data.mail_count || 0"/>
                            <small>
                                <t t-out="inboundMailCount"/> ricevute ·
                                <t t-out="outboundMailCount"/> inviate
                            </small>
                        </div>
                        <div class="cf360-kpi">
                            <span>Campioni</span>
                            <strong t-out="state.data.kpi.sample_count || 0"/>
                            <small>in preparazione</small>
                        </div>
                        <div class="cf360-kpi">
                            <span>Valore stimato</span>
                            <strong>€<t t-out="kpiRevenue"/></strong>
                            <small>forecast preliminare</small>
                        </div>
                        <div class="cf360-kpi">
                            <span>Prossima</span>
                            <strong t-out="state.data.project.next_action_date || (state.data.kpi.next_activity ? state.data.kpi.next_activity.date : '—')"/>
                            <small t-out="state.data.project.next_action || 'follow-up'"/>
                        </div>
                    </div>

                    <div class="cf360-next-move">
                        <div>
                            <h2 t-out="state.data.project.next_action || 'Definire la prossima azione commerciale'"/>
                            <p>
                                Usa il thread più recente, includi i referenti chiave e collega la risposta al dossier.
                            </p>
                        </div>
                        <button class="cf360-btn cf360-btn-primary" t-on-click="onQuickActionMail">Apri bozza</button>
                    </div>

                    <article class="cf360-panel">
                        <div class="cf360-panel-head cf360-mail-toolbar">
                            <h2>Mail cockpit</h2>
                            <div class="cf360-segmented">
                                <button class="active">Tutte</button>
                                <button>Da leggere</button>
                                <button>Broker</button>
                                <button>Cliente</button>
                            </div>
                            <button class="cf360-btn" t-on-click="() => this.onTabChange('mail')">Vista thread</button>
                        </div>
                        <div class="cf360-panel-body cf360-mail-list">
                            <t t-if="!state.data.mail || !state.data.mail.length">
                                <div class="cf360-empty">
                                    <i class="fa fa-envelope-o"/>
                                    Nessuna mail su questo dossier
                                </div>
                            </t>
                            <t t-foreach="displayedMail" t-as="m" t-key="m.casafolino_id">
                                <button t-attf-class="cf360-mail #{m.is_outbound ? 'outbound' : 'inbound'}"
                                        t-on-click="() => this.onOpenMailThread(m)">
                                    <span t-attf-class="cf360-iconbox #{m.is_outbound ? 'out' : m.partner_name &amp;&amp; m.partner_name.toLowerCase().includes('alice') ? 'violet' : ''}">
                                        <i t-attf-class="fa #{m.is_outbound ? 'fa-paper-plane' : 'fa-envelope'}"/>
                                    </span>
                                    <span class="cf360-mail-copy">
                                        <span class="cf360-mail-subject">
                                            <strong t-out="m.subject"/>
                                            <span t-attf-class="cf360-pill #{m.partner_name &amp;&amp; m.partner_name.toLowerCase().includes('alice') ? 'violet' : 'blue'}">
                                                <t t-out="m.partner_name || 'dossier'"/>
                                            </span>
                                        </span>
                                        <p>
                                            <t t-out="m.sender_name"/>
                                            <t t-if="m.preview_text"> · <t t-out="m.preview_text"/></t>
                                        </p>
                                    </span>
                                    <span class="cf360-mail-meta" t-out="m.date_label"/>
                                </button>
                            </t>
                        </div>
                    </article>

                    <article class="cf360-panel">
                        <div class="cf360-panel-head">
                            <h2>Execution board</h2>
                            <span class="cf360-pill amber">azioni aperte</span>
                        </div>
                        <div class="cf360-panel-body cf360-board">
                            <div class="cf360-lane">
                                <h3>Oggi</h3>
                                <div class="cf360-task">
                                    <strong t-out="state.data.project.next_action || 'Preparare follow-up'"/>
                                    <div><span t-out="state.data.project.owner_name || 'Owner'"/><span t-out="state.data.project.next_action_date || 'oggi'"/></div>
                                </div>
                                <div class="cf360-task">
                                    <strong>Verifica materiali e listino</strong>
                                    <div><span>Team</span><span>prima invio</span></div>
                                </div>
                            </div>
                            <div class="cf360-lane">
                                <h3>In attesa</h3>
                                <div class="cf360-task">
                                    <strong>Conferma prodotti target</strong>
                                    <div><span>Cliente</span><span>esterno</span></div>
                                </div>
                                <div class="cf360-task">
                                    <strong>Allineamento broker</strong>
                                    <div><span>Broker</span><span>cc</span></div>
                                </div>
                            </div>
                            <div class="cf360-lane">
                                <h3>Pronto</h3>
                                <div class="cf360-task">
                                    <strong>Catalogo digitale export</strong>
                                    <div><span>PDF</span><span>caricato</span></div>
                                </div>
                                <div class="cf360-task">
                                    <strong>Schede prodotto</strong>
                                    <div><span>QA</span><span>ok</span></div>
                                </div>
                            </div>
                        </div>
                    </article>
                </div>

                <aside class="cf360-right-stack">
                    <article class="cf360-panel">
                        <div class="cf360-panel-head">
                            <h2>Timeline</h2>
                            <button class="cf360-btn">Filtra</button>
                        </div>
                        <div class="cf360-panel-body cf360-activity">
                            <t t-if="!state.data.timeline || !state.data.timeline.length">
                                <div class="cf360-empty">Nessuna attività recente</div>
                            </t>
                            <t t-foreach="displayedTimeline" t-as="ev" t-key="ev_index">
                                <div class="cf360-event">
                                    <span class="cf360-dot">
                                        <i t-attf-class="fa #{ev.type === 'mail' ? 'fa-envelope' : ev.type === 'activity' ? 'fa-calendar' : ev.type === 'message' ? 'fa-comment' : 'fa-check'}"/>
                                    </span>
                                    <span class="cf360-event-copy">
                                        <strong t-out="ev.title"/>
                                        <small>
                                            <t t-if="ev.author" t-out="ev.author + ' · '"/>
                                            <t t-out="ev.date_label"/>
                                        </small>
                                    </span>
                                </div>
                            </t>
                        </div>
                    </article>

                    <article class="cf360-panel">
                        <div class="cf360-panel-head">
                            <h2>Documenti e prove</h2>
                            <span class="cf360-pill blue">
                                <t t-out="state.data.documenti ? state.data.documenti.attachments_count : 0"/> file
                            </span>
                        </div>
                        <div class="cf360-panel-body cf360-facts">
                            <div class="cf360-fact"><span>Catalogo export</span><strong>PDF</strong></div>
                            <div class="cf360-fact"><span>Schede prodotto</span><strong t-out="state.data.documenti ? state.data.documenti.attachments_count : 0"/></div>
                            <div class="cf360-fact"><span>Campionature</span><strong t-out="state.data.kpi.sample_count || 0"/></div>
                            <div class="cf360-fact"><span>Certificati</span><strong>da verificare</strong></div>
                        </div>
                    </article>

                    <article class="cf360-panel">
                        <div class="cf360-panel-head">
                            <h2>Guardrail</h2>
                            <span class="cf360-pill red">attenzione</span>
                        </div>
                        <div class="cf360-panel-body cf360-facts">
                            <div class="cf360-fact"><span>Broker in CC</span><strong>sempre</strong></div>
                            <div class="cf360-fact"><span>Lingua</span><strong t-out="state.data.project.dossier_lang || 'ES / EN'"/></div>
                            <div class="cf360-fact"><span>Risposta entro</span><strong>24h</strong></div>
                            <div class="cf360-fact"><span>Owner backup</span><strong>Team</strong></div>
                        </div>
                    </article>
                </aside>
            </section>

            <section class="cf360-tab-page" t-if="state.activeTab === 'timeline'">
                <article class="cf360-panel">
                    <div class="cf360-panel-head">
                        <h2>Evoluzione dossier</h2>
                        <div class="cf360-segmented">
                            <t t-foreach="timelineFilters" t-as="filter" t-key="filter.id">
                                <button t-attf-class="#{state.timelineFilter === filter.id ? 'active' : ''}"
                                        t-on-click="() => this.onTimelineFilter(filter.id)"
                                        t-out="filter.label"/>
                            </t>
                        </div>
                    </div>
                    <div class="cf360-panel-body cf360-activity">
                        <t t-if="!filteredTimeline.length">
                            <div class="cf360-empty">Nessuna evoluzione per questo filtro</div>
                        </t>
                        <t t-foreach="filteredTimeline" t-as="ev" t-key="ev_index">
                            <div class="cf360-event">
                                <span class="cf360-dot">
                                    <i t-attf-class="fa #{ev.type === 'mail' ? 'fa-envelope' : ev.type === 'activity' ? 'fa-calendar' : ev.type === 'message' ? 'fa-comment' : 'fa-check'}"/>
                                </span>
                                <span class="cf360-event-copy">
                                    <strong t-out="ev.title"/>
                                    <small>
                                        <t t-if="ev.author" t-out="ev.author + ' · '"/>
                                        <t t-out="ev.date_label"/>
                                    </small>
                                </span>
                            </div>
                        </t>
                    </div>
                </article>
            </section>

            <section class="cf360-tab-page" t-if="state.activeTab === 'documenti'">
                <article class="cf360-panel">
                    <div class="cf360-panel-head">
                        <h2>Documenti, listini e cataloghi</h2>
                        <div class="cf360-actions">
                            <button class="cf360-btn" t-on-click="onUploadDocument">
                                <i class="fa fa-upload"/> Carica documento
                            </button>
                            <button class="cf360-btn cf360-btn-primary" t-on-click="onOpenDocuments">
                                <i class="fa fa-folder-open"/> Apri archivio
                            </button>
                        </div>
                    </div>
                    <div class="cf360-panel-body cf360-doc-list">
                        <t t-if="!state.data.documenti || !state.data.documenti.attachments.length">
                            <div class="cf360-empty">
                                <i class="fa fa-folder-open-o"/>
                                Nessun documento collegato al dossier o al cliente.
                            </div>
                        </t>
                        <t t-foreach="state.data.documenti.attachments" t-as="doc" t-key="doc.id">
                            <a class="cf360-doc-row" t-att-href="doc.url" target="_blank">
                                <span class="cf360-iconbox">
                                    <i t-attf-class="fa #{doc.icon_class || 'fa-file-o'}"/>
                                </span>
                                <span class="cf360-doc-copy">
                                    <strong t-out="doc.name"/>
                                    <small>
                                        <t t-out="doc.source === 'project' ? 'Dossier' : 'Cliente'"/>
                                        <t t-if="doc.size_label"> · <t t-out="doc.size_label"/></t>
                                        <t t-if="doc.date_label"> · <t t-out="doc.date_label"/></t>
                                    </small>
                                </span>
                                <span class="cf360-pill blue">scarica</span>
                            </a>
                        </t>
                    </div>
                </article>
            </section>

            <section class="cf360-tab-page" t-if="state.activeTab === 'mail'">
                <article class="cf360-panel">
                    <div class="cf360-panel-head">
                        <h2>Comunicazioni</h2>
                        <div class="cf360-actions">
                            <button class="cf360-btn" t-on-click="onOpenDocuments">
                                <i class="fa fa-paperclip"/> Allegati/listini
                            </button>
                            <button class="cf360-btn cf360-btn-primary" t-on-click="onQuickActionMail">
                                <i class="fa fa-envelope"/> Scrivi email
                            </button>
                        </div>
                    </div>
                    <div class="cf360-panel-body cf360-mail-list">
                        <t t-if="!state.data.mail || !state.data.mail.length">
                            <div class="cf360-empty">Nessuna comunicazione collegata</div>
                        </t>
                        <t t-foreach="state.data.mail" t-as="m" t-key="m.casafolino_id">
                            <button t-attf-class="cf360-mail #{m.is_outbound ? 'outbound' : 'inbound'}"
                                    t-on-click="() => this.onOpenMailThread(m)">
                                <span t-attf-class="cf360-iconbox #{m.is_outbound ? 'out' : ''}">
                                    <i t-attf-class="fa #{m.is_outbound ? 'fa-paper-plane' : 'fa-envelope'}"/>
                                </span>
                                <span class="cf360-mail-copy">
                                    <span class="cf360-mail-subject">
                                        <strong t-out="m.subject"/>
                                        <span class="cf360-pill blue" t-out="m.partner_name || 'dossier'"/>
                                    </span>
                                    <p>
                                        <t t-out="m.sender_name"/>
                                        <t t-if="m.preview_text"> · <t t-out="m.preview_text"/></t>
                                    </p>
                                </span>
                                <span class="cf360-mail-meta" t-out="m.date_label"/>
                            </button>
                        </t>
                    </div>
                </article>
            </section>

            <section class="cf360-tab-page" t-if="state.activeTab === 'storico'">
                <article class="cf360-panel">
                    <div class="cf360-panel-head">
                        <h2>Storico commerciale</h2>
                        <div class="cf360-actions">
                            <button class="cf360-btn" t-on-click="onOpenSaleOrders">
                                <i class="fa fa-list"/> Preventivi esistenti
                            </button>
                            <button class="cf360-btn cf360-btn-primary" t-on-click="onQuickActionOffer">
                                <i class="fa fa-file-text-o"/> Crea preventivo
                            </button>
                        </div>
                    </div>
                    <div class="cf360-panel-body cf360-doc-list">
                        <t t-if="!state.data.commerciale || !state.data.commerciale.orders.length">
                            <div class="cf360-empty">Nessun preventivo o ordine ancora collegato al cliente.</div>
                        </t>
                        <t t-foreach="state.data.commerciale.orders" t-as="order" t-key="order.id">
                            <button class="cf360-doc-row" t-on-click="() => this.onOpenSaleOrder(order.id)">
                                <span class="cf360-iconbox">
                                    <i class="fa fa-file-text-o"/>
                                </span>
                                <span class="cf360-doc-copy">
                                    <strong t-out="order.name"/>
                                    <small>
                                        <t t-out="order.state_label"/>
                                        <t t-if="order.date_label"> · <t t-out="order.date_label"/></t>
                                    </small>
                                </span>
                                <span class="cf360-pill green">
                                    <t t-out="order.currency"/> <t t-out="Math.round(order.amount_total || 0)"/>
                                </span>
                            </button>
                        </t>
                    </div>
                </article>
            </section>
        </main>
    </div>
</t>

</templates>
