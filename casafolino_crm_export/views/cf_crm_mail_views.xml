<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Smart button email sul form trattativa -->
    <record id="view_cf_export_lead_form_mail_inherit" model="ir.ui.view">
        <field name="name">cf.export.lead.form.mail.inherit</field>
        <field name="model">cf.export.lead</field>
        <field name="inherit_id" ref="casafolino_crm_export.view_cf_export_lead_form"/>
        <field name="arch" type="xml">

            <!-- Smart button email -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_emails" type="object"
                    class="oe_stat_button" icon="fa-envelope">
                    <field name="email_count" widget="statinfo" string="Email"/>
                </button>
            </xpath>

            <!-- Bottone Scrivi Email nell header -->
            <xpath expr="//header/button[@name='action_mark_contacted']" position="before">
                <button name="action_compose_email" string="Scrivi Email"
                    type="object" class="btn-primary"
                    invisible="not partner_id"/>
            </xpath>

            <!-- Tab Email nella notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Email" name="emails">
                    <div class="cf_lead_email_timeline">
                        <button name="action_view_emails" type="object"
                            class="btn btn-sm btn-secondary mb-3">
                            <i class="fa fa-envelope"/> Vedi tutte le email
                        </button>
                        <field name="last_email_date" readonly="1"
                            string="Ultima email ricevuta"/>
                    </div>
                </page>
            </xpath>

        </field>
    </record>

    <!-- Vista lista email filtrata per trattativa -->
    <record id="action_cf_lead_emails" model="ir.actions.act_window">
        <field name="name">Email Trattativa</field>
        <field name="res_model">cf.mail.message</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("export_lead_id", "=", active_id)]</field>
        <field name="context">{"default_export_lead_id": active_id}</field>
    </record>

</odoo>
