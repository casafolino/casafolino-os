<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_cf_sample" model="ir.ui.view">
        <field name="name">sale.order.form.cf.sample</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='client_order_ref']" position="after">
                <field name="cf_is_sample_order"/>
                <field name="cf_sample_id" invisible="not cf_is_sample_order"/>
            </xpath>
        </field>
    </record>

</odoo>
