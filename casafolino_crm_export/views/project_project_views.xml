<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client action: Dashboard 360 -->
    <record id="action_project_dashboard_360" model="ir.actions.client">
        <field name="name">Vista progetto 360</field>
        <field name="tag">casafolino_crm_export.project_dashboard</field>
        <field name="target">current</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         FORM VIEW — Dossier Commerciale CasaFolino
         ══════════════════════════════════════════════════════════════ -->

    <record id="project_project_form_casafolino" model="ir.ui.view">
        <field name="name">project.project.form.casafolino</field>
        <field name="model">project.project</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <!-- ── HEADER: hide standard, add dossier statusbar ──── -->

            <xpath expr="//button[@name='action_open_share_project_wizard']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header/field[@name='stage_id']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_open_project_dashboard_360"
                        string="Apri Vista 360"
                        type="object"
                        class="btn-primary"
                        icon="fa-pie-chart"/>
                <field name="cf_status_dossier" widget="statusbar"
                       statusbar_visible="exploration,active,on_hold,won,closed"/>
            </xpath>

            <!-- ── BUTTON BOX: hide standard, add 5 dossier stats ── -->

            <xpath expr="//button[@name='action_view_tasks']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//button[@name='project_update_all_action']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-handshake-o"
                        type="object" name="action_open_dossier_leads">
                    <field name="cf_lead_count" string="Lead" widget="statinfo"/>
                </button>
                <button class="oe_stat_button" icon="fa-envelope-o"
                        type="object" name="action_open_dossier_mails">
                    <field name="cf_mail_count" string="Mail" widget="statinfo"/>
                </button>
                <button class="oe_stat_button" icon="fa-flask"
                        type="object" name="action_open_dossier_samples">
                    <field name="cf_sample_count" string="Campion." widget="statinfo"/>
                </button>
                <button class="oe_stat_button" icon="fa-shopping-cart"
                        type="object" name="action_open_dossier_orders">
                    <field name="cf_order_count" string="Ordini" widget="statinfo"/>
                </button>
                <button class="oe_stat_button" icon="fa-users"
                        type="object" name="action_open_dossier_actors">
                    <field name="cf_actor_count" string="Network" widget="statinfo"/>
                </button>
            </xpath>

            <!-- ── TITLE: fix placeholder, hide star ──── -->

            <xpath expr="//field[@name='is_favorite']"
                   position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="placeholder">es. Costco Canada — Miele acacia 2026</attribute>
            </xpath>

            <!-- ── BODY: hide task-tracking fields ──── -->

            <xpath expr="//field[@name='label_tasks']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- ── HIDE casafolino_project header groups ──── -->

            <xpath expr="//field[@name='cf_template_id']/.." position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='cf_partner_id']/.." position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- ── BODY: 2 rows x 2 columns layout ──── -->

            <xpath expr="//field[@name='label_tasks']" position="before">
                <!-- Row 1: CLIENTE | BRIEF COMMERCIALE -->
                <group col="2">
                    <group string="Cliente">
                        <label for="partner_id" string="Cliente"/>
                        <field name="partner_id" nolabel="1"/>
                        <label for="cf_buyer_id" string="Buyer"/>
                        <field name="cf_buyer_id" nolabel="1"
                               options="{'no_create': True}"
                               context="{'default_parent_id': partner_id}"/>
                        <label for="cf_dossier_lang" string="Lingua"/>
                        <field name="cf_dossier_lang" nolabel="1"/>
                    </group>
                    <group string="Brief Commerciale">
                        <label for="cf_project_type" string="Tipo Progetto"/>
                        <field name="cf_project_type" nolabel="1" widget="selection"/>
                        <label for="cf_volume_target" string="Volume Target"/>
                        <div class="o_row">
                            <field name="cf_volume_target" nolabel="1" class="oe_inline"/>
                            <field name="cf_volume_unit" nolabel="1" class="oe_inline"/>
                        </div>
                        <label for="cf_margin_target" string="Margine Target %"/>
                        <field name="cf_margin_target" nolabel="1" widget="percentage"/>
                        <label for="cf_certification_ids" string="Certificazioni"/>
                        <field name="cf_certification_ids" nolabel="1" widget="many2many_tags"
                               options="{'color_field': 'color', 'no_create': True}"/>
                        <label for="cf_next_action" string="Prossima Azione"/>
                        <field name="cf_next_action" nolabel="1" placeholder="es. Inviare campionature 220g"/>
                        <label for="cf_next_action_date" string="Data Prossima Azione"/>
                        <field name="cf_next_action_date" nolabel="1"/>
                    </group>
                </group>
                <!-- Row 2: META | DETTAGLI COMMERCIALI -->
                <group col="2">
                    <group string="Meta">
                        <label for="cf_template_origin_id" string="Da Template"/>
                        <field name="cf_template_origin_id" nolabel="1" readonly="1"/>
                        <label for="date" string="Data Target"/>
                        <field name="date" nolabel="1"/>
                        <label for="user_id" string="Responsabile"/>
                        <field name="user_id" nolabel="1"/>
                        <label for="cf_co_user_ids" string="Co-responsabili"/>
                        <field name="cf_co_user_ids" nolabel="1" widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>
                    <group string="Dettagli Commerciali">
                        <label for="cf_incoterms" string="Incoterms"/>
                        <field name="cf_incoterms" nolabel="1"/>
                        <label for="cf_payment_term" string="Pagamento"/>
                        <field name="cf_payment_term" nolabel="1"/>
                        <label for="cf_moq" string="MOQ"/>
                        <field name="cf_moq" nolabel="1"/>
                        <label for="cf_lead_time" string="Lead Time (gg)"/>
                        <field name="cf_lead_time" nolabel="1"/>
                        <label for="cf_shelf_life" string="Shelf Life (mesi)"/>
                        <field name="cf_shelf_life" nolabel="1"/>
                    </group>
                </group>
            </xpath>

            <!-- ── NOTEBOOK: dossier tabs ──── -->

            <xpath expr="//notebook" position="inside">

                <page string="Checkpoint" name="cf_checkpoint">
                    <field name="task_ids" mode="list">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="user_ids" widget="many2many_tags"/>
                            <field name="stage_id"/>
                            <field name="date_deadline"/>
                        </list>
                    </field>
                </page>

                <page string="Mail timeline" name="cf_mail_timeline">
                    <field name="cf_dossier_mail_ids" mode="list" readonly="1">
                        <list>
                            <field name="email_date" string="Data"/>
                            <field name="subject"/>
                            <field name="sender_email" string="Da"/>
                            <field name="partner_id" string="Contatto"/>
                        </list>
                    </field>
                </page>

                <page string="Lead correlati" name="cf_leads">
                    <field name="cf_lead_ids" mode="list">
                        <list>
                            <field name="name"/>
                            <field name="stage_id"/>
                            <field name="expected_revenue"/>
                            <field name="user_id"/>
                            <field name="create_date"/>
                        </list>
                    </field>
                </page>

                <page string="Campionature" name="cf_samples">
                    <field name="cf_dossier_sample_ids" mode="list" readonly="1">
                        <list>
                            <field name="reference"/>
                            <field name="state" widget="badge"/>
                            <field name="partner_id"/>
                            <field name="create_date"/>
                        </list>
                    </field>
                </page>

                <page string="Documenti" name="cf_documents">
                    <field name="cf_dossier_attachment_ids" mode="list">
                        <list>
                            <field name="name"/>
                            <field name="mimetype" string="Tipo"/>
                            <field name="file_size" string="Dimensione"/>
                            <field name="create_date" string="Caricato il"/>
                        </list>
                    </field>
                </page>

                <page string="Network e Commissioni" name="cf_network">
                    <field name="cf_actor_ids" mode="list">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="role"/>
                            <field name="commission_basis"/>
                            <field name="commission_value"/>
                            <field name="notes"/>
                        </list>
                    </field>
                </page>

                <page string="Note interne" name="cf_notes">
                    <field name="cf_internal_notes"
                           placeholder="Note interne (solo team)..."
                           nolabel="1"/>
                </page>

                <page string="Dossier commerciale" name="cf_dossier">
                    <group>
                        <group string="Stato">
                            <field name="cf_status_dossier"/>
                            <field name="cf_dossier_priority" widget="priority"/>
                        </group>
                        <group string="Relazioni">
                            <field name="cf_managed_by_id"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Valore">
                            <field name="cf_dossier_value_estimate" widget="monetary"/>
                        </group>
                        <group string="Statistiche">
                            <field name="cf_lead_count" readonly="1"/>
                            <field name="cf_open_issues_count" readonly="1"/>
                            <field name="cf_last_activity_date" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         SEARCH VIEW — Dossier filters
         ══════════════════════════════════════════════════════════════ -->

    <record id="project_project_search_casafolino" model="ir.ui.view">
        <field name="name">project.project.search.casafolino</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_project_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Dossier attivi" name="dossier_active"
                        domain="[('cf_status_dossier', '=', 'active')]"/>
                <filter string="Dossier esplorativi" name="dossier_exploration"
                        domain="[('cf_status_dossier', '=', 'exploration')]"/>
                <filter string="Priorita alta" name="dossier_high_priority"
                        domain="[('cf_dossier_priority', '=', 'high')]"/>
                <filter string="Miei dossier (resp. o co-resp.)" name="dossier_mine"
                        domain="['|',('user_id', '=', uid),('cf_co_user_ids', 'in', [uid])]"/>
                <separator/>
                <filter string="Raggruppa per Status" name="group_by_status"
                        context="{'group_by': 'cf_status_dossier'}"/>
                <filter string="Raggruppa per Agente" name="group_by_managed_by"
                        context="{'group_by': 'cf_managed_by_id'}"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         ACTION: Progetti 360 (list/form)
         ══════════════════════════════════════════════════════════════ -->

    <record id="action_cf_project_dossier" model="ir.actions.act_window">
        <field name="name">Progetti 360</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('cf_status_dossier', '!=', False)]</field>
        <field name="context">{'default_cf_status_dossier': 'exploration'}</field>
    </record>

</odoo>
