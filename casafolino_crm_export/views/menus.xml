<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Actions config -->
    <record id="action_cf_sequence" model="ir.actions.act_window">
        <field name="name">Sequenze Follow-up</field>
        <field name="res_model">cf.export.sequence</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_cf_cert" model="ir.actions.act_window">
        <field name="name">Certificazioni</field>
        <field name="res_model">cf.export.certification</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root menu -->
    <menuitem id="menu_cf_export_root" name="Export CRM" sequence="20"
        web_icon="casafolino_crm_export,static/description/icon.png"/>

    <!-- Pipeline -->
    <menuitem id="menu_cf_all" name="Tutte le Pipeline"
        parent="menu_cf_export_root" action="action_cf_crm_all" sequence="1"/>
    <menuitem id="menu_cf_america" name="America"
        parent="menu_cf_export_root" action="action_cf_crm_america" sequence="2"/>
    <menuitem id="menu_cf_europa" name="Europa"
        parent="menu_cf_export_root" action="action_cf_crm_europa" sequence="3"/>
    <menuitem id="menu_cf_italia" name="Italia"
        parent="menu_cf_export_root" action="action_cf_crm_italia" sequence="4"/>
    <menuitem id="menu_cf_medio_oriente" name="Medio Oriente"
        parent="menu_cf_export_root" action="action_cf_crm_medio_oriente" sequence="5"/>
    <menuitem id="menu_cf_australia" name="Australia"
        parent="menu_cf_export_root" action="action_cf_crm_australia" sequence="6"/>
    <menuitem id="menu_cf_altri" name="Altri Mercati"
        parent="menu_cf_export_root" action="action_cf_crm_altri" sequence="7"/>

    <!-- Operativo -->
    <menuitem id="menu_cf_samples" name="Campionature"
        parent="menu_cf_export_root" action="action_cf_sample" sequence="10"/>
    <menuitem id="menu_cf_fairs" name="Fiere"
        parent="menu_cf_export_root" action="action_cf_fair" sequence="11"/>

    <!-- Configurazione -->
    <menuitem id="menu_cf_config" name="Configurazione"
        parent="menu_cf_export_root" sequence="99" groups="base.group_system"/>
    <menuitem id="menu_cf_sequences" name="Sequenze Follow-up"
        parent="menu_cf_config" action="action_cf_sequence" sequence="1"/>
    <menuitem id="menu_cf_certs" name="Certificazioni"
        parent="menu_cf_config" action="action_cf_cert" sequence="2"/>

</odoo>
