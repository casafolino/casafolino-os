<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Card Scanner client action -->
    <record id="action_card_scanner" model="ir.actions.client">
        <field name="name">Card Scanner SIAL</field>
        <field name="tag">casafolino_card_scanner</field>
    </record>

    <!-- Actions config -->
    <record id="action_cf_sequence" model="ir.actions.act_window">
        <field name="name">Sequenze Follow-up</field>
        <field name="res_model">cf.export.sequence</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_cf_cert" model="ir.actions.act_window">
        <field name="name">Certificazioni</field>
        <field name="res_model">cf.export.certification</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Settings action -->
    <record id="action_crm_export_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'casafolino_crm_export'}</field>
    </record>

    <!-- Root menu -->
    <menuitem id="menu_cf_export_root" name="Export CRM" sequence="20"
        web_icon="casafolino_crm_export,static/description/icon.png"/>

    <!-- Card Scanner — first item -->
    <menuitem id="menu_card_scanner" name="Nuovo lead da biglietto"
        parent="menu_cf_export_root" action="action_card_scanner" sequence="0"/>

    <!-- Pipeline principale -->
    <menuitem id="menu_cf_all" name="Tutte le Pipeline"
        parent="menu_cf_export_root" action="action_cf_crm_all" sequence="10"/>

    <!-- Operatori -->
    <menuitem id="menu_cf_antonio" name="Antonio"
        parent="menu_cf_export_root" action="action_crm_lead_antonio" sequence="15"/>
    <menuitem id="menu_cf_josefina" name="Josefina"
        parent="menu_cf_export_root" action="action_crm_lead_josefina" sequence="20"/>

    <!-- Operativo -->
    <menuitem id="menu_cf_samples" name="Campionature"
        parent="menu_cf_export_root" action="action_cf_sample" sequence="30"/>
    <menuitem id="menu_cf_fairs" name="Fiere"
        parent="menu_cf_export_root" action="action_cf_fair" sequence="31"/>

    <!-- Configurazione -->
    <menuitem id="menu_cf_config" name="Configurazione"
        parent="menu_cf_export_root" sequence="99" groups="base.group_system"/>
    <menuitem id="menu_cf_sequences" name="Sequenze Follow-up"
        parent="menu_cf_config" action="action_cf_sequence" sequence="1"/>
    <menuitem id="menu_cf_certs" name="Certificazioni"
        parent="menu_cf_config" action="action_cf_cert" sequence="2"/>
    <menuitem id="menu_cf_settings" name="Fair Follow-up Settings"
        parent="menu_cf_config" action="action_crm_export_config" sequence="3"/>

</odoo>
