<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_crm_export" model="ir.ui.view">
        <field name="name">res.config.settings.crm.export.fair</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="CRM Export" string="CRM Export">
                    <block title="Fair Follow-up Settings" name="fair_followup_settings">
                        <setting string="Catalogue (EN)" help="Select the Catalogue document to attach to fair follow-up emails">
                            <field name="fair_attachment_catalog"/>
                        </setting>
                        <setting string="Company Profile (EN)" help="Select the Company Profile document to attach to fair follow-up emails">
                            <field name="fair_attachment_company_profile"/>
                        </setting>
                        <setting string="Fair CC Email" help="Email address to CC on all fair follow-up emails">
                            <field name="fair_cc_email" placeholder="josefina.lazzaro@casafolino.com"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
