<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Template list view -->
    <record id="view_cf_dossier_template_list" model="ir.ui.view">
        <field name="name">cf.dossier.template.list</field>
        <field name="model">cf.dossier.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="icon"/>
                <field name="name"/>
                <field name="code"/>
                <field name="category" widget="badge"/>
                <field name="default_lang"/>
                <field name="default_incoterms"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Template form view -->
    <record id="view_cf_dossier_template_form" model="ir.ui.view">
        <field name="name">cf.dossier.template.form</field>
        <field name="model">cf.dossier.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_dossier" string="Crea Dossier"
                                type="object" class="oe_stat_button" icon="fa-plus"/>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="icon"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="default_lang"/>
                            <field name="default_volume_unit"/>
                            <field name="default_incoterms"/>
                            <field name="default_payment_term"/>
                            <field name="default_certification_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <field name="description" placeholder="Descrizione del template..."/>
                    <notebook>
                        <page string="Checkpoint">
                            <field name="checkpoint_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="expected_duration_days"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_cf_dossier_template" model="ir.actions.act_window">
        <field name="name">Template Dossier</field>
        <field name="res_model">cf.dossier.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Wizard: create from template -->
    <record id="view_cf_dossier_create_from_template_form" model="ir.ui.view">
        <field name="name">cf.dossier.create.from.template.form</field>
        <field name="model">cf.dossier.create.from.template</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="template_id"/>
                    <field name="name"/>
                    <field name="partner_id"/>
                </group>
                <footer>
                    <button name="action_create" string="Crea Dossier"
                            type="object" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard action -->
    <record id="action_cf_dossier_create_from_template" model="ir.actions.act_window">
        <field name="name">Nuovo Dossier da Template</field>
        <field name="res_model">cf.dossier.create.from.template</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Actor list view -->
    <record id="view_cf_dossier_actor_list" model="ir.ui.view">
        <field name="name">cf.dossier.actor.list</field>
        <field name="model">cf.dossier.actor</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="role" widget="badge"/>
                <field name="commission_basis"/>
                <field name="commission_value"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- Actor form view -->
    <record id="view_cf_dossier_actor_form" model="ir.ui.view">
        <field name="name">cf.dossier.actor.form</field>
        <field name="model">cf.dossier.actor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="role"/>
                        </group>
                        <group>
                            <field name="commission_basis"/>
                            <field name="commission_value"/>
                            <field name="commission_currency_id"/>
                            <field name="active"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Note..."/>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
