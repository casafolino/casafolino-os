<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         ACTIONS
         ============================================================ -->

    <record id="action_cf_crm_all" model="ir.actions.act_window">
        <field name="name">Tutte le Pipeline</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('type','=','opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

    <record id="action_crm_lead_antonio" model="ir.actions.act_window">
        <field name="name">Antonio</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('user_id.login', '=', 'antonio@casafolino.com'), ('type', '=', 'opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

    <record id="action_crm_lead_josefina" model="ir.actions.act_window">
        <field name="name">Josefina</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('user_id.login', '=', 'josefina.lazzaro@casafolino.com'), ('type', '=', 'opportunity')]</field>
        <field name="context">{'default_type': 'opportunity'}</field>
    </record>

    <!-- ============================================================
         KANBAN — custom view
         ============================================================ -->

    <record id="cf_crm_lead_view_kanban" model="ir.ui.view">
        <field name="name">crm.lead.kanban.cf</field>
        <field name="model">crm.lead</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" quick_create="false"
                    class="o_kanban_small_column o_opportunity_kanban cf_kanban_enriched"
                    js_class="casafolino_crm_lead_kanban">
                <field name="stage_id"/>
                <field name="partner_id"/>
                <field name="expected_revenue"/>
                <field name="cf_lead_score"/>
                <field name="cf_rotting_state"/>
                <field name="cf_user_color"/>
                <field name="cf_date_next_followup"/>
                <field name="user_id"/>
                <field name="priority"/>
                <field name="activity_state"/>
                <field name="color"/>
                <field name="tag_ids"/>
                <field name="casafolino_has_unread_mail"/>
                <field name="casafolino_unread_mail_count"/>
                <field name="casafolino_has_overdue_followup"/>
                <field name="casafolino_no_activity_warning"/>
                <field name="casafolino_days_since_last_activity"/>
                <field name="casafolino_origin_fair_tag_id"/>
                <field name="casafolino_relative_last_activity"/>
                <field name="casafolino_stage_position"/>
                <field name="casafolino_owner_avatar_class"/>
                <field name="casafolino_owner_avatar_initials"/>
                <field name="casafolino_card_title"/>
                <field name="casafolino_product_category_label"/>
                <field name="casafolino_stage_label"/>
                <field name="phone"/>
                <field name="email_from"/>
                <progressbar field="activity_state"
                    colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="cf-crm-card cf-enriched #{record.casafolino_owner_avatar_class.raw_value}">
                            <!-- Header: title + category + revenue -->
                            <div class="cf-card-header">
                                <span class="cf-card-title">
                                    <t t-out="record.casafolino_card_title.raw_value"/>
                                </span>
                                <span class="cf-card-category" t-if="record.casafolino_product_category_label.raw_value">
                                    <t t-out="record.casafolino_product_category_label.raw_value"/>
                                </span>
                                <span class="cf-card-value" t-if="record.expected_revenue.raw_value">
                                    <t t-set="rev_k" t-value="Math.round(record.expected_revenue.raw_value / 1000)"/>
                                    <t t-out="rev_k"/>k
                                </span>
                            </div>

                            <!-- Stage progress bar 9 segments -->
                            <div class="cf-stage-progress">
                                <t t-set="pos" t-value="record.casafolino_stage_position.raw_value || 0"/>
                                <t t-foreach="[1,2,3,4,5,6,7,8,9]" t-as="seg" t-key="seg">
                                    <div t-attf-class="cf-seg #{seg &lt;= pos ? 'cf-seg-active' : 'cf-seg-inactive'}"
                                         t-attf-style="#{seg &lt;= pos ? 'background:' + record.cf_user_color.raw_value : ''}"/>
                                </t>
                            </div>

                            <!-- Stage label -->
                            <div class="cf-stage-label">
                                <t t-out="record.casafolino_stage_label.raw_value"/>
                            </div>

                            <!-- Dynamic badges (max 3) -->
                            <div class="cf-badges">
                                <t t-if="record.casafolino_has_overdue_followup.raw_value">
                                    <span class="cf-badge cf-badge-danger">follow-up dovuto</span>
                                </t>
                                <t t-if="record.casafolino_unread_mail_count.raw_value > 0">
                                    <span class="cf-badge cf-badge-info"><t t-out="record.casafolino_unread_mail_count.raw_value"/> mail nuove</span>
                                </t>
                                <t t-if="record.casafolino_no_activity_warning.raw_value">
                                    <span class="cf-badge cf-badge-warning">no attività <t t-out="record.casafolino_days_since_last_activity.raw_value"/>gg</span>
                                </t>
                                <t t-if="record.casafolino_origin_fair_tag_id.raw_value">
                                    <span class="cf-badge cf-badge-fair"><field name="casafolino_origin_fair_tag_id"/></span>
                                </t>
                            </div>

                            <!-- Footer: custom avatar + relative time -->
                            <div class="cf-card-footer">
                                <div t-attf-class="cf-owner-avatar size-md #{record.casafolino_owner_avatar_class.raw_value}"
                                     t-att-title="record.user_id.value">
                                    <t t-out="record.casafolino_owner_avatar_initials.raw_value"/>
                                </div>
                                <div class="cf-footer-time">
                                    <t t-out="record.casafolino_relative_last_activity.value"/>
                                </div>
                            </div>

                            <!-- Quick actions (hover only) -->
                            <div class="cf-kanban-quick-actions">
                                <a t-attf-href="tel:#{record.phone.raw_value || ''}"
                                   class="cf-qa-btn" title="Chiama"
                                   t-if="record.phone.raw_value">
                                    <i class="fa fa-phone"/>
                                </a>
                                <button name="action_send_email" type="object"
                                        class="cf-qa-btn" title="Email">
                                    <i class="fa fa-envelope"/>
                                </button>
                                <a type="open" class="cf-qa-btn" title="Apri">
                                    <i class="fa fa-external-link"/>
                                </a>
                                <button name="action_kanban_archive" type="object"
                                        class="cf-qa-btn cf-qa-archive" title="Archivia">
                                    <i class="fa fa-archive"/>
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         PREMIUM FORM — standalone (NOT inherited)
         ============================================================ -->

    <record id="cf_crm_lead_view_form_premium" model="ir.ui.view">
        <field name="name">crm.lead.form.cf.premium</field>
        <field name="model">crm.lead</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Trattativa Export" class="cf-premium-form">
                <header>
                    <button name="action_mark_contacted" string="Contatto Registrato"
                        type="object" class="btn-primary"/>
                    <button name="action_schedule_followup" string="Follow-up +7gg"
                        type="object" class="btn-secondary"/>
                    <field name="stage_id" widget="statusbar"
                        options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <!-- SMART BUTTONS -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_partner_emails" type="object"
                            class="oe_stat_button" icon="fa-envelope">
                            <field name="cf_email_count" widget="statinfo" string="Email"/>
                        </button>
                        <button name="action_view_samples" type="object"
                            class="oe_stat_button" icon="fa-flask">
                            <field name="cf_sample_count" widget="statinfo" string="Campionature"/>
                        </button>
                    </div>

                    <!-- KPI BANNER -->
                    <div class="cf-kpi-banner">
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value cf-kpi-score">
                                <field name="cf_lead_score"/>
                            </div>
                            <div class="cf-kpi-label">SCORE</div>
                        </div>
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value">
                                <field name="cf_forecast_value" widget="monetary"/>
                            </div>
                            <div class="cf-kpi-label">FORECAST</div>
                        </div>
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value">
                                <field name="cf_rotting_state" widget="badge"
                                    decoration-success="cf_rotting_state == 'ok'"
                                    decoration-warning="cf_rotting_state == 'warning'"
                                    decoration-danger="cf_rotting_state in ('danger','dead')"/>
                            </div>
                            <div class="cf-kpi-label">STATO</div>
                        </div>
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value">
                                <field name="cf_days_in_stage"/>
                                <span class="cf-kpi-unit">gg</span>
                            </div>
                            <div class="cf-kpi-label">IN FASE</div>
                        </div>
                    </div>

                    <!-- CONTACT CARD -->
                    <div class="cf-contact-card">
                        <div class="cf-contact-left">
                            <div class="cf-avatar">
                                <field name="cf_partner_image" widget="image"
                                    options="{'size': [64, 64]}"/>
                            </div>
                            <div class="cf-contact-text">
                                <div class="cf-deal-name">
                                    <field name="name" placeholder="Nome trattativa..."/>
                                </div>
                                <div class="cf-company-name">
                                    <field name="partner_id" placeholder="Azienda/Contatto"/>
                                </div>
                                <div class="cf-contact-meta">
                                    <span invisible="not email_from">
                                        <i class="fa fa-envelope-o"/> <field name="email_from" widget="email"/>
                                    </span>
                                    <span invisible="not phone">
                                        <i class="fa fa-phone"/> <field name="phone" widget="phone"/>
                                    </span>
                                    <span invisible="not cf_partner_country">
                                        <i class="fa fa-globe"/> <field name="cf_partner_country"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="cf-contact-right">
                            <div class="cf-action-buttons">
                                <button name="action_send_email" type="object"
                                    class="cf-action-btn" title="Invia Email"
                                    invisible="not partner_id">
                                    <i class="fa fa-envelope"/>
                                </button>
                                <button name="action_schedule_followup" type="object"
                                    class="cf-action-btn" title="Pianifica Follow-up">
                                    <i class="fa fa-calendar-plus-o"/>
                                </button>
                                <button name="action_mark_contacted" type="object"
                                    class="cf-action-btn" title="Segna Contattato">
                                    <i class="fa fa-check"/>
                                </button>
                            </div>
                            <div class="cf-priority-user">
                                <field name="priority" widget="priority"/>
                                <field name="user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </div>

                    <!-- 2-COLUMN LAYOUT -->
                    <div class="row cf-layout">

                        <!-- LEFT: TABS -->
                        <div class="col-lg-8 cf-main-col">
                            <notebook>
                                <!-- Tab: Attività -->
                                <page string="Attività" name="activities">
                                    <field name="activity_ids"/>
                                </page>

                                <!-- Tab: Email -->
                                <page string="Email" name="emails">
                                    <div class="o_row mb-3">
                                        <button name="action_send_email" type="object"
                                            string="Scrivi Email" class="btn btn-primary btn-sm"
                                            invisible="not partner_id"/>
                                    </div>
                                    <field name="cf_partner_email_ids" readonly="1" nolabel="1">
                                        <list decoration-muted="message_type == 'notification'">
                                            <field name="date" string="Data"/>
                                            <field name="subject" string="Oggetto"/>
                                            <field name="email_from" string="Da"/>
                                        </list>
                                    </field>
                                </page>

                                <!-- Tab: Dettagli -->
                                <page string="Dettagli" name="export_details">
                                    <group>
                                        <group string="Classificazione">
                                            <field name="tag_ids" widget="many2many_tags"
                                                options="{'color_field': 'color'}"/>
                                            <field name="cf_language"/>
                                            <field name="cf_fair_id"/>
                                        </group>
                                        <group string="Commerciale">
                                            <field name="cf_certifications_required"
                                                widget="many2many_tags"/>
                                        </group>
                                    </group>
                                </page>

                                <!-- Tab: Campionature -->
                                <page string="Campionature" name="samples">
                                    <div class="o_row mb-3">
                                        <button name="action_create_sample" type="object"
                                            string="+ Nuova Campionatura"
                                            class="btn btn-primary btn-sm"/>
                                    </div>
                                    <field name="cf_sample_ids">
                                        <list editable="bottom">
                                            <field name="reference" readonly="1"/>
                                            <field name="product_ids" widget="many2many_tags"/>
                                            <field name="stage_id"/>
                                            <field name="state" widget="badge"/>
                                            <field name="date_sent"/>
                                            <field name="tracking_number"/>
                                            <field name="feedback_score"/>
                                        </list>
                                    </field>
                                </page>

                                <!-- Tab: Note -->
                                <page string="Note" name="notes">
                                    <field name="description" placeholder="Note sulla trattativa..."/>
                                </page>
                            </notebook>
                        </div>

                        <!-- RIGHT: SIDEBAR -->
                        <div class="col-lg-4 cf-sidebar-col">
                            <!-- Deal Info -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Informazioni Deal</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Ricavi previsti</span>
                                    <span class="cf-prop-value"><field name="expected_revenue"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Probabilità</span>
                                    <span class="cf-prop-value"><field name="probability"/>%</span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Forecast</span>
                                    <span class="cf-prop-value"><field name="cf_forecast_value" widget="monetary"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Chiusura prevista</span>
                                    <span class="cf-prop-value"><field name="date_deadline"/></span>
                                </div>
                            </div>

                            <!-- Scoring -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Scoring</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Lead Score</span>
                                    <span class="cf-prop-value"><field name="cf_lead_score" widget="progressbar"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Stato</span>
                                    <span class="cf-prop-value"><field name="cf_rotting_state" widget="badge"
                                        decoration-success="cf_rotting_state == 'ok'"
                                        decoration-warning="cf_rotting_state == 'warning'"
                                        decoration-danger="cf_rotting_state in ('danger','dead')"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Ultimo aggiornamento</span>
                                    <span class="cf-prop-value"><field name="cf_rotting_days_display"/></span>
                                </div>
                            </div>

                            <!-- Follow-up -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Follow-up</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Ultimo contatto</span>
                                    <span class="cf-prop-value"><field name="cf_date_last_contact"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Prossimo</span>
                                    <span class="cf-prop-value"><field name="cf_date_next_followup"/></span>
                                </div>
                                <div class="cf-prop-row" invisible="not cf_next_activity_summary">
                                    <span class="cf-prop-label">Prossima attività</span>
                                    <span class="cf-prop-value"><field name="cf_next_activity_summary"/></span>
                                </div>
                            </div>

                            <!-- Contatto -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Contatto</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Email</span>
                                    <span class="cf-prop-value"><field name="email_from" widget="email"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Telefono</span>
                                    <span class="cf-prop-value"><field name="phone" widget="phone"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Paese</span>
                                    <span class="cf-prop-value"><field name="cf_partner_country"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Lingua</span>
                                    <span class="cf-prop-value"><field name="cf_language"/></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
         BIND views to actions (kanban + form)
         ============================================================ -->

    <!-- action_cf_crm_all -->
    <record id="action_cf_crm_all_kanban" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="cf_crm_lead_view_kanban"/>
        <field name="act_window_id" ref="action_cf_crm_all"/>
    </record>
    <record id="action_cf_crm_all_form" model="ir.actions.act_window.view">
        <field name="sequence">3</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="cf_crm_lead_view_form_premium"/>
        <field name="act_window_id" ref="action_cf_crm_all"/>
    </record>

    <!-- action_crm_lead_antonio -->
    <record id="action_crm_lead_antonio_kanban" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="cf_crm_lead_view_kanban"/>
        <field name="act_window_id" ref="action_crm_lead_antonio"/>
    </record>
    <record id="action_crm_lead_antonio_form" model="ir.actions.act_window.view">
        <field name="sequence">3</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="cf_crm_lead_view_form_premium"/>
        <field name="act_window_id" ref="action_crm_lead_antonio"/>
    </record>

    <!-- action_crm_lead_josefina -->
    <record id="action_crm_lead_josefina_kanban" model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="cf_crm_lead_view_kanban"/>
        <field name="act_window_id" ref="action_crm_lead_josefina"/>
    </record>
    <record id="action_crm_lead_josefina_form" model="ir.actions.act_window.view">
        <field name="sequence">3</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="cf_crm_lead_view_form_premium"/>
        <field name="act_window_id" ref="action_crm_lead_josefina"/>
    </record>

    <!-- ============================================================
         SEARCH — eredita dalla nativa
         ============================================================ -->

    <record id="cf_crm_lead_view_search" model="ir.ui.view">
        <field name="name">crm.lead.search.cf</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter string="Standby" name="cf_stage_standby" domain="[('stage_id.name','=','Standby')]"/>
                <filter string="Inattivi 30gg+" name="cf_inactive_30" domain="[('cf_date_last_contact','&lt;', (context_today() - datetime.timedelta(days=30)).strftime('%%Y-%%m-%%d'))]"/>
                <separator/>
                <filter string="Mail nuova" name="cf_unread_mail" domain="[('casafolino_has_unread_mail', '=', True)]"/>
                <filter string="Follow-up dovuto" name="cf_overdue_followup" domain="[('activity_ids.date_deadline', '&lt;', context_today().strftime('%%Y-%%m-%%d'))]"/>
                <filter string="No attività &gt; 30gg" name="cf_no_activity" domain="[('casafolino_days_since_last_activity', '&gt;', 30), ('stage_id.name', 'not in', ['Vinta', 'Persa'])]"/>
                <filter string="Da fiera" name="cf_fair_origin" domain="[('tag_ids.cf_category', '=', 'fair')]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Tag" name="group_tag" context="{'group_by': 'tag_ids'}"/>
                    <filter string="Operatore" name="group_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Stage" name="group_stage" context="{'group_by': 'stage_id'}"/>
                    <filter string="Fiera origine" name="group_fair" context="{'group_by': 'casafolino_origin_fair_tag_id'}"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ============================================================
         FORM — inherited (still used by native CRM menus)
         ============================================================ -->

    <record id="cf_crm_lead_view_form" model="ir.ui.view">
        <field name="name">crm.lead.form.cf</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_samples" type="object"
                        class="oe_stat_button" icon="fa-flask">
                    <field name="cf_sample_count" widget="statinfo" string="Campionature"/>
                </button>
                <button name="action_view_partner_emails" type="object"
                        class="oe_stat_button" icon="fa-envelope">
                    <field name="cf_email_count" widget="statinfo" string="Email"/>
                </button>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Export" name="export_info">
                    <group string="Classificazione" name="cf_export">
                        <group>
                            <field name="tag_ids" widget="many2many_tags"
                                options="{'color_field': 'color'}"/>
                            <field name="cf_language"/>
                        </group>
                        <group>
                            <field name="cf_fair_id"/>
                        </group>
                    </group>
                    <group string="Certificazioni" name="cf_certs">
                        <field name="cf_certifications_required" widget="many2many_tags" nolabel="1"
                               options="{'color_field': 'color'}"/>
                    </group>
                </page>
                <page string="Campionature" name="cf_samples">
                    <field name="cf_sample_ids">
                        <list editable="bottom">
                            <field name="reference"/>
                            <field name="stage_id"/>
                            <field name="state"/>
                            <field name="product_ids" widget="many2many_tags"/>
                            <field name="date_sent"/>
                            <field name="tracking_number"/>
                            <field name="feedback_score"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ============================================================
         LIST — eredita dalla nativa
         ============================================================ -->

    <record id="cf_crm_lead_view_list" model="ir.ui.view">
        <field name="name">crm.lead.list.cf</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='stage_id']" position="after">
                <field name="tag_ids" widget="many2many_tags" optional="show"
                    options="{'color_field': 'color'}"/>
                <field name="cf_lead_score" optional="show" string="Score"/>
                <field name="cf_rotting_state" optional="hide" widget="badge"
                       decoration-success="cf_rotting_state == 'ok'"
                       decoration-warning="cf_rotting_state == 'warning'"
                       decoration-danger="cf_rotting_state in ('danger', 'dead')"/>
                <field name="cf_date_next_followup" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
