        <field name="context">{'default_type':'opportunity','default_cf_market':'altri'}</field>
    </record>

    <!-- ============================================================
         KANBAN — custom view
         ============================================================ -->

    <record id="cf_crm_lead_view_kanban" model="ir.ui.view">
        <field name="name">crm.lead.kanban.cf</field>
        <field name="model">crm.lead</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" quick_create="false"
                    class="o_kanban_small_column o_opportunity_kanban">
                <field name="stage_id"/>
                <field name="partner_id"/>
                <field name="expected_revenue"/>
                <field name="cf_lead_score"/>
                <field name="cf_rotting_state"/>
                <field name="cf_market"/>
                <field name="cf_channel"/>
                <field name="cf_date_next_followup"/>
                <field name="user_id"/>
                <field name="priority"/>
                <field name="activity_state"/>
                <field name="color"/>
                <progressbar field="activity_state"
                    colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="cf-crm-card card-rotting-#{record.cf_rotting_state.raw_value or 'ok'}">
                            <div class="cf-card-header">
                                <div class="cf-card-title">
                                    <field name="name"/>
                                </div>
                                <div t-attf-class="cf-score-badge #{record.cf_lead_score.raw_value >= 60 ? 'score-high' : record.cf_lead_score.raw_value >= 30 ? 'score-medium' : 'score-low'}">
                                    <t t-out="record.cf_lead_score.raw_value"/>
                                </div>
                            </div>
                            <div class="cf-card-partner">
                                <field name="partner_id"/>
                            </div>
                            <div class="cf-card-meta">
                                <span class="cf-card-value">
                                    <field name="expected_revenue" widget="monetary"/>
                                </span>
                                <span t-attf-class="cf-rotting-dot dot-#{record.cf_rotting_state.raw_value or 'ok'}"/>
                            </div>
                            <div class="cf-card-meta" t-if="record.cf_channel.raw_value">
                                <span t-attf-class="cf-channel-badge channel-#{record.cf_channel.raw_value}">
                                    <field name="cf_channel"/>
                                </span>
                            </div>
                            <div class="cf-card-followup" t-if="record.cf_date_next_followup.raw_value">
                                Follow-up: <field name="cf_date_next_followup"/>
                            </div>
                            <div class="cf-card-actions">
                                <button class="btn-cf-action" name="action_mark_contacted" type="object"
                                        title="Segna Contattato">✅ Contatto</button>
                                <button class="btn-cf-action" name="action_schedule_followup" type="object"
                                        title="Follow-up +7gg">📅 +7gg</button>
                            </div>
                            <div class="d-flex justify-content-end mt-1">
                                <field name="user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         PREMIUM FORM — standalone (NOT inherited)
         ============================================================ -->

    <record id="cf_crm_lead_view_form_premium" model="ir.ui.view">
        <field name="name">crm.lead.form.cf.premium</field>
        <field name="model">crm.lead</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Trattativa Export" class="cf-premium-form">
                <header>
                    <button name="action_mark_contacted" string="Contatto Registrato"
                        type="object" class="btn-primary"/>
                    <button name="action_schedule_followup" string="Follow-up +7gg"
                        type="object" class="btn-secondary"/>
                    <field name="stage_id" widget="statusbar"
                        options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <!-- SMART BUTTONS -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_partner_emails" type="object"
                            class="oe_stat_button" icon="fa-envelope">
                            <field name="cf_email_count" widget="statinfo" string="Email"/>
                        </button>
                        <button name="action_view_samples" type="object"
                            class="oe_stat_button" icon="fa-flask">
                            <field name="cf_sample_count" widget="statinfo" string="Campionature"/>
                        </button>
                    </div>

                    <!-- KPI BANNER -->
                    <div class="cf-kpi-banner">
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value cf-kpi-score">
                                <field name="cf_lead_score"/>
                            </div>
                            <div class="cf-kpi-label">SCORE</div>
                        </div>
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value">
                                <field name="cf_forecast_value" widget="monetary"/>
                            </div>
                            <div class="cf-kpi-label">FORECAST</div>
                        </div>
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value">
                                <field name="cf_rotting_state" widget="badge"
                                    decoration-success="cf_rotting_state == 'ok'"
                                    decoration-warning="cf_rotting_state == 'warning'"
                                    decoration-danger="cf_rotting_state in ('danger','dead')"/>
                            </div>
                            <div class="cf-kpi-label">STATO</div>
                        </div>
                        <div class="cf-kpi-item">
                            <div class="cf-kpi-value">
                                <field name="cf_days_in_stage"/>
                                <span class="cf-kpi-unit">gg</span>
                            </div>
                            <div class="cf-kpi-label">IN FASE</div>
                        </div>
                    </div>

                    <!-- CONTACT CARD -->
                    <div class="cf-contact-card">
                        <div class="cf-contact-left">
                            <div class="cf-avatar">
                                <field name="cf_partner_image" widget="image"
                                    options="{'size': [64, 64]}"/>
                            </div>
                            <div class="cf-contact-text">
                                <div class="cf-deal-name">
                                    <field name="name" placeholder="Nome trattativa..."/>
                                </div>
                                <div class="cf-company-name">
                                    <field name="partner_id" placeholder="Azienda/Contatto"/>
                                </div>
                                <div class="cf-contact-meta">
                                    <span invisible="not email_from">
                                        <i class="fa fa-envelope-o"/> <field name="email_from" widget="email"/>
                                    </span>
                                    <span invisible="not phone">
                                        <i class="fa fa-phone"/> <field name="phone" widget="phone"/>
                                    </span>
                                    <span invisible="not cf_partner_country">
                                        <i class="fa fa-globe"/> <field name="cf_partner_country"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="cf-contact-right">
                            <div class="cf-action-buttons">
                                <button name="action_send_email" type="object"
                                    class="cf-action-btn" title="Invia Email"
                                    invisible="not partner_id">
                                    <i class="fa fa-envelope"/>
                                </button>
                                <button name="action_schedule_followup" type="object"
                                    class="cf-action-btn" title="Pianifica Follow-up">
                                    <i class="fa fa-calendar-plus-o"/>
                                </button>
                                <button name="action_mark_contacted" type="object"
                                    class="cf-action-btn" title="Segna Contattato">
                                    <i class="fa fa-check"/>
                                </button>
                            </div>
                            <div class="cf-priority-user">
                                <field name="priority" widget="priority"/>
                                <field name="user_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </div>

                    <!-- 2-COLUMN LAYOUT -->
                    <div class="row cf-layout">

                        <!-- LEFT: TABS -->
                        <div class="col-lg-8 cf-main-col">
                            <notebook>
                                <!-- Tab: Attività -->
                                <page string="Attività" name="activities">
                                    <field name="activity_ids"/>
                                </page>

                                <!-- Tab: Email -->
                                <page string="Email" name="emails">
                                    <div class="o_row mb-3">
                                        <button name="action_send_email" type="object"
                                            string="Scrivi Email" class="btn btn-primary btn-sm"
                                            invisible="not partner_id"/>
                                    </div>
                                    <field name="cf_partner_email_ids" readonly="1" nolabel="1">
                                        <list decoration-muted="message_type == 'notification'">
                                            <field name="date" string="Data"/>
                                            <field name="subject" string="Oggetto"/>
                                            <field name="email_from" string="Da"/>
                                        </list>
                                    </field>
                                </page>

                                <!-- Tab: Dettagli -->
                                <page string="Dettagli" name="export_details">
                                    <group>
                                        <group string="Mercato">
                                            <field name="cf_market"/>
                                            <field name="cf_channel"/>
                                            <field name="cf_language"/>
                                            <field name="cf_fair_id"/>
                                        </group>
                                        <group string="Commerciale">
                                            <field name="tag_ids" widget="many2many_tags"
                                                options="{'color_field': 'color'}"/>
                                            <field name="cf_certifications_required"
                                                widget="many2many_tags"/>
                                        </group>
                                    </group>
                                </page>

                                <!-- Tab: Campionature -->
                                <page string="Campionature" name="samples">
                                    <div class="o_row mb-3">
                                        <button name="action_create_sample" type="object"
                                            string="+ Nuova Campionatura"
                                            class="btn btn-primary btn-sm"/>
                                    </div>
                                    <field name="cf_sample_ids">
                                        <list editable="bottom">
                                            <field name="reference" readonly="1"/>
                                            <field name="product_ids" widget="many2many_tags"/>
                                            <field name="stage_id"/>
                                            <field name="state" widget="badge"/>
                                            <field name="date_sent"/>
                                            <field name="tracking_number"/>
                                            <field name="feedback_score"/>
                                        </list>
                                    </field>
                                </page>

                                <!-- Tab: Note -->
                                <page string="Note" name="notes">
                                    <field name="description" placeholder="Note sulla trattativa..."/>
                                </page>
                            </notebook>
                        </div>

                        <!-- RIGHT: SIDEBAR -->
                        <div class="col-lg-4 cf-sidebar-col">
                            <!-- Deal Info -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Informazioni Deal</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Ricavi previsti</span>
                                    <span class="cf-prop-value"><field name="expected_revenue"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Probabilità</span>
                                    <span class="cf-prop-value"><field name="probability"/>%</span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Forecast</span>
                                    <span class="cf-prop-value"><field name="cf_forecast_value" widget="monetary"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Chiusura prevista</span>
                                    <span class="cf-prop-value"><field name="date_deadline"/></span>
                                </div>
                            </div>

                            <!-- Scoring -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Scoring</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Lead Score</span>
                                    <span class="cf-prop-value"><field name="cf_lead_score" widget="progressbar"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Stato</span>
                                    <span class="cf-prop-value"><field name="cf_rotting_state" widget="badge"
                                        decoration-success="cf_rotting_state == 'ok'"
                                        decoration-warning="cf_rotting_state == 'warning'"
                                        decoration-danger="cf_rotting_state in ('danger','dead')"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Ultimo aggiornamento</span>
                                    <span class="cf-prop-value"><field name="cf_rotting_days_display"/></span>
                                </div>
                            </div>

                            <!-- Follow-up -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Follow-up</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Ultimo contatto</span>
                                    <span class="cf-prop-value"><field name="cf_date_last_contact"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Prossimo</span>
                                    <span class="cf-prop-value"><field name="cf_date_next_followup"/></span>
                                </div>
                                <div class="cf-prop-row" invisible="not cf_next_activity_summary">
                                    <span class="cf-prop-label">Prossima attività</span>
                                    <span class="cf-prop-value"><field name="cf_next_activity_summary"/></span>
                                </div>
                            </div>

                            <!-- Contatto -->
                            <div class="cf-prop-card">
                                <div class="cf-prop-title">Contatto</div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Email</span>
                                    <span class="cf-prop-value"><field name="email_from" widget="email"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Telefono</span>
                                    <span class="cf-prop-value"><field name="phone" widget="phone"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Paese</span>
                                    <span class="cf-prop-value"><field name="cf_partner_country"/></span>
                                </div>
                                <div class="cf-prop-row">
                                    <span class="cf-prop-label">Lingua</span>
                                    <span class="cf-prop-value"><field name="cf_language"/></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================================
