<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Legacy Mail Hub lead tab referenced cf_mail_history_ids, a removed field.
         Disable by search so fresh databases do not try to recreate the view. -->
    <function model="ir.ui.view" name="write">
        <value model="ir.ui.view" search="[('name', '=', 'crm.lead.form.cf.premium.mail.hub')]"/>
        <value eval="{'active': False}"/>
    </function>

</odoo>
