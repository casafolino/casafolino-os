<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- S2: Disable casafolino_project form inherit on project.project.
         casafolino_crm_export is the sole owner of the dossier form.
         The model fields from casafolino_project remain active; only the
         form view inherit is deactivated to avoid xpath conflicts. -->
    <record id="casafolino_project.cf_project_form" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <!-- S2: Disable casafolino_initiative form inherit on project.project.
         The initiative_id field remains on project.project (via model inherit);
         only the form tab injection is deactivated. -->
    <record id="casafolino_initiative.view_project_form_initiative" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

</odoo>
