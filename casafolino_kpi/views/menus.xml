<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_cf_kpi_dashboard" model="ir.actions.client">
        <field name="name">KPI Dashboard</field>
        <field name="tag">cf_kpi_dashboard</field>
    </record>
    <record id="action_cf_kpi" model="ir.actions.act_window">
        <field name="name">Snapshots KPI</field>
        <field name="res_model">cf.kpi.snapshot</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_cf_kpi_root" name="KPI" sequence="10"
        web_icon="casafolino_kpi,static/description/icon.png"/>
    <menuitem id="menu_cf_kpi_dashboard" name="Dashboard" parent="menu_cf_kpi_root"
        action="action_cf_kpi_dashboard" sequence="0"/>
    <menuitem id="menu_cf_kpi_snapshots" name="Snapshots" parent="menu_cf_kpi_root"
        action="action_cf_kpi" sequence="1"/>
</odoo>
