<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record rules permissive (OR) per group_console_api. Necessarie perché il portal
         di default vede solo i propri record (mail "caselle proprie", partner "proprio").
         Non concedono unlink (nessun perm_unlink). -->

    <!-- Mail: legge TUTTE le caselle. Solo lettura (la write triage passa dal gateway sudo). -->
    <record id="rule_console_api_mail_read" model="ir.rule">
        <field name="name">Console API: lettura tutte le mail</field>
        <field name="model_id" ref="casafolino_mail.model_casafolino_mail_message"/>
        <field name="groups" eval="[(4, ref('casafolino_console_access.group_console_api'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Lead: vede/scrive/crea tutti. -->
    <record id="rule_console_api_lead" model="ir.rule">
        <field name="name">Console API: tutti i lead (read/write/create)</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="groups" eval="[(4, ref('casafolino_console_access.group_console_api'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Partner: supera la rule portal "solo il proprio commercial partner". -->
    <record id="rule_console_api_partner" model="ir.rule">
        <field name="name">Console API: tutti i partner (read/write/create)</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="groups" eval="[(4, ref('casafolino_console_access.group_console_api'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
