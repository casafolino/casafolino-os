<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- RETAILER — KANBAN -->
    <record id="view_cf_gdo_retailer_kanban" model="ir.ui.view">
        <field name="name">cf.gdo.retailer.kanban</field>
        <field name="model">cf.gdo.retailer</field>
        <field name="arch" type="xml">
            <kanban quick_create="false">
                <field name="partner_id"/>
                <field name="retailer_type"/>
                <field name="country_id"/>
                <field name="num_stores"/>
                <field name="annual_target"/>
                <field name="listing_ids"/>
                <templates>
                    <t t-name="card">
                        <div class="cf-crm-card card-rotting-ok">
                            <div class="cf-card-header">
                                <span class="cf-card-title"><field name="partner_id"/></span>
                                <span class="badge bg-secondary" style="font-size:10px;">
                                    <field name="retailer_type"/>
                                </span>
                            </div>
                            <div class="cf-card-partner">
                                🌍 <field name="country_id"/> · <field name="num_stores"/> pdv
                            </div>
                            <div class="cf-card-meta">
                                <span class="fw-bold"><field name="annual_target" widget="monetary"/></span>
                                <span class="badge bg-info" style="font-size:10px;">
                                    <t t-esc="record.listing_ids.raw_value ? record.listing_ids.raw_value.length : 0"/> listing
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_cf_gdo_retailer_form" model="ir.ui.view">
        <field name="name">cf.gdo.retailer.form</field>
        <field name="model">cf.gdo.retailer</field>
        <field name="arch" type="xml">
            <form string="Retailer GDO">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="partner_id"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="retailer_type"/>
                            <field name="country_id"/>
                            <field name="num_stores"/>
                            <field name="buyer_id"/>
                        </group>
                        <group>
                            <field name="annual_target"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Listing Prodotti">
                            <field name="listing_ids">
                                <list editable="bottom"
                                      decoration-success="listing_status == 'active'"
                                      decoration-warning="listing_status == 'expiring'"
                                      decoration-danger="listing_status == 'expired'"
                                      decoration-muted="listing_status == 'inactive'">
                                    <field name="product_id"/>
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'active'"
                                        decoration-info="state in ('sample','evaluation')"
                                        decoration-muted="state in ('draft','delisted')"/>
                                    <field name="date_submission"/>
                                    <field name="date_approval"/>
                                    <field name="date_expiry"/>
                                    <field name="selling_price"/>
                                    <field name="num_stores"/>
                                    <field name="listing_status" widget="badge"
                                        decoration-success="listing_status == 'active'"
                                        decoration-warning="listing_status == 'expiring'"
                                        decoration-danger="listing_status == 'expired'"
                                        optional="show"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <field name="notes" placeholder="Note..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="view_cf_gdo_retailer_list" model="ir.ui.view">
        <field name="name">cf.gdo.retailer.list</field>
        <field name="model">cf.gdo.retailer</field>
        <field name="arch" type="xml">
            <list string="Retailer GDO">
                <field name="partner_id"/>
                <field name="retailer_type"/>
                <field name="country_id"/>
                <field name="num_stores"/>
                <field name="annual_target"/>
                <field name="buyer_id"/>
            </list>
        </field>
    </record>
</odoo>
