<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cf_shipment_list" model="ir.ui.view">
        <field name="name">cf.project.shipment.list</field>
        <field name="model">cf.project.shipment</field>
        <field name="arch" type="xml">
            <list string="Spedizioni">
                <field name="project_id"/>
                <field name="partner_id"/>
                <field name="state" widget="badge"/>
                <field name="carrier"/>
                <field name="tracking_number"/>
                <field name="ship_date"/>
                <field name="estimated_delivery"/>
                <field name="product_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="cf_shipment_form" model="ir.ui.view">
        <field name="name">cf.project.shipment.form</field>
        <field name="model">cf.project.shipment</field>
        <field name="arch" type="xml">
            <form string="Spedizione Campioni">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,ready,shipped,delivered,feedback"/>
                </header>
                <sheet>
                    <group>
                        <group string="Spedizione">
                            <field name="project_id"/>
                            <field name="partner_id"/>
                            <field name="carrier"/>
                            <field name="tracking_number"/>
                            <field name="tracking_url" widget="url"/>
                        </group>
                        <group string="Date">
                            <field name="ship_date"/>
                            <field name="estimated_delivery"/>
                            <field name="actual_delivery"/>
                            <field name="weight"/>
                            <field name="shipping_cost"/>
                        </group>
                    </group>
                    <separator string="Prodotti Campionati"/>
                    <field name="product_ids" widget="many2many_tags"/>
                    <separator string="Note"/>
                    <field name="notes"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_cf_shipment" model="ir.actions.act_window">
        <field name="name">Spedizioni</field>
        <field name="res_model">cf.project.shipment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
