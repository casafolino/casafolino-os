<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════
         SEARCH VIEW (inherit — aggiunge filtri CF)
         ══════════════════════════════════════════════════════════════ -->

    <record id="cf_project_search" model="ir.ui.view">
        <field name="name">project.project.search.cf</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_project_filter"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="cf_my_projects" string="I Miei Progetti"
                        domain="[('user_id', '=', uid)]"/>
                <filter name="cf_blocked" string="Bloccati"
                        domain="[('cf_main_blocker', '!=', 'none')]"/>
                <filter name="cf_late" string="In Ritardo"
                        domain="[('cf_traffic_light', '=', 'red')]"/>
                <separator/>
                <filter name="cf_group_type" string="Tipo Progetto"
                        context="{'group_by': 'cf_project_type'}"/>
                <filter name="cf_group_partner" string="Cliente"
                        context="{'group_by': 'cf_partner_id'}"/>
                <filter name="cf_group_traffic" string="Semaforo"
                        context="{'group_by': 'cf_traffic_light'}"/>
            </xpath>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════
         FORM VIEW (inherit — estende il form nativo project)
         ══════════════════════════════════════════════════════════════ -->

    <record id="cf_project_form" model="ir.ui.view">
        <field name="name">project.project.form.cf</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">

            <!-- Smart buttons nel button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-circle"
                        style="pointer-events: none;"
                        invisible="not cf_project_type">
                    <field name="cf_traffic_light" widget="badge"
                           decoration-success="cf_traffic_light == 'green'"
                           decoration-warning="cf_traffic_light == 'yellow'"
                           decoration-danger="cf_traffic_light == 'red'"/>
                </button>
                <button class="oe_stat_button" icon="fa-folder"
                        invisible="cf_project_type != 'fair_prep'">
                    <field name="cf_child_count" string="Sotto-progetti" widget="statinfo"/>
                </button>
            </xpath>

            <!-- Campi CasaFolino PRIMA dei campi nativi (label_tasks) -->
            <xpath expr="//field[@name='label_tasks']" position="before">
                <div style="margin-bottom: 20px; padding: 0 16px;">
                    <!-- Campi principali -->
                    <group col="2">
                        <group string="CasaFolino">
                            <field name="cf_template_id"/>
                            <field name="cf_project_type" widget="selection"/>
                            <field name="cf_target_date"/>
                        </group>
                        <group string="Partner Collegato">
                            <field name="cf_partner_id"/>
                            <field name="cf_partner_country_id"/>
                            <field name="cf_partner_email" widget="email"/>
                        </group>
                    </group>

                    <!-- Progetto padre fiera -->
                    <group col="2" invisible="cf_project_type not in ('sample_fair', 'sample_client')">
                        <group>
                            <field name="cf_parent_project_id"/>
                        </group>
                        <group/>
                    </group>

                    <!-- Metric cards -->
                    <div style="display: flex; gap: 16px; margin: 16px 0; padding: 0;"
                         invisible="not cf_project_type">
                        <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 12px 14px; border: 1px solid #e9ecef;">
                            <div style="font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 4px;">Avanzamento</div>
                            <div style="font-size: 20px; font-weight: 500;">
                                <field name="cf_progress"/>%
                            </div>
                        </div>
                        <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 12px 14px; border: 1px solid #e9ecef;">
                            <div style="font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 4px;">Task</div>
                            <div style="font-size: 20px; font-weight: 500;">
                                <field name="cf_tasks_done"/>/<field name="cf_tasks_total"/>
                            </div>
                            <div style="font-size: 11px; color: #999;">
                                <field name="cf_tasks_blocked"/> bloccate
                            </div>
                        </div>
                        <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 12px 14px; border: 1px solid #e9ecef;">
                            <div style="font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 4px;">Giorni aperti</div>
                            <div style="font-size: 20px; font-weight: 500;">
                                <field name="cf_days_open"/>
                            </div>
                        </div>
                        <div style="flex: 1; background: #f8f9fa; border-radius: 8px; padding: 12px 14px; border: 1px solid #e9ecef;">
                            <div style="font-size: 11px; color: #666; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 4px;">Bloccato da</div>
                            <div style="font-size: 14px; font-weight: 500; margin-top: 4px;">
                                <field name="cf_main_blocker"/>
                            </div>
                        </div>
                    </div>

                    <!-- FAIR DASHBOARD -->
                    <div invisible="cf_project_type != 'fair_prep'"
                         style="margin-top: 24px; border-top: 2px solid #0d6efd; padding-top: 16px;">

                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                            <h4 style="margin: 0; color: #0d6efd; font-size: 16px;">Dashboard Monitoraggio Fiera</h4>
                        </div>

                        <!-- Info base -->
                        <group col="2" string="Date e Sede">
                            <group>
                                <field name="cf_fair_start_date"/>
                                <field name="cf_fair_end_date"/>
                            </group>
                            <group>
                                <field name="cf_fair_location"/>
                                <field name="cf_fair_booth"/>
                            </group>
                        </group>

                        <!-- Progress fiera -->
                        <div style="margin: 8px 0 16px 0;">
                            <div style="font-size: 11px; color: #666; margin-bottom: 4px;">Completamento dashboard fiera</div>
                            <field name="cf_fair_completion" widget="progressbar"/>
                        </div>

                        <!-- Alert temporali -->
                        <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 12px 16px; margin: 12px 0;"
                             invisible="not cf_fair_start_date">
                            <div style="font-size: 12px; font-weight: 600; color: #664d03; margin-bottom: 6px;">
                                ALERT AUTOMATICI
                            </div>
                            <div style="display: flex; gap: 24px; font-size: 12px;">
                                <span><field name="cf_alert_90_sent" widget="boolean_toggle" readonly="1"/> -90 gg</span>
                                <span><field name="cf_alert_60_sent" widget="boolean_toggle" readonly="1"/> -60 gg</span>
                                <span><field name="cf_alert_30_sent" widget="boolean_toggle" readonly="1"/> -30 gg</span>
                                <span><field name="cf_alert_7_sent" widget="boolean_toggle" readonly="1"/> -7 gg</span>
                            </div>
                        </div>

                        <!-- Buyer Program -->
                        <group string="Buyer Program e Networking" col="2">
                            <group>
                                <field name="cf_buyer_program_contacted" widget="boolean_toggle"/>
                                <field name="cf_matchmaking_open" widget="boolean_toggle"/>
                                <field name="cf_matchmaking_url" widget="url"/>
                            </group>
                            <group>
                                <field name="cf_matchmaking_notes" placeholder="Note appuntamenti, nomi buyer confermati..."/>
                            </group>
                        </group>

                        <!-- Concorsi -->
                        <group string="Concorsi e Campionatura Giuria" col="2">
                            <group>
                                <field name="cf_contest_checked" widget="boolean_toggle"/>
                                <field name="cf_contest_deadline"/>
                                <field name="cf_contest_samples_sent" widget="boolean_toggle"/>
                                <field name="cf_contest_samples_tracking"/>
                            </group>
                            <group>
                                <field name="cf_contest_requirements" placeholder="Requisiti prodotto, formato, etichette..."/>
                            </group>
                        </group>

                        <!-- Campionatura stand -->
                        <group string="Ordine Campionatura Stand" col="2">
                            <group>
                                <field name="cf_stand_samples_ordered" widget="boolean_toggle"/>
                                <field name="cf_stand_samples_date"/>
                            </group>
                            <group>
                                <field name="cf_stand_samples_notes" placeholder="Prodotti, quantita, formato espositivo..."/>
                            </group>
                        </group>

                        <!-- Grafica -->
                        <group string="Allestimento e Grafica" col="2">
                            <group>
                                <field name="cf_graphics_reviewed" widget="boolean_toggle"/>
                                <field name="cf_catalogue_digital" widget="boolean_toggle"/>
                                <field name="cf_catalogue_print_qty"/>
                                <field name="cf_catalogue_print_done" widget="boolean_toggle"/>
                            </group>
                        </group>

                        <!-- Social -->
                        <group string="Comunicazione e Social LinkedIn" col="2">
                            <group>
                                <field name="cf_linkedin_savedate" widget="boolean_toggle"/>
                                <field name="cf_linkedin_stand" widget="boolean_toggle"/>
                            </group>
                            <group>
                                <field name="cf_linkedin_notes" placeholder="Piano editoriale: date post, immagini, testi..."/>
                            </group>
                        </group>

                        <!-- Checklist ultima settimana -->
                        <div style="background: #f8d7da; border: 1px solid #f5c2c7; border-radius: 8px; padding: 12px 16px; margin: 12px 0;">
                            <div style="font-size: 12px; font-weight: 600; color: #842029; margin-bottom: 8px;">
                                CHECKLIST ULTIMA SETTIMANA (-7 giorni)
                            </div>
                            <group col="2">
                                <group>
                                    <field name="cf_badges_downloaded" widget="boolean_toggle"/>
                                    <field name="cf_delivery_confirmed" widget="boolean_toggle"/>
                                </group>
                                <group>
                                    <field name="cf_delivery_notes" placeholder="Orari scarico, rampa, referente magazzino fiera..."/>
                                </group>
                            </group>
                        </div>

                        <!-- Note e contatti -->
                        <group string="Note e Contatti Utili" col="1">
                            <field name="cf_fair_contacts" placeholder="Numeri utili: referente ICE, ufficio fiera, agente locale, hotel..."/>
                            <field name="cf_post_fair_notes" placeholder="Note post-fiera: lead raccolti, feedback, follow-up da fare..."/>
                        </group>
                    </div>
                </div>
            </xpath>

            <!-- Smart button fiera -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-check-square-o"
                        invisible="cf_project_type != 'fair_prep'">
                    <div class="o_field_widget o_stat_info">
                        <field name="cf_fair_completion" widget="float_factor"/>
                        <span class="o_stat_text">% Fiera</span>
                    </div>
                </button>
            </xpath>

            <!-- Tab aggiuntivi nel notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Spedizioni" name="cf_shipments"
                      invisible="cf_project_type not in ('sample_fair', 'sample_client', 'custom_label')">
                    <field name="cf_shipment_ids" mode="list">
                        <list editable="bottom">
                            <field name="state" widget="badge"
                                   decoration-info="state == 'shipped'"
                                   decoration-success="state in ('delivered', 'feedback')"
                                   decoration-warning="state == 'ready'"
                                   decoration-muted="state == 'draft'"/>
                            <field name="carrier"/>
                            <field name="tracking_number"/>
                            <field name="ship_date"/>
                            <field name="estimated_delivery"/>
                            <field name="product_ids" widget="many2many_tags"/>
                        </list>
                    </field>
                </page>
                <page string="Sotto-progetti" name="cf_children"
                      invisible="cf_project_type != 'fair_prep'">
                    <field name="cf_child_project_ids">
                        <list>
                            <field name="name"/>
                            <field name="cf_project_type" widget="badge"/>
                            <field name="cf_partner_id"/>
                            <field name="cf_progress" widget="progressbar"/>
                            <field name="cf_traffic_light" widget="badge"
                                   decoration-success="cf_traffic_light == 'green'"
                                   decoration-warning="cf_traffic_light == 'yellow'"
                                   decoration-danger="cf_traffic_light == 'red'"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
