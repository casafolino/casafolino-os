<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_cf_project" model="ir.module.category">
        <field name="name">CasaFolino Project</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_cf_project_user" model="res.groups">
        <field name="name">Utente Progetti</field>
        <field name="category_id" ref="module_category_cf_project"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_cf_project_manager" model="res.groups">
        <field name="name">Manager Progetti</field>
        <field name="category_id" ref="module_category_cf_project"/>
        <field name="implied_ids" eval="[(4, ref('group_cf_project_user'))]"/>
    </record>

</odoo>
