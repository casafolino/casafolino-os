<?xml version="1.0" encoding="UTF-8"?>
<templates>
  <t t-name="casafolino_cockpit.CockpitMain">
    <div class="ck-cockpit">
      <t t-if="state.screen === 'regia'">
        <CockpitRegia
          dailyLineEnabled="state.dailyLineEnabled"
          onSelectProject.bind="goToDossier"/>
      </t>
      <t t-if="state.screen === 'dossier'">
        <CockpitDossier
          partnerId="state.selectedPartnerId"
          expandedInitiativeId="state.selectedInitiativeId"
          onBack.bind="goToRegia"/>
      </t>
    </div>
  </t>
</templates>
