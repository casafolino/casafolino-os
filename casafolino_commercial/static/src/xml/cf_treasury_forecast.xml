<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
<t t-name="casafolino_treasury.CfTreasuryForecast">
<div class="cf-forecast o_action" style="background:#f0f2f5;min-height:100vh;font-family:system-ui,sans-serif;">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between px-4 py-3"
         style="background:#1a1f2e;color:#fff;box-shadow:0 2px 8px rgba(0,0,0,.3);">
        <div class="d-flex align-items-center gap-3">
            <span style="font-size:20px;">&#128202;</span>
            <h4 class="mb-0 fw-bold" style="font-size:17px;">Forecast &amp; Scenari</h4>
        </div>
        <button class="btn btn-sm" style="background:#2d3348;color:#d1d5db;border:1px solid #3d4560;"
                t-on-click="onRefresh">&#8635; Aggiorna</button>
    </div>

    <t t-if="state.loading">
        <div class="d-flex justify-content-center align-items-center" style="height:300px;">
            <div class="spinner-border" style="color:#5A6E3A;"/>
        </div>
    </t>
    <t t-elif="state.error">
        <div class="alert alert-danger m-4"><t t-esc="state.error"/></div>
    </t>
    <t t-elif="state.data">
    <div class="px-4 py-4">

        <!-- Confronto MoM / YoY / QoQ -->
        <t t-if="state.data.comparison">
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div style="background:#fff;border-radius:10px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#9ca3af;margin-bottom:6px;">
                        Fatturato MTD
                    </div>
                    <div style="font-size:20px;font-weight:800;color:#1a1f2e;">
                        <t t-esc="formatAmount(state.data.comparison.revenue_mtd)"/>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div style="background:#fff;border-radius:10px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#9ca3af;margin-bottom:6px;">
                        vs Mese Prec. (MoM)
                    </div>
                    <div t-attf-class="fw-bold #{deltaClass(state.data.comparison.mom)}" style="font-size:18px;">
                        <t t-esc="deltaArrow(state.data.comparison.mom)"/>
                        <t t-esc="state.data.comparison.mom.pct"/>%
                        <span style="font-size:12px;font-weight:400;">
                            (<t t-esc="formatAmount(state.data.comparison.mom.abs)"/>)
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div style="background:#fff;border-radius:10px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#9ca3af;margin-bottom:6px;">
                        vs Anno Prec. (YoY)
                    </div>
                    <div t-attf-class="fw-bold #{deltaClass(state.data.comparison.yoy)}" style="font-size:18px;">
                        <t t-esc="deltaArrow(state.data.comparison.yoy)"/>
                        <t t-esc="state.data.comparison.yoy.pct"/>%
                        <span style="font-size:12px;font-weight:400;">
                            (<t t-esc="formatAmount(state.data.comparison.yoy.abs)"/>)
                        </span>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div style="background:#fff;border-radius:10px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
                    <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:#9ca3af;margin-bottom:6px;">
                        vs Trimestre Prec. (QoQ)
                    </div>
                    <div t-attf-class="fw-bold #{deltaClass(state.data.comparison.qoq)}" style="font-size:18px;">
                        <t t-esc="deltaArrow(state.data.comparison.qoq)"/>
                        <t t-esc="state.data.comparison.qoq.pct"/>%
                        <span style="font-size:12px;font-weight:400;">
                            (<t t-esc="formatAmount(state.data.comparison.qoq.abs)"/>)
                        </span>
                    </div>
                </div>
            </div>
        </div>
        </t>

        <!-- Parametri scenari -->
        <div style="background:#fff;border-radius:10px;padding:20px 24px;box-shadow:0 1px 4px rgba(0,0,0,.08);margin-bottom:20px;">
            <div style="font-size:13px;font-weight:700;color:#374151;margin-bottom:14px;">
                Parametri Scenari
            </div>
            <div class="row g-3 align-items-end">
                <div class="col-auto">
                    <label style="font-size:11px;color:#6b7280;font-weight:600;">
                        Ottimistico +%
                    </label>
                    <input type="number" class="form-control form-control-sm"
                           style="width:90px;"
                           t-att-value="state.optPct"
                           t-on-change="onOptPctChange"
                           min="0" max="100"/>
                </div>
                <div class="col-auto">
                    <label style="font-size:11px;color:#6b7280;font-weight:600;">
                        Pess. -% incassi
                    </label>
                    <input type="number" class="form-control form-control-sm"
                           style="width:90px;"
                           t-att-value="state.pesPctIn"
                           t-on-change="onPesPctInChange"
                           min="0" max="100"/>
                </div>
                <div class="col-auto">
                    <label style="font-size:11px;color:#6b7280;font-weight:600;">
                        Pess. +% uscite
                    </label>
                    <input type="number" class="form-control form-control-sm"
                           style="width:90px;"
                           t-att-value="state.pesPctOut"
                           t-on-change="onPesPctOutChange"
                           min="0" max="100"/>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary" t-on-click="onApplyScenarios"
                            style="background:#5A6E3A;border:none;margin-top:auto;">
                        Applica
                    </button>
                </div>
                <div class="col-auto ms-auto" style="font-size:12px;color:#9ca3af;">
                    Saldo iniziale:
                    <strong><t t-esc="formatAmount(state.data.base_balance)"/></strong>
                    &nbsp;|&nbsp; Media mensile entrate:
                    <strong><t t-esc="formatAmount(state.data.avg_monthly_inflow)"/></strong>
                    &nbsp;|&nbsp; uscite:
                    <strong><t t-esc="formatAmount(state.data.avg_monthly_outflow)"/></strong>
                </div>
            </div>
        </div>

        <!-- Grafico lineare + tavola scenari -->
        <div class="row g-3 mb-4">
            <div class="col-lg-8">
                <div style="background:#fff;border-radius:10px;padding:20px 24px;box-shadow:0 1px 4px rgba(0,0,0,.08);">
                    <div style="font-size:13px;font-weight:700;color:#374151;margin-bottom:14px;">
                        Proiezione Saldo 3 Mesi
                    </div>
                    <div style="position:relative;height:260px;">
                        <canvas t-ref="forecastChart"/>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div style="background:#fff;border-radius:10px;padding:20px 24px;box-shadow:0 1px 4px rgba(0,0,0,.08);height:100%;">
                    <div style="font-size:13px;font-weight:700;color:#374151;margin-bottom:14px;">
                        Saldo Previsto
                    </div>
                    <!-- Tabella 30/60/90 x 3 scenari -->
                    <table class="table table-sm mb-0" style="font-size:12px;">
                        <thead>
                            <tr style="color:#9ca3af;">
                                <th></th>
                                <th>30gg</th>
                                <th>60gg</th>
                                <th>90gg</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="color:#22c55e;font-weight:700;">Ott.</td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['30d'].opt)"/></td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['60d'].opt)"/></td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['90d'].opt)"/></td>
                            </tr>
                            <tr>
                                <td style="color:#3b82f6;font-weight:700;">Base</td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['30d'].base)"/></td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['60d'].base)"/></td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['90d'].base)"/></td>
                            </tr>
                            <tr>
                                <td style="color:#ef4444;font-weight:700;">Pess.</td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['30d'].pes)"/></td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['60d'].pes)"/></td>
                                <td class="fw-bold"><t t-esc="formatAmount(state.data.scenarios['90d'].pes)"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
    </t>
</div>
</t>
</templates>
