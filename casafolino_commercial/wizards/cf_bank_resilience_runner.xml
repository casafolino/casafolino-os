<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_cf_bank_resilience_runner_form" model="ir.ui.view">
        <field name="name">cf.bank.resilience.runner.form</field>
        <field name="model">cf.bank.resilience.runner</field>
        <field name="arch" type="xml">
            <form string="Bonifica Conti Bancari Archiviati">
                <group>
                    <div class="alert alert-info" role="alert">
                        Questo strumento risolve automaticamente le fatture bloccate
                        da conti bancari archiviati: riassegna a un bank attivo con
                        stesso IBAN, oppure riattiva il bank archiviato.
                    </div>
                </group>
                <group>
                    <field name="result_text" widget="text" invisible="not result_text"/>
                </group>
                <footer>
                    <button name="action_run" string="Esegui bonifica completa"
                            type="object" class="btn btn-primary"/>
                    <button name="action_dry_run" string="Esegui solo dry-run"
                            type="object" class="btn btn-secondary"/>
                    <button string="Chiudi" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cf_bank_resilience_runner" model="ir.actions.act_window">
        <field name="name">Bonifica Conti Bancari Archiviati</field>
        <field name="res_model">cf.bank.resilience.runner</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_cf_tools_root"
              name="Strumenti CasaFolino"
              parent="account.menu_finance_configuration"
              sequence="99"/>

    <menuitem id="menu_cf_bank_resilience"
              name="Bonifica conti bancari archiviati"
              parent="menu_cf_tools_root"
              action="action_cf_bank_resilience_runner"
              sequence="10"/>

</odoo>
