<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_discount_wizard_form" model="ir.ui.view">
        <field name="name">sale.discount.wizard.form</field>
        <field name="model">sale.discount.wizard</field>
        <field name="arch" type="xml">
            <form string="Applica Sconto Massivo">
                <group>
                    <field name="discount" widget="percentage"/>
                    <field name="order_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_apply" string="Applica a tutte le righe" type="object" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
