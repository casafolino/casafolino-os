<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_invoice_footer_blocks"
              inherit_id="account.report_invoice_document"
              priority="20">
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-if="o.footer_block_ids">
                <div style="margin-top:20px; border-top:2px solid #6B4A1E; padding-top:12px;">
                    <t t-foreach="o.footer_block_ids.sorted('sequence')" t-as="block">
                        <div style="margin-bottom:12px;">
                            <strong style="color:#6B4A1E; font-size:10pt;">
                                <t t-esc="block.name"/>
                            </strong>
                            <table style="width:100%; font-size:9pt; margin-top:4px;">
                                <t t-foreach="block.get_display_lines()" t-as="line">
                                    <tr>
                                        <td t-if="line[0]" style="width:30%; color:#888; padding:1px 4px;">
                                            <t t-esc="line[0]"/>
                                        </td>
                                        <td t-if="not line[0]" colspan="2" style="padding:1px 4px;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                        <td t-if="line[0]" style="padding:1px 4px; font-weight:500;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>
    </template>

    <template id="report_saleorder_footer_blocks"
              inherit_id="sale.report_saleorder_document"
              priority="20">
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-if="doc.footer_block_ids">
                <div style="margin-top:20px; border-top:2px solid #6B4A1E; padding-top:12px;">
                    <t t-foreach="doc.footer_block_ids.sorted('sequence')" t-as="block">
                        <div style="margin-bottom:12px;">
                            <strong style="color:#6B4A1E; font-size:10pt;">
                                <t t-esc="block.name"/>
                            </strong>
                            <table style="width:100%; font-size:9pt; margin-top:4px;">
                                <t t-foreach="block.get_display_lines()" t-as="line">
                                    <tr>
                                        <td t-if="line[0]" style="width:30%; color:#888; padding:1px 4px;">
                                            <t t-esc="line[0]"/>
                                        </td>
                                        <td t-if="not line[0]" colspan="2" style="padding:1px 4px;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                        <td t-if="line[0]" style="padding:1px 4px; font-weight:500;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>
    </template>

</odoo>
