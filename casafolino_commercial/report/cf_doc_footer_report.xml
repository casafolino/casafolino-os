<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== PREVENTIVO / ORDINE VENDITA ===== -->
    <template id="report_saleorder_footer_blocks"
              inherit_id="sale.report_saleorder_document"
              priority="20">
        <xpath expr="//div[@name='so_total_summary']" position="after">
            <t t-if="doc.footer_block_ids">
                <div style="margin-top:16px;">
                    <t t-foreach="doc.footer_block_ids.sorted('sequence')" t-as="block">
                        <div style="margin-bottom:10px; break-inside:avoid;">
                            <div style="background:#6B4A1E; color:#fff; padding:4px 10px; font-size:9pt; font-weight:bold; letter-spacing:0.5px;">
                                <t t-esc="block.name"/>
                            </div>
                            <table style="width:100%; border-collapse:collapse;">
                                <t t-foreach="block.get_display_lines()" t-as="line">
                                    <tr style="border-bottom:1px solid #f0ece6;">
                                        <td t-if="line[0]" style="width:35%; padding:4px 10px; font-size:9pt; color:#888; background:#faf8f5;">
                                            <t t-esc="line[0]"/>
                                        </td>
                                        <td t-if="line[0]" style="padding:4px 10px; font-size:9pt; font-weight:600; color:#222;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                        <td t-if="not line[0]" colspan="2" style="padding:4px 10px; font-size:9pt; color:#444; background:#faf8f5;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>
    </template>

    <!-- ===== FATTURA ===== -->
    <template id="report_invoice_footer_blocks"
              inherit_id="account.report_invoice_document"
              priority="20">
        <xpath expr="//div[hasclass('clearfix')]" position="after">
            <t t-if="o.footer_block_ids">
                <div style="margin-top:16px;">
                    <t t-foreach="o.footer_block_ids.sorted('sequence')" t-as="block">
                        <div style="margin-bottom:10px; break-inside:avoid;">
                            <div style="background:#6B4A1E; color:#fff; padding:4px 10px; font-size:9pt; font-weight:bold; letter-spacing:0.5px;">
                                <t t-esc="block.name"/>
                            </div>
                            <table style="width:100%; border-collapse:collapse;">
                                <t t-foreach="block.get_display_lines()" t-as="line">
                                    <tr style="border-bottom:1px solid #f0ece6;">
                                        <td t-if="line[0]" style="width:35%; padding:4px 10px; font-size:9pt; color:#888; background:#faf8f5;">
                                            <t t-esc="line[0]"/>
                                        </td>
                                        <td t-if="line[0]" style="padding:4px 10px; font-size:9pt; font-weight:600; color:#222;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                        <td t-if="not line[0]" colspan="2" style="padding:4px 10px; font-size:9pt; color:#444; background:#faf8f5;">
                                            <t t-esc="line[1]"/>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </div>
            </t>
        </xpath>
    </template>

</odoo>
