<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==== LISTA CASHFLOW ==== -->
    <record id="view_cf_cashflow_list" model="ir.ui.view">
        <field name="name">cf.treasury.cashflow.line.list</field>
        <field name="model">cf.treasury.cashflow.line</field>
        <field name="arch" type="xml">
            <list string="Cashflow"
                  decoration-success="move_type == 'in'"
                  decoration-danger="move_type == 'out'"
                  decoration-muted="move_type == 'forecast'">
                <field name="date" string="Data"/>
                <field name="name" string="Descrizione"/>
                <field name="move_type" string="Tipo" widget="badge"
                       decoration-success="move_type == 'in'"
                       decoration-danger="move_type == 'out'"
                       decoration-info="move_type == 'forecast'"/>
                <field name="amount" string="Importo"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="journal_id" string="Conto" optional="show"/>
                <field name="source" string="Origine" optional="show"/>
                <field name="origin_move_id" string="Fattura" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ==== FORM CASHFLOW ==== -->
    <record id="view_cf_cashflow_form" model="ir.ui.view">
        <field name="name">cf.treasury.cashflow.line.form</field>
        <field name="model">cf.treasury.cashflow.line</field>
        <field name="arch" type="xml">
            <form string="Riga Cashflow">
                <sheet>
                    <group>
                        <group string="Dati">
                            <field name="date"/>
                            <field name="name"/>
                            <field name="move_type"/>
                            <field name="amount"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                        <group string="Dettagli">
                            <field name="journal_id"/>
                            <field name="source" readonly="1"/>
                            <field name="origin_move_id" readonly="source == 'manual'"/>
                        </group>
                    </group>
                    <group string="Note">
                        <field name="note" nolabel="1" placeholder="Note aggiuntive..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==== SEARCH CASHFLOW ==== -->
    <record id="view_cf_cashflow_search" model="ir.ui.view">
        <field name="name">cf.treasury.cashflow.line.search</field>
        <field name="model">cf.treasury.cashflow.line</field>
        <field name="arch" type="xml">
            <search string="Cashflow">
                <field name="name" string="Descrizione"/>
                <field name="journal_id" string="Conto"/>
                <separator/>
                <filter name="f_in" string="Entrate"
                        domain="[('move_type', '=', 'in')]"/>
                <filter name="f_out" string="Uscite"
                        domain="[('move_type', '=', 'out')]"/>
                <filter name="f_forecast" string="Previsioni"
                        domain="[('move_type', '=', 'forecast')]"/>
                <separator/>
                <filter name="f_manual" string="Manuali"
                        domain="[('source', '=', 'manual')]"/>
                <filter name="f_auto" string="Automatiche"
                        domain="[('source', '=', 'auto')]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter name="g_type" string="Tipo"
                            context="{'group_by': 'move_type'}"/>
                    <filter name="g_journal" string="Conto"
                            context="{'group_by': 'journal_id'}"/>
                    <filter name="g_month" string="Mese"
                            context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==== ACTION CASHFLOW ==== -->
    <record id="action_cf_treasury_cashflow" model="ir.actions.act_window">
        <field name="name">Cashflow</field>
        <field name="res_model">cf.treasury.cashflow.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cf_cashflow_search"/>
    </record>

    <!-- ==== ACTION EXPORT CASHFLOW ==== -->
    <record id="action_cf_export_cashflow" model="ir.actions.act_window">
        <field name="name">Esporta Cashflow XLS</field>
        <field name="res_model">cf.treasury.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_section': 'cashflow'}</field>
    </record>

    <!-- ==== CLIENT ACTIONS per OWL ==== -->
    <record id="action_cf_treasury_forecast" model="ir.actions.client">
        <field name="name">Forecast &amp; Scenari</field>
        <field name="tag">cf_treasury_forecast</field>
    </record>

    <record id="action_cf_treasury_clients" model="ir.actions.client">
        <field name="name">Analisi Clienti</field>
        <field name="tag">cf_treasury_clients</field>
    </record>

    <record id="action_cf_treasury_categories" model="ir.actions.client">
        <field name="name">Analisi per Categoria</field>
        <field name="tag">cf_treasury_categories</field>
    </record>
</odoo>
