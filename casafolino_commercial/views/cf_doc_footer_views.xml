<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cf_doc_footer_block_list" model="ir.ui.view">
        <field name="name">cf.doc.footer.block.list</field>
        <field name="model">cf.doc.footer.block</field>
        <field name="arch" type="xml">
            <list string="Blocchi Documento">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="block_type"/>
                <field name="bank_id" optional="show"/>
                <field name="payment_term_id" optional="show"/>
                <field name="active" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_cf_doc_footer_block_form" model="ir.ui.view">
        <field name="name">cf.doc.footer.block.form</field>
        <field name="model">cf.doc.footer.block</field>
        <field name="arch" type="xml">
            <form string="Blocco Documento">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="block_type"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Contenuto">
                        <field name="bank_id"
                               invisible="block_type != 'bank'"/>
                        <field name="payment_term_id"
                               invisible="block_type != 'payment_term'"/>
                        <field name="note"
                               invisible="block_type != 'note'"
                               widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cf_doc_footer_blocks" model="ir.actions.act_window">
        <field name="name">Blocchi Documento</field>
        <field name="res_model">cf.doc.footer.block</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_sale_order_footer_blocks" model="ir.ui.view">
        <field name="name">sale.order.footer.blocks</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Blocchi Documento" name="footer_blocks">
                    <field name="footer_block_ids"
                           widget="many2many_tags"
                           domain="[('active','=',True)]"
                           options="{'no_create': False}"/>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_footer_blocks" model="ir.ui.view">
        <field name="name">account.move.footer.blocks</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Blocchi Documento" name="footer_blocks">
                    <field name="footer_block_ids"
                           widget="many2many_tags"
                           domain="[('active','=',True)]"
                           options="{'no_create': False}"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
