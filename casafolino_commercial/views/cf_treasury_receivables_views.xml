<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==== LISTA CREDITI CLIENTI ==== -->
    <record id="view_cf_recv_list" model="ir.ui.view">
        <field name="name">account.move.line.cf.recv.list</field>
        <field name="model">account.move.line</field>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <list string="Crediti Clienti"
                  decoration-danger="x_treasury_aging_bucket == 'scaduto'"
                  decoration-warning="x_treasury_aging_bucket == '0_30'"
                  decoration-info="x_treasury_aging_bucket == '31_60'">
                <field name="partner_id" string="Cliente"/>
                <field name="move_id" string="Fattura"/>
                <field name="date_maturity" string="Scadenza"/>
                <field name="x_treasury_date_prevista" string="Incasso Previsto" optional="show"/>
                <field name="amount_residual" string="Da Incassare"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="x_treasury_overdue_days" string="gg Scaduto" optional="show"/>
                <field name="x_treasury_aging_bucket" string="Fascia"
                       widget="badge"
                       decoration-danger="x_treasury_aging_bucket == 'scaduto'"
                       decoration-warning="x_treasury_aging_bucket == '0_30'"
                       decoration-info="x_treasury_aging_bucket in ('31_60','61_90')"
                       decoration-muted="x_treasury_aging_bucket == 'oltre_90'"/>
                <field name="x_treasury_stato" string="Stato"
                       widget="badge"
                       decoration-success="x_treasury_stato == 'fatto'"
                       decoration-warning="x_treasury_stato == 'approvato'"
                       decoration-muted="x_treasury_stato == 'da_fare'"/>
            </list>
        </field>
    </record>

    <!-- ==== FORM CREDITI CLIENTI ==== -->
    <record id="view_cf_recv_form" model="ir.ui.view">
        <field name="name">account.move.line.cf.recv.form</field>
        <field name="model">account.move.line</field>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <form string="Credito Cliente">
                <header>
                    <field name="x_treasury_stato" widget="statusbar"
                           statusbar_visible="da_fare,approvato,fatto"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="partner_id" class="oe_edit_only"/>
                        <h1><field name="partner_id" readonly="1"/></h1>
                        <h4>
                            <field name="move_id" readonly="1"/>
                        </h4>
                    </div>
                    <group>
                        <group string="Scadenza">
                            <field name="date_maturity" readonly="1"/>
                            <field name="amount_residual" readonly="1"/>
                            <field name="x_treasury_overdue_days" readonly="1"/>
                            <field name="x_treasury_aging_bucket" readonly="1"/>
                        </group>
                        <group string="Pianificazione">
                            <field name="x_treasury_date_prevista"/>
                            <field name="x_treasury_stato"/>
                        </group>
                    </group>
                    <group string="Note Tesoreria">
                        <field name="x_treasury_note" nolabel="1"
                               placeholder="Annotazioni interne, accordi di pagamento..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==== SEARCH CREDITI ==== -->
    <record id="view_cf_recv_search" model="ir.ui.view">
        <field name="name">account.move.line.cf.recv.search</field>
        <field name="model">account.move.line</field>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <search string="Crediti Clienti">
                <field name="partner_id" string="Cliente"/>
                <field name="move_id" string="Fattura"/>
                <separator/>
                <filter name="f_scaduti" string="Scaduti"
                        domain="[('date_maturity', '&lt;', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="f_future" string="In scadenza"
                        domain="[('date_maturity', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="f_da_fare" string="Da fare"
                        domain="[('x_treasury_stato', '=', 'da_fare')]"/>
                <filter name="f_approvato" string="Approvati"
                        domain="[('x_treasury_stato', '=', 'approvato')]"/>
                <filter name="f_fatto" string="Incassati"
                        domain="[('x_treasury_stato', '=', 'fatto')]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter name="g_partner" string="Cliente"
                            context="{'group_by': 'partner_id'}"/>
                    <filter name="g_stato" string="Stato"
                            context="{'group_by': 'x_treasury_stato'}"/>
                    <filter name="g_month" string="Mese scadenza"
                            context="{'group_by': 'date_maturity:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==== ACTION CREDITI ==== -->
    <record id="action_cf_treasury_receivables" model="ir.actions.act_window">
        <field name="name">Crediti Clienti</field>
        <field name="res_model">account.move.line</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[
            ('account_id.account_type', '=', 'asset_receivable'),
            ('parent_state', '=', 'posted'),
            ('reconciled', '=', False),
        ]</field>
        <field name="view_ids" eval="[
            (5,0,0),
            (0,0,{'view_mode':'list','view_id':ref('view_cf_recv_list')}),
            (0,0,{'view_mode':'form','view_id':ref('view_cf_recv_form')}),
        ]"/>
        <field name="search_view_id" ref="view_cf_recv_search"/>
    </record>

    <!-- ==== ACTION EXPORT CREDITI ==== -->
    <record id="action_cf_export_recv" model="ir.actions.act_window">
        <field name="name">Esporta Crediti XLS</field>
        <field name="res_model">cf.treasury.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_section': 'receivables'}</field>
    </record>
</odoo>
