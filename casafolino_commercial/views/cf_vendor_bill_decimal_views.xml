<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_vendor_bill_line_subtotal_precision" model="ir.ui.view">
        <field name="name">account.move.form.vendor.bill.line.subtotal.precision</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='quantity']" position="after">
                <field name="cf_vendor_bill_quantity_six_decimals"
                       string="Quantita"
                       optional="show"
                       digits="[16, 6]"
                       column_invisible="parent.move_type not in ['in_invoice', 'in_refund']"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='quantity']" position="attributes">
                <attribute name="column_invisible">parent.move_type in ['in_invoice', 'in_refund']</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='price_unit']" position="after">
                <field name="cf_vendor_bill_price_unit_six_decimals"
                       string="Prezzo"
                       optional="show"
                       digits="[16, 6]"
                       column_invisible="parent.move_type not in ['in_invoice', 'in_refund']"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='price_unit']" position="attributes">
                <attribute name="column_invisible">parent.move_type in ['in_invoice', 'in_refund']</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='discount']" position="after">
                <field name="cf_vendor_bill_discount_six_decimals"
                       string="Disc.%"
                       width="50px"
                       optional="show"
                       digits="[16, 6]"
                       column_invisible="parent.move_type not in ['in_invoice', 'in_refund']"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='discount']" position="attributes">
                <attribute name="column_invisible">parent.move_type in ['in_invoice', 'in_refund']</attribute>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='price_subtotal']" position="after">
                <field name="cf_price_subtotal_six_decimals"
                       string="Imponibile"
                       optional="show"
                       digits="[16, 6]"
                       column_invisible="parent.move_type not in ['in_invoice', 'in_refund']"/>
            </xpath>
            <xpath expr="//field[@name='invoice_line_ids']/list//field[@name='price_subtotal']" position="attributes">
                <attribute name="column_invisible">parent.move_type in ['in_invoice', 'in_refund']</attribute>
            </xpath>
        </field>
    </record>
</odoo>
