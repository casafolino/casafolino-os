<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="cf_erp_login_layout" inherit_id="web.login_layout" priority="99">
        <xpath expr="//t[@t-call='website.layout']" position="replace">
            <t t-set="cf_request_host" t-value="request.httprequest.host.split(':')[0] if request and request.httprequest and request.httprequest.host else ''"/>
            <t t-if="cf_request_host == 'erp.casafolino.com'" t-call="web.frontend_layout">
                <t t-set="cf_lang_code" t-value="request.env.lang or 'en_US'"/>
                <t t-set="cf_lang" t-value="'it' if cf_lang_code == 'it_IT' else 'fr' if cf_lang_code == 'fr_FR' else 'es' if cf_lang_code == 'es_ES' else 'de' if cf_lang_code == 'de_DE' else 'en'"/>
                <t t-set="html_data" t-value="{'style': 'height: 100%;'}"/>
                <t t-set="title">Login | CasaFolino ERP</t>
                <t t-set="body_classname" t-value="'cf-erp-login-body'"/>
                <t t-set="no_header" t-value="True"/>
                <t t-set="no_footer" t-value="True"/>

                <main class="cf-erp-login">
                    <section class="cf-erp-login__brand">
                        <div class="cf-erp-login__mark">
                            <img src="/casafolino_home/static/description/icon.png" alt="CasaFolino ERP"/>
                        </div>
                        <p class="cf-erp-login__eyebrow">CasaFolino ERP</p>
                        <h1>
                            <t t-if="cf_lang == 'it'">Gestionale CasaFolino</t>
                            <t t-elif="cf_lang == 'fr'">ERP CasaFolino</t>
                            <t t-elif="cf_lang == 'es'">ERP CasaFolino</t>
                            <t t-elif="cf_lang == 'de'">CasaFolino ERP</t>
                            <t t-else="">CasaFolino ERP</t>
                        </h1>
                        <p class="cf-erp-login__copy">
                            <t t-if="cf_lang == 'it'">Accesso riservato al team CasaFolino per gestire CRM, vendite, produzione, HACCP, magazzino, amministrazione e attivita operative.</t>
                            <t t-elif="cf_lang == 'fr'">Acces reserve a l'equipe CasaFolino pour gerer CRM, ventes, production, HACCP, stock, administration et operations.</t>
                            <t t-elif="cf_lang == 'es'">Acceso reservado al equipo CasaFolino para gestionar CRM, ventas, produccion, HACCP, almacen, administracion y operaciones.</t>
                            <t t-elif="cf_lang == 'de'">Reservierter Zugang fur das CasaFolino Team zur Verwaltung von CRM, Vertrieb, Produktion, HACCP, Lager, Verwaltung und Betrieb.</t>
                            <t t-else="">Reserved access for the CasaFolino team to manage CRM, sales, production, HACCP, inventory, administration and operations.</t>
                        </p>
                        <div class="cf-erp-login__signals" aria-label="ERP areas">
                            <span>CRM</span>
                            <span>Vendite</span>
                            <span>Produzione</span>
                            <span>HACCP</span>
                            <span>Magazzino</span>
                            <span>Amministrazione</span>
                        </div>
                    </section>

                    <section class="cf-erp-login__panel" aria-label="Accesso ERP CasaFolino">
                        <div class="cf-erp-login__panel-header">
                            <p>
                                <t t-if="cf_lang == 'it'">Sistema aziendale riservato</t>
                                <t t-elif="cf_lang == 'fr'">Systeme interne reserve</t>
                                <t t-elif="cf_lang == 'es'">Sistema interno reservado</t>
                                <t t-elif="cf_lang == 'de'">Reserviertes Unternehmenssystem</t>
                                <t t-else="">Reserved company system</t>
                            </p>
                            <h2>
                                <t t-if="cf_lang == 'it'">Accedi all'ERP</t>
                                <t t-elif="cf_lang == 'fr'">Acceder a l'ERP</t>
                                <t t-elif="cf_lang == 'es'">Accede al ERP</t>
                                <t t-elif="cf_lang == 'de'">Beim ERP anmelden</t>
                                <t t-else="">Sign in to ERP</t>
                            </h2>
                        </div>
                        <div class="cf-erp-login__form">
                            <t t-out="0"/>
                        </div>
                    </section>
                </main>
            </t>
            <t t-else="" t-call="website.layout">
                <t t-out="0"/>
            </t>
        </xpath>
    </template>

    <template id="cf_erp_login_form" inherit_id="web.login" priority="99">
        <xpath expr="//form[@role='form']" position="before">
            <t t-set="cf_request_host" t-value="request.httprequest.host.split(':')[0] if request and request.httprequest and request.httprequest.host else ''"/>
            <div t-if="cf_request_host == 'erp.casafolino.com'" class="cf-erp-login__notice">
                Accesso riservato agli utenti autorizzati CasaFolino.
            </div>
        </xpath>
        <xpath expr="//button[@type='submit' and hasclass('btn-primary')]" position="replace">
            <t t-set="cf_request_host" t-value="request.httprequest.host.split(':')[0] if request and request.httprequest and request.httprequest.host else ''"/>
            <button t-if="cf_request_host == 'erp.casafolino.com'" type="submit" class="btn btn-primary cf-erp-login__submit">Accedi all'ERP</button>
            <button t-else="" type="submit" class="btn btn-primary">Accedi</button>
        </xpath>
    </template>
</odoo>
