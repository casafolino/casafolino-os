<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client action 3 scrivanie (kept for backward compat, F2 evolves to 4) -->
    <record id="action_scrivania_commerciale" model="ir.actions.client">
        <field name="name">Scrivania Commerciale</field>
        <field name="tag">cf_scrivania_commerciale</field>
    </record>

    <record id="action_scrivania_operativa" model="ir.actions.client">
        <field name="name">Scrivania Operativa</field>
        <field name="tag">cf_scrivania_operativa</field>
    </record>

    <record id="action_scrivania_admin" model="ir.actions.client">
        <field name="name">Scrivania Admin</field>
        <field name="tag">cf_scrivania_admin</field>
    </record>

    <!-- Root menu: Sala Controllo — sole visible cockpit in apps grid -->
    <menuitem id="menu_cf_home_root"
              name="Sala Controllo"
              action="action_scrivania_commerciale"
              sequence="1"
              web_icon="casafolino_home,static/description/icon.png"/>
</odoo>
