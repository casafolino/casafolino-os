<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Commercial desktop is now an alias of the new CasaFolino OS console. -->
    <record id="action_scrivania_commerciale" model="ir.actions.client">
        <field name="name">Sala Controllo</field>
        <field name="tag">casafolino_pipeline_control</field>
        <field name="target">current</field>
        <field name="context">{'default_view': 'control'}</field>
    </record>

    <record id="action_scrivania_operativa" model="ir.actions.client">
        <field name="name">Scrivania Produzione</field>
        <field name="tag">cf_scrivania_operativa</field>
    </record>

    <record id="action_scrivania_admin" model="ir.actions.client">
        <field name="name">Scrivania Tesoreria</field>
        <field name="tag">cf_scrivania_admin</field>
    </record>

    <!-- Root menu: single visible cockpit in apps grid -->
    <menuitem id="menu_cf_home_root"
              name="Sala Controllo"
              action="casafolino_pipeline_control.action_cf_pipeline_control"
              sequence="1"
              web_icon="casafolino_home,static/description/icon.png"/>
</odoo>
