    <record id="casafolino_initiative.menu_initiative_root" model="ir.ui.menu">
        <field name="parent_id" ref="casafolino_home.menu_ws_crm"/>
        <field name="sequence">40</field>
    </record>

    <record id="casafolino_commercial.menu_cf_gdo_root" model="ir.ui.menu">
        <field name="parent_id" ref="casafolino_home.menu_ws_crm"/>
