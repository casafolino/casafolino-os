<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Reparent all custom root menus under the 4 Workspace clusters.
        After this, only "Workspace CasaFolino" remains in the apps grid.
    -->

    <!-- ============================================================
         CRM cluster — commercial, sales, contacts, KPI
         ============================================================ -->
