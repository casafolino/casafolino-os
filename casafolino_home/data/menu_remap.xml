        <field name="parent_id" ref="casafolino_home.menu_cf_home_root"/>
        <field name="sequence">40</field>
    </record>

    <!-- ============================================================
         Legacy: Scrivania (casafolino_workspace) — reparent under Workspace, bottom
         ============================================================ -->
