<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
<t t-name="casafolino_home.HomeDashboard">
    <div class="cf-home-wrap">

        <!-- Loading -->
        <t t-if="state.loading">
            <div class="cf-home-loading">
                <div class="cf-spin"/>
                <span>Caricamento KPI...</span>
            </div>
        </t>

        <!-- Error -->
        <t t-elif="state.error">
            <div class="cf-home-loading">
                <span style="font-size:24px;">⚠️</span>
                <span t-esc="state.error"/>
                <button class="btn btn-sm btn-outline-secondary" t-on-click="onRefresh">Riprova</button>
            </div>
        </t>

        <!-- Dashboard content -->
        <t t-else="">
            <!-- Header -->
            <div class="cf-home-header">
                <div class="cf-logo">🌿</div>
                <h1>CasaFolino OS</h1>
                <span style="font-size:12px; color:#aaa; margin-left:4px;">Dashboard — <t t-esc="state.dateLabel"/></span>
                <button class="cf-sync-btn" t-on-click="onRefresh" t-att-disabled="state.refreshing">
                    <span t-if="state.refreshing">⟳ Aggiorno...</span>
                    <span t-else="">⟳ Aggiorna</span>
                </button>
            </div>

            <!-- KPI principali -->
            <div class="cf-home-section-title">📊 KPI Principali</div>
            <div class="cf-home-kpi-grid">

                <!-- Mail non lette -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#5A6E3A" t-on-click="onOpenMail">
                    <span class="cf-kpi-icon">📧</span>
                    <div class="cf-kpi-val" t-esc="state.kpis.mail_unread"/>
                    <div class="cf-kpi-lbl">Email non lette</div>
                </div>

                <!-- Deal attivi CRM -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#2563eb" t-on-click="onOpenCrm">
                    <t t-if="state.kpis.crm_rotting > 0">
                        <span class="cf-kpi-badge warn"><t t-esc="state.kpis.crm_rotting"/> rotting</span>
                    </t>
                    <span class="cf-kpi-icon">🤝</span>
                    <div class="cf-kpi-val" t-esc="state.kpis.crm_active"/>
                    <div class="cf-kpi-lbl">Deal attivi CRM</div>
                </div>

                <!-- NC HACCP aperte -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#dc3545" t-on-click="onOpenHaccp">
                    <t t-if="state.kpis.haccp_nc_critical > 0">
                        <span class="cf-kpi-badge"><t t-esc="state.kpis.haccp_nc_critical"/> critiche</span>
                    </t>
                    <span class="cf-kpi-icon">🦠</span>
                    <div t-attf-class="cf-kpi-val #{state.kpis.haccp_nc_open > 0 and 'negative' or ''}">
                        <t t-esc="state.kpis.haccp_nc_open"/>
                    </div>
                    <div class="cf-kpi-lbl">NC HACCP aperte</div>
                </div>

                <!-- Saldo Treasury -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#0d9488" t-on-click="onOpenTreasury">
                    <span class="cf-kpi-icon">💰</span>
                    <div t-attf-class="cf-kpi-val #{state.kpis.treasury_balance &lt; 0 and 'negative' or ''}">
                        € <t t-esc="formatCurrency(state.kpis.treasury_balance)"/>
                    </div>
                    <div class="cf-kpi-lbl">Saldo liquidità</div>
                </div>

            </div>

            <!-- Seconda riga KPI -->
            <div class="cf-home-kpi-grid" style="margin-top:14px;">

                <!-- Follow-up oggi -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#7c3aed" t-on-click="onOpenFollowup">
                    <t t-if="state.kpis.crm_followup_today > 0">
                        <span class="cf-kpi-badge warn">oggi</span>
                    </t>
                    <span class="cf-kpi-icon">📅</span>
                    <div class="cf-kpi-val" t-esc="state.kpis.crm_followup_today"/>
                    <div class="cf-kpi-lbl">Follow-up da fare oggi</div>
                </div>

                <!-- Commesse in produzione -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#f59e0b" t-on-click="onOpenProduction">
                    <span class="cf-kpi-icon">🏭</span>
                    <div class="cf-kpi-val" t-esc="state.kpis.prod_in_progress"/>
                    <div class="cf-kpi-lbl">Commesse in produzione</div>
                </div>

                <!-- Scadenze imminenti -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#ea580c" t-on-click="onOpenExpiring">
                    <t t-if="state.kpis.expiring_soon > 0">
                        <span class="cf-kpi-badge warn">7gg</span>
                    </t>
                    <span class="cf-kpi-icon">⏰</span>
                    <div t-attf-class="cf-kpi-val #{state.kpis.expiring_soon > 0 and 'negative' or ''}">
                        <t t-esc="state.kpis.expiring_soon"/>
                    </div>
                    <div class="cf-kpi-lbl">Scadenze entro 7 giorni</div>
                </div>

                <!-- Vendite YTD -->
                <div class="cf-home-kpi-card" style="--cf-kpi-color:#16a34a" t-on-click="onOpenKpi">
                    <span class="cf-kpi-icon">📈</span>
                    <div class="cf-kpi-val">€ <t t-esc="formatCurrency(state.kpis.kpi_ytd)"/></div>
                    <div class="cf-kpi-lbl">Vendite YTD</div>
                </div>

            </div>

            <!-- Moduli rapidi -->
            <div class="cf-home-section-title">🧭 Navigazione Rapida</div>
            <div class="cf-home-modules">
                <div class="cf-home-mod-card" t-on-click="onOpenMail">
                    <span class="cf-mod-icon">📧</span>
                    <div class="cf-mod-info">
                        <div class="cf-mod-name">CasaFolino Mail</div>
                        <div class="cf-mod-stat"><t t-esc="state.kpis.mail_unread"/> non lette</div>
                    </div>
                    <span class="cf-mod-arrow">›</span>
                </div>
                <div class="cf-home-mod-card" t-on-click="onOpenCrm">
                    <span class="cf-mod-icon">🤝</span>
                    <div class="cf-mod-info">
                        <div class="cf-mod-name">CRM Export</div>
                        <div class="cf-mod-stat"><t t-esc="state.kpis.crm_active"/> deal · € <t t-esc="formatCurrency(state.kpis.crm_forecast)"/> forecast</div>
                    </div>
                    <span class="cf-mod-arrow">›</span>
                </div>
                <div class="cf-home-mod-card" t-on-click="onOpenHaccp">
                    <span class="cf-mod-icon">🦠</span>
                    <div class="cf-mod-info">
                        <div class="cf-mod-name">HACCP</div>
                        <div class="cf-mod-stat"><t t-esc="state.kpis.haccp_nc_open"/> NC aperte · <t t-esc="state.kpis.haccp_nc_critical"/> critiche</div>
                    </div>
                    <span class="cf-mod-arrow">›</span>
                </div>
                <div class="cf-home-mod-card" t-on-click="onOpenTreasury">
                    <span class="cf-mod-icon">💰</span>
                    <div class="cf-mod-info">
                        <div class="cf-mod-name">Treasury</div>
                        <div class="cf-mod-stat">Saldo: € <t t-esc="formatCurrency(state.kpis.treasury_balance)"/></div>
                    </div>
                    <span class="cf-mod-arrow">›</span>
                </div>
                <div class="cf-home-mod-card" t-on-click="onOpenProduction">
                    <span class="cf-mod-icon">🏭</span>
                    <div class="cf-mod-info">
                        <div class="cf-mod-name">Produzione</div>
                        <div class="cf-mod-stat"><t t-esc="state.kpis.prod_active"/> attive · <t t-esc="state.kpis.prod_in_progress"/> in corso</div>
                    </div>
                    <span class="cf-mod-arrow">›</span>
                </div>
                <div class="cf-home-mod-card" t-on-click="onOpenKpi">
                    <span class="cf-mod-icon">📊</span>
                    <div class="cf-mod-info">
                        <div class="cf-mod-name">KPI</div>
                        <div class="cf-mod-stat">YTD: € <t t-esc="formatCurrency(state.kpis.kpi_ytd)"/> · MO: <t t-esc="state.kpis.kpi_mo_open"/></div>
                    </div>
                    <span class="cf-mod-arrow">›</span>
                </div>
            </div>
        </t>
    </div>
</t>
</templates>
