<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="casafolino_home.CFWorkspace">
        <div class="cf-wu">
            <aside class="cf-wu-rail">
                <div class="cf-wu-logo">CF</div>
                <button class="cf-wu-nav active" title="Sala controllo" aria-label="Sala controllo">
                    <i class="fa fa-home"/>
                </button>
                <button class="cf-wu-nav" title="CRM" aria-label="CRM" t-on-click="onOpenPipeline">
                    <i class="fa fa-bullseye"/>
                </button>
                <button class="cf-wu-nav" title="Dossier" aria-label="Dossier" t-on-click="onOpenProjects">
                    <i class="fa fa-folder-open"/>
                </button>
                <button class="cf-wu-nav" title="Lavagna" aria-label="Lavagna" t-on-click="onOpenLavagna">
                    <i class="fa fa-clipboard"/>
                </button>
                <button class="cf-wu-nav" title="Mail" aria-label="Mail" t-on-click="onOpenMiaCasella">
                    <i class="fa fa-envelope"/>
                </button>
            </aside>

            <main class="cf-wu-main">
                <section class="cf-wu-command">
                    <form class="cf-wu-search" t-on-submit="onSubmitGlobalSearch">
                        <i class="fa fa-search"/>
                        <input type="search"
                               t-att-value="state.identityQuery"
                               t-on-input="onSearchInput"
                               t-on-focus="onFocusGlobalSearch"
                               t-on-click="onFocusGlobalSearch"
                               placeholder="Cerca telefono, nome, email, lead, dossier, prodotto o testo mail"/>
                        <button type="submit">Cerca</button>
                    </form>
                    <div class="cf-wu-quick">
                        <button class="cf-wu-btn primary" t-on-click="onNewLead">
                            <i class="fa fa-plus"/>
                            <span>Nuovo lead</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenPipeline">
                            <i class="fa fa-columns"/>
                            <span>Apri pipeline</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenProjects">
                            <i class="fa fa-folder-open"/>
                            <span>Apri dossier</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenLavagna">
                            <i class="fa fa-clipboard"/>
                            <span>Lavagna oggi</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenMiaCasella">
                            <i class="fa fa-envelope"/>
                            <span>Mail hub</span>
                        </button>
                    </div>
                </section>

                <section class="cf-wu-hero">
                    <div>
                        <div class="cf-wu-badge">Percorso unico: telefono &gt; lead &gt; pipeline &gt; dossier</div>
                        <h1>Sala controllo commerciale</h1>
                        <p>Quando squilla il telefono parti da qui: crei o cerchi il contatto, lo lavori in pipeline e apri il dossier solo quando il funnel e' maturo.</p>
                    </div>
                    <div class="cf-wu-kpis">
                        <button class="cf-wu-kpi" t-on-click="onOpenPipeline">
                            <span>Lead aperti</span>
                            <strong t-out="formatKpi(state.kpi.crm.lead_aperti)"/>
                        </button>
                        <button class="cf-wu-kpi" t-on-click="onOpenProjects">
                            <span>Dossier attivi</span>
                            <strong t-out="formatKpi(state.kpi.crm.progetti_attivi)"/>
                        </button>
                        <button class="cf-wu-kpi" t-on-click="onOpenPipeline">
                            <span>Follow-up oggi</span>
                            <strong t-out="formatKpi(state.kpi.crm.sla_scadenza)"/>
                        </button>
                        <button class="cf-wu-kpi" t-on-click="onOpenMiaCasella">
                            <span>Mail da smistare</span>
                            <strong t-out="formatKpi(state.kpi.crm.mail_pending)"/>
                        </button>
                    </div>
                </section>

                <section class="cf-wu-board">
                    <section class="cf-wu-intake" aria-label="Azioni rapide">
                        <button class="cf-wu-intake-card primary" t-on-click="onNewLead">
                            <h3>Telefono / lead <em>30 sec</em></h3>
                            <p>Creo o cerco il contatto, raccolgo nome, telefono, email, fonte e tipo cliente.</p>
                            <span>Nuovo lead</span>
                        </button>
                        <button class="cf-wu-intake-card" t-on-click="onOpenPipeline">
                            <h3>Pipeline <em>CRM</em></h3>
                            <p>Qualifico la richiesta e porto avanti listino, quotazione, campioni o follow-up.</p>
                            <span>Apri pipeline</span>
                        </button>
                        <button class="cf-wu-intake-card" t-on-click="onOpenProjects">
                            <h3>Dossier <em>360</em></h3>
                            <p>Apro la storia profonda quando esistono documenti, mail, campioni o decisioni.</p>
                            <span>Scegli dossier</span>
                        </button>
                        <button class="cf-wu-intake-card" t-on-click="onOpenMiaCasella">
                            <h3>Mail in arrivo <em>inbox</em></h3>
                            <p>Smisto la mail: lead nuovo, follow-up pipeline o messaggio collegato al dossier.</p>
                            <span>Mail hub</span>
                        </button>
                    </section>

                    <article class="cf-wu-panel cf-wu-panel-pipeline">
                        <header class="cf-wu-panel-head">
                            <div>
                                <h2>CRM / Pipeline</h2>
                                <p>Ogni telefonata nasce qui, anche se poi diventa cliente o dossier.</p>
                            </div>
                            <button class="cf-wu-btn sm" t-on-click="onOpenPipeline">Apri</button>
                        </header>
                        <div class="cf-wu-panel-body">
                            <div class="cf-wu-pipeline">
                                <div class="cf-wu-stage">
                                    <h3><span>Nuova</span><b>1</b></h3>
                                    <button class="cf-wu-card" t-on-click="onNewLead">
                                        <strong>Telefonata in ingresso</strong>
                                        <span>Nome, telefono, email, fonte lead</span>
                                    </button>
                                </div>
                                <div class="cf-wu-stage">
                                    <h3><span>Da qualificare</span><b>2</b></h3>
                                    <button class="cf-wu-card" t-on-click="onOpenPipeline">
                                        <strong>Rivenditore / broker</strong>
                                        <span>Canale, categoria, interesse prodotto</span>
                                    </button>
                                    <button class="cf-wu-card" t-on-click="onOpenPipeline">
                                        <strong>Negoziante</strong>
                                        <span>Listino, condizioni, zona servita</span>
                                    </button>
                                </div>
                                <div class="cf-wu-stage">
                                    <h3><span>Listino / quotazione</span><b>2</b></h3>
                                    <button class="cf-wu-card" t-on-click="onOpenMiaCasella">
                                        <strong>Invio listino</strong>
                                        <span>Email pronta, allegati e follow-up</span>
                                    </button>
                                    <button class="cf-wu-card" t-on-click="onOpenPipeline">
                                        <strong>Quotazione prodotto</strong>
                                        <span>Prezzo, quantita', margine, note</span>
                                    </button>
                                </div>
                                <div class="cf-wu-stage">
                                    <h3><span>Pronta dossier</span><b>1</b></h3>
                                    <button class="cf-wu-card" t-on-click="onNewProject">
                                        <strong>Apri dossier</strong>
                                        <span>Contratto, campioni, timeline e responsabilita'</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="cf-wu-panel">
                        <header class="cf-wu-panel-head">
                            <div>
                                <h2>Mail commerciale</h2>
                                <p>Inbox operativa collegata a lead, pipeline e dossier.</p>
                            </div>
                            <button class="cf-wu-btn sm" t-on-click="onOpenMiaCasella">Apri</button>
                        </header>
                        <div class="cf-wu-panel-body cf-wu-mail-list">
                            <t t-if="state.mailRows.length">
                                <div class="cf-wu-mail-row live" t-foreach="state.mailRows" t-as="mail" t-key="mail.id">
                                    <button class="cf-wu-mail-open" t-on-click="() => this.onOpenMailRow(mail)">
                                        <span class="cf-wu-mail-icon">
                                            <i class="fa fa-envelope"/>
                                        </span>
                                        <span>
                                            <strong t-out="mail.subject"/>
                                            <em>
                                                <t t-out="mail.sender"/> - <t t-out="mail.preview"/>
                                            </em>
                                        </span>
                                        <b t-att-class="mail.badgeClass" t-out="mail.badge"/>
                                    </button>
                                    <button class="cf-wu-mail-action" t-on-click="() => this.onCreateLeadFromMail(mail)">
                                        <i class="fa" t-att-class="mail.lead_id ? 'fa-folder-open' : 'fa-plus'"/>
                                        <span t-out="mail.actionLabel"/>
                                    </button>
                                </div>
                            </t>
                            <t t-else="">
                            <button class="cf-wu-mail-row" t-on-click="onOpenMiaCasella">
                                <span class="cf-wu-mail-icon">
                                    <i class="fa fa-envelope"/>
                                </span>
                                <span>
                                    <strong>Re: quotazione Costco Canada</strong>
                                    <em>Mail collegata a dossier - richiede risposta entro oggi</em>
                                </span>
                                <b class="amber">oggi</b>
                            </button>
                            <button class="cf-wu-mail-row" t-on-click="onOpenMiaCasella">
                                <span class="cf-wu-mail-icon">
                                    <i class="fa fa-envelope-open"/>
                                </span>
                                <span>
                                    <strong>Nuova richiesta listino export</strong>
                                    <em>Da trasformare in lead e mettere in pipeline</em>
                                </span>
                                <b>lead</b>
                            </button>
                            <button class="cf-wu-mail-row" t-on-click="onOpenMiaCasella">
                                <span class="cf-wu-mail-icon">
                                    <i class="fa fa-paperclip"/>
                                </span>
                                <span>
                                    <strong>Listino export Francia</strong>
                                    <em>Bozza pronta - collegare follow-up alla pipeline</em>
                                </span>
                                <b class="green">pronta</b>
                            </button>
                            </t>
                        </div>
                    </article>

                    <article class="cf-wu-panel">
                        <header class="cf-wu-panel-head">
                            <div>
                                <h2>Dossier attivi</h2>
                                <p>Vista 360 solo per opportunita' gia' profonde.</p>
                            </div>
                            <button class="cf-wu-btn sm" t-on-click="onOpenProjects">Apri elenco</button>
                        </header>
                        <div class="cf-wu-panel-body cf-wu-list">
                            <t t-if="state.dossierRows.length">
                                <button class="cf-wu-row" t-foreach="state.dossierRows" t-as="dossier" t-key="dossier.id" t-on-click="() => this.onOpenDossier360(dossier)">
                                    <span class="cf-wu-row-top">
                                        <strong t-out="dossier.title"/>
                                        <em t-att-class="dossier.status === 'active' ? 'green' : dossier.status === 'paused' ? 'amber' : dossier.status === 'closed' ? 'violet' : ''" t-out="dossier.status"/>
                                    </span>
                                    <span class="cf-wu-mini">
                                        <t t-out="dossier.partner"/> - <t t-out="dossier.nextAction"/>
                                    </span>
                                </button>
                            </t>
                            <t t-else="">
                                <button class="cf-wu-row" t-on-click="onOpenProjects">
                                    <span class="cf-wu-row-top">
                                        <strong>Nessun dossier pronto</strong>
                                        <em>elenco</em>
                                    </span>
                                    <span class="cf-wu-mini">Apri Progetti 360 per creare o selezionare un dossier.</span>
                                </button>
                            </t>
                        </div>
                    </article>

                    <article class="cf-wu-panel">
                        <header class="cf-wu-panel-head">
                            <div>
                                <h2>Lavagna oggi</h2>
                                <p>Azioni operative collegate a lead, dossier e mail.</p>
                            </div>
                            <button class="cf-wu-btn sm" t-on-click="onOpenLavagna">Apri</button>
                        </header>
                        <div class="cf-wu-panel-body cf-wu-list">
                            <button class="cf-wu-row" t-on-click="onOpenPipeline">
                                <span class="cf-wu-row-top">
                                    <strong>Richiamare lead nuovo</strong>
                                    <em class="red">Oggi</em>
                                </span>
                                <span class="cf-wu-mini">Recuperare dati minimi e scegliere template di qualifica.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenMiaCasella">
                                <span class="cf-wu-row-top">
                                    <strong>Inviare listino</strong>
                                    <em class="amber">Mail</em>
                                </span>
                                <span class="cf-wu-mini">Usare template commerciale e registrare follow-up in pipeline.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenProjects">
                                <span class="cf-wu-row-top">
                                    <strong>Aggiornare dossier</strong>
                                    <em class="green">360</em>
                                </span>
                                <span class="cf-wu-mini">Allineare timeline, prossima azione e documenti mancanti.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenLavagna">
                                <span class="cf-wu-row-top">
                                    <strong>Priorita' del giorno</strong>
                                    <em>Board</em>
                                </span>
                                <span class="cf-wu-mini">Tenere visibile solo cio' che serve per decidere subito.</span>
                            </button>
                        </div>
                    </article>
                </section>

                <div t-if="state.identityPanelOpen" class="cf-wu-identity-backdrop">
                    <section class="cf-wu-identity">
                        <header class="cf-wu-identity-head">
                            <div>
                                <span>Controllo duplicati</span>
                                <h2 t-out="identityContextTitle"/>
                                <p>Prima di creare qualcosa, verifica se esiste gia' come contatto, lead, dossier o mail.</p>
                            </div>
                            <button class="cf-wu-icon-btn" t-on-click="closeIdentityPanel" aria-label="Chiudi">
                                <i class="fa fa-times"/>
                            </button>
                        </header>
                        <form class="cf-wu-identity-search" t-on-submit="onSubmitGlobalSearch">
                            <i class="fa fa-search"/>
                            <input type="search"
                                   t-att-value="state.identityQuery"
                                   t-on-input="onSearchInput"
                                   t-on-focus="onFocusGlobalSearch"
                                   placeholder="Scrivi nome, telefono, email, azienda o oggetto mail"/>
                            <button type="submit">Cerca</button>
                        </form>
                        <div t-if="state.identityLoading" class="cf-wu-identity-empty">
                            Sto cercando in contatti, lead, dossier e mail...
                        </div>
                        <div t-elif="!hasIdentityResults" class="cf-wu-identity-empty">
                            <strong>Nessun risultato ancora.</strong>
                            <span>Cerca almeno due caratteri prima di creare un nuovo lead o aprire un nuovo dossier.</span>
                        </div>
                        <div t-else="" class="cf-wu-identity-grid">
                            <section class="cf-wu-identity-section" t-foreach="identitySections" t-as="section" t-key="section.key">
                                <header>
                                    <i class="fa" t-att-class="section.icon"/>
                                    <strong t-out="section.title"/>
                                    <span t-out="section.rows.length"/>
                                </header>
                                <t t-if="section.rows.length">
                                    <button class="cf-wu-identity-row"
                                            t-foreach="section.rows"
                                            t-as="row"
                                            t-key="section.key + '-' + row.id"
                                            t-on-click="() => this.onOpenIdentityResult(row)">
                                        <strong t-out="row.title"/>
                                        <span t-out="row.subtitle"/>
                                        <em t-out="section.label"/>
                                    </button>
                                </t>
                                <div t-else="" class="cf-wu-identity-none">Nessun risultato</div>
                            </section>
                        </div>
                        <footer class="cf-wu-identity-actions">
                            <button class="cf-wu-btn" t-on-click="onOpenMailHub">
                                <i class="fa fa-envelope"/>
                                <span>Apri mail hub</span>
                            </button>
                            <button class="cf-wu-btn" t-on-click="onOpenProjects">
                                <i class="fa fa-folder-open"/>
                                <span>Apri elenco dossier</span>
                            </button>
                            <button t-if="state.identityContext === 'mail' &amp;&amp; state.identityMail"
                                    class="cf-wu-btn primary"
                                    t-on-click="onConfirmCreateLeadFromMail">
                                <i class="fa fa-plus"/>
                                <span>Crea lead da questa mail</span>
                            </button>
                            <button t-else="" class="cf-wu-btn primary" t-on-click="onCreateNewLead">
                                <i class="fa fa-plus"/>
                                <span>Crea nuovo lead</span>
                            </button>
                        </footer>
                    </section>
                </div>
            </main>
        </div>
    </t>
</templates>
