<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="casafolino_home.CFWorkspace">
        <div class="cf-wu">
            <aside class="cf-wu-rail">
                <div class="cf-wu-logo">CF</div>
                <button class="cf-wu-nav active" title="Sala controllo" aria-label="Sala controllo">
                    <i class="fa fa-home"/>
                </button>
                <button class="cf-wu-nav" title="CRM" aria-label="CRM" t-on-click="onOpenPipeline">
                    <i class="fa fa-bullseye"/>
                </button>
                <button class="cf-wu-nav" title="Dossier" aria-label="Dossier" t-on-click="onOpenProjects">
                    <i class="fa fa-folder-open"/>
                </button>
                <button class="cf-wu-nav" title="Lavagna" aria-label="Lavagna" t-on-click="onOpenLavagna">
                    <i class="fa fa-clipboard"/>
                </button>
                <button class="cf-wu-nav" title="Mail" aria-label="Mail" t-on-click="onOpenMiaCasella">
                    <i class="fa fa-envelope"/>
                </button>
            </aside>

            <main class="cf-wu-main">
                <section class="cf-wu-command">
                    <div class="cf-wu-search">
                        <i class="fa fa-search"/>
                        <span>Cerca contatto, lead, dossier, email o prodotto</span>
                    </div>
                    <div class="cf-wu-quick">
                        <button class="cf-wu-btn primary" t-on-click="onNewLead">
                            <i class="fa fa-plus"/>
                            <span>Nuovo lead</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenPipeline">
                            <i class="fa fa-columns"/>
                            <span>Apri pipeline</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenProjects">
                            <i class="fa fa-folder-open"/>
                            <span>Apri dossier</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenLavagna">
                            <i class="fa fa-clipboard"/>
                            <span>Lavagna oggi</span>
                        </button>
                        <button class="cf-wu-btn" t-on-click="onOpenMiaCasella">
                            <i class="fa fa-envelope"/>
                            <span>Mail hub</span>
                        </button>
                    </div>
                </section>

                <section class="cf-wu-hero">
                    <div>
                        <div class="cf-wu-badge">Percorso unico: telefono &gt; lead &gt; pipeline &gt; dossier</div>
                        <h1>Sala controllo commerciale</h1>
                        <p>Quando squilla il telefono parti da qui: crei o cerchi il contatto, lo lavori in pipeline e apri il dossier solo quando il funnel e' maturo.</p>
                    </div>
                    <div class="cf-wu-kpis">
                        <button class="cf-wu-kpi" t-on-click="onOpenPipeline">
                            <span>Lead aperti</span>
                            <strong t-out="formatKpi(state.kpi.crm.lead_aperti)"/>
                        </button>
                        <button class="cf-wu-kpi" t-on-click="onOpenProjects">
                            <span>Dossier attivi</span>
                            <strong t-out="formatKpi(state.kpi.crm.progetti_attivi)"/>
                        </button>
                        <button class="cf-wu-kpi" t-on-click="onOpenPipeline">
                            <span>Follow-up oggi</span>
                            <strong t-out="formatKpi(state.kpi.crm.sla_scadenza)"/>
                        </button>
                        <button class="cf-wu-kpi" t-on-click="onOpenMiaCasella">
                            <span>Mail da smistare</span>
                            <strong t-out="formatKpi(state.kpi.crm.mail_pending)"/>
                        </button>
                    </div>
                </section>

                <section class="cf-wu-board">
                    <article class="cf-wu-panel cf-wu-panel-pipeline">
                        <header class="cf-wu-panel-head">
                            <div>
                                <h2>CRM / Pipeline</h2>
                                <p>Ogni telefonata nasce qui, anche se poi diventa cliente o dossier.</p>
                            </div>
                            <button class="cf-wu-btn sm" t-on-click="onOpenPipeline">Apri</button>
                        </header>
                        <div class="cf-wu-panel-body">
                            <div class="cf-wu-pipeline">
                                <div class="cf-wu-stage">
                                    <h3><span>Nuova</span><b>1</b></h3>
                                    <button class="cf-wu-card" t-on-click="onNewLead">
                                        <strong>Telefonata in ingresso</strong>
                                        <span>Nome, telefono, email, fonte lead</span>
                                    </button>
                                </div>
                                <div class="cf-wu-stage">
                                    <h3><span>Da qualificare</span><b>2</b></h3>
                                    <button class="cf-wu-card" t-on-click="onOpenPipeline">
                                        <strong>Rivenditore / broker</strong>
                                        <span>Canale, categoria, interesse prodotto</span>
                                    </button>
                                    <button class="cf-wu-card" t-on-click="onOpenPipeline">
                                        <strong>Negoziante</strong>
                                        <span>Listino, condizioni, zona servita</span>
                                    </button>
                                </div>
                                <div class="cf-wu-stage">
                                    <h3><span>Listino / quotazione</span><b>2</b></h3>
                                    <button class="cf-wu-card" t-on-click="onOpenMiaCasella">
                                        <strong>Invio listino</strong>
                                        <span>Email pronta, allegati e follow-up</span>
                                    </button>
                                    <button class="cf-wu-card" t-on-click="onOpenPipeline">
                                        <strong>Quotazione prodotto</strong>
                                        <span>Prezzo, quantita', margine, note</span>
                                    </button>
                                </div>
                                <div class="cf-wu-stage">
                                    <h3><span>Pronta dossier</span><b>1</b></h3>
                                    <button class="cf-wu-card" t-on-click="onNewProject">
                                        <strong>Apri dossier</strong>
                                        <span>Contratto, campioni, timeline e responsabilita'</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="cf-wu-panel">
                        <header class="cf-wu-panel-head">
                            <div>
                                <h2>Dossier attivi</h2>
                                <p>Vista 360 solo per opportunita' gia' profonde.</p>
                            </div>
                            <button class="cf-wu-btn sm" t-on-click="onOpenProjects">Apri</button>
                        </header>
                        <div class="cf-wu-panel-body cf-wu-list">
                            <button class="cf-wu-row" t-on-click="onOpenProjects">
                                <span class="cf-wu-row-top">
                                    <strong>Private label pasta fresca</strong>
                                    <em class="green">Campioni</em>
                                </span>
                                <span class="cf-wu-mini">Cliente GDO - prossimo step: feedback qualita' e scheda tecnica.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenProjects">
                                <span class="cf-wu-row-top">
                                    <strong>Export retail Germania</strong>
                                    <em class="amber">Quotazione</em>
                                </span>
                                <span class="cf-wu-mini">Broker - margini da confermare prima della proposta finale.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenProjects">
                                <span class="cf-wu-row-top">
                                    <strong>Food service Milano</strong>
                                    <em class="violet">Contratto</em>
                                </span>
                                <span class="cf-wu-mini">Cliente attivo - listino aggiornato, task amministrativo aperto.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenProjects">
                                <span class="cf-wu-row-top">
                                    <strong>Linea premium negozi</strong>
                                    <em>Onboarding</em>
                                </span>
                                <span class="cf-wu-mini">Contatto caldo - dossier aperto dopo qualifica commerciale.</span>
                            </button>
                        </div>
                    </article>

                    <article class="cf-wu-panel">
                        <header class="cf-wu-panel-head">
                            <div>
                                <h2>Lavagna oggi</h2>
                                <p>Azioni operative collegate a lead, dossier e mail.</p>
                            </div>
                            <button class="cf-wu-btn sm" t-on-click="onOpenLavagna">Apri</button>
                        </header>
                        <div class="cf-wu-panel-body cf-wu-list">
                            <button class="cf-wu-row" t-on-click="onOpenPipeline">
                                <span class="cf-wu-row-top">
                                    <strong>Richiamare lead nuovo</strong>
                                    <em class="red">Oggi</em>
                                </span>
                                <span class="cf-wu-mini">Recuperare dati minimi e scegliere template di qualifica.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenMiaCasella">
                                <span class="cf-wu-row-top">
                                    <strong>Inviare listino</strong>
                                    <em class="amber">Mail</em>
                                </span>
                                <span class="cf-wu-mini">Usare template commerciale e registrare follow-up in pipeline.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenProjects">
                                <span class="cf-wu-row-top">
                                    <strong>Aggiornare dossier</strong>
                                    <em class="green">360</em>
                                </span>
                                <span class="cf-wu-mini">Allineare timeline, prossima azione e documenti mancanti.</span>
                            </button>
                            <button class="cf-wu-row" t-on-click="onOpenLavagna">
                                <span class="cf-wu-row-top">
                                    <strong>Priorita' del giorno</strong>
                                    <em>Board</em>
                                </span>
                                <span class="cf-wu-mini">Tenere visibile solo cio' che serve per decidere subito.</span>
                            </button>
                        </div>
                    </article>
                </section>
            </main>
        </div>
    </t>
</templates>
