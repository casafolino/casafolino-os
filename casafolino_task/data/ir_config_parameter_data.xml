<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Soglie semaforo in ORE LAVORATIVE -->
        <record id="cf_task_param_soft" model="ir.config_parameter">
            <field name="key">casafolino_task.soft_hours</field>
            <field name="value">4</field>
        </record>
        <record id="cf_task_param_hard" model="ir.config_parameter">
            <field name="key">casafolino_task.hard_hours</field>
            <field name="value">8</field>
        </record>
        <!-- Anti-spam re-alert rosso (ore reali) -->
        <record id="cf_task_param_realert" model="ir.config_parameter">
            <field name="key">casafolino_task.red_realert_hours</field>
            <field name="value">24</field>
        </record>
        <!-- Utente escalation (Antonio = id 2) -->
        <record id="cf_task_param_esc_user" model="ir.config_parameter">
            <field name="key">casafolino_task.escalation_user_id</field>
            <field name="value">2</field>
        </record>
        <!-- Canali notifica attivi -->
        <record id="cf_task_param_channels" model="ir.config_parameter">
            <field name="key">casafolino_task.notify_channels</field>
            <field name="value">mail,inapp</field>
        </record>
    </data>
</odoo>
