<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="layout_footer" model="ir.ui.view">
        <field name="name">CasaFolino B2B Footer</field>
        <field name="type">qweb</field>
        <field name="key">casafolino_b2b_theme.layout_footer</field>
        <field name="inherit_id" ref="website.layout"/>
        <field name="website_id" ref="casafolino_b2b_portal.website_b2b_casafolino"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='footer']" position="replace">
                <div id="footer" class="cf-b2b-odoo-footer" t-if="not no_footer">
                    <div class="cf-b2b-odoo-footer__inner">
                        <section>
                            <img class="cf-b2b-odoo-footer__logo" src="/casafolino_b2b_portal/static/src/img/brand/casafolino-logo-white.svg" alt="CasaFolino"/>
                            <p>Portale riservato ad acquisti all'ingrosso di prodotti CasaFolino per retail, Ho.Re.Ca., distributori e operatori professionali.</p>
                        </section>
                        <section>
                            <h2>Area B2B</h2>
                            <a href="/b2b">Catalogo ingrosso</a>
                            <a href="/my/orders">I miei ordini</a>
                            <a href="/my/invoices?filterby=invoices">Le mie fatture</a>
                            <a href="/b2b/register">Richiedi accesso</a>
                        </section>
                        <section>
                            <h2>CasaFolino</h2>
                            <p>CasaFolino Srl Societa' Benefit</p>
                            <p>Via Prunia, 1 - 88046 Lamezia Terme (CZ)</p>
                            <p>P.IVA IT03783120797</p>
                        </section>
                        <section>
                            <h2>Contatti</h2>
                            <a href="mailto:info@casafolino.com">info@casafolino.com</a>
                            <a href="tel:+390968407195">+39 0968 407195</a>
                            <a href="https://casafolino.com">casafolino.com</a>
                        </section>
                    </div>
                    <div class="cf-b2b-odoo-copyright">
                        <span>Copyright (c) CasaFolino Srl Societa' Benefit</span>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
