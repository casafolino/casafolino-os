<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cf_raw_material_summary_wizard_form" model="ir.ui.view">
        <field name="name">cf.raw.material.summary.wizard.form</field>
        <field name="model">cf.raw.material.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Resoconto Materie Prime">
                <sheet>
                    <field name="summary_html" nolabel="1"/>
                    <field name="note" nolabel="1" invisible="not note"/>
                    <notebook>
                        <page string="Da acquistare" name="purchase">
                            <field name="line_ids" nolabel="1" domain="[('need_purchase', '=', True)]">
                                <list create="0" edit="0" delete="0" default_order="purchase_qty desc">
                                    <field name="product_code" optional="show"/>
                                    <field name="product_id"/>
                                    <field name="purchase_qty" sum="Totale da acquistare"/>
                                    <field name="product_uom_id"/>
                                    <field name="required_qty" optional="show"/>
                                    <field name="available_qty" optional="show"/>
                                    <field name="production_summary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tutto il fabbisogno" name="all_materials">
                            <field name="line_ids" nolabel="1">
                                <list create="0" edit="0" delete="0"
                                      decoration-danger="need_purchase"
                                      decoration-success="not need_purchase">
                                    <field name="availability_state" widget="badge"/>
                                    <field name="product_code" optional="show"/>
                                    <field name="product_id"/>
                                    <field name="required_qty" sum="Totale serve"/>
                                    <field name="available_qty"/>
                                    <field name="reserved_qty" optional="hide"/>
                                    <field name="purchase_qty" sum="Totale da acquistare"/>
                                    <field name="product_uom_id"/>
                                    <field name="source_count" optional="hide"/>
                                    <field name="production_summary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Origini" name="origins">
                            <group>
                                <field name="sale_order_ids" widget="many2many_tags" invisible="not sale_order_ids"/>
                                <field name="production_ids" widget="many2many_tags"/>
                            </group>
                            <field name="line_ids" nolabel="1">
                                <list create="0" edit="0" delete="0">
                                    <field name="product_id"/>
                                    <field name="required_qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="production_names"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_print_report" type="object" string="Stampa PDF" class="btn-primary"/>
                    <button string="Chiudi" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cf_raw_material_summary_mrp" model="ir.actions.act_window">
        <field name="name">Resoconto Materie Prime</field>
        <field name="res_model">cf.raw.material.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_cf_raw_material_summary_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" eval="False"/>
    </record>

    <record id="action_cf_raw_material_summary_sale" model="ir.actions.act_window">
        <field name="name">Resoconto Materie Prime</field>
        <field name="res_model">cf.raw.material.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_cf_raw_material_summary_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" eval="False"/>
    </record>

    <record id="action_cf_raw_material_summary_mrp_server" model="ir.actions.server">
        <field name="name">Resoconto Materie Prime</field>
        <field name="model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = {
    "type": "ir.actions.act_window",
    "name": "Resoconto Materie Prime",
    "res_model": "cf.raw.material.summary.wizard",
    "view_mode": "form",
    "view_id": env.ref("casafolino_operations.view_cf_raw_material_summary_wizard_form").id,
    "target": "new",
    "context": {
        "active_model": "mrp.production",
        "active_ids": records.ids,
    },
}</field>
    </record>

    <record id="action_cf_raw_material_summary_sale_server" model="ir.actions.server">
        <field name="name">Resoconto Materie Prime</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = {
    "type": "ir.actions.act_window",
    "name": "Resoconto Materie Prime",
    "res_model": "cf.raw.material.summary.wizard",
    "view_mode": "form",
    "view_id": env.ref("casafolino_operations.view_cf_raw_material_summary_wizard_form").id,
    "target": "new",
    "context": {
        "active_model": "sale.order",
        "active_ids": records.ids,
    },
}</field>
    </record>
</odoo>
