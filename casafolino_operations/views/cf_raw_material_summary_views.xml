<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cf_raw_material_summary_wizard_form" model="ir.ui.view">
        <field name="name">cf.raw.material.summary.wizard.form</field>
        <field name="model">cf.raw.material.summary.wizard</field>
        <field name="arch" type="xml">
            <form string="Resoconto Materie Prime">
                <sheet>
                    <group>
                        <field name="sale_order_ids" widget="many2many_tags" invisible="not sale_order_ids"/>
                        <field name="production_ids" widget="many2many_tags"/>
                        <field name="note" invisible="not note"/>
                    </group>
                    <field name="line_ids" nolabel="1">
                        <list create="0" edit="0" delete="0" decoration-danger="purchase_qty &gt; 0">
                            <field name="product_id"/>
                            <field name="required_qty" sum="Totale richiesto"/>
                            <field name="available_qty"/>
                            <field name="reserved_qty"/>
                            <field name="purchase_qty" sum="Totale da acquistare"/>
                            <field name="product_uom_id"/>
                            <field name="source_count"/>
                            <field name="production_names"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_print_report" type="object" string="Stampa PDF" class="btn-primary"/>
                    <button string="Chiudi" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_cf_raw_material_summary_mrp" model="ir.actions.act_window">
        <field name="name">Resoconto Materie Prime</field>
        <field name="res_model">cf.raw.material.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_cf_raw_material_summary_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'active_model': 'mrp.production'}</field>
        <field name="binding_model_id" ref="mrp.model_mrp_production"/>
        <field name="binding_view_types">list,form</field>
    </record>

    <record id="action_cf_raw_material_summary_sale" model="ir.actions.act_window">
        <field name="name">Resoconto Materie Prime</field>
        <field name="res_model">cf.raw.material.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_cf_raw_material_summary_wizard_form"/>
        <field name="target">new</field>
        <field name="context">{'active_model': 'sale.order'}</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">list,form</field>
    </record>
</odoo>
