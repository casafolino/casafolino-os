<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="cf_mail_client.App">
        <div class="cf-mail-app">
            <t t-call="cf_mail_client.Sidebar"/>
            <t t-call="cf_mail_client.ListCol"/>
            <t t-call="cf_mail_client.DetailCol"/>
        </div>
    </t>

    <t t-name="cf_mail_client.Sidebar">
        <div class="cf-mail-sidebar">
            <div class="cf-mail-logo">
                <div class="cf-mail-logo-mark">CF</div>
                <div class="cf-mail-logo-text">
                    CasaFolino
                    <span>Mail Client</span>
                </div>
            </div>
            <button class="cf-mail-compose-btn" t-on-click="openComposer">
                <i class="fa fa-pen"/>
                Nuovo Messaggio
            </button>
            <div class="cf-mail-nav-item" t-att-class="state.folder === 'INBOX' ? 'active' : ''" t-on-click="() => this.setFolder('INBOX')">
                <i class="fa fa-inbox nav-icon"/>
                Inbox
                <span t-if="state.totalUnread > 0" class="cf-mail-nav-badge" t-esc="state.totalUnread"/>
            </div>
            <div class="cf-mail-nav-item" t-att-class="state.folder === 'Starred' ? 'active' : ''" t-on-click="() => this.setFolder('Starred')">
                <i class="fa fa-star nav-icon"/>
                Preferiti
            </div>
            <div class="cf-mail-nav-item" t-att-class="state.folder === 'Sent' ? 'active' : ''" t-on-click="() => this.setFolder('Sent')">
                <i class="fa fa-paper-plane nav-icon"/>
                Inviati
            </div>
            <div class="cf-mail-nav-item" t-att-class="state.folder === 'Archived' ? 'active' : ''" t-on-click="() => this.setFolder('Archived')">
                <i class="fa fa-archive nav-icon"/>
                Archivio
            </div>
            <div class="cf-mail-divider"/>
            <div class="cf-mail-section-title">Account</div>
            <t t-foreach="state.accounts" t-as="acc" t-key="acc.id">
                <div class="cf-mail-account-header" t-on-click="() => this.selectAccount(acc.id)">
                    <div class="cf-mail-account-dot" t-att-style="'background:' + acc.color"/>
                    <span style="flex:1;font-size:11px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" t-esc="acc.email"/>
                    <span t-if="acc.unread > 0" style="font-size:10px;background:#5A6E3A;color:white;border-radius:8px;padding:1px 6px;" t-esc="acc.unread"/>
                </div>
            </t>
        </div>
    </t>

    <t t-name="cf_mail_client.ListCol">
        <div class="cf-mail-list-col">
            <div class="cf-mail-list-toolbar">
                <div class="cf-mail-search-wrap">
                    <i class="fa fa-search"/>
                    <input type="text" t-att-value="state.search" t-on-input="onSearch" placeholder="Cerca in Mail..."/>
                </div>
                <button class="cf-mail-toolbar-btn" t-on-click="loadMessages" title="Sincronizza">
                    <i class="fa fa-sync"/>
                </button>
            </div>
            <t t-if="state.selectedIds.length > 0" t-call="cf_mail_client.BulkBar"/>
            <div class="cf-mail-list-header">
                <input type="checkbox" t-on-change="toggleSelectAll" style="accent-color:#5A6E3A"/>
                <span class="cf-mail-list-header-label" t-esc="listHeaderLabel"/>
            </div>
            <div class="cf-mail-email-list">
                <t t-if="state.loading">
                    <div class="cf-mail-loading"><i class="fa fa-spinner fa-spin"/> Caricamento...</div>
                </t>
                <t t-elif="state.messages.length === 0">
                    <div class="cf-mail-empty">
                        <i class="fa fa-inbox"/>
                        <span>Nessun messaggio</span>
                    </div>
                </t>
                <t t-else="">
                    <t t-foreach="state.messages" t-as="msg" t-key="msg.id">
                        <div t-att-class="'cf-mail-email-item ' + (msg.is_read ? 'read' : 'unread') + (state.selectedMsg and state.selectedMsg.id === msg.id ? ' selected' : '')"
                             t-on-click="(ev) => this.selectMsg(msg, ev)">
                            <input type="checkbox" class="cf-item-cb"
                                   t-att-checked="state.selectedIds.includes(msg.id)"
                                   t-on-change="(ev) => this.toggleSelect(msg.id, ev)"
                                   t-on-click.stop="() => {}"/>
                            <div class="cf-item-avatar" t-att-style="'background:' + this.avatarColor(msg.from_name || msg.from_address)">
                                <t t-esc="this.avatarInitial(msg.from_name || msg.from_address)"/>
                            </div>
                            <div class="cf-item-body">
                                <div class="cf-item-row1">
                                    <span class="cf-item-from" t-esc="msg.from_name || msg.from_address"/>
                                    <span class="cf-item-date" t-esc="msg.date_short"/>
                                </div>
                                <div class="cf-item-subject" t-esc="msg.subject"/>
                                <div class="cf-item-snippet" t-esc="msg.snippet"/>
                                <div t-if="msg.tags and msg.tags.length > 0" class="cf-item-tags">
                                    <t t-foreach="msg.tags" t-as="tag" t-key="tag.id">
                                        <span class="cf-mail-tag" t-att-style="'background:' + tag.color + '22;color:' + tag.color" t-esc="tag.name"/>
                                    </t>
                                </div>
                            </div>
                            <div class="cf-item-actions">
                                <button class="cf-item-action-btn" t-on-click.stop="(ev) => this.quickStar(msg.id, ev)" title="Preferita">
                                    <i t-att-class="'fa fa-star' + (msg.is_starred ? '' : '-o')"/>
                                </button>
                                <button class="cf-item-action-btn" t-on-click.stop="(ev) => this.quickArchive(msg.id, ev)" title="Archivia">
                                    <i class="fa fa-archive"/>
                                </button>
                            </div>
                        </div>
                    </t>
                </t>
            </div>
        </div>
    </t>

    <t t-name="cf_mail_client.BulkBar">
        <div class="cf-mail-bulk-bar">
            <i class="fa fa-check-square"/>
            <span t-esc="state.selectedIds.length"/> selezionate
            <button class="cf-mail-bulk-btn" t-on-click="() => this.bulkAction('read')">Lette</button>
            <button class="cf-mail-bulk-btn" t-on-click="() => this.bulkAction('archive')">
                <i class="fa fa-archive"/> Archivia
            </button>
            <button class="cf-mail-bulk-btn" t-on-click="() => this.bulkAction('star')">
                <i class="fa fa-star"/>
            </button>
            <button class="cf-mail-bulk-btn danger" t-on-click="() => this.bulkAction('delete')">
                <i class="fa fa-trash"/>
            </button>
        </div>
    </t>

    <t t-name="cf_mail_client.DetailCol">
        <div class="cf-mail-detail-col">
            <t t-if="!state.selectedMsg">
                <div class="cf-mail-detail-empty">
                    <i class="fa fa-envelope-open"/>
                    <p>Seleziona un messaggio</p>
                </div>
            </t>
            <t t-else="">
                <div class="cf-mail-detail-header">
                    <div class="cf-mail-detail-subject" t-esc="state.msgDetail.subject || state.selectedMsg.subject"/>
                    <div class="cf-mail-detail-meta">
                        <div class="cf-mail-sender-avatar" t-att-style="'background:' + this.avatarColor(state.msgDetail.from_name || state.msgDetail.from_address || '')">
                            <t t-esc="this.avatarInitial(state.msgDetail.from_name || state.msgDetail.from_address || '')"/>
                        </div>
                        <div class="cf-mail-sender-info">
                            <div class="cf-mail-sender-name" t-esc="state.msgDetail.from_name || state.msgDetail.from_address"/>
                            <div class="cf-mail-sender-email" t-esc="state.msgDetail.from_address"/>
                        </div>
                        <div class="cf-mail-detail-date" t-esc="state.msgDetail.date"/>
                    </div>
                    <div class="cf-mail-detail-actions">
                        <button class="cf-mail-btn-primary" t-on-click="openReply">
                            <i class="fa fa-reply"/> Rispondi
                        </button>
                        <button class="cf-mail-btn-secondary" t-on-click="openForward">
                            <i class="fa fa-share"/> Inoltra
                        </button>
                        <button t-att-class="'cf-mail-btn-icon' + (state.selectedMsg.is_starred ? ' starred' : '')"
                                t-on-click="() => this.quickStar(state.selectedMsg.id, null)">
                            <i class="fa fa-star"/>
                        </button>
                        <button class="cf-mail-btn-icon" t-on-click="() => this.quickArchive(state.selectedMsg.id, null)">
                            <i class="fa fa-archive"/>
                        </button>
                        <button class="cf-mail-btn-icon lead" t-on-click="createLead" title="Crea Trattativa CRM">
                            <i class="fa fa-plus"/>
                        </button>
                    </div>
                </div>
                <div class="cf-mail-detail-body">
                    <div class="cf-mail-email-content" t-ref="emailContent">
                        <t t-if="state.loadingDetail">
                            <div class="cf-mail-loading"><i class="fa fa-spinner fa-spin"/> Caricamento...</div>
                        </t>
                    </div>
                    <div class="cf-mail-context-panel">
                        <div class="cf-mail-ctx-section">
                            <div class="cf-mail-ctx-title"><i class="fa fa-user"/> Contatto</div>
                            <div t-if="state.msgDetail.partner_name" class="cf-mail-contact-card">
                                <div class="cf-mail-contact-avatar" t-att-style="'background:' + this.avatarColor(state.msgDetail.partner_name)">
                                    <t t-esc="this.avatarInitial(state.msgDetail.partner_name)"/>
                                </div>
                                <div>
                                    <div class="cf-mail-contact-name" t-esc="state.msgDetail.partner_name"/>
                                    <div class="cf-mail-contact-company" t-esc="state.msgDetail.from_address"/>
                                </div>
                            </div>
                            <div t-else="" style="font-size:12px;color:#80868b">Mittente non in rubrica</div>
                        </div>
                        <div t-if="state.msgDetail.partner_leads and state.msgDetail.partner_leads.length > 0" class="cf-mail-ctx-section">
                            <div class="cf-mail-ctx-title"><i class="fa fa-handshake"/> Trattative</div>
                            <t t-foreach="state.msgDetail.partner_leads" t-as="lead" t-key="lead.id">
                                <div class="cf-mail-ctx-item">
                                    <span class="cf-mail-ctx-item-name" t-esc="lead.name"/>
                                    <span class="cf-mail-ctx-badge blue" t-esc="lead.stage"/>
                                </div>
                            </t>
                        </div>
                        <div t-if="state.msgDetail.partner_orders and state.msgDetail.partner_orders.length > 0" class="cf-mail-ctx-section">
                            <div class="cf-mail-ctx-title"><i class="fa fa-shopping-cart"/> Ordini</div>
                            <t t-foreach="state.msgDetail.partner_orders" t-as="ord" t-key="ord.id">
                                <div class="cf-mail-ctx-item">
                                    <span class="cf-mail-ctx-item-name" t-esc="ord.name"/>
                                    <span class="cf-mail-ctx-badge green" t-esc="(ord.currency || '€') + ' ' + ord.amount"/>
                                </div>
                            </t>
                        </div>
                        <div class="cf-mail-ctx-section">
                            <div class="cf-mail-ctx-title"><i class="fa fa-user-circle"/> Assegna a</div>
                            <select class="cf-mail-ctx-select" t-on-change="onAssignChange">
                                <option value="">— Seleziona —</option>
                                <t t-foreach="state.users" t-as="u" t-key="u.id">
                                    <option t-att-value="u.id"
                                            t-att-selected="state.msgDetail.assigned_user_id === u.id"
                                            t-esc="u.name"/>
                                </t>
                            </select>
                            <div t-if="state.msgDetail.assigned_user_name" class="cf-mail-assigned-badge">
                                <i class="fa fa-check-circle"/>
                                <t t-esc="state.msgDetail.assigned_user_name"/>
                            </div>
                        </div>
                        <div class="cf-mail-ctx-section">
                            <div class="cf-mail-ctx-title"><i class="fa fa-link"/> Collega CRM</div>
                            <select class="cf-mail-ctx-select" t-on-change="onLeadLinkChange">
                                <option value="">— Seleziona trattativa —</option>
                                <t t-foreach="state.leads" t-as="l" t-key="l.id">
                                    <option t-att-value="l.id"
                                            t-att-selected="state.msgDetail.lead_id === l.id"
                                            t-esc="l.name"/>
                                </t>
                            </select>
                        </div>
                    </div>
                </div>
                <t t-if="state.showComposer" t-call="cf_mail_client.Composer"/>
            </t>
        </div>
    </t>

    <t t-name="cf_mail_client.Composer">
        <div class="cf-mail-composer">
            <div class="cf-mail-composer-header">
                <span class="cf-mail-composer-title" t-esc="state.composerMode === 'reply' ? '&#8617; Rispondi' : state.composerMode === 'forward' ? '&#8618; Inoltra' : '&#9998; Nuovo messaggio'"/>
                <div style="display:flex;gap:4px">
                    <button class="cf-mail-btn-icon" style="width:28px;height:28px;font-size:11px" t-on-click="closeComposer">
                        <i class="fa fa-times"/>
                    </button>
                </div>
            </div>
            <div class="cf-mail-composer-fields">
                <div class="cf-mail-composer-field">
                    <span class="cf-mail-composer-label">A:</span>
                    <input class="cf-mail-composer-input" t-att-value="state.composerTo" t-on-input="(e) => this.state.composerTo = e.target.value"/>
                </div>
                <div class="cf-mail-composer-field">
                    <span class="cf-mail-composer-label">Ogg:</span>
                    <input class="cf-mail-composer-input" t-att-value="state.composerSubject" t-on-input="(e) => this.state.composerSubject = e.target.value"/>
                </div>
            </div>
            <div class="cf-mail-composer-toolbar">
                <button class="cf-mail-fmt-btn" t-on-click="() => document.execCommand('bold')"><b>B</b></button>
                <button class="cf-mail-fmt-btn" t-on-click="() => document.execCommand('italic')"><i>I</i></button>
                <button class="cf-mail-fmt-btn" t-on-click="() => document.execCommand('underline')"><u>U</u></button>
                <div class="cf-mail-fmt-sep"/>
                <button class="cf-mail-fmt-btn" t-on-click="() => document.execCommand('insertUnorderedList')"><i class="fa fa-list-ul"/></button>
                <button class="cf-mail-fmt-btn" t-on-click="() => document.execCommand('insertOrderedList')"><i class="fa fa-list-ol"/></button>
                <div class="cf-mail-fmt-sep"/>
                <button class="cf-mail-fmt-btn"><i class="fa fa-paperclip"/></button>
            </div>
            <div class="cf-mail-composer-body" contenteditable="true" t-ref="composerBody"
                 style="font-family:'Plus Jakarta Sans',sans-serif"/>
            <div class="cf-mail-composer-footer">
                <button class="cf-mail-btn-primary" t-on-click="sendEmail">
                    <i class="fa fa-paper-plane"/> Invia
                </button>
                <button class="cf-mail-btn-secondary" t-on-click="closeComposer">
                    Annulla
                </button>
            </div>
        </div>
    </t>
</templates>
