<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="cf_lead_mail_widget.Main">
    <div class="cf-lead-mail">
        <!-- Toolbar -->
        <div class="cf-lead-mail-toolbar">
            <button class="btn btn-primary btn-sm" t-on-click="onClickNewEmail">
                <i class="fa fa-pencil me-1"/> Nuova Email
            </button>
            <button class="btn btn-outline-secondary btn-sm ms-1" t-on-click="loadMessages">
                <i class="fa fa-refresh"/>
            </button>
            <span class="ms-2 text-muted small" t-if="state.messages.length">
                <t t-esc="state.messages.length"/> email
            </span>
        </div>

        <!-- Loading -->
        <div t-if="state.loading" class="text-center py-3 text-muted">
            <i class="fa fa-spinner fa-spin"/> Caricamento...
        </div>

        <!-- Empty -->
        <div t-if="!state.loading and !state.messages.length" class="text-center py-4 text-muted">
            <i class="fa fa-inbox fa-2x mb-2 d-block"/>
            Nessuna email collegata
        </div>

        <!-- Email list -->
        <div t-if="!state.loading and state.messages.length" class="cf-lead-mail-list">
            <t t-foreach="state.messages" t-as="msg" t-key="msg.id">
                <div t-attf-class="cf-lead-mail-row #{!msg.is_read ? 'cf-unread' : ''} #{state.expandedId === msg.id ? 'cf-expanded' : ''}"
                     t-on-click="() => this.onClickRow(msg.id)">
                    <div class="cf-lead-mail-row-main">
                        <span t-attf-class="cf-lead-mail-dir #{msg.direction === 'out' ? 'cf-dir-out' : 'cf-dir-in'}">
                            <i t-attf-class="fa #{msg.direction === 'out' ? 'fa-arrow-right' : 'fa-arrow-left'}"/>
                        </span>
                        <span class="cf-lead-mail-sender" t-esc="msg.from_name || msg.from_address"/>
                        <span class="cf-lead-mail-subject" t-esc="msg.subject"/>
                        <span t-if="msg.has_attachments" class="cf-lead-mail-att-icon"><i class="fa fa-paperclip"/></span>
                        <span class="cf-lead-mail-date" t-esc="msg.date_short"/>
                    </div>
                </div>

                <!-- Expanded detail -->
                <t t-if="state.expandedId === msg.id">
                    <div class="cf-lead-mail-detail">
                        <t t-if="!state.expandedDetail">
                            <div class="text-center py-2 text-muted">
                                <i class="fa fa-spinner fa-spin"/> Caricamento...
                            </div>
                        </t>
                        <t t-if="state.expandedDetail">
                            <div class="cf-lead-mail-detail-header">
                                <div><strong>Da:</strong> <t t-esc="state.expandedDetail.from_name"/> &lt;<t t-esc="state.expandedDetail.from_address"/>&gt;</div>
                                <div t-if="state.expandedDetail.to_address"><strong>A:</strong> <t t-esc="state.expandedDetail.to_address"/></div>
                                <div t-if="state.expandedDetail.cc_address"><strong>CC:</strong> <t t-esc="state.expandedDetail.cc_address"/></div>
                                <div><strong>Data:</strong> <t t-esc="state.expandedDetail.date"/></div>
                            </div>
                            <div class="cf-lead-mail-detail-actions mb-2">
                                <button class="btn btn-sm btn-outline-primary" t-on-click="() => this.onClickReply(msg)">
                                    <i class="fa fa-reply me-1"/> Rispondi
                                </button>
                            </div>
                            <!-- Allegati -->
                            <div t-if="state.expandedDetail.attachments and state.expandedDetail.attachments.length" class="cf-lead-mail-attachments mb-2">
                                <t t-foreach="state.expandedDetail.attachments" t-as="att" t-key="att.id">
                                    <a t-attf-href="/web/content/ir.attachment/#{att.id}/#{att.name}" target="_blank" class="cf-att-chip">
                                        <i class="fa fa-paperclip me-1"/><t t-esc="att.name"/>
                                    </a>
                                </t>
                            </div>
                            <div class="cf-lead-mail-body">
                                <iframe class="cf-lead-mail-iframe" t-att-srcdoc="state.expandedDetail.body_html"/>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </div>

        <!-- Composer -->
        <t t-if="state.showComposer">
            <div class="cf-lead-mail-composer">
                <div class="cf-lead-mail-composer-header">
                    <strong t-if="state.replyToId">Rispondi</strong>
                    <strong t-else="">Nuova Email</strong>
                    <button class="btn-close btn-sm float-end" t-on-click="onCloseComposer"/>
                </div>
                <div class="cf-lead-mail-composer-fields">
                    <!-- Toolbar -->
                    <div class="mb-2">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-secondary" t-on-click="onToggleTemplates">
                                <i class="fa fa-file-text-o me-1"/> Template
                            </button>
                            <div style="position:relative;display:inline-block;">
                                <button class="btn btn-outline-secondary" t-on-click="toggleAttachDropdown">
                                    <i class="fa fa-paperclip me-1"/> Allega
                                </button>
                                <div t-if="state.showAttachDropdown" style="position:absolute;top:100%;left:0;background:#fff;border:1px solid #dee2e6;border-radius:4px;box-shadow:0 2px 8px rgba(0,0,0,.15);z-index:100;white-space:nowrap;margin-top:2px;">
                                    <div style="padding:6px 12px;cursor:pointer;font-size:12px;" t-on-click="onAttachFromPC">
                                        <i class="fa fa-laptop me-1"/> Dal computer
                                    </div>
                                    <div style="padding:6px 12px;cursor:pointer;font-size:12px;border-top:1px solid #f0f0f0;" t-on-click="openAttachFromOdoo">
                                        <i class="fa fa-folder-o me-1"/> Da Documenti Odoo
                                    </div>
                                    <div style="padding:6px 12px;cursor:pointer;font-size:12px;border-top:1px solid #f0f0f0;" t-on-click="openUrlModal">
                                        <i class="fa fa-link me-1"/> Da URL
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input type="file" class="d-none" t-ref="fileInput" multiple="multiple" t-on-change="onFileSelected"/>
                    </div>
                    <!-- Template list -->
                    <div t-if="state.showTemplates" class="cf-template-list mb-2">
                        <t t-foreach="state.templates" t-as="tpl" t-key="tpl.id">
                            <div class="cf-template-item" t-on-click="() => this.onSelectTemplate(tpl)">
                                <span class="badge bg-secondary me-1" t-esc="tpl.category"/>
                                <t t-esc="tpl.name"/>
                            </div>
                        </t>
                        <div t-if="!state.templates.length" class="text-muted small p-2">Nessun template</div>
                    </div>
                    <div class="mb-1">
                        <label class="cf-composer-label">A:</label>
                        <input class="form-control form-control-sm" t-att-value="state.composerTo" t-on-input="onInputTo"/>
                    </div>
                    <div class="mb-1">
                        <label class="cf-composer-label">CC:</label>
                        <input class="form-control form-control-sm" t-att-value="state.composerCc" t-on-input="onInputCc"/>
                    </div>
                    <div class="mb-1">
                        <label class="cf-composer-label">Oggetto:</label>
                        <input class="form-control form-control-sm" t-att-value="state.composerSubject" t-on-input="onInputSubject"/>
                    </div>
                    <div class="mb-2">
                        <div class="cf-composer-body form-control" contenteditable="true"
                             t-ref="composerBody"
                             t-on-input="onInputBody"
                             style="min-height: 120px;"/>
                    </div>
                    <!-- Attachment list -->
                    <div t-if="state.composerAttachments.length" class="cf-composer-att-list mb-2">
                        <t t-foreach="state.composerAttachments" t-as="att" t-key="att.id || att.tempId">
                            <div class="cf-att-chip">
                                <i class="fa fa-paperclip me-1"/>
                                <t t-esc="att.name"/>
                                <span class="text-muted ms-1 small" t-if="att.size">(<t t-esc="Math.round(att.size/1024)"/>KB)</span>
                                <i class="fa fa-times ms-1 cf-att-remove" t-on-click="() => this.onRemoveAttachment(att)"/>
                            </div>
                        </t>
                    </div>
                    <button class="btn btn-primary btn-sm" t-on-click="onSendEmail"
                            t-att-disabled="state.composerSending">
                        <i t-attf-class="fa #{state.composerSending ? 'fa-spinner fa-spin' : 'fa-paper-plane'} me-1"/>
                        Invia
                    </button>
                </div>
            </div>
        </t>

        <!-- Modale: Allega da Odoo -->
        <div t-if="state.showAttachModal" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:1050;display:flex;align-items:center;justify-content:center;">
            <div style="background:#fff;border-radius:8px;width:500px;max-height:70vh;display:flex;flex-direction:column;">
                <div style="padding:12px 16px;border-bottom:1px solid #dee2e6;display:flex;justify-content:space-between;align-items:center;">
                    <strong>Allega da Documenti Odoo</strong>
                    <span style="cursor:pointer;font-size:18px;" t-on-click="closeAttachModal">&#x2715;</span>
                </div>
                <div style="padding:8px 16px;">
                    <input type="text" placeholder="Cerca documento..." t-att-value="state.attachModalSearch"
                           t-on-input="onAttachModalSearch"
                           style="width:100%;padding:6px 10px;border:1px solid #ddd;border-radius:4px;font-size:13px;"/>
                </div>
                <div style="overflow-y:auto;flex:1;padding:0 16px;">
                    <t t-foreach="state.attachModalResults" t-as="r" t-key="r.id || r_index">
                        <div style="display:flex;align-items:center;padding:6px 0;border-bottom:1px solid #f5f5f5;cursor:pointer;font-size:13px;"
                             t-on-click="() => this.toggleAttachSelect(r.id)">
                            <input type="checkbox" t-att-checked="state.attachModalSelected.indexOf(r.id) >= 0" style="margin-right:8px;"/>
                            <i class="fa fa-file-o me-1" style="color:#888;"/>
                            <span style="flex:1;" t-esc="r.name"/>
                            <span class="text-muted ms-2" style="font-size:11px;" t-if="r.size">
                                <t t-esc="Math.round(r.size / 1024)"/>KB
                            </span>
                        </div>
                    </t>
                    <div t-if="!state.attachModalResults.length" class="text-muted text-center py-3">Nessun risultato</div>
                </div>
                <div style="padding:10px 16px;border-top:1px solid #dee2e6;text-align:right;">
                    <button class="btn btn-primary btn-sm me-1" t-on-click="confirmAttachFromOdoo">
                        Aggiungi (<t t-esc="state.attachModalSelected.length"/>)
                    </button>
                    <button class="btn btn-secondary btn-sm" t-on-click="closeAttachModal">Annulla</button>
                </div>
            </div>
        </div>

        <!-- Modale: URL -->
        <div t-if="state.showUrlModal" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:1050;display:flex;align-items:center;justify-content:center;">
            <div style="background:#fff;border-radius:8px;width:450px;padding:20px;">
                <div style="margin-bottom:12px;display:flex;justify-content:space-between;align-items:center;">
                    <strong>Allega da URL</strong>
                    <span style="cursor:pointer;font-size:18px;" t-on-click="closeUrlModal">&#x2715;</span>
                </div>
                <input type="text" placeholder="https://..." t-att-value="state.urlInput"
                       t-on-input="onUrlInput"
                       style="width:100%;padding:8px 10px;border:1px solid #ddd;border-radius:4px;font-size:13px;margin-bottom:12px;"/>
                <div style="text-align:right;">
                    <button class="btn btn-primary btn-sm me-1" t-on-click="confirmUrlAttach">Scarica e allega</button>
                    <button class="btn btn-secondary btn-sm" t-on-click="closeUrlModal">Annulla</button>
                </div>
            </div>
        </div>
    </div>
</t>

</templates>
