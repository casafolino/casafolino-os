<?xml version="1.0" encoding="UTF-8"?>
<templates>
  <t t-name="casafolino_mail.Sidebar360">
    <div class="mv3-sidebar360">
      <div t-if="props.loading" class="mv3-sidebar360__loading">
        <i class="fa fa-spinner fa-spin"/>
      </div>
      <div t-if="!props.loading and props.data" class="mv3-sidebar360__content">

        <!-- 1. Company / Identity Block -->
        <div class="mv3-sidebar360__block mv3-company-block" t-if="props.data.company and props.data.company.name">
          <div class="mv3-company-block__header">
            <h3 t-out="props.data.company.name"/>
            <span t-if="props.data.company.hotness_score"
                  t-att-class="'mv3-hotness-badge ' + this.getHotnessClass(props.data.company.hotness_tier)">
              <t t-out="props.data.company.hotness_emoji"/>
              <strong t-out="props.data.company.hotness_score"/>/100
            </span>
          </div>
          <div class="mv3-company-block__meta">
            <t t-if="props.data.company.country">
              <span t-out="props.data.company.country"/>
            </t>
            <span t-if="props.data.company.vat" class="mv3-company-block__vat">
              P.IVA: <t t-out="props.data.company.vat"/>
            </span>
          </div>
          <div t-if="props.data.company.website" class="mv3-company-block__website">
            <a t-att-href="props.data.company.website" target="_blank">
              <t t-out="props.data.company.website"/>
            </a>
          </div>
          <div class="mv3-tags" t-if="props.data.company.tags and props.data.company.tags.length > 0">
            <t t-foreach="props.data.company.tags" t-as="tag" t-key="tag.id">
              <span class="mv3-tag"><t t-out="tag.name"/></span>
            </t>
          </div>
          <div class="mv3-company-block__feedback">
            <button class="btn btn-xs btn-outline-success" t-on-click="pinHot" title="Pin Hot">🔥 Pin Hot</button>
            <button class="btn btn-xs btn-outline-secondary" t-on-click="pinIgnore" title="Pin Ignore">🚫 Ignora</button>
          </div>
        </div>

        <!-- 2. NBA Block (sticky) -->
        <div t-if="props.data.nba and props.data.nba.nba_text"
             t-att-class="'mv3-nba-block mv3-nba-block--' + (props.data.nba.nba_urgency || 'info')">
          <div class="mv3-nba-block__icon">🎯</div>
          <div class="mv3-nba-block__body">
            <div class="mv3-nba-block__label">Next Best Action</div>
            <div class="mv3-nba-block__text" t-out="props.data.nba.nba_text"/>
            <div t-if="props.data.nba.nba_from_llm" class="mv3-nba-block__meta">
              <span>🤖 AI suggestion</span>
            </div>
            <div t-elif="props.data.nba.nba_rule_id" class="mv3-nba-block__meta">
              <span>Regola #<t t-out="props.data.nba.nba_rule_id"/></span>
            </div>
          </div>
          <button class="mv3-nba-block__dismiss"
                  t-on-click="dismissNba"
                  title="Ignora suggerimento">×</button>
        </div>

        <!-- 3. Person Block -->
        <div class="mv3-sidebar360__block mv3-person-block" t-if="props.data.person and props.data.person.name">
          <h4>Contatto</h4>
          <div class="mv3-person-block__name" t-out="props.data.person.name"/>
          <div t-if="props.data.person.role" class="mv3-person-block__role" t-out="props.data.person.role"/>
          <div t-if="props.data.person.email" class="mv3-person-block__email">
            <i class="fa fa-envelope-o"/> <t t-out="props.data.person.email"/>
          </div>
          <div t-if="props.data.person.phone" class="mv3-person-block__phone">
            <i class="fa fa-phone"/> <t t-out="props.data.person.phone"/>
          </div>
        </div>

        <!-- 4. Relation Block -->
        <div class="mv3-sidebar360__block mv3-relation-block" t-if="props.data.relation">
          <h4>Relazione</h4>
          <div class="mv3-relation-block__row">
            <span class="mv3-relation-block__label">Primo contatto</span>
            <span t-out="props.data.relation.first_contact || '-'"/>
          </div>
          <div class="mv3-relation-block__row">
            <span class="mv3-relation-block__label">Email totali</span>
            <span t-out="props.data.relation.total_emails"/>
          </div>
          <div class="mv3-relation-block__row">
            <span class="mv3-relation-block__label">Ultima risposta</span>
            <span t-out="props.data.relation.last_reply || '-'"/>
          </div>
        </div>

        <!-- 5. Business Block -->
        <div class="mv3-sidebar360__block mv3-business-block" t-if="props.data.business">
          <h4>Business</h4>
          <div class="mv3-business-block__row">
            <span class="mv3-business-block__label">Fatturato YTD</span>
            <span t-out="this.formatCurrency(props.data.business.ytd_revenue)"/>
          </div>
          <div class="mv3-business-block__row">
            <span class="mv3-business-block__label">Ordini aperti</span>
            <span t-out="props.data.business.open_orders"/>
          </div>
          <div class="mv3-business-block__row">
            <span class="mv3-business-block__label">Scaduto</span>
            <span t-att-class="props.data.business.overdue > 0 ? 'text-danger fw-bold' : ''"
                  t-out="props.data.business.overdue"/>
          </div>
        </div>

        <!-- 6. Pipeline Block -->
        <div class="mv3-sidebar360__block mv3-pipeline-block"
             t-if="props.data.pipeline and props.data.pipeline.length > 0">
          <h4>Pipeline</h4>
          <t t-foreach="props.data.pipeline" t-as="lead" t-key="lead.id">
            <div class="mv3-pipeline-block__item">
              <div class="mv3-pipeline-block__name" t-out="lead.name"/>
              <div class="mv3-pipeline-block__meta">
                <span class="mv3-pipeline-block__stage" t-out="lead.stage"/>
                <span t-if="lead.revenue" class="mv3-pipeline-block__revenue">
                  €<t t-out="Math.round(lead.revenue).toLocaleString('it-IT')"/>
                </span>
              </div>
            </div>
          </t>
        </div>

        <!-- 6b. Commercial Context Block (F6) -->
        <div class="mv3-sidebar360__block mv3-commercial-block">
          <div class="mv3-commercial-block__header" t-on-click="toggleCommercialContext">
            <h4>💼 Commercial Context</h4>
            <i t-att-class="'fa ' + (state.commercialExpanded ? 'fa-chevron-up' : 'fa-chevron-down')"/>
          </div>
          <div t-if="state.commercialExpanded and state.commercialData" class="mv3-commercial-block__body">
            <div class="mv3-commercial-block__kpis">
              <div class="mv3-commercial-block__kpi">
                <span class="mv3-commercial-block__kpi-label">Fatturato 12m</span>
                <span class="mv3-commercial-block__kpi-value" t-out="this.formatCurrency(state.commercialData.total_revenue_12m)"/>
              </div>
              <div class="mv3-commercial-block__kpi">
                <span class="mv3-commercial-block__kpi-label"># Ordini</span>
                <span class="mv3-commercial-block__kpi-value" t-out="state.commercialData.order_count_12m"/>
              </div>
              <div class="mv3-commercial-block__kpi">
                <span class="mv3-commercial-block__kpi-label">Ultimo ordine</span>
                <span class="mv3-commercial-block__kpi-value" t-out="state.commercialData.last_order_date || '-'"/>
              </div>
            </div>
            <div t-if="state.commercialData.top_skus and state.commercialData.top_skus.length" class="mv3-commercial-block__skus">
              <strong>Top 5 SKU</strong>
              <t t-foreach="state.commercialData.top_skus" t-as="sku" t-key="sku.product_id">
                <div class="mv3-commercial-block__sku-row">
                  <span t-out="sku.name"/> <small class="text-muted">(<t t-out="Math.round(sku.qty)"/> pz)</small>
                </div>
              </t>
            </div>
            <div class="mv3-commercial-block__counts">
              <span>Lead aperti: <strong t-out="state.commercialData.open_leads_count"/></span>
              <span>Quote aperte: <strong t-out="state.commercialData.open_quotes_count"/></span>
            </div>
            <div class="mv3-commercial-block__meta">
              <span>Listino: <t t-out="state.commercialData.pricelist || '-'"/></span>
              <span>Pagamento: <t t-out="state.commercialData.payment_term || '-'"/></span>
            </div>
            <button class="btn btn-sm btn-outline-primary mt-2" t-on-click="openPartnerForm">
              Apri partner completo
            </button>
          </div>
          <div t-if="state.commercialExpanded and state.commercialLoading" class="text-center p-2">
            <i class="fa fa-spinner fa-spin"/>
          </div>
        </div>

        <!-- 6c. Quick Convert Quote (F6) -->
        <div class="mv3-sidebar360__block mv3-quote-block" t-if="props.data.partner_id">
          <button class="btn btn-sm btn-warning w-100" t-on-click="openQuoteWizard">
            💰 Crea offerta
          </button>
        </div>

        <!-- 7. Timeline Block -->
        <div class="mv3-sidebar360__block mv3-timeline-block"
             t-if="props.data.timeline and props.data.timeline.length > 0">
          <h4>Timeline</h4>
          <t t-foreach="props.data.timeline" t-as="ev" t-key="ev.id">
            <div class="mv3-timeline-block__item">
              <span class="mv3-timeline-block__icon" t-out="this.getDirectionIcon(ev.direction)"/>
              <div class="mv3-timeline-block__detail">
                <div class="mv3-timeline-block__subject" t-out="ev.subject"/>
                <div class="mv3-timeline-block__date" t-out="ev.date"/>
              </div>
            </div>
          </t>
        </div>

        <!-- 8. Private Notes Block -->
        <div class="mv3-sidebar360__block mv3-notes-block">
          <h4>Note private</h4>
          <textarea class="mv3-notes-block__textarea"
                    t-att-value="state.notesValue"
                    t-on-input="onNotesInput"
                    placeholder="Scrivi note private su questo partner..."
                    rows="3"/>
        </div>

        <!-- 9. Quick Actions Block -->
        <div class="mv3-sidebar360__block mv3-actions-block" t-if="props.data.quick_actions">
          <h4>Azioni rapide</h4>
          <div class="mv3-actions-block__buttons">
            <t t-foreach="props.data.quick_actions" t-as="action" t-key="action.key">
              <button class="btn btn-sm btn-outline-secondary mv3-actions-block__btn"
                      t-on-click="() => this.onQuickAction(action.key)">
                <i t-att-class="'fa ' + action.icon"/> <t t-out="action.label"/>
              </button>
            </t>
          </div>
        </div>

      </div>
    </div>
  </t>
</templates>
