<?xml version="1.0" encoding="UTF-8"?>
<templates>
  <t t-name="casafolino_mail.SidebarLeft">
    <div class="mv3-sidebar-left">
      <!-- Compose button -->
      <div class="mv3-sidebar-left__icon mv3-sidebar-left__compose-btn"
           t-on-click="onComposeNew" title="Nuovo messaggio (c)">
        <i class="fa fa-pencil-square-o"/>
      </div>

      <div class="mv3-sidebar-left__divider"/>

      <!-- Tutti (inbox) -->
      <div class="mv3-sidebar-left__icon"
           t-att-class="{'mv3-sidebar-left__icon--active': !state.selectedAccountId and state.activeFolder === 'inbox'}"
           t-on-click="selectAll" title="Tutti">
        <span>📬</span>
        <span class="mv3-sidebar-left__badge" t-if="totalUnread > 0">
          <t t-out="totalUnread > 99 ? '99+' : totalUnread"/>
        </span>
      </div>

      <!-- Account avatars -->
      <t t-foreach="props.accounts" t-as="account" t-key="account.id">
        <div class="mv3-sidebar-left__avatar"
             t-att-class="{'mv3-sidebar-left__avatar--active': state.selectedAccountId === account.id}"
             t-att-style="'background:' + this.getAccountColor(account_index)"
             t-on-click="() => this.selectAccount(account.id)"
             t-att-title="account.name + ' (' + account.email + ') — ' + (account.unread_count || 0) + ' non lette'">
          <t t-out="account.initials || 'U'"/>
          <span class="mv3-sidebar-left__badge" t-if="account.unread_count > 0">
            <t t-out="account.unread_count > 99 ? '99+' : account.unread_count"/>
          </span>
        </div>
      </t>

      <div class="mv3-sidebar-left__divider"/>

      <!-- Folder icons -->
      <div class="mv3-sidebar-left__icon"
           t-att-class="{'mv3-sidebar-left__icon--active': state.activeFolder === 'starred'}"
           t-on-click="() => this.selectFolder('starred')" title="Speciali">
        <span>⭐</span>
      </div>
      <div class="mv3-sidebar-left__icon"
           t-att-class="{'mv3-sidebar-left__icon--active': state.activeFolder === 'snoozed'}"
           t-on-click="() => this.selectFolder('snoozed')" title="Snoozed">
        <span>💤</span>
      </div>
      <div class="mv3-sidebar-left__icon"
           t-att-class="{'mv3-sidebar-left__icon--active': state.activeFolder === 'scheduled'}"
           t-on-click="() => this.selectFolder('scheduled')" title="Programmate">
        <span>⏰</span>
      </div>
      <div class="mv3-sidebar-left__icon"
           t-att-class="{'mv3-sidebar-left__icon--active': state.activeFolder === 'sent'}"
           t-on-click="() => this.selectFolder('sent')" title="Inviati">
        <span>📤</span>
      </div>
      <div class="mv3-sidebar-left__icon"
           t-att-class="{'mv3-sidebar-left__icon--active': state.activeFolder === 'trash'}"
           t-on-click="() => this.selectFolder('trash')" title="Cestino">
        <span>🗑️</span>
      </div>
      <div class="mv3-sidebar-left__icon"
           t-att-class="{'mv3-sidebar-left__icon--active': state.activeFolder === 'dismissed'}"
           t-on-click="() => this.selectFolder('dismissed')" title="Mittenti dismessi">
        <span>🔄</span>
      </div>

      <!-- Spacer -->
      <div class="mv3-sidebar-left__spacer"/>

      <!-- V17: Notification bell toggle -->
      <div t-att-class="'mv3-sidebar-left__icon' + (props.notificationsEnabled ? ' mv3-sidebar-left__icon--active' : '')"
           t-on-click="onToggleNotifications"
           t-att-title="props.notificationsEnabled ? 'Disattiva notifiche' : 'Attiva notifiche'">
        <span t-if="props.notificationsEnabled">🔔</span>
        <span t-else="">🔕</span>
        <span class="mv3-sidebar-left__badge" t-if="props.notifUnreadCount > 0 and props.notificationsEnabled">
          <t t-out="props.notifUnreadCount > 99 ? '99+' : props.notifUnreadCount"/>
        </span>
      </div>

      <!-- Settings -->
      <div class="mv3-sidebar-left__icon" t-on-click="onOpenSettings" title="Impostazioni">
        <span>⚙️</span>
      </div>
    </div>
  </t>
</templates>
