<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="casafolino_mail.CFInboxSelector">
    <div t-if="state.isVisible" class="cf-inbox-selector">
        <button t-on-click="onToggleDropdown"
                t-attf-class="cf-inbox-pill cf-color-#{currentUser.color_class}">
            <span t-attf-class="cf-inbox-avatar cf-color-#{currentUser.color_class}">
                <t t-out="getInitials(currentUser.name)"/>
            </span>
            <span class="cf-inbox-pill-text">
                <t t-if="currentUser.is_self">la tua inbox</t>
                <t t-else="">vedo come <strong t-out="currentUser.name"/></t>
            </span>
            <i class="fa fa-chevron-down" style="margin-left:4px;"/>
        </button>

        <div t-if="state.isOpen" class="cf-inbox-dropdown">
            <t t-foreach="state.supervisableUsers" t-as="u" t-key="u.id">
                <div t-on-click="() => this.onSelectUser(u.id)"
                     t-attf-class="cf-inbox-dropdown-item #{u.id === state.viewingAsUserId ? 'active' : ''}">
                    <span t-attf-class="cf-inbox-avatar cf-color-#{u.color_class}">
                        <t t-out="getInitials(u.name)"/>
                    </span>
                    <span class="cf-inbox-dropdown-name">
                        <t t-out="u.name"/>
                        <small t-if="u.is_self" class="text-muted"> (tu)</small>
                    </span>
                    <small class="text-muted"><t t-out="u.accounts_count"/> caselle</small>
                </div>
            </t>
        </div>
    </div>
</t>

</templates>
