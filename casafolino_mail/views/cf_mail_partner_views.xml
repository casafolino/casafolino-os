<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_batch_enrich_007" model="ir.actions.server">
        <field name="name">Arricchisci selezionati con AI</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_enrich_007_batch()</field>
    </record>

    <record id="action_partner_emails" model="ir.actions.act_window">
        <field name="name">Email Contatto</field>
        <field name="res_model">cf.mail.message</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("partner_id","=",active_id)]</field>
    </record>

    <record id="view_partner_form_007" model="ir.ui.view">
        <field name="name">res.partner.form.007</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_enrich_007" string="Arricchisci con AI" type="object" class="oe_stat_button" icon="fa-user-secret"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Agente 007" name="agente_007">
                    <header>
                        <button name="action_enrich_007" string="Arricchisci con AI" type="object" class="btn-primary"/>
                    </header>
                    <group string="Stato Arricchimento">
                        <group>
                            <field name="cf_007_enriched" readonly="1"/>
                            <field name="cf_007_enriched_date" readonly="1"/>
                            <field name="cf_007_enriched_from" readonly="1"/>
                        </group>
                        <group>
                            <field name="cf_007_potenziale"/>
                            <field name="cf_007_ruolo_commerciale"/>
                        </group>
                    </group>
                    <group string="Note Agente">
                        <field name="cf_007_note_agente" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Valutazione CasaFolino">
                        <group>
                            <field name="cf_007_prodotti_interesse"/>
                            <field name="cf_007_mercati"/>
                            <field name="cf_007_certificazioni"/>
                            <field name="cf_007_canali_vendita"/>
                        </group>
                    </group>
                    <group string="Anagrafica Verificata">
                        <group>
                            <field name="cf_007_ragione_sociale"/>
                            <field name="cf_007_piva"/>
                            <field name="cf_007_codice_fiscale"/>
                            <field name="cf_007_rea"/>
                            <field name="cf_007_pec"/>
                            <field name="cf_007_forma_giuridica"/>
                        </group>
                        <group>
                            <field name="cf_007_indirizzo"/>
                            <field name="cf_007_cap"/>
                            <field name="cf_007_citta"/>
                            <field name="cf_007_provincia"/>
                            <field name="cf_007_paese"/>
                            <field name="cf_007_sito_web" widget="url"/>
                            <field name="cf_007_linkedin_company" widget="url"/>
                            <field name="cf_007_telefono"/>
                        </group>
                    </group>
                    <group string="Dati Societari">
                        <group>
                            <field name="cf_007_ateco"/>
                            <field name="cf_007_ateco_desc"/>
                            <field name="cf_007_capitale_sociale"/>
                            <field name="cf_007_data_costituzione"/>
                            <field name="cf_007_anzianita"/>
                            <field name="cf_007_stato_attivita"/>
                        </group>
                        <group>
                            <field name="cf_007_settore"/>
                            <field name="cf_007_marchi"/>
                            <field name="cf_007_dimensione"/>
                        </group>
                    </group>
                    <group string="Dati Finanziari Pubblici">
                        <group>
                            <field name="cf_007_fatturato"/>
                            <field name="cf_007_fatturato_anno"/>
                            <field name="cf_007_trend_ricavi"/>
                        </group>
                        <group>
                            <field name="cf_007_utile"/>
                            <field name="cf_007_dipendenti"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_partner_search_cf" model="ir.ui.view">
        <field name="name">res.partner.search.cf</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.res_partner_view_search"/>
        <field name="arch" type="xml">
            <search position="inside">
                <filter string="Non contattati da 90+ giorni"
                    name="cold_contacts"
                    domain="[('cf_last_contact', '&lt;', (context_today() - datetime.timedelta(days=90)).strftime('%Y-%m-%d %H:%M:%S'))]"/>
                <filter string="Mai contattati"
                    name="never_contacted"
                    domain="[('cf_last_contact', '=', False)]"/>
                <filter string="Contattati questo mese"
                    name="active_this_month"
                    domain="[('cf_last_contact', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Paese" name="group_country" context="{'group_by': 'country_id'}"/>
                    <filter string="Fonte" name="group_source" context="{'group_by': 'cf_source'}"/>
                    <filter string="Valutazione" name="group_rating" context="{'group_by': 'cf_rating'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
