<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Backfill AI Wizard Form -->
    <record id="casafolino_mail_backfill_ai_wizard_form" model="ir.ui.view">
        <field name="name">casafolino.mail.backfill.ai.wizard.form</field>
        <field name="model">casafolino.mail.backfill.ai.wizard</field>
        <field name="arch" type="xml">
            <form string="Backfill AI Classification">
                <group>
                    <group string="Filtri">
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="account_ids" widget="many2many_tags"/>
                        <field name="max_messages"/>
                    </group>
                    <group string="Stima" invisible="state == 'draft'">
                        <field name="estimated_count"/>
                        <field name="estimated_cost_eur"/>
                    </group>
                </group>
                <field name="result_message" invisible="state != 'done'" readonly="1"/>
                <field name="state" invisible="1"/>
                <footer>
                    <button name="action_estimate" string="Stima costo Groq"
                            type="object" class="btn btn-primary"
                            invisible="state not in ('draft', 'estimated')"/>
                    <button name="action_run_backfill" string="Lancia backfill"
                            type="object" class="btn btn-success"
                            invisible="state != 'estimated'"/>
                    <button string="Chiudi" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for wizard -->
    <record id="action_casafolino_mail_backfill_ai" model="ir.actions.act_window">
        <field name="name">Backfill AI Classification</field>
        <field name="res_model">casafolino.mail.backfill.ai.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
