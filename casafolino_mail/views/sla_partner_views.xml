<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ SEARCH VIEW ══════════════════════════════════════════════ -->

    <record id="casafolino_mail_sla_partner_search" model="ir.ui.view">
        <field name="name">casafolino.mail.sla.partner.search</field>
        <field name="model">casafolino.mail.sla.partner</field>
        <field name="arch" type="xml">
            <search string="SLA Buyer">
                <field name="partner_id"/>
                <filter name="critical" string="Critical"
                        domain="[('sla_status', '=', 'critical')]"/>
                <filter name="warning" string="Warning"
                        domain="[('sla_status', '=', 'warning')]"/>
                <filter name="silent_7" string="Silenti &gt; 7gg"
                        domain="[('days_of_silence', '>=', 7)]"/>
                <filter name="never_replied" string="Mai risposto"
                        domain="[('avg_our_response_hours', '=', False), ('in_count_30d', '>', 0)]"/>
                <filter name="fast" string="Veloci (&lt; 4h)"
                        domain="[('avg_our_response_hours', '>', 0), ('avg_our_response_hours', '&lt;', 4)]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_sla" string="Stato SLA"
                            context="{'group_by': 'sla_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══ LIST VIEW ═════════════════════════════════════════════════ -->

    <record id="casafolino_mail_sla_partner_list" model="ir.ui.view">
        <field name="name">casafolino.mail.sla.partner.list</field>
        <field name="model">casafolino.mail.sla.partner</field>
        <field name="arch" type="xml">
            <list string="SLA Dashboard Buyer"
                  decoration-danger="sla_status == 'critical'"
                  decoration-warning="sla_status == 'warning'"
                  decoration-success="sla_status == 'ok'"
                  create="0" edit="0" delete="0">
                <field name="partner_id" string="Partner"/>
                <field name="open_leads_count" string="Lead aperti"/>
                <field name="days_of_silence" string="Silenzio (gg)"/>
                <field name="avg_our_response_hours" string="Ns risposta (h)"/>
                <field name="avg_their_response_hours" string="Loro risposta (h)"/>
                <field name="in_count_30d" string="IN 30gg"/>
                <field name="out_count_30d" string="OUT 30gg"/>
                <field name="last_in_date" string="Ultimo IN"/>
                <field name="last_out_date" string="Ultimo OUT"/>
                <field name="sla_status" string="Stato SLA" widget="badge"
                       decoration-success="sla_status == 'ok'"
                       decoration-warning="sla_status == 'warning'"
                       decoration-danger="sla_status == 'critical'"/>
                <button name="action_open_emails" string="Email" type="object"
                        icon="fa-envelope-o"/>
            </list>
        </field>
    </record>

    <!-- ══ FORM VIEW (read-only detail) ══════════════════════════════ -->

    <record id="casafolino_mail_sla_partner_form" model="ir.ui.view">
        <field name="name">casafolino.mail.sla.partner.form</field>
        <field name="model">casafolino.mail.sla.partner</field>
        <field name="arch" type="xml">
            <form string="SLA Partner" create="0" edit="0" delete="0">
                <div class="o_row mb-3">
                    <button name="action_open_emails" string="Apri Email"
                            type="object" class="btn btn-primary"/>
                </div>
                <group>
                    <group string="Partner">
                        <field name="partner_id"/>
                        <field name="open_leads_count"/>
                        <field name="sla_status" widget="badge"/>
                    </group>
                    <group string="Tempi">
                        <field name="days_of_silence"/>
                        <field name="avg_our_response_hours"/>
                        <field name="avg_their_response_hours"/>
                    </group>
                    <group string="Volume 30gg">
                        <field name="in_count_30d"/>
                        <field name="out_count_30d"/>
                        <field name="last_in_date"/>
                        <field name="last_out_date"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- ══ ACTION ═════════════════════════════════════════════════════ -->

    <record id="action_casafolino_mail_sla_partner" model="ir.actions.act_window">
        <field name="name">SLA Buyer</field>
        <field name="res_model">casafolino.mail.sla.partner</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="casafolino_mail_sla_partner_search"/>
        <field name="context">{'search_default_critical': 1}</field>
    </record>

</odoo>
