<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ──────────────────────────────────────────────────── -->
    <record id="view_cf_mail_sender_rule_list" model="ir.ui.view">
        <field name="name">cf.mail.sender.rule.list</field>
        <field name="model">cf.mail.sender.rule</field>
        <field name="arch" type="xml">
            <list string="Regole Mittenti" decoration-success="action == 'keep'" decoration-danger="action == 'exclude'">
                <field name="email"/>
                <field name="action" widget="badge"
                       decoration-success="action == 'keep'"
                       decoration-danger="action == 'exclude'"/>
                <field name="partner_id"/>
                <field name="full_sync_done" widget="boolean_toggle" string="Sync storica"/>
                <field name="message_count" string="Email archivio"/>
                <button name="unlink" type="object" string="Elimina" icon="fa-trash"
                        class="btn-danger" confirm="Eliminare questa regola?"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ──────────────────────────────────────────────────── -->
    <record id="view_cf_mail_sender_rule_form" model="ir.ui.view">
        <field name="name">cf.mail.sender.rule.form</field>
        <field name="model">cf.mail.sender.rule</field>
        <field name="arch" type="xml">
            <form string="Regola Mittente">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="email" placeholder="email@esempio.com"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="action" widget="radio"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="full_sync_done" widget="boolean_toggle"/>
                            <field name="message_count" string="Email in archivio"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search view ────────────────────────────────────────────────── -->
    <record id="view_cf_mail_sender_rule_search" model="ir.ui.view">
        <field name="name">cf.mail.sender.rule.search</field>
        <field name="model">cf.mail.sender.rule</field>
        <field name="arch" type="xml">
            <search string="Regole Mittenti">
                <field name="email" string="Email"/>
                <field name="partner_id"/>
                <filter name="keep" string="Solo KEEP" domain="[('action','=','keep')]"/>
                <filter name="exclude" string="Solo ESCLUSI" domain="[('action','=','exclude')]"/>
                <filter name="sync_pending" string="Sync storica pendente"
                        domain="[('action','=','keep'),('full_sync_done','=',False)]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_action" string="Azione" context="{'group_by': 'action'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────── -->
    <record id="action_cf_mail_sender_rules" model="ir.actions.act_window">
        <field name="name">Regole Mittenti</field>
        <field name="res_model">cf.mail.sender.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_cf_mail_sender_rule_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Nessuna regola mittente configurata
            </p>
            <p>
                Le regole si creano automaticamente quando clicchi
                <b>Tieni mittente</b> o <b>Escludi mittente</b> su un'email,
                oppure puoi crearle manualmente qui.
            </p>
        </field>
    </record>

    <!-- ── Server actions per azioni massive ──────────────────────────── -->
    <record id="action_keep_senders_bulk" model="ir.actions.server">
        <field name="name">Tieni mittenti selezionati</field>
        <field name="model_id" ref="model_cf_mail_message"/>
        <field name="binding_model_id" ref="model_cf_mail_message"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
emails = records.mapped('from_address')
emails = list({e.strip().lower() for e in emails if e})
for email in emails:
    env['cf.mail.sender.rule'].set_rule(email, 'keep', trigger_sync=True)
raise UserError('Regola KEEP applicata a %d mittenti. Sync storica avviata.' % len(emails))
        </field>
    </record>

    <record id="action_exclude_senders_bulk" model="ir.actions.server">
        <field name="name">Escludi mittenti selezionati</field>
        <field name="model_id" ref="model_cf_mail_message"/>
        <field name="binding_model_id" ref="model_cf_mail_message"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
emails = records.mapped('from_address')
emails = list({e.strip().lower() for e in emails if e})
for email in emails:
    env['cf.mail.sender.rule'].set_rule(email, 'exclude', trigger_sync=False)
raise UserError('Mittenti esclusi: %d. Tutte le loro email sono state eliminate.' % len(emails))
        </field>
    </record>

    <!-- ── Pulsanti nella form singola email ──────────────────────────── -->
    <record id="view_cf_mail_message_form_sender_btns" model="ir.ui.view">
        <field name="name">cf.mail.message.form.sender.btns</field>
        <field name="model">cf.mail.message</field>
        <field name="inherit_id" ref="casafolino_mail.view_cf_mail_message_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_keep_sender" type="object"
                        string="Tieni mittente"
                        class="btn-success"
                        invisible="not from_address"/>
                <button name="action_exclude_sender" type="object"
                        string="Escludi mittente"
                        class="btn-danger"
                        invisible="not from_address"
                        confirm="Eliminare tutte le email di questo mittente e escluderlo dalle sync future?"/>
            </xpath>
        </field>
    </record>

</odoo>
