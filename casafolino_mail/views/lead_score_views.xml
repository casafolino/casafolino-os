<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ SEARCH VIEW ══════════════════════════════════════════════ -->

    <record id="casafolino_mail_lead_score_search" model="ir.ui.view">
        <field name="name">casafolino.mail.lead.score.search</field>
        <field name="model">casafolino.mail.lead.score</field>
        <field name="arch" type="xml">
            <search string="Lead Scoring">
                <field name="partner_id"/>
                <field name="partner_email"/>
                <filter name="hot" string="Hot"
                        domain="[('tier', '=', 'hot')]"/>
                <filter name="warm" string="Warm"
                        domain="[('tier', '=', 'warm')]"/>
                <filter name="orphan" string="Orfani (senza lead)"
                        domain="[('has_open_lead', '=', False)]"/>
                <filter name="with_lead" string="Con lead aperto"
                        domain="[('has_open_lead', '=', True)]"/>
                <filter name="top20" string="Top 20"
                        domain="[('rank', '&lt;=', 20)]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_tier" string="Tier"
                            context="{'group_by': 'tier'}"/>
                    <filter name="group_lead" string="Lead aperto"
                            context="{'group_by': 'has_open_lead'}"/>
                    <filter name="group_country" string="Paese"
                            context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══ LIST VIEW ═════════════════════════════════════════════════ -->

    <record id="casafolino_mail_lead_score_list" model="ir.ui.view">
        <field name="name">casafolino.mail.lead.score.list</field>
        <field name="model">casafolino.mail.lead.score</field>
        <field name="arch" type="xml">
            <list string="Lead Scoring TOP 20"
                  decoration-danger="tier == 'hot'"
                  decoration-warning="tier == 'warm'"
                  decoration-muted="tier in ('cold', 'frozen')"
                  create="0" edit="0" delete="0">
                <field name="rank" string="#"/>
                <field name="partner_id" string="Partner"/>
                <field name="partner_email" string="Email"/>
                <field name="score" string="Score"/>
                <field name="tier" string="Tier" widget="badge"
                       decoration-danger="tier == 'hot'"
                       decoration-warning="tier == 'warm'"
                       decoration-info="tier == 'cold'"
                       decoration-muted="tier == 'frozen'"/>
                <field name="inbound_count_90d" string="IN 90gg"/>
                <field name="outbound_count_90d" string="OUT 90gg"/>
                <field name="last_inbound_date" string="Ultimo IN"/>
                <field name="has_open_lead" string="Lead" widget="boolean"/>
                <field name="frequency_score" string="Freq" optional="hide"/>
                <field name="recency_score" string="Rec" optional="hide"/>
                <field name="engagement_score" string="Eng" optional="hide"/>
                <field name="lead_bonus" string="Lead+" optional="hide"/>
                <field name="sentiment_bonus" string="Sent+" optional="hide"/>
                <button name="action_open_emails" string="Email" type="object"
                        icon="fa-envelope-o" class="btn-link"/>
                <button name="action_create_lead" string="Crea Lead" type="object"
                        icon="fa-plus-circle" class="btn-link"
                        invisible="has_open_lead"/>
            </list>
        </field>
    </record>

    <!-- ══ FORM VIEW ═════════════════════════════════════════════════ -->

    <record id="casafolino_mail_lead_score_form" model="ir.ui.view">
        <field name="name">casafolino.mail.lead.score.form</field>
        <field name="model">casafolino.mail.lead.score</field>
        <field name="arch" type="xml">
            <form string="Lead Score" create="0" edit="0" delete="0">
                <div class="o_row mb-3">
                    <button name="action_open_emails" string="Vedi Email"
                            type="object" class="btn btn-primary"/>
                    <button name="action_create_lead" string="Crea Lead"
                            type="object" class="btn btn-success"
                            invisible="has_open_lead"/>
                </div>
                <group>
                    <group string="Partner">
                        <field name="rank"/>
                        <field name="partner_id"/>
                        <field name="partner_email"/>
                        <field name="country_id"/>
                        <field name="has_open_lead"/>
                    </group>
                    <group string="Score">
                        <field name="score"/>
                        <field name="tier" widget="badge"/>
                        <field name="frequency_score"/>
                        <field name="recency_score"/>
                        <field name="engagement_score"/>
                        <field name="lead_bonus"/>
                        <field name="sentiment_bonus"/>
                    </group>
                    <group string="Attività 90gg">
                        <field name="inbound_count_90d"/>
                        <field name="outbound_count_90d"/>
                        <field name="last_inbound_date"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- ══ ACTION ═════════════════════════════════════════════════════ -->

    <record id="action_casafolino_mail_lead_score" model="ir.actions.act_window">
        <field name="name">Lead Scoring TOP 20</field>
        <field name="res_model">casafolino.mail.lead.score</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('rank', '&lt;=', 20)]</field>
        <field name="search_view_id" ref="casafolino_mail_lead_score_search"/>
    </record>

</odoo>
