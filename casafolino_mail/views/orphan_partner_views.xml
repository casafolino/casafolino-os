<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ SEARCH VIEW ══════════════════════════════════════════════ -->

    <record id="casafolino_mail_orphan_partner_search" model="ir.ui.view">
        <field name="name">casafolino.mail.orphan.partner.search</field>
        <field name="model">casafolino.mail.orphan.partner</field>
        <field name="arch" type="xml">
            <search string="Buyer Senza Lead">
                <field name="partner_id"/>
                <field name="partner_email"/>
                <filter name="hot" string="Hot"
                        domain="[('priority', '=', 'hot')]"/>
                <filter name="no_reply" string="Senza risposta nostra"
                        domain="[('has_reply', '=', False)]"/>
                <filter name="last_7d" string="Ultimi 7gg"
                        domain="[('last_inbound_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%%Y-%%m-%%d'))]"/>
                <filter name="high_volume" string="Volume alto"
                        domain="[('inbound_count_90d', '&gt;=', 5)]"/>
                <separator/>
                <group expand="0" string="Raggruppa per">
                    <filter name="group_priority" string="Priorità"
                            context="{'group_by': 'priority'}"/>
                    <filter name="group_country" string="Paese"
                            context="{'group_by': 'country_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══ LIST VIEW ═════════════════════════════════════════════════ -->

    <record id="casafolino_mail_orphan_partner_list" model="ir.ui.view">
        <field name="name">casafolino.mail.orphan.partner.list</field>
        <field name="model">casafolino.mail.orphan.partner</field>
        <field name="arch" type="xml">
            <list string="Buyer Senza Lead"
                  decoration-danger="priority == 'hot'"
                  decoration-warning="priority == 'warm'"
                  decoration-muted="priority == 'cold'"
                  create="0" edit="0" delete="0">
                <field name="partner_id" string="Partner"/>
                <field name="partner_email" string="Email"/>
                <field name="country_id" string="Paese" optional="show"/>
                <field name="inbound_count_90d" string="# IN 90gg"/>
                <field name="outbound_count_90d" string="# OUT 90gg"/>
                <field name="last_inbound_date" string="Ultimo IN"/>
                <field name="has_reply" string="Risposto" widget="boolean"/>
                <field name="priority" string="Priorità" widget="badge"
                       decoration-danger="priority == 'hot'"
                       decoration-warning="priority == 'warm'"
                       decoration-muted="priority == 'cold'"/>
                <button name="action_create_lead" string="Crea Lead" type="object"
                        icon="fa-plus-circle" class="btn-link"/>
                <button name="action_open_emails" string="Email" type="object"
                        icon="fa-envelope-o" class="btn-link"/>
            </list>
        </field>
    </record>

    <!-- ══ FORM VIEW (read-only detail) ══════════════════════════════ -->

    <record id="casafolino_mail_orphan_partner_form" model="ir.ui.view">
        <field name="name">casafolino.mail.orphan.partner.form</field>
        <field name="model">casafolino.mail.orphan.partner</field>
        <field name="arch" type="xml">
            <form string="Buyer Senza Lead" create="0" edit="0" delete="0">
                <div class="o_row mb-3">
                    <button name="action_create_lead" string="Crea Lead"
                            type="object" class="btn btn-primary"/>
                    <button name="action_open_emails" string="Vedi Email"
                            type="object" class="btn btn-secondary"/>
                </div>
                <group>
                    <group string="Partner">
                        <field name="partner_id"/>
                        <field name="partner_email"/>
                        <field name="country_id"/>
                        <field name="priority" widget="badge"/>
                    </group>
                    <group string="Attività 90gg">
                        <field name="inbound_count_90d"/>
                        <field name="outbound_count_90d"/>
                        <field name="has_reply"/>
                        <field name="days_active"/>
                        <field name="first_inbound_date"/>
                        <field name="last_inbound_date"/>
                    </group>
                </group>
            </form>
        </field>
    </record>

    <!-- ══ ACTION ═════════════════════════════════════════════════════ -->

    <record id="action_casafolino_mail_orphan_partner" model="ir.actions.act_window">
        <field name="name">Buyer Senza Lead</field>
        <field name="res_model">casafolino.mail.orphan.partner</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="casafolino_mail_orphan_partner_search"/>
    </record>

</odoo>
