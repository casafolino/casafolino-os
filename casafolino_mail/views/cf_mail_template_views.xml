<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cf_mail_template_list" model="ir.ui.view">
        <field name="name">cf.mail.template.list</field>
        <field name="model">cf.mail.template</field>
        <field name="arch" type="xml">
            <list string="Template Email">
                <field name="name"/>
                <field name="subject"/>
                <field name="category"/>
                <field name="language"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="cf_mail_template_form" model="ir.ui.view">
        <field name="name">cf.mail.template.form</field>
        <field name="model">cf.mail.template</field>
        <field name="arch" type="xml">
            <form string="Template Email">
                <group>
                    <group>
                        <field name="name"/>
                        <field name="subject"/>
                        <field name="category"/>
                        <field name="language"/>
                    </group>
                    <group>
                        <field name="user_id"/>
                        <field name="active"/>
                    </group>
                </group>
                <separator string="Corpo email"/>
                <field name="body_html" widget="html"/>
                <separator string="Allegati di default"/>
                <field name="attachment_ids"/>
            </form>
        </field>
    </record>

    <record id="action_cf_mail_template" model="ir.actions.act_window">
        <field name="name">Template Email</field>
        <field name="res_model">cf.mail.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_casafolino_mail_templates"
              name="Template Email"
              parent="casafolino_mail.menu_casafolino_mail_hub_root"
              action="action_cf_mail_template"
              sequence="40"/>

</odoo>
