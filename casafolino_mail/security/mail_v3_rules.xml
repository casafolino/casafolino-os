<odoo>
  <data noupdate="1">
    <record id="rule_message_own" model="ir.rule">
      <field name="name">Mail V3: own messages</field>
      <field name="model_id" ref="casafolino_mail.model_casafolino_mail_message"/>
      <field name="domain_force">[('account_id.responsible_user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="rule_message_admin" model="ir.rule">
      <field name="name">Mail V3: admin sees all</field>
      <field name="model_id" ref="casafolino_mail.model_casafolino_mail_message"/>
      <field name="domain_force">[(1,'=',1)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_admin'))]"/>
    </record>
    <record id="rule_draft_own" model="ir.rule">
      <field name="name">Mail V3: own drafts</field>
      <field name="model_id" ref="model_casafolino_mail_draft"/>
      <field name="domain_force">[('user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="rule_thread_own" model="ir.rule">
      <field name="name">Mail V3: own threads</field>
      <field name="model_id" ref="model_casafolino_mail_thread"/>
      <field name="domain_force">[('account_id.responsible_user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="rule_thread_admin" model="ir.rule">
      <field name="name">Mail V3: admin threads</field>
      <field name="model_id" ref="model_casafolino_mail_thread"/>
      <field name="domain_force">[(1,'=',1)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_admin'))]"/>
    </record>
  </data>
</odoo>
