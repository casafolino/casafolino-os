<odoo>
  <data noupdate="1">
    <!-- Account rules -->
    <record id="rule_account_own" model="ir.rule">
      <field name="name">Mail V3: own account</field>
      <field name="model_id" ref="casafolino_mail.model_casafolino_mail_account"/>
      <field name="domain_force">[('responsible_user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="rule_account_admin" model="ir.rule">
      <field name="name">Mail V3: admin sees all accounts</field>
      <field name="model_id" ref="casafolino_mail.model_casafolino_mail_account"/>
      <field name="domain_force">[(1,'=',1)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_admin'))]"/>
    </record>
    <!-- Message rules -->
    <record id="rule_message_own" model="ir.rule">
      <field name="name">Mail V3: own account messages</field>
      <field name="model_id" ref="casafolino_mail.model_casafolino_mail_message"/>
      <field name="domain_force">[('account_id.responsible_user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="rule_message_admin" model="ir.rule">
      <field name="name">Mail V3: admin sees all messages</field>
      <field name="model_id" ref="casafolino_mail.model_casafolino_mail_message"/>
      <field name="domain_force">[(1,'=',1)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_admin'))]"/>
    </record>
    <!-- Draft rules -->
    <record id="rule_draft_own" model="ir.rule">
      <field name="name">Mail V3: own drafts</field>
      <field name="model_id" ref="model_casafolino_mail_draft"/>
      <field name="domain_force">[('user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="rule_draft_admin" model="ir.rule">
      <field name="name">Mail V3: admin sees all drafts</field>
      <field name="model_id" ref="model_casafolino_mail_draft"/>
      <field name="domain_force">[(1,'=',1)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_admin'))]"/>
    </record>
    <!-- Thread rules -->
    <record id="rule_thread_own" model="ir.rule">
      <field name="name">Mail V3: own threads</field>
      <field name="model_id" ref="model_casafolino_mail_thread"/>
      <field name="domain_force">[('account_id.responsible_user_id', '=', user.id)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="rule_thread_admin" model="ir.rule">
      <field name="name">Mail V3: admin sees all threads</field>
      <field name="model_id" ref="model_casafolino_mail_thread"/>
      <field name="domain_force">[(1,'=',1)]</field>
      <field name="groups" eval="[(4, ref('group_mail_v3_admin'))]"/>
    </record>
  </data>
</odoo>
