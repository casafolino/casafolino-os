<odoo>
  <data noupdate="1">
    <record id="group_mail_v3_user" model="res.groups">
      <field name="name">Mail V3 — Standard User</field>
      <field name="category_id" ref="base.module_category_productivity"/>
    </record>
    <record id="group_mail_v3_beta" model="res.groups">
      <field name="name">Mail V3 — Beta Tester</field>
      <field name="category_id" ref="base.module_category_productivity"/>
      <field name="implied_ids" eval="[(4, ref('group_mail_v3_user'))]"/>
    </record>
    <record id="group_mail_v3_admin" model="res.groups">
      <field name="name">Mail V3 — Admin</field>
      <field name="category_id" ref="base.module_category_productivity"/>
      <field name="implied_ids" eval="[(4, ref('group_mail_v3_beta'))]"/>
    </record>
    <!-- Assign admin user -->
    <function model="res.users" name="write">
      <value eval="[ref('base.user_admin')]"/>
      <value eval="{'groups_id': [(4, ref('group_mail_v3_admin'))]}"/>
    </function>
  </data>
</odoo>
