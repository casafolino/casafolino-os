<odoo>

    <!-- ══ casafolino.mail.account ═══════════════════════════════════ -->

    <!-- Utente normale: vede solo i propri account -->
    <record id="rule_mail_account_user" model="ir.rule">
        <field name="name">CasaFolino Mail: solo propri account</field>
        <field name="model_id" ref="model_casafolino_mail_account"/>
        <field name="domain_force">[('responsible_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Admin: vede tutti gli account -->
    <record id="rule_mail_account_admin" model="ir.rule">
        <field name="name">CasaFolino Mail: admin vede tutti gli account</field>
        <field name="model_id" ref="model_casafolino_mail_account"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

