<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ casafolino.mail.account ═══════════════════════════════════ -->

    <!-- Utente normale: vede solo i propri account -->
    <record id="rule_mail_account_user" model="ir.rule">
        <field name="name">CasaFolino Mail: solo propri account</field>
        <field name="model_id" ref="model_casafolino_mail_account"/>
        <field name="domain_force">[('responsible_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Admin: vede tutti gli account -->
    <record id="rule_mail_account_admin" model="ir.rule">
        <field name="name">CasaFolino Mail: admin vede tutti gli account</field>
        <field name="model_id" ref="model_casafolino_mail_account"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!-- ══ casafolino.mail.message ═══════════════════════════════════ -->

    <!-- Utente normale: vede solo email delle proprie caselle -->
    <record id="rule_mail_message_user" model="ir.rule">
        <field name="name">CasaFolino Mail: solo email proprie caselle</field>
        <field name="model_id" ref="model_casafolino_mail_message"/>
        <field name="domain_force">[('account_id.responsible_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Admin: vede tutte le email -->
    <record id="rule_mail_message_admin" model="ir.rule">
        <field name="name">CasaFolino Mail: admin vede tutte le email</field>
        <field name="model_id" ref="model_casafolino_mail_message"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!-- ══ casafolino.mail.tracking ══════════════════════════════════ -->

    <record id="rule_mail_tracking_user" model="ir.rule">
        <field name="name">CasaFolino Mail: tracking proprie email</field>
        <field name="model_id" ref="model_casafolino_mail_tracking"/>
        <field name="domain_force">[('account_id.responsible_user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_mail_tracking_admin" model="ir.rule">
        <field name="name">CasaFolino Mail: admin vede tutto il tracking</field>
        <field name="model_id" ref="model_casafolino_mail_tracking"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

</odoo>
