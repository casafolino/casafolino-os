<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sync IMAP ogni 5 minuti per tutti gli account abilitati -->
        <record id="ir_cron_cf_mail_sync" model="ir.cron">
            <field name="name">CasaFolino Mail: Sync IMAP (5 min)</field>
            <field name="model_id" search="[('model','=','cf.mail.account')]" model="ir.model"/>
            <field name="state">code</field>
            <field name="code">model._sync_all_accounts()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
