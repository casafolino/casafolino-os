<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cron_backfill_ai_classification" model="ir.cron">
        <field name="name">Mail Hub: Backfill AI Classification</field>
        <field name="model_id" search="[('model', '=', 'casafolino.mail.message')]"/>
        <field name="state">code</field>
        <field name="code">model._cron_backfill_ai_classification()</field>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
        <field name="priority">15</field>
    </record>

</odoo>
