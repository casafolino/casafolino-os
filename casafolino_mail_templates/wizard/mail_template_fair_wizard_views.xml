<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mail_template_fair_wizard_form" model="ir.ui.view">
        <field name="name">mail.template.fair.wizard.form</field>
        <field name="model">mail.template.fair.wizard</field>
        <field name="arch" type="xml">
            <form string="Nuova Fiera — Crea Template">
                <group>
                    <field name="fair_name" placeholder="Es. PLMA Amsterdam 2026"/>
                    <field name="languages"/>
                    <field name="cc_email"/>
                    <field name="create_partner_category"/>
                    <field name="create_crm_tag"/>
                </group>
                <footer>
                    <button name="action_create_templates" type="object"
                            string="Crea Template" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_new_fair_wizard" model="ir.actions.act_window">
        <field name="name">Nuova Fiera</field>
        <field name="res_model">mail.template.fair.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
