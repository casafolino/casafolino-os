<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mail_template_tag_list" model="ir.ui.view">
        <field name="name">casafolino.mail.template.tag.list</field>
        <field name="model">casafolino.mail.template.tag</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="is_fair_tag"/>
                <field name="description"/>
                <field name="template_count" string="Template"/>
            </list>
        </field>
    </record>

    <record id="action_mail_template_tags" model="ir.actions.act_window">
        <field name="name">Tag Template</field>
        <field name="res_model">casafolino.mail.template.tag</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
